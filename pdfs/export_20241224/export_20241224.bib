	url = {https://www.scielo.br/j/rbent/a/XkdjjK5rhhhkxwHMtHMHV3J/?lang=en},
	doi = {https://doi.org/10.1590/S0085-56262009000100033},
	abstract = {It is reported for the first time oil collecting by bees of the genus Caenonomada on flowers of Plantaginaceae. Females of Caenonomada unicalcarata were observed collecting oil on flowers of Angelonia cornigera, and males and females of Caenonomada bruneri and C. aff. unicalcarata were observed on flowers of Angelonia and Monopera (Plantaginaceae). The record of Caenonomada on Plantaginaceae suggests the use of trichomatic oil glands as a primitive condition in the tribe Tapinotaspidini.},
	language = {en},
	urldate = {2024-12-24},
