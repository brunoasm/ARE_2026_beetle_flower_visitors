@article{WOS:000254541300021,
  abstract = {Males of pollinating and some non-pollinating fig wasps are wingless and
quite dissimilar to their co-specific females. Due to the accentuated
sexual dimorphism, males and females of some fig wasp species were
described in different genera. We used morphological sperm features
obtained from male seminal vesicles and female spermathecas to associate
sexes in three non-pollinating fig wasp species, genus Idarnes, that are
associated with Ficus citrifolia in Brazil. Sperm obtained from each
female morph species presented diagnostic features that led to the
association with sperm obtained from males. This method can potentially
be used to help enlighten taxonomic problems in other wasp species with
sexual di- or polymorphism.},
