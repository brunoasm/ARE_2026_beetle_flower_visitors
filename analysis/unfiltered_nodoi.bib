Sambucus},
  keywords-plus = {BLAKEA-PENDULIFLORA MELASTOMATACEAE; FLORAL NECTARIES;
REPRODUCTIVE-BIOLOGY; MEMECYLACEAE; LEGUMINOSAE; POLLINATION; PHYLOGENY},
  language = {English},
  month = {NOV},
