@inproceedings{WOS:000313670300015,
  abstract = {Distant hybridization was carried out between genera of Litchi and
Dimocarpus. Four cross combinations were set: `Shixia' x'Ziniangxi',
`Zaoshulongyan' x'Ziniangxi', `Gushan No.2' x'Ziniangxi' and `Ziniangxi'
x `Shixia'. In order to improve the cross compatibility between the
parents, maternal pollen was killed by UV irradiation and then mixed
with the vital paternal pollen to pollinate the maternal parent. As the
result, 35 filial progeny seedlings were obtained from the four
combinations, and two of them from `Ziniangxi' x `Shixia' were confirmed
to be true intergeneric hybrids by SRAP-PCR analysis and morphological
characteristics. This result shows that the distant hybridization
