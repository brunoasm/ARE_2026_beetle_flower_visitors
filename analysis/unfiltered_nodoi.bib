@article{WOS:A1986D043400034,
  abstract = {Intergeneric hybrids between wingnut (Pterocarya sp.) and walnut
(Juglans regia) were developed by regenerating plants from somatic
embryos produced on immature cotyledons of seed from
control-pollinations. Hybridization was confirmed by isozyme analysis
using starch gel electrophoresis. To the best of our knowledge, this is
the first report of hybrids between wingnut, which has a high level of
