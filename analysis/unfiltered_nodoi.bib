@inproceedings{WOS:000323222200001,
  abstract = {Predictions and expectations for the improvement of loquat (Eriobotrya
japonica Lindl.) in the next decade are based on extrapolation from
current research in loquat as well as progress made in other members of
the Rosaceae. Research underway in China indicates the development of
seedless loquat will be the next great advance in loquat
commercialization. Selection within seedless triploids that occur from
rare spontaneous occurrence in diploid open pollinated seed derived from
non-reduction in megaspores can be expected to achieve diversity in
size, color, season of ripening, and adaptability. Within triploids,
parthenocarpy will be the next trait that needs to be addressed in order
to eliminate the need for pollination or gibberellin application. The
production of seedless triploids from tetraploid x diploid crosses needs
to be explored. Selection of rootstocks from Eriobotrya species with
high compatibility indicate that progress in loquat production can be
achieved from rootstock selection and breeding. Progress in genomic
analysis of loquat will initiate the next great advance in loquat
breeding for both scion and rootstock improvement.},
