@article{WOS:A1985AHC5800001,
  abstract = {An explosive mechanism involving the entire pop flower of C. canadense
(L.) Aschers. and Graebn. is described in detail. The only other species
in the genus, C. suecicum (L.) Aschers. and Graebn., appears to possess
an identical mechanism. The basic elements of the mechanism are: a
sensitive antenna-like structure projecting from one petal of the
unopened flower bud, reflexive petals, and stamen filaments possessing
elbow springs which act to catapult the pollen in the anthers upwards
toward the tope of the flower. In comparison to all other rapid movement
pollination mechanisms in the Angiosperms, this explosive mechanism is
singularly unique. The presence of this unique mechanism has taxonomic
implications for the question of the validity of the genus
Chamaepericlymenum as an entity distinct from the genus Cornus in which
the 2 spp. discussed have often been placed.},
