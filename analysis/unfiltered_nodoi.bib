@article{WOS:A1984TL11300007,
  abstract = {The Odemera spp. are not rare visitors of flowers in central and
southern Europe. They are slender (10 mm long, 2 mm wide). The proboscis
possesses long and strong bristles on the galea and lacinia suitable for
shoveling pollen and picking up nectar. Due to the shortness of the
proboscis (0.9 mm) flowers with free nectar and pollen can be exploited,
especially Apiaceae (nectar and pollen) and Asteraceae (pollen).
Eighty-four percent of the food plants are white and yellow-green.
Pollen transfer is lightened by fine hairs on the body. Oedemera spp. do
not show flower constancy but are successful pollinators. In central
Europe there are no flowers especially adapted to pollination by
Oedemera or other Coleoptera; this is true also for Apiaceae so far
known to be pollinated by beetles.},
