  author = {Venecz, JI and Aarssen, LW},
  da = {2024-12-06},
  doc-delivery-number = {108CA},
  issn = {0003-3847},
  journal = {ANNALES BOTANICI FENNICI},
  journal-iso = {Ann. Bot. Fenn.},
  keywords = {apical dominance; compensatory responses; Lythrum salicaria},
  keywords-plus = {SEED PRODUCTION; HERBIVORY; OVERCOMPENSATION; ALLOCATION; PLANTS; GROWTH},
  language = {English},
  number = {2},
