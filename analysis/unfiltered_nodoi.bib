@article{WOS:A1985A759200002,
  abstract = {In May-August 1982 and April-August 1983 quantitative and qualitative
studies on the atmospheric pollen were carried out in the town of C.
using Durham''s method. The number of total atmospheric pollen granules
was found to exceed 1,200/sq. cm in May and 1,100/sq. cm in June. The
pollen of trees (Corylus, Quercus, etc.) and the pollen of poaceous
plants, the main allergogenic pollen, were found to predominate in the
first part of the period and the pollen of poaceous plants (Gramineae)
in the rest of the pollination season. The authors consider that the
pollen of Compositae can have a certain allergogenic importance in
