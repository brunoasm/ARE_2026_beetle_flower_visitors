@article{WOS:000273583100011,
  abstract = {Anthurium `UPLB White' is a selection from among the germplasm
collection of anthuriums at the University of the Philippines Los Banos
(UPLB). The spathe is basically white with occasional pink blushes at
maturity, slightly ridged with medium texture, large to extra large in
size, broad heart in shape and with open lobes. The spadix is reddish
