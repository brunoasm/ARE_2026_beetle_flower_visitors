  journal = {ZOOLOGISCHER ANZEIGER},
  journal-iso = {Zool. Anz.},
  keywords = {colour preference; flower visitor; innate flower detection; releaser;
wavelength-specific behaviour; colour vision; colour pattern},
  keywords-plus = {REPRODUCTIVE-BIOLOGY; HONEY-BEES; VISION; ULTRAVIOLET; POLLINATION;
BEHAVIOR; BUMBLEBEES; EVOLUTION; DISCRIMINATION; ORCHIDACEAE},
  language = {English},
