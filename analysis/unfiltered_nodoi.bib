@article{WOS:A1990FM92800006,
  abstract = {Plantago lagopus L., a weed belonging to family Plantaginaceae, has
several features that allow its pollen to be easily drifted by wind. The
syndrome of anemophily sensu Faegri and van der Pijl is represented in
