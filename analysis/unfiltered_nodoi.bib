@article{WOS:A1991EY03800009,
  abstract = {The effect of gibberellic acid (GA3) was studied on a wide range of
crosses between various garden roses and two hardy breeding lines. 
Although there were fewer seeds per fruit, fruit set was higher in most
crosses when GA3 was applied to the stigma at the rate of 250 ppm ten
days after pollination.  However, higher fruit set did not result in
more seeds per pollination for many crosses and seemed to be related to
the degree of male parentage.  Both parents used had a major effect on
pollination success.  Recently developed Rosa cultivars have a narrow
genetic base and the use of distantly related cultivars as parents would
possibly give a high seed set and greater numbers of progeny.},
