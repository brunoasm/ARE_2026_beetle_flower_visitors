@article{WOS:000320568000005,
  abstract = {The reproductive biology of Handroanthus heptaphyllus, Tabebuia nodosa y
Fridericia dichotoma (Bignoniaceae) was studied in El Bagual natural
reserve, Formosa Province, Argentina, to describe aspects of floral
biology, floral rewards, reproductive system, pollinators, and floral
visitors. The results show that species are self-incompatible,
non-autogamous and pollinator-dependent (large to medium-sized bees).
The fruit set in manually cross-pollinated flowers was higher than the
in control flowers. Manually self-pollinated flowers did not set fruits
in any of these species. Relative reproductive success was low in the
three species. Such low reproductive success may be due to pollen or
pollination limitation caused by high levels of geitonogamy.},
