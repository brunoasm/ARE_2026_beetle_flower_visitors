  keywords = {ANTIPODAL CELLS; ULTRASTRUCTURAL CHANGES; FUNCTIONS; HORDEUM VULGARE;
GRAMINEAE},
  keywords-plus = {MEGAGAMETOPHYTE DEVELOPMENT; MATURE MEGAGAMETOPHYTE},
