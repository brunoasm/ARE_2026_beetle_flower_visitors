  language = {English},
  number = {4},
  number-of-cited-references = {2},
  pages = {293-306},
  publisher = {AMER SOC AGRONOMY},
  research-areas = {Agriculture},
  times-cited = {43},
  title = {THE POLYCROSS PROGENY PERFORMANCE AS AN INDEX OF THE COMBINING ABILITY
OF ALFALFA CLONES},
