@article{WOS:000171633800028,
  abstract = {Bee visits in six tropical woody bamboos (Bambusoideae: Poaceae) -
Bambusa bambos (native), Bambusa sp., B. vulgaris (both cultivated),
Ochlandra ebracteata, O. scriptoria, O. travancorica (all endemic) were
studied. The bees were predominantly of order Hymenoptera and belong to
genera Apis, Halictus, Trigona, Braunsapis and Ceratina. In Ochlandra
spp and B. vulgaris the bees visited the florets only at the male stage.
In B. bambos and Bambusa sp., the florets are wide opened and the male
