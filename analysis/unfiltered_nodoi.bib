phenology; fruit set; green flowers; hummingbird pollination; island
pollination; nectar production; passerine pollination; pollen/ovule
ratio; pollen deposition; pollination limitation; pollination syndrome},
  keywords-plus = {REPRODUCTIVE EFFORT; HUMMINGBIRDS; NECTAR; COMMUNITY; SYSTEMS;
COMPETITION; LEGUMINOSAE; POPULATIONS; EVOLUTION; SELECTION},
