  journal = {LIFE SCIENCE JOURNAL-ACTA ZHENGZHOU UNIVERSITY OVERSEAS EDITION},
  journal-iso = {Life Sci. J.},
  keywords = {palynomorphology; pollen grains; structure; taxa; Asteraceae},
