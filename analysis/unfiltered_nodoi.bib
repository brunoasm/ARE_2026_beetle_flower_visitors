@article{WOS:000186609900015,
  abstract = {Diallel cross and ovule culture were carried out among 15 Alstroemeria
species. Ovules harvested 14 days after pollination were cultured on
1/2MS medium containing 3\% sucrose at 20 degreesC under a 16-hr
photoperiod. Embryo germination occurred in 196 out of 210 combinations
of the diallel. A. angustifolia, A. ligtu, A. magenta and A. pelegrina
