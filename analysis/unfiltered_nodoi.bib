@article{WOS:A1988N923600007,
  abstract = {Short-range crosses within a population have been shown to affect
several fitness-related characters such as fruit-set and seedling
survival. In this study, selfed progeny and progeny produced by crossing
the highly inbreeding Scleranthus annuus (Caryophyllaceae) at distances
of 6 m, 12 m, 25 m, 50 m, and 100 m were compared for male reproductive
characters. The flowers of progeny from crossing distances of 6 m and 12
m had significantly more stamens and more staminodes developing into 
fertile stamens. Furthermore, the 10 stamens in the flower showed
different response to crossing. Two stamens, closest to the styles, are
always present as fully fertile. The other 8 stamen-positions are
developed into stamens and staminodes to a varying degree indicating
that the reduction of stamens in S. annuus is a non-random process. The
reduction of stamens in S. annuus is compared with the 10 stamens found
in the partly outcrossing, ant-pollinated, S. perennis.},
