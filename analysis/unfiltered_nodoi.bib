@article{WOS:000230797300009,
  abstract = {Heterostyly is found in 25 Angiosperm families. This genetic trait
expresses two floral morphs with different style and anther lengths.
Distylous species, with short-style (S) and long-style (L) flowers,
usually show genetic self-incompatibility. Previous data suggest that
Cordia species may express sporophitic self-incompatibility. With the
aim, of evaluating the expression of self-incompatibility in Cordia
curassavica, we studied a population using hand-pollination and
observing pollen tube growth. Results showed that intermorph crosses
produced the higher proportion of viable pollen tubes at stigma, style
and ovary. Intramorph LXL crosses produced no viable pollen tubes at the
stigma. Intramorph BxB crosses produced 50\% and 10\% viable pollen
tubes at stigma and style, but some ovarian inhibition of pollen tube
growth was observed. Self-pollination produced no pollen tubes at the
stigma. The results suggest that C. curassavica shows a partial
compatible response of B morph, with 10\% fruit-set.},
