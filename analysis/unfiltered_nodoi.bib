@article{WOS:000185533800002,
  abstract = {The knowledge of the reproductive biology is an essential step in the
building of conservation projects of endangered species. The protected
Corymborkis corymbis in La Reunion island is only represented by few
populations. Its fecundity in natural conditions is very low (around
3\%). The study of its breeding system shows that the species is
partially self-compatible but not self-fertile. This paper proposes
