@article{WOS:A1990DC19600001,
  abstract = {Several species of native bees were examined as pollinators of three
species of Cuphea, a prospective oil-seed crop, in greenhouse and field
trials, and records of flower visitation by bees were assembled from
literature and museum sources. The most successful pollinator in the
greenhouse was the gregarious megachilid, Osmia bruneri Cockerell, which
constructed 106 nests and produced 139 progeny using the pollen, nectar
and leaves of Cuphea leptopoda Hemsley. Two female Xylocopa californica
Cresson also produced progeny in the greenhouse. In the field the only
consistent visitors of Cuphea were three species of bumblebees (Bombus
fervidus (Fabr.), B. huntii Greene and B. occidentalis Greene).},
