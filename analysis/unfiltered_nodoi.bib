@article{WOS:000082048800007,
  abstract = {Floral traits related to pollination are compared in Gonolobus fraternus
and G. chloranthus. Observations on pollinators (Apidae, Vespidae,
Calliphoridae, Tachinidae) in Gonolobus fraternus are reported. In spite
