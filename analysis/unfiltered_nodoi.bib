@article{WOS:A1990DB11000002,
  abstract = {Anthers and corollas from fresh flowers of 27 taxa of Solanaceae were
separately stored in jars and then smelled. The anthers nearly always
produced scents, but the corollas often did not, and when present, the
corolla scents were different from those of the anthers. We hypothesize
