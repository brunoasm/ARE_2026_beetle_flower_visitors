@article{WOS:000174838000003,
  abstract = {In the plant kingdom the process of fertilization includes gamete
production, transport, attraction and gamete fusion. Sexual reproduction
is elaborated in the history of plant life cycles and strongly connected
with plant dispersal. In mosses and ferns fertilization takes place in
water. In most seed plants, the water is replaced by the cytoplasm of
the pollen tube and a degenerated synergid. The gametes are simple
cells.
In seed plants the sporophyte develops an interaction with the male and
female gametophytes. A pollination stimulus seems to include the
activation of the ovule to attract and receive the pollen tube.
The syngamic phase includes pollen tube attraction, penetration into the
micropyle and a synergid, the release and transport of the sperm cells
and fusion of cells and nuclei. For pollen tube attraction, calcium,
carbohydrates and proteins are mentioned and seem to be excreted by the
synergids.
Before penetration a swelling and stop of the pollen tube tip and
reorientation of the pollen tube growth can happen. The pollen tube
enters the synergid passing the filliform apparatus and arrives in a
degenerating cell. There, pollen tube growth stops and the pressure in
the pollen tube cytoplasm results in bursting of the pollen tube tip and
release of the cytoplasm. Sperm cells become located near and in the
``intercellular space{''} between the egg apparatus and the central
cell. There are several types of gamete fusion with and without the
exclusion of the cytoplasm of the sperm cell in the egg cell or central
cell.
There are different types of double fertilization and profitable to
angiosperms by having increased numbers of ovules, successful seed set
and a short generation time. The regulation of fertilization includes
gene actions, depends on sporophyte-gametophyte interactions and is
influenced by environmental conditions.},
  address = {SOLIPSKA 14A-1, 02-482 WARSAW, POLAND},
  affiliation = {Willemse, M (Corresponding Author), Univ Wageningen \& Res Ctr, Lab Plant Cell Biol, Arboretumlaan 4, NL-6703 BD Wageningen, Netherlands.
