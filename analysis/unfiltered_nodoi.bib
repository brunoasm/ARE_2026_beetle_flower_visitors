  journal = {RHODORA},
  journal-iso = {Rhodora},
  keywords = {CYPRIPEDIUM ARIETINUM; CYPRIPEDIUM ACAULE; LADYS SLIPPER ORCHIDS;
GENETIC VARIATION; CONSERVATION},
  language = {English},
