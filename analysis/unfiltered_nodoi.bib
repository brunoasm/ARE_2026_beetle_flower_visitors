  journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
  journal-iso = {Bot. J. Linnean Soc.},
  keywords = {food deception; `kettle-trap'; phenology; pollen viability; Syrphidae;
Thailand},
  keywords-plus = {CYPRIPEDIUM-CALCEOLUS ORCHIDACEAE; HOVER-FLIES DIPTERA; SYRPHIDAE;
