  keywords = {dichogamy; geitonogamy; inflorescence size; interference avoidance; male
reproductive success; pollen discounting; protandry},
  keywords-plus = {INBREEDING DEPRESSION; EPILOBIUM-ANGUSTIFOLIUM; SELF-FERTILIZATION;
FLOWERING PLANTS; OUTCROSSING RATE; ECHIUM-VULGARE; FLORAL DISPLAY;
