@article{WOS:A1993LT49800016,
  abstract = {The article reviews the role of thrips in the pollination of members of
Asteraceae, solanaceae and Fabaceae. Several features such as the highly
synchronized phenology of flowering with the life cycle of thrips,
modification of flowers to facilitate pollen transfer by thrips and
definite pattern of host succession that help maintain the population of
thrips are reported. We argue that these features represent strategies
in plants favouring a strong association between the thrips and the
plants.},
