@article{WOS:A1990EH76700019,
  abstract = {Four Pimpinella anisum L. populations taken from different geographical
regions were studied with respect to allozyme variability. 9 loci
encoding enzymes in seed tissues were analysed in total. Average
heterozygosity was 0.056, the proportion of polymorphic loci and the
average number of alleles per locus beign 32.67\% and 1.22,
respectively. The observed distribution of genotypes of polymorphic loci
does not correspond to the values expected according to Hardi-Weinberg
law. Genotype frequencies for polymorphic locus est1 differ in the
populations. The populations analysed were similar genetically. The
level of biochemical polymorphism discovered was close to the values
