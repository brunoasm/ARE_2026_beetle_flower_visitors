  keywords = {ANGIOSPERMS, SCROPHULARIACEAE, PAULOWNIA-TAIWANIANA, P-FORTUNEI,
P-KAWAKAMII; ISOZYMES, MORPHOLOGY, WOOD ANATOMY, TRICHOMES,
INFLORESCENCE GRAFTING, GENETIC ANALYSES; FLORA OF TAIWAN},
  language = {English},
