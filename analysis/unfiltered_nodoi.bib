@article{WOS:000165953000004,
  abstract = {A revision of Pachycentria Blume, which includes the monotypic
Pogonanthera Plume, is presented. Pachycentria comprises eight species
and one subspecies. Two species, P. vogelkopensis and P. hanseniana, are
newly described. The genus is distinguished from other genera in the
Medinillinae by a small ovary in an urceolate hypanthium, and by seeds
with comb-shaped tests cells. Andromonoecy is recorded for three species
of the genus. Pollination by bees and dispersal by birds and ants has
been observed in the field. Pachycentria is distributed in Burma,
Thailand, Peninsular Malaysia, Sumatra, Java, Borneo, Philippines,
