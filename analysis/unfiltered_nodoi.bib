@article{WOS:A1979HW41600015,
  abstract = {Observations, mainly from Oland, Sweden, on the pollination of H.
monorchis (L.) R. Br. were presented. Hymenoptera, Parasitica,
Chloropidae and Scatopsidae (Diptera) together made up 94\% of the
flower visitors. The genera Tetrastichus Hal. (Hymenoptera,
Chalcidoidea, Eulophidae) and Trachysiphonella End. (Diptera,
Chloropidae) represented 32 and 33\% of the visitors, respectively.
Pollination occurred mainly by Tetrastichus spp. which carried 65\% of
the pollinaria. Of this genus females were more than 7 times as frequent
as males. The occurrence of pollinaria on visitors indicated that the
flowers were optimally adapted to pollen vectors about 1.30 mm long and
0.35 mm wide. Experiments with traps demonstrated that the floral
fragrance was essential for the attraction of pollinators. The visitors
fed on nectar which was secreted and concealed in a short spur. The
plant was completely and successfully entomogamous. The habit of pollen
vectors to revisit flowers in the same inflorescence for hours suggested
considerable geitonogamy. A theory was presented that the flower-type of
H. monorchis arose by an evolutionary shift from more long-spurred
ancestors adapted to larger pollen vectors.},
