@article{WOS:A1990CR14100006,
  abstract = {At Visakhapatnam (17.degree.42''N-82.degree.18''E) (India), Moringa
oleifera Lam. flowers twice a year, once during February-May and again
during September-November. Both geitonogamous and xenogamous
pollinations produce fruit, but the latter mode is superior. The flowers
