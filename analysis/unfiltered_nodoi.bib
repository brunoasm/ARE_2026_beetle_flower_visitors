@article{WOS:A1984SX65600009,
  abstract = {This study represents the 1st case of getting orchid seedlings directly
from ovules in vitro culture of ovaries or ovules excised before
fertilization. By the usual in vitro culture of mature seeds, at least
240 days was required from pollination to obtaining seedlings of D.
pulcherrima. By the new method with pollinated but not fertilized
ovaries or ovules, the period could be shortened by about 150 days. The
seedlings obtained were diploid, suggesting the occurrence of
fertilization during the culturing. In ovule culture, seedlings were
obtained only when the basal medium was supplemented with sucrose or
coconut water. While in ovary culture, they were obtained without the
addition of sucrose, perhaps because sucrose was supplied from the ovary
wall.},
