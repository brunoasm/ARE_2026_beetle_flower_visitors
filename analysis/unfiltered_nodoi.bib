@article{WOS:A1982PU59600005,
  abstract = {G. arborea, a medium-sized to large tree native to the tropical forests
of South and East Asia, is widely cultivated in tropical regions.
Investigations of the pollination biology and the breeding system,
conducted on trees cultivated in Costa Rica, reveal that the species is
