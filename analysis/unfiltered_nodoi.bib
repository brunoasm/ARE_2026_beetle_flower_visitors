@article{WOS:A1995TJ86600006,
  abstract = {The flowers of Basistemon spinosus, a Neotropic shrubby member of the
tribe Hemimerideae, were found to secrete fatty oil as an attractant.
The pollinators, oil-collecting bees of the exomalopsine genus
Paratetrapedia, were observed in the Chaco forest of northern Argentina.
In contrast to related genera, the carpet of oil-producing glandular
hairs (elaiophore) is single, and the cavity that bears it, is only
slightly bisaccate. Flower features suggest less close affinity to
Angelonia than has previously been assumed, but rather tending towards
Old World relatives.},
