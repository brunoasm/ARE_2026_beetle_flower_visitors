  journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
  journal-iso = {Bot. J. Linnean Soc.},
  keywords = {anther; inflorescence; ovule; pokeweed},
  keywords-plus = {INFLORESCENCE ARCHITECTURE; HELIANTHUS-ANNUUS; FRUIT-SET; SPIKE;
POLLINATION; FLOWERS; GROWTH; WHEAT},
