@article{WOS:A1977DS23400004,
  abstract = {Post-pollination details in 5 spp. of Cyperaceae (Eleocharis
atropurpurea, E. congesta, Fimbristylis tetragona, Fuirena trilobites
and Scirpus lateriflorus) are described. The course of development is
uniform in all the species with a few exceptions. Double fertilization
is synchronous, endosperm is nuclear and the development of embryo is of
the Onagrad type. The topographic relations of the epicotyl and the
cotyledon conform to the Haccius'' concept of the monocotyledonous
embryo. The pericarp remains free from the seed coat throughout the
development.},
