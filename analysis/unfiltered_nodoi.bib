@article{WOS:A1992HB45600005,
  abstract = {The self incompatible, monomorphic flowers of Ziziphus mucronata are
protandrous and dichogamous. Dichogamy is complete and the flower can
furthermore be regarded as heterodichogamous. The use of hydrogen
peroxide, guaiacol and peroxidase activity to indicate stigma
receptivity. as was assessed morphologically during anthesis, proved
inadequate. The use of protein synthesis rate as determined with pulse
labelling of stigmatic tissue, is proposed as a sensitive, relatively
easy and reliable method for indicating stigma receptivity. Six
different gene products were detected unique to receptive stigmatic
tissue. The polypeptides which are induced in receptive stigmatic tissue
are not glycoproteins with D-mannose or D-glucose as carbohydrate
residues. Four glycopolypeptides with molecular weights of 63.4. 57.7.
54.4 and 40 kilodalton, however, are present at all stages in the
stigmatic tissue.},
