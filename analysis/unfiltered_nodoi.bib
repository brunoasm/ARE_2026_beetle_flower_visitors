@article{WOS:A1992JG71000006,
  abstract = {In the angiosperms, three-fourths of all species produce only perfect,
hermaphrodite flowers and structural sex change and androdioecy are very
rare. However, present studies in a population of Orchis morio
(Orchidaceae) show that animal pollinators adjust gender in structurally
hermaphroditic plants through differential visitation rates in response
to floral display variation: small-display plants become unisexual,
mostly male, while large-display plants become hermaphroditic.
Pollinators' psychophysical preference dictates that plants having
floral displays that increase with age will undergo functional sex
change while plants having small floral displays will remain
functionally unisexual or neuter. The results indicate that functional
sex change and male-biased breeding systems are probably common
phenomena in the angiosperms.},
