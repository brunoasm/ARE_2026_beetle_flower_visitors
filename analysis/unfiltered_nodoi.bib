@article{WOS:A1996UN50700010,
  abstract = {Ca2+ distribution along unpollinated, self- and out-pollinated pistils
and in pollen grains of the fertile Crocus cartwrightianus Herb. and the
sterile C. sativus L. (Iridaceae) plants has been studied by means of
Ca2+ selective microelectrodes and the fluorochrome chlorotetracycline.
A different Ca2+ distribution along pistils of both Crocus species has
