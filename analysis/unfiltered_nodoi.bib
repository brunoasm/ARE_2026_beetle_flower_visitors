  journal-iso = {N. Z. J. Bot.},
  keywords = {Loranthaceae; Peraxilla; Alepis; Tupeia; Ileostylus; Trilepidea; bird
pollination; self-compatibility; dioecy; breeding systems; explosive
flowering; nectar production},
