@article{WOS:A1948UC60100001,
  abstract = {To find the best combining clones for single-crosses, or vars., in
alfalfa improvement, the polycross test has been proposed. This is
similar to a top-cross test but involves random {[}male] parentage with
small amts. of selfing, depending on the self-fertility of the clone.
Polycross seed is produced when clones to be tested are interplanted so
as to provide random pollination. 8 alfalfa clones were vegeta-tively
increased in cooperative work at the Nebraska Expt. Station and seed was
produced from each of them from the polycross nursery, from single
crosses among them, from a top-cross with Arizona Common and from them
interplanted with Arizona Common. Tests on the forage yield, bacterial
wilt resistance, cold resistance, and potato leafhopper resistance were
conducted on the seed thus produced. In each of the 4 characters the
rank of the clones was practically the same whether they were ranked
according to the performance of their polycross progenies, their Arizona
Common top-crosses, their Arizona Common polycrosses, or on the average
performance of the single-crosses having a given clone as a common
parent. These results indicate the high value of a polycross test as an
index of general combining ability. Selection for low self-fertility of
the clones resulted in higher forage productivity of the progeny. There
was a significant, positive correlation between the cold resistance
under controlled conditions and field results. The performance of the
clones themselves, particularly with respect to insect and disease
resistance, is an indication of the performance of their progenies.
Clones selected for high combining ability by the polycross method
produced a synthetic var. having a significantly higher forage yield
than standard vars. or low combining clones chosen by the same technic.
Comparisons with selfed progenies indicated the polycross progenies gave
equally good results for selecting desirable material. So long as this
is true it is not necessary to go to the extra labor of utilizing selfed
progenies for testing purposes. Other advantages of the polycross method
in alfalfa improvement are that it provides sufficient seed for adequate
testing, only one isolation block is required for a given type of
material, and through 2d cycle selection it provides an excellent
opportunity to obtain superior combinations by natural crosses between
selected clones.},
  address = {677 S SEGOE RD, MADISON, WI 53711 USA},
  author = {TYSDAL, HM and CRANDALL, BH},
  da = {2024-12-07},
