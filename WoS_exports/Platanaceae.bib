   AARHUS UNIV, DEPT GEOL, DK-8000 AARHUS, DENMARK.},
DOI = {10.1126/science.232.4752.852},
ISSN = {0036-8075},
EISSN = {1095-9203},
Research-Areas = {Science \& Technology - Other Topics},
