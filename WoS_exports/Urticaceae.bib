Language = {French},
Affiliation = {Fac Med, Ctr Epidemiol Populat, BP 87900, F-21079 Dijon, France.
   Fac Med, Ctr Epidemiol Populat, F-21079 Dijon, France.},
DOI = {10.1016/S0335-7457(00)80134-3},
ISSN = {0335-7457},
Keywords = {allergy; circadian rythm; pollination},
Keywords-Plus = {DIURNAL-VARIATION; GRASS-POLLEN},
Research-Areas = {Allergy},
