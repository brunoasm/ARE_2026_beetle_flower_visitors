Address = {9600 GARSINGTON RD, OXFORD OX4 2DQ, OXON, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Huang, SQ (Corresponding Author), Wuhan Univ, Coll Life Sci, Wuhan 430072, Peoples R China.
   Wuhan Univ, Coll Life Sci, Wuhan 430072, Peoples R China.},
DOI = {10.1111/j.1469-8137.2006.01766.x},
ISSN = {0028-646X},
Keywords = {floral dimorphism; floral display size; monoecious; pollen receipt;
   pollen removal; pollinator choice; pollinator-mediated selection;
