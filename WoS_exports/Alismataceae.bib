
@article{ WOS:A1997YJ68000001,
Author = {Vieira, MF and Lima, NAD},
Title = {Pollination of Echinodorus grandiflorus (Alismataceae)},
Journal = {AQUATIC BOTANY},
Year = {1997},
Volume = {58},
Number = {2},
Pages = {89-98},
Month = {SEP},
Abstract = {Studies on the pollination and breeding system of Echinodorus
   grandiflorus (Chamisso and Schlechtendal) Micheli were carried out on
   two natural populations in Vicosa, Minas Gerais State, southeastern
   Brazil. One population was formed by individuals of ssp. grandiflorus
   and the other by individuals of sap. aureus (Fassett) Haynes and
   Holm-Nielsen. The flowering periods were within the rainy season. Flower
   anthesis occurred during the morning hours and flowers lasted ca. 8 h.
   E. grandiflorus ssp. grandiflorus is self-incompatible; few fruits, but
   many adventitious plantlets are produced at the inflorescences. E.
   grandiflorus ssp. aureus is self-compatible; many fruits and few
   adventitious plantlets are formed. Bees are the main flower visitors.
   The bee Protodiscelis echinodori (Colletidae) presents oligolectic
   foraging behavior, i.e., collects pollen from a single plant species or
   a group of related plant species. (C) 1997 Elsevier Science B.V.},
