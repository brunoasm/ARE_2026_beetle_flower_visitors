   Calvino, Ana; Galetto, Leonardo, Consejo Nacl Invest Cient \& Tecn, IMBIV, Cordoba, Argentina.},
DOI = {10.1007/s11258-009-9717-x},
ISSN = {1385-0237},
Keywords = {Fitness; Local density; Phenotypic gender; Plant height; Size-dependent
