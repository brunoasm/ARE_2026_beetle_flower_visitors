@article{ WOS:000245945800006,
Author = {Andrieu, Emilie and Debussche, Max and Thompson, John D.},
Title = {Size-dependent reproduction and gender modification in the
   hermaphroditic perennial plant <i>Paeonia officinalis</i>},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {2007},
Volume = {168},
Number = {4},
Pages = {435-441},
Month = {MAY},
Abstract = {In this study, we quantify how reproduction and allocation to male and
   female functions vary in relation to plant size during two consecutive
   but contrasting reproductive seasons in the hermaphroditic perennial
   herb Paeonia officinalis. Small flowering individuals in 2003 did not
   flower in 2004; thus, flowering probability is related to size, with an
   emphasis on survival. In terms of absolute numbers of stamens and
   ovules, large plants allocated more resources to reproduction than did
   small plants by the production of additional flowering stems. In
   contrast, in terms of relative allocation, large plants allocated a
   similar proportion of resources to reproduction as did small plants.
   Significant size- dependent gender modification occurred only in the
   second year of the experiment, when larger plants were more female than
   small plants. Hand- pollinations performed to minimize external effects
   on seed set and a severe drought in 2003 may have contributed to sex
   allocation costs in small plants. Our results suggest that differential
   expression of between- year reproductive costs in relation to plant size
   may lead to size- dependent reproduction and be a key feature driving
   size- dependent gender modification in perennial plants.},
