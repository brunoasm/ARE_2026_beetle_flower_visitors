Author = {Bernhard, A},
Title = {Floral structure and development of <i>Ceratiosicyos laevis</i>
   (Achariaceae) and its systematic position},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1999},
Volume = {131},
Number = {2},
Pages = {103-113},
