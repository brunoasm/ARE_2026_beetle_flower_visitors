Title = {Molecular phylogenetic analysis of Phyllanthaceae (Phyllanthoideae Pro
   Parte, Euphorbiaceae sensu lato) using plastid <i>RBCL</i> DNA sequences},
Journal = {AMERICAN JOURNAL OF BOTANY},
