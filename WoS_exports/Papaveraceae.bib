@article{ WOS:000373732000010,
Author = {Dohzono, Ikumi and Kaneko, Shingo and Yokoyama, Jun and Isagi, Yuji},
Title = {Isolation and characterization of microsatellite loci from <i>Corydalis
   ambigua</i> (Papaveraceae)},
