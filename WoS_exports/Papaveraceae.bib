@article{ WOS:A1986C470800015,
Author = {NORTON, CR and QU, Y and STRALEY, GB},
Title = {SELF-FERTILITY AND CROSS-COMPATABILITY AMONG 6 SPECIES OF MECONOPSIS
   (PAPAVERACEAE)},
Journal = {JOURNAL OF HORTICULTURAL SCIENCE \& BIOTECHNOLOGY},
Year = {1986},
Volume = {61},
Number = {2},
Pages = {257-263},
Month = {APR},
Abstract = {The six species studied were M. cambrica, M. quintuplinervia, M.
   betonicifolia, M. horridula, M. aculeata and M. villosa. Trials with
   selfing and crossing showed that the number of seeds per pollination
   increased with the percentage of capsules that set seed, and that the
   number of seeds per capsule increased with the percentage of capsules
   setting seed. Such data could be used to provide an index of
   incompatibility. Various pollination treatments with M. betonicifolia
   are described, some of which showed that this species is both self- and
   cross-compatible. The results of chromosome counts and degree of ploidy
   are described, and it is shown that compatibility is largely based on
   both ploidy level and pollen type differences.},
