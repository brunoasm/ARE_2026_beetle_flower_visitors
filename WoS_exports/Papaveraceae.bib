@article{ WOS:A1992KF53700001,
Author = {LYON, DL},
Title = {BEE POLLINATION OF FACULTATIVELY XENOGAMOUS SANGUINARIA-CANADENSIS L},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1992},
Volume = {119},
Number = {4},
Pages = {368-375},
Month = {OCT-DEC},
Abstract = {The protogynous flowers of Sanguinaria canadensis L. (Papaveraceae) were
   facultatively xenogamous. They were cross-pollinated by bees, primarily
   female Adrena carlini, when flying conditions permitted and
   self-pollinated in their absence, which was a consequence of cool and/or
   rainy weather. Moderate to high pollinator activity did not occur until
   air temperatures reached 17-20-degrees-C. On cool but sunny days higher
   temperatures occurred just above the surface litter and the bees were
   active. Self-pollination usually occurred on day 3 if flowers had not
   already been cross-pollinated. Fruit set and seed set in self-pollinated
   flowers, emasculated open-pollinated flowers and open-pollinated
   controls were equivalent. Both light and temperature appeared to affect
   daily flower opening and closing. Flowers did not open if air
   temperature was less than 8-degrees-C, and at increasingly higher
   temperature opened earlier and closed later but at the same temperature
   opened later and closed earlier if it was cloudy. Facultative xenogamy
   in this spring flowering species is adaptive because the flowers were
   cross-pollinated when conditions favored pollinator activity but
   self-pollinated when pollinator activity was suppressed by cool and/or
   rainy weather. The research was done in east-central Iowa.},
Publisher = {TORREY BOTANICAL CLUB},
Address = {NEW YORK BOTANICAL GARDEN, BRONX, NY 10458},
Type = {Article},
Language = {English},
Affiliation = {LYON, DL (Corresponding Author), CORNELL COLL,DEPT BIOL,MT VERNON,IA 52314, USA.},
DOI = {10.2307/2996724},
ISSN = {0040-9618},
Keywords = {ADRENA-CARLINI; FACULTATIVE XENOGAMY; FLORAL BEHAVIOR; LIGHT AND
   TEMPERATURE EFFECTS; POLLINATOR ACTIVITY; SELF-POLLINATION;
   THERMOREGULATION},
