@article{ WOS:A1984SM24200001,
Author = {SCHNEIDER, EL and NICHOLS, DM},
Title = {FLORAL BIOLOGY OF ARGEMONE-AURANTIACA (PAPAVERACEAE)},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1984},
Volume = {111},
Number = {1},
Pages = {1-7},
Abstract = {Anthesis of A. aurantiaca occurs over 3 consecutive days with flowers
   opening each morning and closing in the late afternoon. This stigma is
   receptive in early morning 1st-day flowers and by late morning the
   numerous stamens begin to dehisce, releasing large quantities of pollen.
   By the end of the 2nd day anthers have shriveled and the stigma has
   become non-receptive. During the 3rd day the petals and stamens abscise.
   Hymenoptera (Dialictus and Halictus) and Coleoptera (Euphoria and Lytta)
   were the most abundant and effective pollinators. Hymenoptera are
   effective cross-pollinators while Coleoptera facilitate
   self-pollination. The overall floral architecture as well as the floral
   behavior are adaptations which facilitate the pollination of Argemone by
   beetles.},
