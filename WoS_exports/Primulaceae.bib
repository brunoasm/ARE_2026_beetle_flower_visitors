@article{ WOS:A1994ND70300011,
Author = {ZHILYAEV, GG},
Title = {GENETIC INTERRELATIONS AND PHENETIC SIMILARITY PATTERNS BETWEEN
   POPULATIONS OF SOLDANELLA-HUNGARICA SIMONK (PRIMULACEAE) IN CARPATHIANS},
