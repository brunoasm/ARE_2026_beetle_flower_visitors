@article{ WOS:A1983QK23900011,
Author = {ANDERSON, RC and BEARE, MH},
Title = {BREEDING SYSTEM AND POLLINATION ECOLOGY OF TRIENTALIS BOREALIS
   (PRIMULACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1983},
Volume = {70},
Number = {3},
Pages = {408-415},
Abstract = {Selfing in T. borealis is reduced by spatial separation of stigma and
   anthers during anther dehiscence and by internal self-incompatibility.
   Artifical self-pollination resulted in low levels of fruit set (2.0\%).
   Crosses made within patches of plants yielded variable (0-72.7\%), but
   generally low fruit set (.hivin.x = 21.4\%). This may be caused by
   patches often consisting of a single genet. Crosses made among patches
   resulted in uniformly high levels of fruit set (.hivin.x = 84.3\%).
   Pollinator activity was higher at open sites than at heavily shaded
   sites and was correlated with fruit set. Pollinator activity showed no
   correlation with seed set. Apparently, the primary pollinators, Halictid
   and Andrenid bees, play an important role in the breeding system of the
   plant by promoting outcrossing but that availability of efficiency of
   pollinators may limit seed set.},
