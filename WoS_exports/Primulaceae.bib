@article{ WOS:A1983RR03400004,
Author = {SIMPSON, BB and NEFF, JL and SEIGLER, DS},
Title = {FLORAL BIOLOGY AND FLORAL REWARDS OF LYSIMACHIA (PRIMULACEAE)},
Journal = {AMERICAN MIDLAND NATURALIST},
Year = {1983},
Volume = {110},
Number = {2},
Pages = {249-256},
Abstract = {Field and chemical studies showed that female bees of the genus Macropis
   (Melittidae) visit flowers of Lysimachia in the New World in order to
   collect liquids secreted by trichome elaiophores at the bases of the
   petals and/or anther filaments. The association between the genera is
   not obligatory on the part of the plants. Several New World species are
   restricted to areas without Macropis. All New World taxa apparently
   reproduce vegetatively via rhizomes and can be pollinated by other bees.
   Dependency of Macropis on Lysimachia and a predominant association with
   L. ciliata are indicated.},
