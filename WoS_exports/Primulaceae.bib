Year = {1994},
Volume = {55},
Number = {1},
Pages = {128-138},
Month = {JAN-FEB},
Abstract = {Eleven populations of Soldanella hungarica were studied along
   altitudinal transect from 960 to 2060 m above see level. Phenetic
   similarity between them does not depend significantly on their genetic
   interrelations, the most influential factors being ecological ones. This
   makes it understandable existence of `'sibling'' populations, between
   which there is no genetic interchanges. Two kinds of populations are
   shown to be recognized in respect of their genetic interactions, donor
   and acceptor ones.},
