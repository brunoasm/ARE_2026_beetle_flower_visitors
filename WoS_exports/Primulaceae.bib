@article{ WOS:000318883200007,
Author = {Paulino Neto, Hipolito Ferreira},
Title = {Floral biology and breeding system of <i>Bauhinia forficata</i>
   (Leguminosae: Caesalpinioideae), a moth-pollinated tree in southeastern
   Brazil},
Journal = {BRAZILIAN JOURNAL OF BOTANY},
Year = {2013},
Volume = {36},
