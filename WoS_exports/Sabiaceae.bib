   Sato, A. A. Wong; Kato, M., Kyoto Univ, Grad Sch Human \& Environm Studies, Kyoto, Japan.},
DOI = {10.1111/plb.12699},
ISSN = {1435-8603},
EISSN = {1438-8677},
Keywords = {Dichogamy; explosive pollen release; male bumblebee; protandry;
   Sabiaceae; tactile stimulus},
Keywords-Plus = {FLOWER; MORPHOLOGY; MECHANISM; ANATOMY; NECTAR; GENUS},
Research-Areas = {Plant Sciences},
