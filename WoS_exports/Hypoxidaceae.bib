   Cent Univ Venezuela, Inst Expt Biol, Ctr Bot Trop, Caracas, Venezuela.},
ISSN = {0034-7744},
Keywords = {Hypoxys decumbens; perennial herb; mixed mating system; autogamy;
   outbreeding depression; pollination; fruit and seed set; biomass
