Author = {Keim, A. P. and Kartawinata, K. and Mustaqim, W. A. and Sujarwo, W.},
Title = {A new species of Freycinetia Gaudich. (<i>Pandanaceae;
   Freycinetoideae</i>) with pseudopetioliform leaves from Arfak Mountains,
   Papua, Indonesia},
Journal = {BLUMEA},
Year = {2022},
Volume = {67},
Number = {2},
Pages = {156-158},
Abstract = {A new species of Freycinetia Gaudich. (Pandanaceae; Freycinetoidea) with
   obvious pseudopetiolate basal leaf from Mount Tombrok in the vicinity of
   the Arfak Mountains, West Papua, Indonesian New Guinea, is newly
   described as Freycinetia pseudopetiolata A.P.Keim, K.Kartawinata \&
   W.Sujarwo. The possession of the pseudopetiolate basal leaf form places
   this new species in the section Pseudopetiolosae; thus marking the first
   presence of the section for mainland New Guinea.},
