@article{ WOS:A1984SS56300009,
Author = {COX, PA},
Title = {CHIROPTEROPHILY AND ORNITHOPHILY IN FREYCINETIA (PANDANACEAE) IN SAMOA},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1984},
Volume = {144},
Number = {3-4},
Pages = {277-290},
Abstract = {Field observations, experiments and SEM {[}scanning electron microscope]
   micrographs of hair and feather samples indicate the dioecious liana F.
   reineckei to be both chiropterophilous and ornithophilous with the
   prinicpal pollinators being an endemic flying fox, Pteropus samoensis,
   and an endemic starling, Aplonis atrifuscus. Nutritional analysis of
   staminate and pistillate inflorescences indicate qualitative and
   quantitative differences between the rewards offered by the 2 sexes. No
   nectar is presented, the principal pollinator rewards being fleshy
   bracts and pollen. As a result, staminate and bisexual inflorescences
   sustain higher levels of pollinator damage, a factor which may tend to
   maintain dioecism within the population.},
