@article{ WOS:A1977DT21800010,
Author = {SCHEMSKE, DW},
Title = {FLOWERING PHENOLOGY AND SEED SET IN CLAYTONIA-VIRGINICA (PORTULACACEAE)},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1977},
Volume = {104},
Number = {3},
Pages = {254-263},
Abstract = {Data on seed set and flowering phenology were obtained for C. virginica
   L. in Brownfield and Hart Woods in central Illinois {[}USA]. At both
   sites flowering time varied markedly between years with temperature as
   the proximate cue. Mean seed set per ovary at Brownfield and Hart was
   greatest in 1974, lowest in 1975 and intermediate in 1976. As determined
   from censuses of flowers on marked inflorescences at Brownfield in 1975
   and 1976, seed set was highest in flowers 1st-pistillate between the 25
   and 50\% cumulative flowering points. In both years, flowers opening
   early and late in the phenological sequence had reduced seed production
   and seed set declined rapidly during the latter periods of heavy
   flowering. Maximum seed set coincided with the 1st of the 2 peaks in th
   bimodal 1975 flowering sequence but preceded peak flowering in 1976.
   Abortion rates were highest in flowers 1st-pistillate during the final
   periods of Claytonia flowering when reduction of light due to canopy
   development was most severe. The evolution of Claytonia flowering time
   was influenced by cold temperatures early in the season which minimize
   pollination probabilities and development of the canopy late in the
   season which reduces photosynthetic capabilities.},
