Year = {1991},
Volume = {40},
Number = {3},
Pages = {219-223},
Abstract = {Examination of pollen grains recovered from the digestive tract of
   certain Madagascan hover flies (Melanostoma spp.) revealed that at least
   one species consumes large quantities of pollen of nominally
   anemophilous taxa (Poaceae, Cyperaceae).  The significance of this
   finding is discussed in the light of similar fly-anemophile
   relationships observed elsewhere in the world.},
