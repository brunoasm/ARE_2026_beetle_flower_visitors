@article{ WOS:000234314100014,
Author = {Mizianty, M and Bieniek, W and Czech, A and Strzalka, W and Szklarczyk,
   M},
Title = {Variability and structure of natural populations of <i>Elymus
   caninus</i> (L.) L. and their possible relationship with <i>Hordelymus
   europaeus</i> (L.) Jess. ex Harz as revealed by AFLP analysis},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2005},
Volume = {256},
Number = {1-4},
Pages = {193-200},
Month = {NOV},
Abstract = {The AFLP method was used to study the inter-population variability of
   eight populations of Elymus caninus (L.) L. as well as three populations
   of Hordelymus europaeus (L.) Jess. ex Harz. In these studies a clear
   distinction was found between two phenotypes of E. caninus collected in
   the same locality. It also appeared that two populations of E. caninus
   representing the ``pauciflorum{''} morphotype were clustered together,
   similarly as two populations of E. caninus exhibiting morphotype
   ``caninus{''}. Additionally, the populations of the ``pauciflorum{''}
   type were clustered together with all samples of H. europaeus.
   Furthermore, the same approach was applied to analyze the
   intra-population variability of E. caninus. The populations ranged from
   nearly uniform to as diverse as the samples collected from different
   localities. In some populations of this species the presence of off-type
   plants was revealed. Our data indicate the predominantly
   self-pollinating character of E. caninus and the possible genetic
   relationship between of E. caninus and H. europaeus.},
