@article{ WOS:A1977ED99400016,
Author = {AUQUIER, P},
Title = {BIOLOGY OF REPRODUCTION IN GENUS FESTUCA (POACEAE) .1. POLLINATION
   SYSTEMS},
Journal = {BULLETIN DE LA SOCIETE ROYALE DE BOTANIQUE DE BELGIQUE},
Year = {1977},
Volume = {110},
Number = {1-2},
Pages = {129-150},
Abstract = {Reproduction by auto- and allogamy is considered among different taxa of
   the genus Festuca, mainly in those from Middle Europe. The few cases of
   cleistogamy seem to be linked to response to drastic climatic
   conditions. It was not possible to reveal eventuality of agamospermic
   reproduction. The fertilization systems studied are discussed in
   relationship with some aspects of evolutive dynamism and ecogeographical
   potentialities of taxa.},
Publisher = {SOC ROYAL BOTAN BELGIQUE},
Address = {NIEUWELAAN 38, B-1860 MEISE, BELGIUM},
