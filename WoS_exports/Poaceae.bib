@article{ WOS:001181507800001,
Author = {Richard, Geraldina Alicia and Zabala, Juan Marcelo and Tomas, Pablo and
   Alegre, Macarena and Marinoni, Lorena del Rosario and Cerino, Maria
   Carolina and Pensiero, Francisco Jose},
Title = {Reproductive biology of<i> Elymus</i><i> scabrifolius</i> (Do<euro>ll)
   J. H. Hunz. (Poaceae: Triticeae), an important phytogenetic resource for
   saline environments},
Journal = {SOUTH AFRICAN JOURNAL OF BOTANY},
Year = {2024},
Volume = {167},
Pages = {12-19},
Month = {APR},
Abstract = {Elymus scabrifolius is a perennial forage species valued as a plant
   genetic resource for degraded areas and for crop improvement, being a
   source of salt -tolerant related genes. In this study, we determined the
   breeding system of this species by analyzing seed set under different
   pollination treatments, phenology, floral traits, and embryological
   development in four Argentine populations. The results indicate that E.
   scabrifolius has a mixed, sexual, and mainly autogamous reproductive
   system. Plants from all populations produced high seed percentages, with
   significant differences among them. Self-pollination occurred
   fundamentally between the chasmogamous florets of the same plant by
   geitonogamy. This mode of selfing results from the flowering synchrony
   and the architecture of inflorescences. Self-pollination by cleistogamy
   had low rates and was observed in only two populations. This information
   may be useful to estimate the potential utility of this species as a
   phytogenetic resource, and to design efficient collection and
   conservation programs. (c) 2024 SAAB. Published by Elsevier B.V. All
   rights reserved.},
