@article{ WOS:A1988M322400002,
Author = {REDDI, CS and REDDI, NS and JANAKI, BA},
Title = {CIRCADIAN PATTERNS OF POLLEN RELEASE IN SOME SPECIES OF POACEAE},
Journal = {REVIEW OF PALAEOBOTANY AND PALYNOLOGY},
Year = {1988},
Volume = {54},
Number = {1-2},
Pages = {11-42},
Month = {FEB},
Abstract = {The daily course and intensity of pollen release in relation to
   meteorological variables were assessed by scoring the anthers dehisced
   each hour for 54 poaceous species in their natural environments at
   Visakhapatnam (17.degree.42''N and 82.degree.18''E), Andhra Pradesh,
   India. Once begun to shed pollen, an inflorescence of any of the grasses
   studied, continued to do so until it ceased to flower, but in Apluda
   mutica, a high rate of anthesis on one day was followed by a feeble rate
   the next day. Each of the species exhibited a characteristic temporal
   pattern of pollen release, and no hour of the day was quiescent.
   Imperata cylindrica and Pennisetum americanum shed pollen without gap
   through the 24-hr period and all through the inflorescence life, even if
   it was rainy. Cynodon dactylon and Perotis sp. flowered twice during a
   circadian cycle, while the other grasses only once, the majority
   releasing pollen over a period of 2-7 hr. Duration and intensity of
   pollen release were inversely  related. Pollen release times of any of
   the species were repeatable on fine weather days, and based on the
   maximal release period ten patterns were recognised. Weather affected
   the normal pattern, and each species responded differently to variations
   in weather factors suggesting that anther dehiscence in them might have
   adapted through a genetic make-up to certain evaporating power of the
   air. Rain exceptionally promoted anthesis in Sehima nervosum. Nocturnal
   pollen release seemed peculiar in  anemophiles, and its adaptive value
   is discussed. Staggered flowering during one day and in some species
   short anthesis of 2-3 hr might function as a reproductive isolating
   mechanism, and/or as a device to avoid waste of pollen and stigma sites
   through unwanted nonsense pollination.},
Publisher = {ELSEVIER},
Address = {RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS},
Type = {Article},
Language = {English},
Affiliation = {ANDHRA UNIV, DEPT ENVIRONM SCI, WALTAIR 530003, ANDHRA PRADESH, INDIA.
   ANDHRA UNIV, DEPT BOT, WALTAIR 530003, ANDHRA PRADESH, INDIA.},
