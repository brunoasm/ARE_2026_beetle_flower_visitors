@article{ WOS:A1989AN77400019,
Author = {JENSEN, KB and HSIAO, C and ASAY, KH},
Title = {GENOMIC AND TAXONOMIC RELATIONSHIPS OF AGROPYRON-VAILLANTIANUM AND
   E-ARIZONICUS (POACEAE, TRITICEAE)},
Journal = {GENOME},
Year = {1989},
Volume = {32},
Number = {4},
Pages = {640-645},
Month = {AUG},
Abstract = {Agropyron vaillantianum (Wulf. and Schreber) Trautv. and E. arizonicus
   (Schribn. and Smith) Gould were studied to describe their (i)
   reproductive characteristics, (ii) meiotic behavior, (iii) genomic
   constitution, and (iv) correct taxonomic alignment based on genomic
   relationships. Both species were found to be self-fertile tetraploids
   (2n = 28) and behaved as strict allotetraploids averaging 14.00 and
   13.77 bivalents per cell, respectively. The hybrids A. vaillantianum
   .times. Pseudoroegneria spicata (Pursh) A. Love, 2n = 14, SS, A.
   vaillantianum .times. E. trachycaulus (Link) Gould ex Shinners, 2n = 28,
   SSHH, and E. arizonicus .times. E. canadensis L., 2n = 28, SSHH,
   averaged 6.12, 12.56, and 12.60 bivalents per cell, respectively.
   Chromosome pairing in this series of hybrids demonstrated that A.
   vaillantianum and E. arizonicus contain the S and H genomes, with each
   taxon having a slight modification resulting from evolutionary pressures
   under different ecological parameters. On the basis of chromosome
   pairing and mode of pollination it is proposed that A. vaillantianum be
   treated in the genus Elymus rather than in the genus Agropyron, with the
   following new name combination: Elymus vaillantianus (Wulf. and Schreb.)
   K.B. Jensen comb. nov., based on Triticum vaillantianum Wulfen and
   Schreber. Elymus typically encompasses those species that are
   self-fertile, and contain the SH genomes. Elymus arizonicus has been
   correctly classified.},
