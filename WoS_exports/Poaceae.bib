Affiliation = {Dresselhaus, T (Corresponding Author), Univ Hamburg, Ohnhorststr 18, D-22609 Hamburg, Germany.
   Univ Hamburg, D-22609 Hamburg, Germany.
   IPK, D-06466 Gatersleben, Germany.},
