DOI = {10.1006/bijl.2001.0602},
ISSN = {0024-4066},
EISSN = {1095-8312},
Keywords = {pollinator-plant coevolution; angiosperin radiation; insect radiation;
   gymnosperm; speciation; extinction},
Keywords-Plus = {TERRESTRIAL-MARINE TELECONNECTIONS; SELF-INCOMPATIBILITY SYSTEMS;
