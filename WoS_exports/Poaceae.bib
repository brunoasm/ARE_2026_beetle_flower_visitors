ISSN = {0934-0882},
Keywords = {apomixis; parthenogenesis; pseudogamy; Tripsacum; microdissection},
Keywords-Plus = {EASTERN GAMAGRASS; WILD RELATIVES; APOMIXIS; MAIZE; GENES; WHEAT;
