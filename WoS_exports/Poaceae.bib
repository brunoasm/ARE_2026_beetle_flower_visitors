@article{ WOS:000165391500001,
Author = {Laaidi, M},
Title = {Intradiurnal variation of pollen shedding. The use in the daily
   management of pollinosis by patients.},
Journal = {REVUE FRANCAISE D ALLERGOLOGIE ET D IMMUNOLOGIE CLINIQUE},
Year = {2000},
Volume = {40},
Number = {6},
Pages = {597-605},
Month = {OCT},
Abstract = {A better acknowledgement of intradiurnal variations of the pollination
   of allergenic taxa must help allergic people to better manage their
   pollinosis day by day. Those variations have been studied in Burgundy
   thanks to four Hirst volumetric traps giving data every two hours. Some
   taxa show little definite cycles, with a pollination more or less
   regular all along the day; they are poplar, ash, birch, oak, pine and
   chestnut-tree. Some others have a more definite cycle, with a real peak:
   this is the case of some trees which shed their grains preferably from
   the end of the morning to the beginning of the evening (alder, hazel,
   Cupressaceae-Taxaceae, willow, hornbeam, plane-free), and this is also
   the case of numerous herbaceous plants which pollinate preferably from
   the beginning of the morning to the beginning of the afternoon (garden
   sorrel, plantain, Urticaceae, mugwort). The Poaceae only have a definite
   cycle in Macon and Montbard, with a double peak in the morning and in
   the evening. This periodicity follows the hourly evolution of
   temperature and relative humidity. A more precise information on the
   cycle of the plant to which he is allergic can help the allergic patient
   to reduce his daily exposure to allergens, ventilating his home during
   the pollen hollow or avoiding to go out and moreover to have an open-air
   physical activity during the pollen peak. (C) 2000 Editions
   scientifiques et medicales Elsevier SAS.},
Publisher = {ELSEVIER FRANCE-EDITIONS SCIENTIFIQUES MEDICALES ELSEVIER},
Address = {65 RUE CAMILLE DESMOULINS, CS50083, 92442 ISSY-LES-MOULINEAUX, FRANCE},
