   Anton, Ana M., Univ Nacl Cordoba, CONICET, Inst Multidisciplinario Biol Vegetal, RA-5000 Cordoba, Argentina.
   Fortunato, Renee H., CIRN INTA, Inst Recursos Biol, RA-1712 Buenos Aires, DF, Argentina.},
DOI = {10.1139/G11-067},
ISSN = {0831-2796},
Keywords = {Stenodrepanum; triploids; diploids; endemic; Fabaceae; Argentina},
