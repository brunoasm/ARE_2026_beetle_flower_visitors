Language = {English},
Affiliation = {Veller, C (Corresponding Author), Harvard Univ, Program Evolutionary Dynam, Cambridge, MA 02138 USA.
   Veller, Carl; Nowak, Martin A., Harvard Univ, Program Evolutionary Dynam, Cambridge, MA 02138 USA.
   Veller, Carl; Nowak, Martin A.; Davis, Charles C., Harvard Univ, Dept Organism \& Evolutionary Biol, Cambridge, MA 02138 USA.
   Nowak, Martin A., Harvard Univ, Dept Math, Cambridge, MA 02138 USA.},
DOI = {10.1111/ele.12442},
ISSN = {1461-023X},
EISSN = {1461-0248},
Keywords = {Bamboos; biological clocks; masting; phenology},
