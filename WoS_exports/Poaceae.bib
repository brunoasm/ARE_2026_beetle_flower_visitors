   Ben Gurion Univ Negev, Dept Life Sci, IL-84990 Sede Boker, Israel.},
DOI = {10.1111/j.1095-8312.1999.tb01859.x},
ISSN = {0024-4066},
Keywords = {afterripening; dry storage duration; germination; NaCl solutions; local
