@article{ WOS:A1994PM23400005,
Author = {VOILOKOV, AV and FUONG, FT and PRIYATKINA, SN and SALTYKOVSKAYA, NA and
   NEMOVA, IA and SMIRNOV, VG},
Title = {IDENTIFICATION AND LOCATION OF SELF-FERTILITY MUTATIONS IN RYE INBRED
   LINES},
Journal = {GENETIKA},
Year = {1994},
Volume = {30},
Number = {8},
Pages = {1057-1064},
Month = {AUG},
Abstract = {A genetic analysis of self-fertility in rye was performed by means of
   scoring the segregation for self-fertility in corresponding hybrids and
   by studying the inheritance of marker (isozyme) loci.  Three mutant
   genes with gametophytic expression, which impairs functioning of the
   system of incompatibility, were found in seven inbred lines.  Each line
   carries one self-fertility mutation.  Two of the described genes S1 and
   S2 may belong to the multiallelic loci S and Z, which control
   interaction of pollen and the pistil in rye.  Self-fertility mutations
   in the third gene S5 were found for the first time.  Mutations of all
   three genes are expressed in the same way in case of self-pollination of
   plants that are heterozygous at them.  Due to selective participation of
   pollen grains in fertilization, deviations in segregation were observed
   in inbred progenies of heterozygotes at markers linked with
   self-fertility mutations.  Linked isozyme markers were found for each of
   the described genes - PRx7 for S1 (1R), beta-GLU for S2 (2R) and Aadhl
   for S5 (5R).  Genetic maps of the fragments of rye chromosomes 1R, 2R,
   and 5R were constructed; they include self-fertility mutations and
   isozyme and morphological markers.},
