@article{ WOS:A1981LJ98000010,
Author = {ADAMS, DE and PERKINS, WE and ESTES, JR},
Title = {POLLINATION SYSTEMS IN PASPALUM-DILATATUM POIR (POACEAE) - AN EXAMPLE OF
   INSECT POLLINATION IN A TEMPERATE GRASS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1981},
Volume = {68},
Number = {3},
Pages = {389-394},
Abstract = {The pollination of P. dilatatum was studied in south-central Oklahoma,
   USA, during the summer of 1979. Pollen was liberated between 0700-0900 h
   except on humid morings (RH {[}relative humidity] .gtoreq. 80\%), when
   there was a delay of 2-3 h and a reduction in the total air-borne pollen
   concentration. A rapid decrease in air-borne pollen concentration with
   distance from the source results from individual pollen grains larger
   (50-70 .mu.m in diameter) than typical wind-pollinated plants, and some
   pollen dispersed as clusters of grains. Several floral characters of P.
   dilatatum suggested that this perennial grass may be entomophilous and
   anemophilous. The pollen grains were larger than most other
   wind-pollinated taxa and the species produced fewer than 2500 pollen
   grains/ovule. Three additional observations corroborate this view:
   solitary bees (Halictidae) actively collect pollen during the morning,
   the number of pollen grains per stigma was significantly (P < 0.001)
   greater on racemes exposed to both wind and bees than on racemes exposed
   only to wind and the combination of bees and wind as pollinators
   significantly (P < 0.001) increased seed set compared to wind alone.},
