   Hay, Joe; Kelly, Dave; Holdaway, Robert J., Univ Canterbury, Sch Biol Sci, Christchurch 1, New Zealand.},
ISSN = {0110-6465},
EISSN = {1177-7788},
Keywords = {edge effects; masting; nitrogen; resource models; seed predation},
Keywords-Plus = {NEW-ZEALAND; WIND POLLINATION; EVOLUTIONARY ECOLOGY; PREDATOR SATIATION;
   FOREST; INFLORESCENCES; REPRODUCTION; PATTERNS; INTERIOR; BENEFITS},
