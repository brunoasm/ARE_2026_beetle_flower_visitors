@article{ WOS:A1993MM34000001,
Author = {KOVACS, G and BARNABAS, B},
Title = {LONG-TERM STORAGE OF RYE AND TRITICALE POLLEN IN LIQUID-NITROGEN},
Journal = {NOVENYTERMELES},
Year = {1993},
Volume = {42},
Number = {4},
Pages = {301-305},
Month = {AUG},
Abstract = {Successful long term storage of Poaceae pollen is generally limited
   compared to that of other species and it seems to vary among Poaceae
   genera. Up to now there has been only a limited number of successful
   research in cryo-storing maize, rye, pearl miller and ryegrass pollen.
   There are no data available about Triticosecale species at all and there
   is no indication about the maximum length of cryopreservation which
   still provides viable, functionable pollen. In our article we report on
   successful cryo- storage method for rye and triticale pollen. The
   experimental data showed that of the two species rye pollen could
   tolerate better the necessary dehydration before storage than triticale
   pollen. From the average of 10 pollinated ears appeared that rye pollen
   could lose more than 50\% of its original water content without
   considerable reduction in pollen viability and fertility. The triticale
   pollen was more sensitive to dehydration which was resulted in a reduced
   seed set. After two years in storage cryopreserved pollen could be used
   for artificial pollinations. Rye pollen survived in a relatively high
   percentage even after a couple of years in deep-frozen condition.
   Triticale pollen showed only a low percentage of survival.},
