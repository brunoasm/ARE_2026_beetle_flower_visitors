Keywords = {Cecidomyiidae; Chionochloa; ISSR; mass flowering; mast seeding; predator
   satiation},
Keywords-Plus = {AMPLIFIED POLYMORPHIC DNA; EVOLUTIONARY ECOLOGY; WIND POLLINATION;
   BOMBYX-MORI; FLY DIPTERA; NEW-ZEALAND; MAST; POPULATIONS; SILKWORM;
