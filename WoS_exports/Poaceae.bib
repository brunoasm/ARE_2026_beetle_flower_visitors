Keywords = {genetic structure; ISSR marker; Orchidaceae; platanthera; allopolyploid},
Keywords-Plus = {NATURAL-POPULATIONS; CLONAL DIVERSITY; ISSR; ALLOZYME; POACEAE; RAPD;
