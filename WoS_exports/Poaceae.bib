EISSN = {2199-6881},
Keywords = {molecular variation; Elymus trachycaulus; E. alaskanus; E. caninus;
   phenetics},
Keywords-Plus = {LENGTH POLYMORPHISM; TRITICEAE; AGROPYRON; RAPD; HYBRIDS; POACEAE},
