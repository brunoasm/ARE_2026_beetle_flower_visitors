Title = {MORPHOLOGY, ANATOMY AND MEIOTIC ANALYSIS OF CEDRELA-FISSILIS VELL
   (MELIACEAE)},
Journal = {ARQUIVOS DE BIOLOGIA E TECNOLOGIA},
Year = {1990},
Volume = {33},
Number = {4},
Pages = {925-937},
Abstract = {Cedrela fissilis Vell. presents interfloral dichogamy. The male flowers
   produce abundant pollen and pistillode with abortive ovules. The female
   flowers possess atrophied anthers and anatropous ovules. The anthesis
   occurs in the end of the day and the pollination is entomophilous. The
   meiotic analysis reveals abnormality such as late and precocious
   ascension of chromosomes. Pollen grains may germinate within the anther
   loculi.},
