   Vikas; Tandon, Rajesh, Univ Delhi, Dept Bot, Delhi 110007, India.},
DOI = {10.1111/j.1442-1984.2010.00311.x},
ISSN = {0913-557X},
EISSN = {1442-1984},
Keywords = {ambophily; arid zone; breeding system; floral biology; Margosa tree;
   self-incompatibility},
Keywords-Plus = {BREEDING SYSTEMS; SEED-SET; POLLINATION; STIGMA; WIND; INCOMPATIBILITY;
