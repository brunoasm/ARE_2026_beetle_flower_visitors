   and Silva, Cleber J. and Carvalho, Larissa S. and Andrade, Nelio J.},
Title = {CHEMICAL COMPOSITION AND ANTIBACTERIAL ACTIVITY OF ESSENTIAL OILS FROM
   VERBENACEAE SPECIES: ALTERNATIVE SOURCES OF (E)-CARYOPHYLLENE AND
   GERMACRENE-D},
Journal = {QUIMICA NOVA},
Year = {2011},
Volume = {34},
Number = {9},
Pages = {1550-1555},
Abstract = {Volatile oils from the leaves of Verbenaceae species Aloysia virgata,
   Lantana camara, Lantana trifolia, Lantana montevidensis, Lippia
   brasiliensis and Lippia sericea were investigated for its chemical
   composition and antibacterial activity. The volatile oils were
   characterized by a high content of sesquiterpenes of which
   (E)-caryophyllene (10-35\%), germacrene-D (5-46\%) and bicyclogermacrene
   (7-17\%) were the major components for all studied species. For the
   flowers, a higher concentration of monoterpenes was observed for the
   species L. camara, L. trifolia and L. brasiliensis. These compounds
   probably act as attractive to specific pollinators. The volatile oils
   from A. virgata was the most active, exhibiting moderate antimicrobial
   activity against the bacteria Staphylococcus aureus, Bacillus cereus and
   Escherichia coli.},
