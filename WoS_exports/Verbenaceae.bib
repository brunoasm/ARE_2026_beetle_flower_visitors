@article{ WOS:001274449200001,
Author = {Abbate, Anthony P. and Campbell, Joshua W. and Grodsky, Steven M. and
   Williams, Geoffrey R.},
Title = {Assessing the attractiveness of native wildflower species to bees
   (Hymenoptera: Anthophila) in the southeastern United States},
Journal = {ECOLOGICAL SOLUTIONS AND EVIDENCE},
Year = {2024},
Volume = {5},
Number = {3},
Month = {JUL},
Abstract = {Habitat loss, agricultural intensification, pesticide use, disease and
   climate change have contributed to the decline of numerous insect
   groups. Recent government initiatives have recognized the importance of
   supplementary wildflower plantings to support native bee populations,
   yet little information exists on the attractiveness of recommended plant
   species to bees. With the use of network analysis and generalized linear
   mixed models, we evaluated the attractiveness of 18 wildflower species
   belonging to 6 families (Apiaceae, Apocynaceae, Asteraceae, Fabaceae,
   Lamiaceae and Verbenaceae) planted in a randomized block design by
   conducting timed targeted sweep netting surveys. We also evaluated the
   floral preferences of four bee species (Apis mellifera, Halictus
   poeyi/ligatus, Bombus griseocollis and Bombus impatiens) to the planted
   wildflower species with the use of GLMs. We found that Asclepias
   tuberosa, Gaillardia pulchella and Verbena hastata attracted the
   greatest abundance, richness and diversity of native bees compared to
   the other wildflower species. Collectively, Asclepias tuberosa,
   Gaillardia pulchella and Verbena hastata attracted 89\% of all bee taxa
   in the study, which exemplifies the importance of including them in a
   wildflower mixture to attract native bees. While several wildflower
   species attracted low abundance, richness and diversity of native bees
   such as Monarda fistulosa, Symphyotrichum pilosum and Eryngium
   yuccifolium, they are still ecologically important for attracting
   uncommon or specialist bee species and should be included in seed mixes
   for this reason. Solution. Our results highlight that each species of
   native wildflower varies in the abundance, richness and diversity of
   native bees they attract; this could be considered in the
   decision-making of landowners and land managers to promote wildflower
   plantings to reflect the needs of certain groups of bees of conservation
   interest.
   Recent government incentives have recognized the importance of
   supplementary wildflower plantings to support native bee populations,
   yet little information exists on the attractiveness of recommended plant
   species to bees. We evaluated the attractiveness of 18 wildflower
   species to native bees through timed sweep netting surveys. Our results
   highlight that each native wildflower species varies in the abundance,
   richness and diversity of native bees they attract; this information
   could be considered in the decision-making of landowners and land
   managers to promote wildflower plantings to support a diversity of
   native bees.image},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Abbate, AP (Corresponding Author), Auburn Univ, Dept Entomol \& Plant Pathol, Auburn, AL 36849 USA.
   Abbate, Anthony P.; Campbell, Joshua W.; Williams, Geoffrey R., Auburn Univ, Dept Entomol \& Plant Pathol, Auburn, AL 36849 USA.
   Campbell, Joshua W., USDA ARS, Pest Management Res Unit, Northern Plains Agr Res Lab, Sidney, MT USA.
   Grodsky, Steven M., Cornell Univ, Dept Nat Resources \& Environm, New York Cooperat Fish \& Wildlife Res Unit, US Geol Survey, Ithaca, NY USA.},
DOI = {10.1002/2688-8319.12363},
Article-Number = {e12363},
EISSN = {2688-8319},
