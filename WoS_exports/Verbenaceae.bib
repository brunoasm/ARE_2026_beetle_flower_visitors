Affiliations = {James Madison University},
Funding-Acknowledgement = {National Geographic Society {[}5014-93]},
Funding-Text = {I thank the Charles Darwin Foundation, the Charles Darwin Research
   Station, the Galapagos National Park Service, and TAME Airlines for
   logistical support. Chantal Blanton, Laura Chellis, Felipe Cruz,
