   Gross, C. L.; Gorrell, L.; Macdonald, M. J.; Fatemi, M., Univ New England, Armidale, NSW 2351, Australia.},
DOI = {10.1111/j.1365-3180.2010.00788.x},
ISSN = {0043-1737},
Keywords = {Lippia; facilitation; weed pollination; pollinator exclusion experiment;
   breeding system; seed germinability; honeybee; Apis mellifera},
