@article{ WOS:000467454500004,
Author = {Amela Garcia, Maria T. and Aquino, Diego and Souza, Agustina and Grohar,
   Mariana C. and Herrera Cano, Anahi N. and Lafuente Diaz, Maiten A. and
   Miguez, Maria B. and Scorza, Victoria and Chamer, Marina},
Title = {REPRODLICTIVE SYSTEM AND FLORAL BIOLOGY OF <i>LANTANA CAMARA</i>
   (VERBENACEAE) IN A RIPARIAN POPULATION OF THE RIO DE LA PLATA},
Journal = {BOLETIN DE LA SOCIEDAD ARGENTINA DE BOTANICA},
Year = {2019},
Volume = {54},
Number = {1},
Pages = {29-42},
Month = {MAR},
Abstract = {Background and aims: The floral biology of Lantana camara, a native
   species of Central and South America and invasive cosmopolitan, still
   presents poorly-known and controversial aspects. The aim of this work
   was to determine the reproductive system, floral attributes and
   pollinators in a coastal population of Rio de la Plata.
   M\&M: The usual methods in pollination biology were employed. The study
   was performed in Ciudad Universitaria, Ciudad Autonoma de Buenos Aires,
   Argentina, during the spring of 2012.
   Results: The flowers emit mild and sweet odor by osmophores arranged
   around the floral tube entrance, in coincidence with the
   absorption-reflection pattern in the UV spectrum. Nectar accumulates in
   the floral tube, probably secreted by trichomes situated at the petals
   base. During anthesis, three floral phases succeed, distinguished by
   changes in corolla coloration, aroma intensity, reward quantity and
   anther and stigma maturity. The psychophilous flowers were visited by
   diurnal lepidopterens and by hymenopterans, dipterans and hummingbirds.
   The highest reproductive success occurred with free pollination; the
   self-incompatibility and P/O indexes showed partial self-compatibility
   and facultative xenogamy, respectively.
   Conclusions: L. camara is capable of successful spontaneous
   self-pollination, probably one reason of its global spread. Due to their
   activity on the flowers, visited floral phase, pollen load and frequency
   of visits, only the butterflies Agraulis vanillae maculosa, Dryas iullia
   alcionea and Cymaenes sp. would pollinate in this site.},
