   Navarro, Luis, Univ Vigo, Dept Biol Vegetal, Fac Ciencias, Vigo 36200, Spain.
   Medel, Rodrigo, Univ Chile, Fac Ciencias, Dept Ciencias Ecol, Santiago, Chile.},
DOI = {10.1111/j.1095-8312.2008.01146.x},
ISSN = {0024-4066},
Keywords = {Cuba; evolution of flower length; phenotypic selection; robbery;
