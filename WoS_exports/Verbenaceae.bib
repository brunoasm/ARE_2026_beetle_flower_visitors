@article{ WOS:A1993KV63400003,
Author = {CRAWFORD, DJ and STUESSY, TF and RODRIGUEZ, R and RONDINELLI, M},
Title = {GENETIC DIVERSITY IN RHAPHITHAMNUS-VENUSTUS (VERBENAECEAE), A SPECIES
   ENDEMIC TO THE JUAN-FERNANDEZ ISLANDS},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1993},
Volume = {120},
Number = {1},
Pages = {23-28},
Month = {JAN-MAR},
Abstract = {Enzyme electrophoresis was used to assess genetic diversity within and
   among populations of Rhaphithamnus venustus (Phil.) Skottsb.
   (Verbenaceae), a species endemic to the Juan Fernandez Islands, Chile.
   The species is a gynodioecious tree that occurs in very small
   populations scattered throughout the island of Masatierra and also is
   found on Masafuera. The flowers are pollinated by hummingbirds. Total
   genetic diversity (H(T)) in the 14 populations and 54 individuals is
   0.028, a low value for a species with the suite of attributes found in
   R. venustus. Two populations of Rhaphithamnus spinosus (A. Juss.)
   Moldenke were examined; this is the only other species in the genus and
   the presumed progenitor of R. venustus. These populations from mainland
   Chile contain four times the total diversity detected in R. venustus.
   Rhaphithamnus venustus appears to have passed through a genetic
   bottleneck during and/or after establishment on the Juan Fernandez
   Islands resulting in the much lower diversity compared to its mainland
   progenitor.},
