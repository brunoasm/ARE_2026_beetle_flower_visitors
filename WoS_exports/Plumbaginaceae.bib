@article{ WOS:A1948YA49400001,
Author = {BAKER, HG},
Title = {DIMORPHISM AND MONOMORPHISM IN THE PLUMBAGINACEAE .1. A SURVEY OF THE
   FAMILY},
Journal = {ANNALS OF BOTANY},
Year = {1948},
Volume = {12},
Number = {47},
Pages = {207-219},
Abstract = {All genera of the Plumbagineae have monomorphic pollen; all genera of
   the Staticeae, with the exception of Aegialitis, show pollen-dimorphism
   which, with the associated stigma-dimorphism, is described and
   illustrated. Derived monomorphism occurs in Limonium and Armeria. The
   Plumbagineae form a well-knit tribe of apparently considerable
   antiquity. In the Staticeae, Aegialitis possesses pollen of the
   Plumbagineae-type and is probably the oldest genus of the tribe. Maps
   show the distributions of all genera of the family. The Staticeae are
   considered not directly derived from the Plumbagineae because of extreme
   modification in embryo-sac structure in the latter. The development of
   in- and out-breeding systems is traced. Heterostyly in Limonium has
   probably been superimposed upon the incompatibility mechanism made
   visible by pollen-and stigma-dimorphism, the latter probably being the
   primitive method in the Staticeae. Self-compatibility (accompanying
   derived monomorphism in Armeria and Limonium) may be of value where
   pollinating insects are sparse and in facilitating establishment after
   long-distance dispersal. The development of heterostyly in the
   Plumbagineae probably represents parallel evolution to its development
   in the Staticeae.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
DOI = {10.1093/oxfordjournals.aob.a083185},
ISSN = {0305-7364},
