   Holland, J. N.; Chamberlain, S. A.; Horn, K. C., Rice Univ, Dept Ecol \& Evolutionary Biol, Houston, TX 77005 USA.},
DOI = {10.1016/j.jaridenv.2009.10.008},
ISSN = {0140-1963},
EISSN = {1095-922X},
