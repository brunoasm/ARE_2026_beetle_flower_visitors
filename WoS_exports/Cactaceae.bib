@article{ WOS:000439539000013,
Author = {Arzabe, Ariel and Aguirre, Luis F. and Baldelomar, Mariela},
Title = {Pollination system of two endemic Bolivian cacti: <i>Harrisia
   tetracanth</i>a and <i>Neoraimondia herzogiana</i>},
Journal = {BRADLEYA},
Year = {2018},
Volume = {36},
Pages = {178-188},
Abstract = {Columnar cacti may present different mating systems that vary according
   to distinct factors, and the studies of these systems are essential to
   preserve cactus species. Bolivia is the fourth country with most
   diversity of Cactaceae, still scarce information about the reproductive
   biology of the endemic cactus species is known. Therefore, we assessed
   the pollination type, pollination syndrome and flower visitors of the
   endemic columnar cacti Harrisia tetracantha and Neoraimondia herzogiana.
   We hypothesize that they would present cross and self-pollination as
   strategies to ensure reproduction in the bioclimatic variable dry
   inter-Andean valleys.},
