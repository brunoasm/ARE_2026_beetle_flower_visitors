@article{ WOS:000351746000002,
Author = {Eggli, Urs and Giorgetta, Mario},
Title = {FLOWERING PHENOLOGY AND OBSERVATIONS ON THE POLLINATION BIOLOGY OF SOUTH
   AMERICAN CACTI. 1. <i>DENMOZA</i> <i>RHODACANTHA</i>},
Journal = {HASELTONIA},
Year = {2015},
Number = {20},
Pages = {3-12},
Month = {FEB},
Abstract = {Pollination biology is an especially important component of the overall
   ecological setting of a plant species since it has direct implications
   on reproductive success. Over time, a typological approach to
   classifying flower-pollinator interactions in the form of ``floral
   syndromes{''} has been developed, and considerable predictive power is
   traditionally ascribed to these syndromes. Recent studies have
   increasingly questioned both the predictive value of the syndrome
   concept, as well as the underlying notion of increasing specialization
   amongst flower-pollinator interactions. The casual discovery that the
   seemingly ornithophilous flowers of the globose to shortly columnar
   South American cactus Denmoza rhodacantha (Cactaceae: Cactoideae:
   Cereeae: Trichocereinae) are visited by solitary pollen-collecting
   halictid bees, rather than the expected hummingbirds, adds another
   example to the growing body of mismatches between floral syndrome and
   observed pollinator.},
