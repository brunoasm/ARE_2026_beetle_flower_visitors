Year = {1985},
Volume = {148},
Number = {3-4},
Pages = {287-289},
Abstract = {Self and outcross pollination treatments were applied to N. intertexta.
   Two distinct patterns of seed production were found, and correlated with
   self-pollinated outcrossed treatments. The outcrossed result resembles
   the field exposed crop. The untouched controls produce a pattern similar
   to the actively selfed group. The self treatments produce substantially
   fewer seed than the outcrosses: thus, self-compatibility is incomplete.},
