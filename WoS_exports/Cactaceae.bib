   Inst Nacl Invest Forestales \& Agropecuarias, CIR Ctr, Queretaro 76140, Mexico.},
Keywords = {apomixis; cactus pear; nopal; seedlings; cactus breeding},
Keywords-Plus = {IDENTIFICATION; APOMIXIS; RAPD},
Research-Areas = {Agriculture},
Web-of-Science-Categories  = {Horticulture},
