@inproceedings{ WOS:000175529000024,
Author = {Amos, BB and Vassiliou, C},
Editor = {Maschinski, J and Holter, L},
Title = {Preliminary report on the reproductive biology of the threatened Chisos
   Mountain hedgehog cactus},
