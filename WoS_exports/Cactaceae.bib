   Univ Nacl Autonoma Mexico, Ctr Invest Ecosistemas, Morelia 58089, Michoacan, Mexico.
   Univ Georgia, Dept Plant Sci \& Genet, Athens, GA 30602 USA.},
DOI = {10.1111/j.1365-294X.2005.02762.x},
ISSN = {0962-1083},
EISSN = {1365-294X},
