@article{ WOS:001138185600004,
Author = {Cardenas-Ramos, Diana and Mandujano, Maria C. and Estrada-Alvarez, Julio
   C. and Sormani, Carlo G. H.},
Title = {Polyphagous and florivorous habits of<i> Latiblattella</i><i>
   tarasca</i> (Saussure, 1862) (Blattodea: Pseudophyllodromidae) on four
   species of the genus<i> Opuntia</i> Mill., 1754 (Caryophyllales:
   Cactaceae), in a portion of the Querétaro semidesert, Mexico},
Journal = {REVISTA CHILENA DE ENTOMOLOGIA},
Year = {2023},
Volume = {49},
Number = {3},
Pages = {625-632},
Abstract = {Consumption of rewards and floral structures by wild cockroaches, as
   well as their role as pollinators in natural ecosystems, has been
   sparsely studied. The aim of this study is to describe the activities
   performed by Latiblattella tarasca on flowers and cladodes of four
   species of Opuntia (O. cantabrigiensis, O. robusta, O. tomentosa, and O.
   streptacantha). In April 2018, nocturnal surveys were conducted over
   three days in a semidesert sector of Queretaro, Mexico. The number of
   individuals, sex, developmental stage, and activity of L. tarasca were
   recorded. In O. robusta, O. tomentosa, and O. streptacantha, few
   individuals of L. tarasca made frequent tours in the cladodes and scarce
   visits in flowers; it is possible that the low abundance of flowers
   conditions the frequency of cockroaches observed on this cactus. Females
   and nymphs were the most abundant at the study site. Latiblattella
   tarasca was observed collecting perianth segments, stamens from dry
   flowers, and pollen from closed flowers of O. cantabrigiensis,
   indicating that this species can be considered both florivorous and
   polynivorous; this feeding behavior does not negatively impact the
   pollination of O. cantabrigiensis flowers since it occurs on
   post-anthesis flowers. Nevertheless, O. cantabrigiensis is the only
   species displaying a low frequency of nocturnal anthesis flowers,
   leaving the possibility that L. tarasca acts as a potential pollinator
   for this cactus.},
Publisher = {SOC CHILENA ENTOMOLOGIA},
Address = {Seccion Entomologia Museo Nacional de Historia Natural. Interior Parque
