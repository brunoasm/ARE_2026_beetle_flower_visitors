Keywords = {Ariocarpus; Cactaceae; endemic species; hand-pollination treatments;
   natural populations; partial self-incompatibility; pollen tube growth;
   self-incompatibility},
Keywords-Plus = {INBREEDING DEPRESSION; BREEDING SYSTEM; REPRODUCTIVE SUCCESS;
