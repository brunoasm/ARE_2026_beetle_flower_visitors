Keywords = {Cactaceae; Colima; conservation; dry forest; endangered bats; evolution;
   pollination; sexual dimorphism; tongue length},
Keywords-Plus = {LEPTONYCTERIS-CURASOAE; SOUTHEASTERN BRAZIL; SEXUAL-DIMORPHISM; COLUMNAR
