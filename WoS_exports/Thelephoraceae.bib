   Iwase, Koji, Tottori Univ, Fungus Mushroom Resource \& Res Ctr, Fac Agr, Tottori 6808553, Japan.},
DOI = {10.1007/s11284-007-0381-0},
ISSN = {0912-3814},
Keywords = {Cephalanthera falcata; hyponex agar medium; mycorrhizal fungus;
   Russulaceae; Thelephoraceae},
