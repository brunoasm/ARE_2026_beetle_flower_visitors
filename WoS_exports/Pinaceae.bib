Address = {525 B ST, STE 1900, SAN DIEGO, CA 92101-4495 USA},
Type = {Article},
Language = {English},
Affiliation = {Wang, XQ (Corresponding Author), Chinese Acad Sci, State Key Lab Systemat \& Evolutionary Bot, Inst Bot, Beijing 100093, Peoples R China.
