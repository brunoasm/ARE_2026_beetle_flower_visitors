@article{ WOS:000238884400002,
Author = {Lewandowski, A. and Wisniewska, M.},
Title = {Short note:: Crossability between <i>Pinus uliginosa</i> and its
   putative parental species <i>Pinus sylvestris</i> and <i>Pinus mugo</i>},
Journal = {SILVAE GENETICA},
Year = {2006},
Volume = {55},
Number = {2},
Pages = {52-54},
Abstract = {Results of artificial fertilization of P. uliginosa with P. syluestris
   and P. mugo are presented and discussed. P. syluestris and P. mugo are
   thought to be the parental species of P. uliginosa. Two grafts of one P.
   uliginosa clone from Arboretum of the Institute of Dendrology in Kornik,
   Poland were used as mother individuals. One individual of P. syluestris
   and one individual of P. mugo were the pollen donors. Three mature cones
   were obtained as the result of artificial pollination of P. uliginosa
   with P. mugo pollen. Out of 107 seeds, 68 were filled what gives 63\%.
   P. uliginosa conelets pollinated with P. syluestris pollen were all
   aborted. Based on obtained data, close phylogenetic relationship between
   P. uliginosa and P. mugo complex is suggested.},
