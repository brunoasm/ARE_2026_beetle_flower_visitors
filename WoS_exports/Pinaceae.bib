@article{ WOS:A1948UE98500004,
Author = {WANG, FH},
Title = {LIFE HISTORY OF KETELEERIA .1. STROBILI, DEVELOPMENT OF THE GAMETOPHYTES
   AND FERTILIZATION IN KETELEERIA EVELYNIANA},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1948},
Volume = {35},
Number = {1},
Pages = {21-27},
Abstract = {The life history of K. evelyniana was worked out with material collected
   in the vicinity of Kunming, Yunnan Prov., China. The microspore
   mother-cell divides during the first week of Jan. The chromosome number
   of Keteleeria is n{[}long dash]12, agreeing with that of most of the
   genera of Pinaceae. Division of the generative cell into stalk and body
   cells occurs before pollination. The pollen grain remains inactive for a
   long time on the nucellus and grows only for a few days. The number of
   archegonia varies from 7 to 12, with 9-11 as the usual range. The
   ventral canal cell persists after fertilization which takes place
   between June 8-17 in Kunming. The megaspore membrane is very thick.},
