Keywords = {conifer; cytoskeleton; microtubule; Picea abies; Pinaceae; pollen;
   pollen tube},
Keywords-Plus = {GENERATIVE CELLS; TUBE GROWTH; VEGETATIVE NUCLEUS; NICOTIANA-TABACUM;
   PYRUS-COMMUNIS; PLANT-CELLS; IN-VITRO; CYTOSKELETON; TOBACCO; MOVEMENT},
