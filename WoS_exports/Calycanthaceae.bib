Keywords = {Chimonanthus; Calycanthaceae; Reproductive biology; Stamen movement},
Keywords-Plus = {POLLINATION; ELONGATION; EVOLUTION; ETHYLENE; LAURALES; ANATOMY; AUXIN},
Research-Areas = {Plant Sciences; Evolutionary Biology},
