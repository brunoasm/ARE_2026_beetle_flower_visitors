   Chinese Acad Sci, Inst Bot, Lab Systemat \& Evolutionary Bot, Beijing 100093, Peoples R China.},
DOI = {10.1111/j.1095-8339.1999.tb00781.x},
ISSN = {0024-4074},
Keywords = {breeding system; late-acting self-incompatibility; pollen contamination;
   pollen viability; stigma receptivity},
