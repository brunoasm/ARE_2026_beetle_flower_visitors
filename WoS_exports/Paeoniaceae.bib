@article{ WOS:A1976CG74100008,
Author = {SCHLISING, RA},
Title = {REPRODUCTIVE PROFICIENCY IN PAEONIA-CALIFORNICA (PAEONIACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1976},
Volume = {63},
Number = {8},
Pages = {1095-1103},
Abstract = {Study of 3 populations of geophytic P. californica in S California
   {[}USA] revealed considerable variation, within and between populations,
   in both potential and in realized seed output. Plants are weakly
   self-compatible, but natural seed set (.hivin.x = 4.2 seeds/carpel) is
   closer to seed set produced in hand cross-pollinations (.hivin.x = 4.5)
   than in self pollinations (.hivin.x = 1.4). Flowers are protogynous,
   nectariferous and scented; 17 spp. of bees {[}Andrena auricoma, Andrena
   sp., Apis mellifera, Ceratina acantha, C. arizonensis, C. puntigena,
   Hylaeus cressoni cressoni, H. polifolii, H. verticalis, Halictus
   tripartitus, Lasioglossum incompletum, L. latifrons, L. ovaliceps, L.
   punctatoventre, L. sisymbrii, L. tegulariforme, Lasioglossum sp.] in 4
   families and 1 sp. of melyrid beetle {[}Trichochrous sp.] were found in
   them and probably account for pollinations at these sites. Counts of
   reproductive parts show greatest inter-population variation in mean
   numbers per plant, of flowers (population means ranged from 16.2-21.2),
   ovules (744-1142), pollen grains (23 million-38 million), and \% viable
   pollen (26.6-81.4). Seed set also varied significantly, with only
   11.4-26.8\% of the ovules maturing into seeds. This low reproductive
   success is probably correlated with the genetic anomalies studied by
   others.sbd.particularly the translocation heterozygosity that causes
   lowered production of viable gametes. The relatively few seeds produced
   are heavy (.hivin.x = 0.184 g/seed) and germination percentages are high
   (.hivin.x = 80\%). The elongation of cotyledon bases during hypogeal
   germination seems to permit optimal germination at soil depths of only
   2-3 cm, but environmental factors such as drought stress and herbivore
   pressure promote high seedling mortality.},
