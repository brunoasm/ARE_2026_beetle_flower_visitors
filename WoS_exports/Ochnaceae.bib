@article{ WOS:A1991GB39500008,
Author = {KUBITZKI, K and AMARAL, MCE},
Title = {TRANSFERENCE OF FUNCTION IN THE POLLINATION SYSTEM OF THE OCHNACEAE},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1991},
Volume = {177},
Number = {1-2},
Pages = {77-80},
Abstract = {Most members of the Ochnaceae possess poricidal anthers that are emptied
   by pollen collecting bees performing vibrational foraging.  In several
   genera, such as Tyleria, Adenarake, and various species of Sauvagesia,
   however, pollen is released by vibration from the anthers through the
   porus of a novel structure formed by staminodia.  These envelop the
   androecium and gynoecium.  Anthers enclosed in this envelope are often
   longicidal.},
