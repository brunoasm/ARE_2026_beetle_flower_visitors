Type = {Article},
Language = {English},
Affiliation = {Taylor, ML (Corresponding Author), Univ Tennessee, Dept Ecol \& Evolutionary Biol, Knoxville, TN 37996 USA.
   Taylor, Mackenzie L.; Williams, Joseph H., Univ Tennessee, Dept Ecol \& Evolutionary Biol, Knoxville, TN 37996 USA.},
