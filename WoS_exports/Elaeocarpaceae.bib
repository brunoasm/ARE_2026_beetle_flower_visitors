   Nistelberger, Heidi, Univ Oslo, Ctr Ecol \& Evolutionary Synth, Dept Biosci, POB 1066, NO-0316 Oslo, Norway.},
DOI = {10.1111/brv.12477},
ISSN = {1464-7931},
EISSN = {1469-185X},
Keywords = {genetic diversity; genetic differentiation; inselbergs; island
