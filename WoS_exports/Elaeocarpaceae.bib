Type = {Article},
Language = {English},
Affiliation = {Butcher, PA (Corresponding Author), 14 Bombi Rd S, Macmasters Beach, NSW 2251, Australia.
   Butcher, P. A.; Bradbury, D.; Krauss, S. L., Bot Gardens \& Pk Author, Kings Pk \& Bot Garden, Perth, WA 6005, Australia.
   Bradbury, D.; Krauss, S. L., Univ Western Australia, Sch Plant Biol, Crawley, WA 6009, Australia.},
DOI = {10.1007/s10592-011-0258-1},
ISSN = {1566-0621},
EISSN = {1572-9737},
Keywords = {Tetratheca; Breeding system; Paternity analysis; Pollen flow;
