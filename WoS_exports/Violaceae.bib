Type = {Article},
Language = {English},
Affiliation = {Griffith, C (Corresponding Author), UNIV KENTUCKY,SCH BIOL SCI,CTR ECOL EVOLUT \& BEHAV,LEXINGTON,KY 40506, USA.},
ISSN = {0040-9618},
Keywords = {pollinators; myrmecochory; clonal growth; Viola blanda},
Keywords-Plus = {POPULATION BIOLOGY; GENUS VIOLA; MYRMECOCHORY; PLANTS},
Research-Areas = {Plant Sciences},
