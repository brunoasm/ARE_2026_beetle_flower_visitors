@article{ WOS:A1984SZ77000007,
Author = {POWLESLAND, MH},
Title = {REPRODUCTIVE-BIOLOGY OF 3 SPECIES OF MELICYTUS (VIOLACEAE) IN
   NEW-ZEALAND},
Journal = {NEW ZEALAND JOURNAL OF BOTANY},
Year = {1984},
Volume = {22},
Number = {1},
Pages = {81-94},
Abstract = {The flower structure, pollination, sex expression, and some secondary
   sex characters of M. lanceolatus, M. ramiflorus and M. micranthus are
   described. All 3 spp. are strictly dioecious. Male-biased sex ratios
   occur in M. lanceolatus and M. ramiflorus. There is a marked contrast in
   flower structure between M. lanceolatus and the other 2 species. In M.
   lanceolatus, as in most species of the Violaceae, the pollen is
   concealed by apical appendages of the anther connectives and fusion
   along the edges of adjacent anthers. Nectar is concealed within purple
   petals. In the flowers of M. ramiflorus and M. micranthus, the anthers
   are free and the apical appendages are much reduced, so the pollen is
   exposed. The petals are white or yellow and are recurved, exposing the
   nectaries, M. lanceolatus represents the more primitive condition, and
   the other 2 spp. show a loss of specialization of flower structure, the
   reverse of the usual trend in floral evolution in the angiosperms. The 3
   spp. are insect pollinated. A variety of insect species visit the
   flowers of M. lanceolatus and M. ramiflorus. Syrphids are the only
   insects which visit flowers of both sexes of M. micranthus. Foraging
   behavior of most insect species on the flowers is unsystematic. Fruit of
   all species are adapted for animal dispersal and 2 spp. of birds
   {[}Hemiphaga novaeseelandia and Zosterops lateralis] were seen feeding
   on berries of M. ramiflorus.},
Publisher = {TAYLOR \& FRANCIS LTD},
Address = {2-4 PARK SQUARE, MILTON PARK, ABINGDON OR14 4RN, OXON, ENGLAND},
Type = {Article},
