@article{ WOS:000232275400007,
Author = {Dötterl, S and Jürgens, A},
Title = {Spatial fragrance patterns in flowers of <i>Silene latifolia</i>:: Lilac
   compounds as olfactory nectar guides?},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2005},
Volume = {255},
Number = {1-2},
Pages = {99-109},
Month = {SEP},
Abstract = {Floral odour can differ qualitatively and quantitatively between
   different parts of the flowers, and these spatial fragrance patterns
   within the flowers can be used by pollinators for orientation on
   flowers. Here we present results of spatial fragrance patterns within
   flowers of the dioecious Silene latifolia (Caryophyllaceae). Volatiles
   were collected and analysed using a highly sensitive dynamic headspace
   method, which allows dramatically reducing the sample time. From all
   flower parts, especially the petals and the anthophore emitted the
   typical flower volatiles of S. latifolia. However, compounds emitted
   from the petals differed from compounds emitted by the anthophore. The
   anthophore emitted the monoterpenoids lilac aldehydes and alcohols,
   whereas, all other typical scent compounds (e.g. benzoids, other
   monoterpenoids) were emitted by the petals. Lilac aldehydes are known to
   be behaviourally very attractive for noctuid moths, and they may serve
   as nectar guides in S. latifolia.},
