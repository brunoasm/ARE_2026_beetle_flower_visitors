Language = {English},
Affiliation = {Univ Connecticut, Dept Ecol \& Evolutionary Biol, Storrs, CT 06269 USA.
   Univ Connecticut, Dept Ecol \& Evolutionary Biol, Storrs, CT 06269 USA.
   Auburn Univ, Dept Biol Sci, Auburn, AL 36849 USA.},
