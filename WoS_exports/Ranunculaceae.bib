   Misaki, Ando; Itagaki, Tomoyuki; Matsubara, Yutaka; Sakai, Satoki, Tohoku Univ, Grad Sch Life Sci, 6-3 Aoba, Sendai, Miyagi 9808578, Japan.},
DOI = {10.1002/ajb2.1099},
