@article{ WOS:A1986C818800001,
Author = {PELLMYR, O},
Title = {POLLINATION ECOLOGY OF 2 NECTARIFEROUS CIMICIFUGA SP (RANUNCULACEAE) AND
   THE EVOLUTION OF ANDROMONOECY},
Journal = {NORDIC JOURNAL OF BOTANY},
Year = {1986},
Volume = {6},
Number = {2},
Pages = {129-138},
Abstract = {The pollination ecology of Cimicifuga americana Michx. and C. laciniata
   Wats., two nectariferous self-incompatible species, was studied. Both
   species are pollinated by bumblebees, the former by workers and the
   latter by males. All bees imbibe nectar and workers also collect pollen,
   meanwhile performing pollination. Large syrphids act as co-pollinators.
   C. americana is andromonoecious, and it is suggested that male-flower
   production at the end of the flowering period contributes a
   disproportionate fitness component because of dichogamy-induced
   female-biased functional sex-ratio in the hermaphroditic flowers at that
   time.},
