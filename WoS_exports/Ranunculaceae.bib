ISSN = {0962-8452},
Keywords = {floral microbiology; floral microclimate; Helleborus foetidus;
   Metschnikowia reukaufii; nectar yeasts; yeast communities},
Keywords-Plus = {HELLEBORUS-FOETIDUS RANUNCULACEAE; FLORAL NECTAR; REPRODUCTIVE SUCCESS;
