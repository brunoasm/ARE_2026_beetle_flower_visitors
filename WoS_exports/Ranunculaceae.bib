Year = {1976},
Volume = {126},
Number = {3},
Pages = {239-242},
Abstract = {Variation patterns of flower color in some species of Anemoneae can be
   correlated with edaphic variables. These examples are used in the
   argument that discriminative pollination through color responsive pollen
   vectors is not the sole cause for non-randomness in intraspecific flower
   color distributions. Some possible reasons for genetic linkage between
