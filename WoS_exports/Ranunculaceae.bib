   Strzalkowska-Abramek, Monika; Jachula, Jacek; Dmitruk, Marta; Pogroszewska, Elzbieta, Univ Life Sci, Lublin, Poland.},
ISSN = {1644-0692},
Keywords = {flowering; staminodes; pollen output; pollen shape; Pulsatilla spp.},
Keywords-Plus = {L. RANUNCULACEAE; POLLINATORS; ABUNDANCE; NECTAR; PLANTS; REPRODUCTION;
   REGENERATION; POPULATION; VERNALIS; DRIVERS},
