ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {Aconitum; Delphinium; floral morphology; nested spurs; pollination;
   postgenital fusion},
Keywords-Plus = {POLLINATION ECOLOGY; ACONITUM-LYCOCTONUM; POLLEN DISPERSAL; SYNOPSIS;
