@article{ WOS:A1978EZ09100005,
Author = {MILLER, RB},
Title = {POLLINATION ECOLOGY OF AQUILEGIA-ELEGANTULA AND AQUILEGIA-CAERULEA
   (RANUNCULACEAE) IN COLORADO},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1978},
Volume = {65},
Number = {4},
Pages = {406-414},
Abstract = {A. elegantula Greene and A. caerulea James occur in montane and
   subalpine habitats in the southern Rocky Mountains of western North
   America. The red and yellow flowers of A. elegantula are nodding,
   odorless, protogynous and secrete a concentrated (44\%) sucrose nectar
   in the floral spurs. Seed set in flowers under pollinator exclosures was
   12\% while seed set in open-pollinated flowers was 65\%. The flowers of
   A. elegantula are pollinated primarily by the Broad-tailed Hummingbird
   (Selasphorus platycercus {[}Swainson]) and by at least 3 spp. of
   pollen-foraging bumblebees {[}Bombus appositus, B. flavifrons and B.
   occidentalis] of which B. occidentalis Greene is the most common. The
   blue and white flowers of A. caerulea are erect, mildly fragrant,
   protandrous and secrete a 26\% sucrose nectar. Seed set in caged flowers
   in the field averaged 39\%, in uncaged flowers 54\%. The most important
   pollinators of A. caerulea are the crepuscular hawkmoth, Hyles (=
   Celerio) lineata (Fabricius) and 10 spp. of pollen-foraging Bombus {[}B.
   appositus, B. bifarius bifarius, B. centralis, B. flavifrons flavifrons,
   B. frigidus, B. kirbyellus, B. mixtus, B. occidentalis, B. rufocinctus
   and B. sylvicola]. The most abundant bumblebee species, B. occidentalis,
   is also a frequent nectar thief. Differences in pollination systems
   alone probably do not constitute an effective antihydridization
   mechanism between A. elegantula and A. caerulea, but do serve to
