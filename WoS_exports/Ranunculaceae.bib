@article{ WOS:A1983QS68500003,
Author = {HERRERA, CM and SORIGUER, RC},
Title = {INTER-FLORAL AND INTRA-FLORAL HETEROGENEITY OF NECTAR PRODUCTION IN
   HELLEBORUS-FOETIDUS L (RANUNCULACEAE)},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1983},
Volume = {86},
Number = {3},
Pages = {253-260},
Abstract = {Three southern Spanish populations of H. foetidus L. were sampled for
   nectar content in the absence of nectarivorous flower visitors {[}mainly
   long-tongued insects]. Nectar volume was measured in individual
   nectaries of flowers at the same stage in the anthesis cycle. Total
   nectar content per flower was extremely variable between plants within
   populations and between flowers within plants, but much less so between
   populations. Average sugar content per flower was roughly similar in the
   3 populations sampled. High variances in nectar abundance occurred also
   among nectaries within the same flower. Heterogeneity in pollinator
   rewards thus occurs simultaneously at several spatial scales, namely
   between nectaries, between flowers and between plants. This implies a
   strong component of uncertainty to foraging pollinators, which may
   therefore tend to avoid Helleborus flowers.},
