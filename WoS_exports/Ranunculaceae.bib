ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {Ovule position; Carpel number; Pollination environment; Apocarpous
   flowers; Seed production; Seed mass; Helleborus foetidus},
Keywords-Plus = {OVULE POSITION; GEOGRAPHICAL VARIATION; PROGENY PERFORMANCE; POLLEN
