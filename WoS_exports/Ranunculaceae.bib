@article{ WOS:A1975BC35000009,
Author = {CHASE, VC and RAVEN, PH},
Title = {EVOLUTIONARY AND ECOLOGICAL RELATIONSHIPS BETWEEN AQUILEGIA-FORMOSA AND
   AQUILEGIA-PUBESCENS (RANUNCULACEAE), 2 PERENNIAL PLANTS},
Journal = {EVOLUTION},
Year = {1975},
Volume = {29},
Number = {3},
Pages = {474-486},
Abstract = {The most important factors in maintaining the specific differences
   between the red-flowered, short-spurred A. formosa and the
   white-flowered, long-spurred, endemic A. pubescens in the Sierra Nevada
   of California (USA) appear to be ecological. Even though their seasons
   of flowering may be somewhat exclusive, there is no evidence for
   differential visitation by any of the major groups of animals that visit
   their flowers: hummingbirds, hawkmoths, bumblebees and syrphid flies.
   This seems remarkable for all consistent differences between the species
   relate to floral characteristics: flower position, sepal and spur color,
   lamina length, lamina color and spur length. These characteristics would
   seem to be consistent with the operation of very different pollination
   systems but such evidently do not in fact, presently exist. Hybrids
   between the 2 species are fully fertile and seem to occur wherever local
   conditions permit; yet at other places, totally distinct populations may
   occur within 100 m of one another without any suggest of hybridization
   whatsoever. The continuing existence of the distinct parental types
   which differ mainly in floral characteristics seems to be the result of
   the linkage of genes determining the plant''s physical appearance with
   those that determine its physiological character, as demonstrated in
   other groups of plants. The kinds of soils on which A. pubescens grows
   and situations in which it occurs are more recent geologically than
   those inhabited by A. formosa. A. pubescens tends to occupy areas from
   which the glaciers have recently retreated. The active processes of
   erosion and weathering in the Sierra Nevada produce a complex mosaic of
   geologically short-lived intermediate habitats, and it is here that
   hybrids between the 2 species and introgressed populations flourish. The
   2 species remain separate where ecologically intermediate habitats do
   not exist. Once its ancestors had reached the Sierra Nevada, not before
   the latest Pliocene, A. pubescens gradually expanded its range as its
   characteristic habitat expanded. Within this range, it has maintained
   its floral characteristics and distinctiveness by virtue of its
   physiologically determined ability to exploit marginal habitats. It has
   remained morphologically distinct in these habitats as a result of the
   linkage of its floral characteristics with the physiological features
   that determine its particular pattern of ecological adaptation. These
   floral characteristics may no longer be adaptive in the same sense as
   those of its ancestors, but they are still functional with respect to
   the wider array of pollinators availabe in the Sierra-Nevada. These
   factors, taken together with the marked ecological differentiation
   between A. pubescens and A. formosa, and their somewhat different
   flowering periods are adequate to maintain them as distinct entities.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {SALEM COLL, WINSTON SALEM, NC 27108 USA.
   MISSOURI BOT GARDEN, 2315 TOWER GROVE AVE, ST LOUIS, MO 63110 USA.},
