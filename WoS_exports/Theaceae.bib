ISSN = {0018-067X},
EISSN = {1365-2540},
Keywords = {allozymes; clonal structure; Eurya emarginata; Moran's I; spatial
   autocorrelation; spatial genetic structure},
Keywords-Plus = {STARCH-GEL ELECTROPHORESIS; POPULATIONS; DIVERSITY; AUTOCORRELATION;
   PATTERNS; BUFFERS},
