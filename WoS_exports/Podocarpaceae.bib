Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Leslie, AB (Corresponding Author), Brown Univ, Dept Ecol \& Evolutionary Biol, Box G-W,80 Waterman St, Providence, RI 02912 USA.
   Leslie, Andrew B.; Crane, Peter R., Yale Univ, Sch Forestry \& Environm Studies, New Haven, CT 06511 USA.
   Beaulieu, Jeremy M., Univ Tennessee, Nat Inst Math \& Biol Synth, Knoxville, TN 37996 USA.
   Knopf, Patrick, Bot Garten Rombergpk, Dortmund, Germany.
   Donoghue, Michael J., Yale Univ, Dept Ecol \& Evolutionary Biol, New Haven, CT 06520 USA.},
DOI = {10.1111/evo.12670},
ISSN = {0014-3820},
EISSN = {1558-5646},
Keywords = {Character correlation; integration; pollination biology; saccate pollen},
Keywords-Plus = {SACCATE POLLEN; MORPHOLOGICAL INTEGRATION; PHENOTYPIC INTEGRATION; COPES
