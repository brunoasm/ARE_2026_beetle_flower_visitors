   Royal Bot Garden Edinburgh, Edinburgh EH3 5LR, Midlothian, Scotland.
   Scottish Crop Res Inst, Dundee DD2 5DA, Scotland.},
DOI = {10.1006/anbo.2001.1426},
ISSN = {0305-7364},
Keywords = {Acmopyle pancheri(Brongn. \& Gris) Pilg.; anatomy; developmental
   morphology; gymnosperms; histology; nuclear magnetic resonance (NMR)
   imaging; ontogeny; ovules; Podocarpaceae; scanning electron microscopy
   (SEM); seed cones},
