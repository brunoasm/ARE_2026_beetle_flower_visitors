@article{ WOS:000077687900010,
Author = {Owens, JN and Takaso, T and Runions, CJ},
Title = {Pollination in conifers},
Journal = {TRENDS IN PLANT SCIENCE},
Year = {1998},
Volume = {3},
Number = {12},
Pages = {479-485},
Month = {DEC},
Abstract = {Our understanding of pollination in conifers has advanced rapidly in
   recent years, but it still lags behind our knowledge of this process in
   angiosperms. In part this is because conifers are not considered to be
   high priority crops and, unlike many cultivated flowers, conifer seed
   cones are generally neither large nor colorful, The use of genetics to
   improve tree growth has primarily been through selection and asexual
   propagation rather than breeding, and because incompatibility is not
   thought to occur in conifer pollination systems, concern about
   pollination has primarily been with regard to seed production. Here we
   examine the ancestral wind-pollination mechanism in conifers and discuss
   how the process may have evolved to improve pollination success.},
