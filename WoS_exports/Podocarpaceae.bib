@article{ WOS:000249830900013,
Author = {Schwendemann, Andrew B. and Wang, George and Mertz, Meredith L. and
   McWilliams, Ryan T. and Thatcher, Scott L. and Osborn, Jeffrey A.},
Title = {Aerodynamics of saccate pollen and its implications for wind pollination},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2007},
Volume = {94},
Number = {8},
Pages = {1371-1381},
Month = {AUG},
Abstract = {Pollen grains of many wind-pollinated plants contain 1-3 air-filled
   bladders, or sacci. Sacci are thought to help orient the pollen grain in
   the pollination droplet. Sacci also increase surface area of the pollen
   grain, yet add minimal mass, thereby increasing dispersal distance;
   however, this aerodynamic hypothesis has not been tested in a published
   study. Using scanning electron and transmission electron microscopy,
   mathematical modeling, and the saccate pollen of three extant conifers
   with structurally different pollen grains (Pinus, Falcatifolium,
   Dacrydium), we developed a computational model to investigate pollen
   flight. The model calculates terminal settling velocity based on
   structural characters of the pollen grain, including lengths, widths,
   and depths of the main body and sacci; angle of saccus rotation; and
   thicknesses of the saccus wall, endoreticulations, intine, and exine.
   The settling speeds predicted by the model were empirically validated by
   stroboscopic photography. This study is the first to quantitatively
   demonstrate the adaptive significance of sacci for the aerodynamics of
   wind pollination. Modeling pollen both with and without sacci indicated
   that sacci can reduce pollen settling speeds, thereby increasing
   dispersal distance, with the exception of pollen grains having robust
   endoreticulations and those with thick saccus walls. Furthermore,
   because the mathematical model is based on structural characters and
   error propagation methods show that the model yields valid results when
   sample sizes are small, the flight dynamics of fossil pollen can be
   investigated. Several fossils were studied, including bisaccate (Pinus,
   Pteruchus, Caytonanthus), monosaccate (Gothania), and nonsaccate
   (Monoletes) pollen types.},
Publisher = {BOTANICAL SOC AMER INC},
Address = {PO BOX 299, ST LOUIS, MO 63166-0299 USA},
Type = {Article},
Language = {English},
Affiliation = {Osborn, JA (Corresponding Author), Truman State Univ, Div Sci, Kirksville, MO 63501 USA.
   Truman State Univ, Div Sci, Kirksville, MO 63501 USA.
   Truman State Univ, Div Math \& Comp Sci, Kirksville, MO 63501 USA.},
DOI = {10.3732/ajb.94.8.1371},
ISSN = {0002-9122},
Keywords = {aerodynamic efficiency; anemophily; computational model; fossil pollen;
   mathematical model; palynology; pollen; saccate pollen; wind pollination},
Keywords-Plus = {CONIFER OVULATE CONES; GYMNOSPERM POLLEN; MORPHOLOGY; ULTRASTRUCTURE;
