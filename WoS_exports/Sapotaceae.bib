   Tran, Hoa T., Inst Agr Genet, Sect Forest Genet \& Conservat, Hanoi, Vietnam.
   Dick, Christopher W., Smithsonian Trop Res Inst, Balboa Ancon, Panama.},
DOI = {10.1016/j.gecco.2014.07.002},
ISSN = {2351-9894},
Keywords = {Barro Colorado Island; Dioecy; Gene dispersal; Microsatellite;
