   Abdullah, Nur Ashikin Psyquay, Univ Putra Malaysia, Dept Crop Sci, Fac Agr \& Food Sci, Bintulu Campus, Bintulu 97008, Sarawak, Malaysia.},
DOI = {10.21273/HORTSCI.51.6.697},
ISSN = {0018-5345},
