Language = {English},
Affiliation = {Mariano-Neto, E (Corresponding Author), Univ Fed Bahia, Inst Biol, BR-40170115 Salvador, BA, Brazil.
   Lima, Marilia Mascarenhas, Univ Estadual Sudoeste Bahia, Dept Ciencias Biol, BR-45206510 Jequie, BA, Brazil.
