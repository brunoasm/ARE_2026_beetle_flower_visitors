@article{ WOS:A1993LE89700017,
Author = {ZIETSMAN, PC},
Title = {POLLINATION IN PELARGONIUM-DOLOMITICUM KNUTH (GERANIACEAE)},
Journal = {SOUTH AFRICAN JOURNAL OF BOTANY},
Year = {1993},
Volume = {59},
Number = {2},
Pages = {259-264},
Month = {APR},
Abstract = {Anthesis in the self-compatible, dichogamous flower of Pelargonium
   dolomiticum Knuth can be divided into three different phases. The male
   phase precedes the female phase, indicating protandry. Dichogamy is
   complete and asynchronous. The activity pattern of Apis mellifera, the
   pollinator of this species, does not correlate with the rewards offered
   by the flower but is intrinsic to the behaviour of the pollinators. In
   P. dolomiticum cross-pollination is favoured by the behavioural pattern
   of the honeybees.},
