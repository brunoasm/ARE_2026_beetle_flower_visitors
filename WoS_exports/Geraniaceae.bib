   Dufay, Mathilde; Lahiani, Emna; Brachi, Benjamin, Univ Sci \& Technol Lille Lille 1, CNRS, UMR 8016, Lab Genet \& Evolut Populat Vegetales, F-59655 Villeneuve Dascq, France.},
DOI = {10.1086/647916},
ISSN = {1058-5893},
Keywords = {gynodioecy; gynomonoecy; sex polymorphism; pollen viability; inbreeding
   depression; floral traits},
Keywords-Plus = {GERANIUM-MACULATUM GERANIACEAE; NOCTIFLORA L. CARYOPHYLLACEAE;
