Month = {FEB},
Abstract = {The presumed relationship between P. antidysentericum (Eckl. \& Zeyh.)
   Kostel., P. divisifolium Vorster, Fl dolomiticum Knuth, P. griseum
   Knuth, P. plurisectum Salter, P. praemorsum (Andr.) Dietr., P. redactum
