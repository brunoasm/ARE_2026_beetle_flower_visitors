DOI = {10.3989/ajbm.2326},
ISSN = {0211-1322},
Keywords = {endemism; geitonogamy; inbreeding depression; mating system; self
   compatibility; stigmatic pollen load},
Keywords-Plus = {COLLINSIA-HETEROPHYLLA PLANTAGINACEAE; SELF-INCOMPATIBILITY; POLLEN
