@article{ WOS:A1978FE89700004,
Author = {GREEN, BB},
Title = {COMPARATIVE ECOLOGY OF GERANIUM-RICHARDSONII AND GERANIUM-NERVOSUM},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1978},
Volume = {105},
Number = {2},
Pages = {108-113},
Abstract = {Two perennial species of wild geranium (G. nervosum Rydb. and G.
   richardsonii Fisch. and Trautv. {[}Geraniaceae] which grow throughout
   the mountainous regions of western North America were studied to examine
   the factors influencing the life stage development and the ecological
   isolation of these 2 morphologically similar species. Seeds which were
   produced in the fall reached maximum germination by Jan. for G. nervosum
   and by Mar. for G. richardsonii. Seeds did not remain viable for more
   than 1 winter. Field experiments, coupled with laboratory water stress
   studies, indicated that G. nervosum seedlings were able to survive in
   drier environments due to their tap root system. The fibrous root system
   of G. richardsonii did not extend deep enough in the soil to reach more
   favorable water potentials. Pollinators {[}Bombus rufocinctus, B.
   bifarius, Diahetus spp. Apis mellifera, B. occidentalis, Anthophora
   terminalis, Trichiotinus assimilis, Mordella atrata, Trichodesus ornatus
   and Epicauta puncticollis] distinguish between the Geranium species,
   thus providing a 2nd isolation mechanism. Hybrids produced from hand
   crossing did not survive after germination.},
