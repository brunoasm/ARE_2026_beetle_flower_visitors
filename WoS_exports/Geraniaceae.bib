Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Univ Georgia, Dept Plant Biol, 2502 Plant Sci Bldg, Athens, GA 30602 USA.
