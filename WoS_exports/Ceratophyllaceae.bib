
@article{ WOS:A1995RN06700007,
Author = {TAKAHASHI, M},
Title = {DEVELOPMENT OF STRUCTURE-LESS POLLEN WALL IN CERATOPHYLLUM-DEMERSUM L
   (CERATOPHYLLACEAE)},
Journal = {JOURNAL OF PLANT RESEARCH},
Year = {1995},
Volume = {108},
Number = {1090},
Pages = {205-208},
Month = {JUN},
Abstract = {Developmental process of structure-less exine is studied in a
   hydrophilous plant, Ceratophyllom demersum L., with electron microscopy.
   The plant shows a characteristic feature in tetrad formation, A callose
   wall is not synthesized and exine initiation does not occur during the
   tetrad stage. After release of microspores, a trilaminar layer with two
   electron-dense lines is formed in the surface of each microspore. The
   trilaminar layer develops to a thin structure-less exine that is
   considered to consist;of only an endexine. The unusual exine would be an
   adaptive feature for submersed pollination in fresh water.},
