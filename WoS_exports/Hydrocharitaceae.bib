ISSN = {0024-4074},
EISSN = {1095-8339},
Keywords = {Acorales; Alismatales; angiosperm systematics; angiospermy; carpels;
   Dioscoreales; flower evolution; ovules; Triuridales},
Keywords-Plus = {THALASSIA-TESTUDINUM HYDROCHARITACEAE; CALLA-PALUSTRIS ARACEAE;
