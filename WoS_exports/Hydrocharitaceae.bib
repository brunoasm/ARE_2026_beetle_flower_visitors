@article{ WOS:A1988R677100003,
Author = {MCMILLAN, C and JEWETTSMITH, J},
Title = {THE SEX-RATIO AND FRUIT PRODUCTION OF LABORATORY-GERMINATED SEEDLINGS OF
   HALOPHILA-ENGELMANNII ASCHERS - (HYDROCHARITACEAE) FROM REDFISH BAY,
   TEXAS},
Journal = {AQUATIC BOTANY},
Year = {1988},
Volume = {32},
Number = {4},
Pages = {329-339},
Month = {DEC},
Abstract = {Approximately equal numbers of staminate and pistillate plants were
   produced within a seedling population of Halophila engelmannii Aschers.
   Among 61 seedlings that produced flowers under laboratory conditions, 33
   were male and 28 were female, indicating a probable 50:50 ratio. Under
   controlled conditions, staminate flowers released pollen during the
   daylight hours and the moniliform strands of pollen grains floated on
   the water surface. After artificial pollination, fruits and seeds
   developed  in the laboratory cultures. Although flowering in the natural
   beds of Redfish Bay was not extensive in 1988, the ratio of staminate to
   pistillate shoots was recorded as 42:58.},
