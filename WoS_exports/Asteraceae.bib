   Univ Lund, Dept Systemat Bot, S-22361 Lund, Sweden.},
DOI = {10.1055/s-2007-978554},
ISSN = {1435-8603},
Keywords = {Achillea ptarmica; floral evolution; pollination; tradeoffs; selection},
