Affiliations = {University of Louisiana Lafayette},
Funding-Acknowledgement = {COYPU foundation; Louisiana Native Plant Society},
Funding-Text = {Many thanks to COYPU foundation and the Louisiana Native Plant Society
   for funding our research. We are grateful for the space and resources
   provided by the University of Louisiana Ecology Center. Special thanks
   to BugGuide and other experts for confirming our insect identifications.},
