@article{ WOS:000731763100004,
Author = {Babaeva, Elena Yu and Polevova, V, Svetlana and Zugkiev, Boris G.},
Title = {IDENTIFICATION OF PROPOLIS AND HONEY SOURCES POLLEN ANALYSIS OF THE
   SOUTH OF NORTH CAUCASUS AND THE LOWER VOLGA},
