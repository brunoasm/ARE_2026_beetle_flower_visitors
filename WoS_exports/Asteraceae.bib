EISSN = {1095-8290},
Keywords = {Echinacea purpurea; eccrine process; floral nectary; floret phenology;
   modified stomata; nectar reabsorption; nectar secretion; phloem;
   ultrastructure},
Keywords-Plus = {FINE-STRUCTURE; EXTRAFLORAL NECTARIES; SUGAR COMPOSITION; MODIFIED
