Address = {RUA BENTO CARLOS, 750 - CENTRO, SAO CARLOS, SP 00000, BRAZIL},
Type = {Article},
Language = {English},
Affiliation = {Rodrigues, LC (Corresponding Author), Univ Fed Minas Gerais UFMG, Inst Ciencias Biol ICB, Dept Zool, Lab Ornitol, CP 486, BR-31270901 Belo Horizonte, MG, Brazil.
   Rodrigues, L. C.; Rodrigues, M., Univ Fed Minas Gerais UFMG, Inst Ciencias Biol ICB, Dept Zool, Lab Ornitol, BR-31270901 Belo Horizonte, MG, Brazil.},
