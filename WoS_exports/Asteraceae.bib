@article{ WOS:A1978HF25400005,
Author = {ELLSTRAND, NC and TORRES, AM and LEVIN, DA},
Title = {DENSITY AND THE RATE OF APPARENT OUTCROSSING IN HELIANTHUS-ANNUS
   (ASTERACEAE)},
Journal = {SYSTEMATIC BOTANY},
Year = {1978},
Volume = {3},
Number = {4},
Pages = {403-407},
Abstract = {Previous studies on pollinator foraging behavior suggest that the
   apparent rate of outcrossing may be inversely correlated with plant
   density. The relationship of apparent outcrossing to plant density was
   examined for wild populations of H. annuus using alcohol dehydrogenase
   allozymes as genetic markers. The apparent rate of outcrossing varies
   from 0.54 to 0.91 (.hivin.y = 0.76) and is significantly inversely
   correlated with plant density. Heterozygote deficiency in the progeny
   also shows a significant inverse correlation. The proportion of
   heterozygotes in the maternal generation is not related to the rate of
   outcrossing.},
