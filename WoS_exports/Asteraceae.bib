   Univ Minnesota, Dept Ecol Evolut \& Behav, St Paul, MN 55108 USA.
   Lincoln Pk Zoo, Conservat \& Sci Dept, Chicago, IL 60614 USA.},
DOI = {10.1086/511313},
ISSN = {0003-0147},
Keywords = {self-incompatibility; pollen limitation; Echinacea angustifolia;
   spatially explicit model; prairie; mating system},
