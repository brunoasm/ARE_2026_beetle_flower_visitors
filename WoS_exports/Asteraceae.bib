@article{ WOS:000358154400032,
Author = {Dorchin, Netta and Astrin, Jonas J. and Bodner, Levona and Harris, Keith
   M.},
Title = {Morphological and Molecular Revision of the Genus <i>Ozirhincus</i>
   (Diptera: Cecidomyiidae)-Long-Snouted Seed-Feeding Gall Midges on
   Asteraceae},
Journal = {PLOS ONE},
Year = {2015},
Volume = {10},
Number = {7},
Month = {JUL 2},
Abstract = {The Palaearctic gall-midge genus Ozirhincus is unique among the
   Cecidomyiidae for its morphology and biology. Unlike most other
   phytophagous gall midges, species in this genus do not induce galls but
   develop inside achenes of Asteraceae plants. The heads of adults are
   characterized by an unusually elongate proboscis, the function of which
   is unclear. Despite a lot of attention from taxonomists in the 19th and
   early 20th century, a proper revision of the genus has been hindered by
   complex host associations, the loss of most relevant type material, and
   the lack of a thorough comparative study of all life stages. The present
   revision integrated morphological, molecular, and life-history data to
   clearly define species boundaries within Ozirhincus, and delimit
   host-plant ranges for each of them. A phylogenetic analysis based on the
   mitochondrial COI and 16S genes confirmed the validity of four distinct
   species but did not resolve the relationships among them. All species
   are oligophages, and some may occur together on the same host plant.
   Species with wider host-plant ranges have wider European and
   circum-Mediterranean distribution ranges, whereas species with narrower
   host ranges are limited to Europe and the Russian Far East. As part of
   the present work, O. hungaricus is reinstated from synonymy, O. tanaceti
   is synonymized under O. longicollis, neotypes are designated for O.
   longicollis and O. millefolii, and a lectotype is designated for O.
   anthemidis.},
