@article{ WOS:001363120000001,
Author = {Labonte, Audrey and Le Corre, Valerie and Matejicek, Annick and Felten,
   Emeline and Turpin, Melinda and Laurent, Emilien and Michel, Severine
   and Ducourtieux, Chantal and Vieren, Eric and Proesmans, Willem and
   Deytieux, Violaine and Cordeau, Stephane and Vanbergen, Adam J.},
Title = {Pollinator functional group abundance and floral heterogeneity in an
   agroecological context affect mating patterns in a self-incompatible
   wild plant},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2024},
Month = {2024 NOV 26},
Abstract = {PremiseRestoration of seminatural field margins can elevate pollinator
   activity. However, how they support wild plant gene flow through
   interactions between pollinators and spatiotemporal gradients in floral
   resources remains largely unknown.MethodsUsing a farm-scale experiment,
   we tested how mating outcomes (expected heterozygosity and paternity
   correlation) of the wild, self-incompatible plant Cyanus segetum
   transplanted into field margins (sown wildflower or grass-legume strips)
   were affected by the abundance of different pollinator functional groups
   (defined by species traits). We also investigated how the maternal plant
   attractiveness, conspecific pollen donor density, and heterospecific
   floral richness and density interacted with pollinator functional group
   abundance to modulate C. segetum mating outcomes.ResultsMultiple
   paternity increased (=lower paternity correlation) with greater local
   abundance of hoverflies (syrphids) and female medium-sized wild bees
   (albeit the latter's effect diminished with decreasing maternal plant
   attractiveness), and the presence of male bumblebees (Bombus) under low
   local floral richness. Cyanus segetum progeny genetic diversity
   increased with male Bombus presence but decreased with greater abundance
   of syrphids and honey bees (Apis mellifera).ConclusionsOverall, field
   margins supported plant-pollinator interactions ensuring multiple
   paternity and conservation of allelic diversity in C. segetum progeny.
   The contribution to plant mating outcomes of different pollinator
   functional groups was dictated by their local abundance or traits
   affecting pollen transfer efficiency. The local floral richness or
   maternal plant attractiveness sometimes modulated these relationships.
   This complex response of wild plant mating patterns to community
   interactions has implications for the use of field margins to restore
   functional pollination systems in farmed landscapes.
   ContexteLa restauration de bordures de champs semi-naturelles permet
   d'augmenter l'activit \& eacute; des pollinisateurs. Cependant, la mani
   \& egrave;re dont elles soutiennent le flux de g \& egrave;nes des
   plantes sauvages par le biais d'interactions entre les pollinisateurs et
   les gradients spatio-temporels de ressources florales reste largement
   inconnue.M \& eacute;thodesNous avons men \& eacute; une exp \&
   eacute;rimentation \& agrave; l'\& eacute;chelle d'une exploitation
   agricole pour tester l'effet de l'abondance de diff \& eacute;rents
   groupes fonctionnels de pollinisateurs (d \& eacute;finis sur base des
   traits des esp \& egrave;ces) sur les composantes g \& eacute;n \&
   eacute;tiques du succ \& egrave;s reproducteur (h \& eacute;t \&
   eacute;rozygotie attendue et corr \& eacute;lation de paternit \&
   eacute;) d'individus de l'esp \& egrave;ce sauvage et auto-incompatible
   Cyanus segetum (bleuet des champs) transplant \& eacute;s dans des
   bordures de champs (bandes sem \& eacute;es d'un m \& eacute;lange de
   fleurs sauvages ou d'un m \& eacute;lange gramin \& eacute;es/l \&
   eacute;gumineuses). Nous avons \& eacute;galement \& eacute;tudi \&
   eacute; comment l'attractivit \& eacute; de la plante-m \& egrave;re, la
   densit \& eacute; d'individus consp \& eacute;cifiques (potentiels
   donneurs de pollen) ainsi que la richesse et la densit \& eacute; des
   fleurs h \& eacute;t \& eacute;rosp \& eacute;cifiques interagissaient
   avec l'abondance des groupes fonctionnels de pollinisateurs pour moduler
   les composantes g \& eacute;n \& eacute;tiques du succ \& egrave;s
   reproducteur de C. segetum.R \& eacute;sultats-cl \& eacute;sLa paternit
   \& eacute; multiple augmente (=corr \& eacute;lation de paternit \&
   eacute; plus faible) avec une plus grande abondance locale de syrphes et
   d'abeilles sauvages femelles de taille moyenne (bien que le second effet
   diminue lorsque l'attractivit \& eacute; de la plante-m \& egrave;re
   diminue), et la pr \& eacute;sence de bourdons (Bombus) m \& acirc;les
   lorsque la richesse florale locale est faible. La diversit \& eacute; g
   \& eacute;n \& eacute;tique de la descendance de Cyanus segetum augmente
   avec la pr \& eacute;sence de Bombus m \& acirc;les, mais diminue avec
   une plus grande abondance de syrphes et d'abeilles domestiques (Apis
   mellifera).ConclusionsDans l'ensemble, les bordures de champs ont
   favoris \& eacute; les interactions entre plantes et pollinisateurs
   capables d'assurer une paternit \& eacute; multiple et la conservation
   d'une diversit \& eacute; all \& eacute;lique au sein des descendances
   de C. segetum. Les contributions relatives des diff \& eacute;rents
   groupes fonctionnels de pollinisateurs aux composantes g \& eacute;n \&
   eacute;tiques du succ \& egrave;s reproducteur des plantes sont dict \&
   eacute;es par l'abondance des groupes de pollinisateurs ou les traits
   qui affectent l'efficacit \& eacute; du transport de pollen. La richesse
   florale locale et l'attractivit \& eacute; de la plante-m \& egrave;re
   modifient dans certains cas ces relations. Cette r \& eacute;ponse
   complexe des dynamiques d'accouplement des plantes sauvages aux
   interactions dans la communaut \& eacute; a des implications pour
   l'utilisation des bordures de champs en vue de restaurer des syst \&
   egrave;mes fonctionnels de pollinisation dans les paysages agricoles.},
