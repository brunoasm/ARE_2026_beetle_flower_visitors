EISSN = {1939-9170},
Keywords = {above- and belowground interactions; associational effects; Asteraceae;
   biotic interactions; competition; interspecific; intraspecific; plant
   resource allocation; plant-plant interactions; Solidago},
Keywords-Plus = {COMPETITION; COMMUNITY; HERBIVORES; MECHANISMS; CHALLENGES; DIVERSITY;
