   Koutecky, Petr; Badurova, Tereza; Stech, Milan; Kosnar, Jan; Karasek, Jakub, Univ S Bohemia, Fac Sci, Dept Bot, Ceske Budejovice 37005, Czech Republic.},
DOI = {10.1111/j.1095-8312.2011.01707.x},
ISSN = {0024-4066},
EISSN = {1095-8312},
Keywords = {flow cytometry; polyploidy; sexual polyploidization},
