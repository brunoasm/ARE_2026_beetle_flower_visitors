Funding-Acknowledgement = {NSERC {[}RGPIN-2019-04041]},
Funding-Text = {General advice on insect identification was generously provided by Dr
   Roger Key (Bedale, UK; formerly Natural England). Dr Timm Karisch
   (Museum fur Naturkunde und Vorgeschichte Dessau) kindly provided
   information on the moth fauna of St Helena and advised on the moth
