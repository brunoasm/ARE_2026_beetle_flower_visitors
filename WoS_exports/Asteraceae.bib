Language = {English},
Affiliation = {Husband, BC (Corresponding Author), Univ Guelph, Dept Bot, Guelph, ON N1G 2W1, Canada.
   Univ Guelph, Dept Bot, Guelph, ON N1G 2W1, Canada.
   Univ Washington, Dept Bot, Seattle, WA 98195 USA.},
DOI = {10.1098/rspb.2002.2196},
ISSN = {0962-8452},
Keywords = {flow cytometry; hybridization; prezygotic barrier; reproductive
   isolation; speciation},
Keywords-Plus = {TUBE GROWTH-RATES; POLYPLOID EVOLUTION; PISTIL LENGTH; CYTOTYPE; SIZE;
   MECHANISMS; FERTILIZATION; HYBRIDIZATION; POPULATION; ASTERACEAE},
Research-Areas = {Life Sciences \& Biomedicine - Other Topics; Environmental Sciences \&
   Ecology; Evolutionary Biology},
