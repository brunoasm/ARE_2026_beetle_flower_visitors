@article{ WOS:000255131000008,
Author = {Sakai, Satoki and Suzuki, Yuka and Itagaki, Tomoyuki and Tsujisawa,
   Hisashi and Makino, Takashi T.},
Title = {On the function of hermaphrodite florets in female inflorescences of
   <i>Petasites japonicus</i> (Asteraceae)},
Journal = {BOTANY-BOTANIQUE},
Year = {2008},
Volume = {86},
Number = {2},
Pages = {179-184},
Month = {FEB},
Note = {Symposium on Ethnobotany held at the 42nd Annual Meeting of the
   Canadian-Botanical-Association, Montreal, CANADA, JUN, 2006},
Organization = {Canadian Botan Soc},
Abstract = {To examine the function of morphologically hermaphroditic, but
   functionally sterile, florets in female inflorescences of Petasites
   japonicus (Sieb. \& Zucc.) Maxim., we conducted experiments in which all
   those florets were removed from female inflorescences. We hypothesize
   that those florets enhance female reproductive success by deceit,
   because they resemble the morphologically hermaphroditic, but
   functionally male florets, in male inflorescences. We found that the
   mean number of pollinator visits per inflorescence did not differ
   between the intact inflorescences and inflorescences in which such
   hermaphrodite florets had been removed. However, the mean duration of
   stay per visit to an inflorescence tended to be shorter in those with
   removed florets than in the intact inflorescences. The achene / female
   floret ratio was smaller in the inflorescences with removed florets than
   in the intact ones. We hence concluded that the hermaphrodite florets in
   female inflorescences enhance female reproductive success through
   prolonged duration of pollinator stay.},
Publisher = {CANADIAN SCIENCE PUBLISHING, NRC RESEARCH PRESS},
Address = {1200 MONTREAL ROAD, BUILDING M-55, OTTAWA, ON K1A 0R6, CANADA},
Type = {Article; Proceedings Paper},
Language = {English},
Affiliation = {Sakai, S (Corresponding Author), Tohoku Univ, Grad Sch Life Sci, Dept Ecol \& Evolutionary Biol, Sendai, Miyagi 9808578, Japan.
   Sakai, Satoki; Suzuki, Yuka; Itagaki, Tomoyuki; Tsujisawa, Hisashi; Makino, Takashi T., Tohoku Univ, Grad Sch Life Sci, Dept Ecol \& Evolutionary Biol, Sendai, Miyagi 9808578, Japan.},
DOI = {10.1139/B07-121},
ISSN = {1916-2790},
Keywords = {dioecy; duration of pollinator stay; floral attraction; hermaphrodite
