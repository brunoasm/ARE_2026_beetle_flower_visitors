   Heidelberg Univ, HIP, D-69120 Heidelberg, Germany.},
DOI = {10.1086/377061},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {pollen tube transmitting tissue; pollen tube competition; quantitative
   aspects of pollination; P/O ratio; P-S/O ratio},
Keywords-Plus = {ORNITHOGALUM-CAUDATUM LILIACEAE; PROGENY VIGOR; OVULE RATIOS;
   POLLINATION INTENSITY; FRUIT MATURATION; BREEDING SYSTEMS; GROWTH; LOAD;
   ATTRITION; GUIDANCE},
