DOI = {10.1002/tax.12281},
ISSN = {0040-0262},
EISSN = {1996-8175},
Keywords = {ancestral state reconstructions; angiosperm orbicule-map; evolutionary
   trend; nanometric particles; phylogenetic analysis; Ubisch bodies},
