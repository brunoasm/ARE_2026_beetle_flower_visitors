@article{ WOS:000267747100001,
Author = {Kuhlmann, Michael and Timmermann, Kim},
Title = {Nest Architecture and floral Hosts of the South African Monolectic
   solitary Bee Othinosmia (Megaloheriades) schultzei (Hymenoptera:
   Megachilidae)},
Journal = {ENTOMOLOGIA GENERALIS},
Year = {2009},
Volume = {32},
Number = {1},
Pages = {1-9},
Abstract = {The solitary bee species Othinosmia (Megaloheriades) schultzei (Friese
   1909) is like most species of the genus endemic to the South African
   winter rainfall area. The females build very resistant hemispherical
   nests made of quartz grains embedded in a resinous matrix on the surface
   of sandstone rocks. Brood cells are exclusively provisioned with pollen
   of Asteraceae. The meloid beetle Stenoria hessei and the chrysidid wasp
   Chrysura schultzei are here recorded for the first time as parasitoids
   of O (M) schultzei. The nesting biology of the species is discussed and
   compared to other species of the genus.},
