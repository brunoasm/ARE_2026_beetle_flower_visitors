@article{ WOS:A1995TA32100009,
Author = {GODT, MJW and HAMRICK, JL},
Title = {THE MATING SYSTEM OF LIATRIS-HELLERI (ASTERACEAE), A THREATENED
   PLANT-SPECIES},
Journal = {HEREDITY},
Year = {1995},
Volume = {75},
Number = {4},
Pages = {398-404},
Month = {OCT},
Abstract = {Multilocus outcrossing rates were estimated for seven populations of
   Liatris helleli, a rare insect-pollinated composite. The mean multilocus
   outcrossing rate was 0.97 (SE = 0.02). None of the populations examined
   had multilocus outcrossing rates that differed significantly from 1.00,
   suggesting that the species is self-incompatible. Seed set was
   insignificant for 770 bagged floral heads, lending further support for
   this view. A small but significant amount of biparental inbreeding was
   detected in three of the seven populations.},
