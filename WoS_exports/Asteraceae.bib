@article{ WOS:A1984SX79800010,
Author = {KADEREIT, JW},
Title = {THE ORIGIN OF SENECIO-VULGARIS (ASTERACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1984},
Volume = {145},
Number = {1-2},
Pages = {135-153},
Abstract = {S. vulgaris L. (2n = 40) is suggested to be of autotetraploid origin
   from S. vernalis Waldst. et Kit (2n = 20). This conclusion is based on
   results obtained from experimental hybridizations and cytological
   observations, and the consideration of morphological affinities,
   patterns of geographical distribution and hybrid formation under natural
   conditions. The morphological differences between the 2 spp. are related
   to a difference in the breeding system. While S. vernalis is
   self-incompatible, S. vulgaris is self-compatible and strongly
   self-pollinating. Equally, other self-pollinating taxa traditionally
   associated with S. vulgaris have evolved independently from outbreeding
   relatives. Within a narrow frame of relationship, annual weeds have
   evolved in different cytotaxonomic circumstances.},
