@article{ WOS:000238899700008,
Author = {Hermes, Marcel G. and Kohler, Andreas},
Title = {The flower-visiting social wasps (Hymenoptera, Vespidae, Polistinae) in
   two areas of Rio Grande do Sul State, southern Brazil},
Journal = {REVISTA BRASILEIRA DE ENTOMOLOGIA},
Year = {2006},
Volume = {50},
Number = {2},
Pages = {268-274},
Month = {APR-JUN},
Abstract = {The flower-visiting social wasps (Hymenoptera, Vespidae, Polistinae) in
   two areas of Rio Grande do Sul State, southern Brazil. The structure of
   flower-visiting social wasps' assemblages in the CPCN Pro-Mata of Sao
   Francisco de Paula and in the Green Belt of Santa Cruz do Sul, Rio
   Grande do Sul, are characterized. A total of 879 polistine wasps were
   collected, of which 475 (11 spp.) in the CPCN and 404 (21 spp.) in the
   Green Belt, from September 1997 to April 2001 and from September 2001 to
   April 2004, respectively. Foraging social wasps were observed on flowers
   of 36 species of angiosperms (20 families) in the Green Belt, and on
   flowers of 54 species of angiosperms (21 families) in the CPCN.
   Asteraceae was the most visited plant family on both studied localities.
   A list of pant species visited by the polistines is provided.},
