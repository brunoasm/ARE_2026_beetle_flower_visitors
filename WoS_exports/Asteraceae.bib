Language = {English},
Affiliation = {Silva, JL (Corresponding Author), Univ Seville, Dept Biol Vegetal \& Ecol, E-41012 Seville, Spain.
   Silva, Jose L.; Mejias, Jose A., Univ Seville, Dept Biol Vegetal \& Ecol, E-41012 Seville, Spain.
   Brennan, Adrian C., Univ Durham, Sch Biol \& Biomed Sci, Durham, England.},
DOI = {10.1093/aobpla/plw029},
Article-Number = {plw029},
ISSN = {2041-2851},
Keywords = {Breakdown of SI; diallel crosses; index of self-incompatibility; S
   allele diversity; Sonchus section Pustulati; sporophytic
   self-incompatibility; resilience},
Keywords-Plus = {SQUALIDUS L. ASTERACEAE; RUTIDOSIS-LEPTORRHYNCHOIDES ASTERACEAE;
