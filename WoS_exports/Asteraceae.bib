ISSN = {0888-8892},
Keywords = {Brassica insularis; Brassicaceae; conservation genetics; fruit set;
   plant mate availability; self-incompatibility},
Keywords-Plus = {INBREEDING DEPRESSION; POPULATION-GENETICS; BALANCING SELECTION; FINITE
