Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Guo, YP (Corresponding Author), Beijing Normal Univ, Coll Life Sci, Minist Educ, Key Lab Biodivers Sci \& Ecol Engn, Beijing 100875, Peoples R China.
   Ren, Jia-Bin; Guo, Yan-Ping, Beijing Normal Univ, Coll Life Sci, Minist Educ, Key Lab Biodivers Sci \& Ecol Engn, Beijing 100875, Peoples R China.},
