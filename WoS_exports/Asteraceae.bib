   Escarre, Josep, CNRS, Ctr Ecol Fonct \& Evolut, F-34033 Montpellier, France.},
DOI = {10.1071/BT07100},
ISSN = {0067-1924},
Keywords-Plus = {CREPIS-SANCTA ASTERACEAE; SQUALIDUS L. ASTERACEAE; SELF-INCOMPATIBILITY;
