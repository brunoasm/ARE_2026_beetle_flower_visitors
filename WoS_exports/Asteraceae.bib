ISSN = {0934-0882},
Keywords = {pollen evolution; pollen diameter; pollen tube growth; common ancestry
   effects; post-pollination processes},
Keywords-Plus = {TUBE GROWTH; NUMBER; STIGMA; PONTEDERIACEAE; STYLE},
