ISSN = {0269-7653},
Keywords = {asteraceae; Crepis sancta; dispersal; heteromorphic; outcrossing},
Keywords-Plus = {SENECIO-VULGARIS L; RAY FLORET LOCUS; IMPATIENS-CAPENSIS; SEXUAL
   REPRODUCTION; EVOLUTIONARY SIGNIFICANCE; OFFSPRING PERFORMANCE;
   INBREEDING DEPRESSION; SIB-COMPETITION; POLYMORPHISM; HYPOTHESIS},
