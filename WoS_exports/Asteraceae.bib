@article{ WOS:A1984TE86200001,
Author = {SHOLES, ODV},
Title = {RESPONSES OF ARTHROPODS TO THE DEVELOPMENT OF GOLDENROD INFLORESCENCES
   (SOLIDAGO, ASTERACEAE)},
Journal = {AMERICAN MIDLAND NATURALIST},
Year = {1984},
Volume = {112},
Number = {1},
Pages = {1-14},
Abstract = {Abundance and species richness of panicle-dwelling arthropods were
   measured during flower development on Solidago juncea and S. altissima.
   Marked plants were periodically censused in situ, and arthropods
   collected from goldenrod panicles in areas adjacent to those used for
   censusing. Arthropods were grouped into 5 guilds: chewing herbivores,
   sucking herbivores, flower-product feeders, parasitoids and predators.
   Sucking herbivores comprised the largest guild, based on numbers of
   individuals and of species. Changes in abundance of the 2 herbivorous
   guilds were not related to plant phenology. In contrast, herbivore
   species richness usually peaked during blooming. Flower feeders,
   parasitoids and predators all peaked in abundance and species richness
   during blooming. Nectar and pollen attracted the flower feeders and
   parasitoids (members of both guilds eat flower products). The dominant
   predators seemed to prefer mobile flower visitors as prey (flower
   feeders, parasitoids and several  herbivore species) and these visitors
   were more numerous during blooming. The panicles attracted a wider
   variety of arthropods than just pollinators because panicles offer a
   wider variety of resources than nectar and pollen.},
