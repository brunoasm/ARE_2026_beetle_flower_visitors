ISSN = {0002-9122},
Keywords = {crop-wild gene flow; Helianthus annuus; seed dispersal; volunteers},
Keywords-Plus = {WILD SUNFLOWER; SEED DISPERSAL; FLOW; CROP; RELATIVES; PLANTS;
   INTROGRESSION; PHENOLOGY; HYBRIDS},
