   Berjano, Regina; Rodriguez-Castaneda, Nancy L.; Ortiz, Pedro L.; Ortiz, Maria K.; Arista, Montserrat, Univ Seville, Dept Biol Vegetal \& Ecol, Apdo 1095, E-41080 Seville, Spain.},
DOI = {10.1002/ajb2.1207},
