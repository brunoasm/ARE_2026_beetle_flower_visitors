@article{ WOS:000336743600013,
Author = {Sharma, Indu and Bharti, Uma and Parihar, Jyoti and Sharma, Namrata},
Title = {Sex-Expression and Reproductive Output in Three Species of
   <i>Artemisia</i> L. Abounding Jammu Province (J\&K), India},
Journal = {NATIONAL ACADEMY SCIENCE LETTERS-INDIA},
Year = {2014},
Volume = {37},
Number = {3},
Pages = {285-288},
Month = {JUN},
Abstract = {Three species of Artemisia L. Family (Asteraceae), namely A. maritima
   L., A. nilagirica Pamp. and A. scoparia Waldst and Kit. growing wild in
   different regions of Jammu province of J\&K, India have been studied for
   their sex expression which is found to be variable. A. maritima is
   hermaphrodite with homomorphic florets, A. nilagirica has heteromorphic
   florets and is gynomonoecious, while A. scoparia is also heteromorphic
   but is having female ray florets and functionally male disc florets. The
   variable floral composition of the three species affects their
   reproductive output both on open pollination and unassisted selfing by
   geitonogamous pollination. All the three species however match in being
   highly protandrous and setting seed either solely or to a greater extent
   by cross pollination.},
