Keywords-Plus = {SEED SIZE VARIATION; SEX-RATIO; POLLEN LIMITATION;
   DESMODIUM-PANICULATUM; OFFSPRING SIZE; GENETIC LOAD; L SCOP; PLANTS;
   EVOLUTION; FEMALES},
Research-Areas = {Plant Sciences},
