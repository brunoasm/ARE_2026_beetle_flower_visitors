Keywords = {heterocarpy; seed heteromorphism; developmental constraints; capitulum
   ontogeny; population genetics},
Keywords-Plus = {MICROSERIS-PYGMAEA ASTERACEAE; HETEROSPERMA-PINNATUM; TECTORUM
