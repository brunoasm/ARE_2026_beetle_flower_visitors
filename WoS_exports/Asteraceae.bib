@article{ WOS:000181841500009,
Author = {Fahn, A},
Title = {Functions and location of secretory tissues in plants and their possible
   evolutionary trends},
Journal = {ISRAEL JOURNAL OF PLANT SCIENCES},
Year = {2002},
Volume = {50},
Number = {S},
Pages = {S59-S64},
Note = {Symposium on New Aspects in the Biology and Systematics of the
   Mediterranean Flora, JERUSALEM, ISRAEL, JAN, 2001},
Abstract = {On the basis of the variability and location of the secretory tissues in
   the plant body, the following, are suggested: (1) In relation to their
   surrounding environment, the secretory tissues fulfill two very
   important ecological functions-protection against herbivores and
   pathogens and attraction of pollinators. (2) The protective function
   preceded the function of attraction. (3) The protective secretory
   tissues are suggested to have expanded during the course of evolution
   from the leaf mesophyll outside, to the epidermis and its trichomes, and
   inside the plant body, to the primary and secondary phloem, and, in a
   few cases, also to the secondary xylem.},
