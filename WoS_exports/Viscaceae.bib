   Grigory and Leonenko, Volodymyr and Janosikova, Katerina and Sytschak,
   Nadiya and Rydlo, Karol and Sytnyk, Dmytro},
Title = {The European mistletoe (<i>Viscum album</i> L.): distribution, host
   range, biotic interactions, and management worldwide with special
   emphasis on Ukraine},
Journal = {BOTANY},
Year = {2020},
