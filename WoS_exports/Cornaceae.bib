
@article{ WOS:A1996VY76000002,
Author = {Guitian, J and Guitian, P and Navarro, L},
Title = {Spatio-temporal variation in the interactions between Cornus sanguinea
   and its pollinators},
Journal = {ACTA OECOLOGICA-INTERNATIONAL JOURNAL OF ECOLOGY},
Year = {1996},
Volume = {17},
Number = {4},
Pages = {285-295},
Abstract = {Spatiotemporal variation in the composition of the pollinator assemblage
   of Cornus sanguinea (Cornaceae) was investigated over a two-year period
   in three populations in the northwest Iberian Peninsula. On average,
   67.4\% of flower visitors were hymenopterans and 22.6\% dipterans. The
   relative frequencies of hymenopteran and dipteran visits varied
   significantly among populations and between plants at their flowering
   peak (''at-their-prime'' plants) and past their flowering peak
   (''past-their-prime'' plants), but not between the two years of study.
   The principal species composition of the pollinator assemblage differed
   significantly between years (Renkonen percentage similarity, PS = 0.38),
   between at-their-prime and past-their prime plants (PS = 0.40) and
   between two of the populations studied (PS = 0.43). Evolutionary theory
   predicts that the development of specialized plant/pollinator
   relationships requires the relative frequency of the interaction to be
   more or less constant. Our results suggest that Cornus sanguinea does
   not interact in a consistent way with any particular species or species
   group.},
Publisher = {ELSEVIER},
Address = {RADARWEG 29, 1043 NX AMSTERDAM, NETHERLANDS},
Type = {Article},
Language = {English},
