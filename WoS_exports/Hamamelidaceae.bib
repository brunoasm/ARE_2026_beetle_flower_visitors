@article{ WOS:A1978FX77900002,
Author = {HESSE, M},
Title = {DEVELOPMENT AND ULTRASTRUCTURE OF POLLENKITT AND EXINE IN CLOSELY
   RELATED ENTOMOPHILOUS AND ANEMOPHILOUS ANGIOSPERMS - RANUNCULACEAE,
   HAMAMELIDACEAE, PLATANACEAE, AND FAGACEAE},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1978},
Volume = {130},
Number = {1-2},
Pages = {13-42},
Abstract = {Transfer of fresh pollen either by wind or by insects is strongly
   related to its degree of stickiness. The sticky substances involved
   should be understood as pollenkitt. Ultrastructural investigations
   indicate that the sticky pollen of entomophilous angiosperms (Hamamelis
   vernalis and H. virginiana and Corylopsis platypetala) results from the
   deposition of usually electron-dense, homogeneous pollenkitt mainly on
   the outside layer of the exine. In contrast, the pollen of anemophilous
   angiosperms (Parrotia persica, Platanus orientalis, Thalictrum flavum
   and Quercus robur), but also of some entomophilous angiosperms with
   special pollination ecology (e.g. Aquilegia vulgaris) is dry and
   powdery. In these cases the pollenkitt often is electron-transparent and
   inhomogeneous and is mainly removed into the cavities of the exine.
   Ultrastructure and deposition of pollen and pollenkitt in ambophilous
   angiosperms (T. minus, Castanea sativa) are .+-. intermediate.},
Publisher = {SPRINGER WIEN},
Address = {Prinz-Eugen-Strasse 8-10, A-1040 Vienna, AUSTRIA},
