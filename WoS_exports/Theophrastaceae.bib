
@article{ WOS:A1997WN46900011,
Author = {Gagne, RJ and Ott, C and Renner, SS},
Title = {A new species of gall midge (Diptera: Cecidomyiidae) from Ecuador
   associated with flowers of Clavija (Theophrastaceae)},
Journal = {PROCEEDINGS OF THE ENTOMOLOGICAL SOCIETY OF WASHINGTON},
Year = {1997},
Volume = {99},
Number = {1},
Pages = {110-114},
Month = {JAN},
Abstract = {A gall midge new to science, Charidiplosis clavijica Gagne, is described
   from specimens found standing on male flowers of Clavija weberbaueri
   (Theophrastaceae) in eastern Ecuador. The new species is notable for
   several unique characters involving the tarsal claws, the male antenna,
   and the female ovipositor. The new species is compared to the widespread
   and only other described congener, Charidiplosis tringularis (Felt), a
   species associated with flowers of cacao.},
