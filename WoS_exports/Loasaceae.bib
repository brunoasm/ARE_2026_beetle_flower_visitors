@article{ WOS:000172964200009,
Author = {Gramacho, M and Santander, T and Farji-Brener, AG},
Title = {Effects of herbivory on ovule number in <i>Loasa speciosa</i>
   (Loasaceae)},
Journal = {REVISTA DE BIOLOGIA TROPICAL},
Year = {2001},
Volume = {49},
Number = {2},
Pages = {513-516},
Month = {JUN},
Abstract = {We examined the direct effect of foliar herbivory on female fitness in
   the herbaceous plant Loasa speciosa (Loasaceae), measuring ovule
   number/flower in 46 shoots with different levels of leaf damage. Ovule
   number/flower was lower in shoots with higher herbivory levels. This
   result suggests that the known negative impact of herbivory on female
   plant fitness (i.e. low seed number) can be a direct consequence of the
   reduction of ovule number.},
