   CONICET, IMBIV, RA-5000 Cordoba, Argentina.},
DOI = {10.1007/BF00984916},
ISSN = {0378-2697},
Keywords = {Loasaceae; Cajophora; Graomys; flower biology; non-flying mammal
   pollination; rodents},
Keywords-Plus = {PROTEACEAE; BIOLOGY; MAMMALS; AFRICAN; FOREST; SYSTEM},
Research-Areas = {Plant Sciences; Evolutionary Biology},
Web-of-Science-Categories  = {Plant Sciences; Evolutionary Biology},
