@article{ WOS:A1976CJ47600003,
Author = {HILL, RJ},
Title = {MENTZELIA-SINUATA (RYDB) HILL,RJ, COMB NOV AND MENTZELIA-SPECIOSA OSTERH
   (LOASACEAE), A SPECIES PAIR FROM ROCKY-MOUNTAIN FRONT RANGE},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1976},
Volume = {103},
Number = {5},
Pages = {212-217},
Abstract = {Mentzelia displays a wide range of evolutionary mechanisms which have
   affected speciation in the genus, including species-specific pollination
   vectors, preferential habitat requirements and formation of aneuploid
   and polyploid series. The taxon M. speciosa, first described by G.E.
   Osterhout in 1901, has a limited distribution in the Rocky Mountain
   Front Range {[}Wyoming, Colorado, USA]. Touterea sinuata (Touterea =
   Mentzelia) described by P.A. Rydberg in 1904 from the same region, was
   quickly placed in synonymy under M. speciosa. Data derived from
   morphological and cytological examinations of populations of putative M.
   speciosa indicate that T. sinuata is a valid taxon. Scanning electron
   microscopy of seed coat microsculpturing would indicate either that
   speciation is recent, or that the taxa have not evolved greatly since
   their initial divergence. The 2 taxa are described, and the new
   combination M. sinuata (T. sinuata Rydb.) is made. Distribution maps,
   leaf silhouettes and caryograms are included. Synonymy and selected
   exsiccatae are given.},
