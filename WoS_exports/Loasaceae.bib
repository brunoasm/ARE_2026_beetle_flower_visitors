@article{ WOS:A1977DL09200001,
Author = {HILL, RJ},
Title = {VARIABILITY OF SOLUBLE SEED PROTEINS IN POPULATIONS OF MENTZELIA-L
   (LOASACEAE) FROM WYOMING AND ADJACENT STATES},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1977},
Volume = {104},
Number = {2},
Pages = {93-101},
Abstract = {Seed proteins from 24 populations representing 11 taxa (M. dispersa, M.
   albicaulis, M. oligosperma, M. rusbyi, M. multiflora, M. speciosa, M.
   sinuata, M. decapetala, M. laevicaulis, M. pumila, M. nuda) from
   Wyoming, Nebraska, Colorado, and Montana (USA) were examined using
   polyacrylamide gel disc electrophoresis. Migration velocities for
   protein bands were calculated. The total number of protein bands for all
   populations (OTU''s operational taxonomic units), as determined by Rp
   values, was found to be 76. The minimum number encountered for any OTU
   was 20 (M. albicaulis (Dougl. ex Hook.) T. et G. and M. oligosperma
   Nutt. ex Sims), while the maximum number was 29 (M. multiflora (Nutt.)
   Gray). A percent similarity matrix was constructed. From these data,
   interspecific similarity was found to be low, ranging from 11.9\%
   between M. nuda (Pursh) T. et G. and M. dispersa S. Wats. to 42.4\%
   between M. nuda and M. speciosa Osterh. By contrast, except in M. pumila
   Nutt. ex T. et G., the intraspecific similarity was found to be
   relatively high, the lowest similarity encountered being 88.0\% between
   populations of M. sinuata (Rydb.) R.J. Hill. The highest intraspecific
   similarity was 100.0\% between populations of m. decapetata (Pursh ex
   Sims) Urban et Gilg, M. multiflora, M. sinuata, M. laevicaulis, and M.
   nuda. A phenogram was constructed using cluster analysis techniques. A
   Minimum Spanning Tree was also constructed using the NT-SYS Computer
   Program. The dissimilarity of seed proteins in members of closely
   allied, but different taxa, is probably due to the high degree of
   endemism and barriers to gene flow, e.g., oligolectic insect
   pollinators, dissynchrony of flowering time, and chromosomal
   alterations, found in the genus.},
Publisher = {TORREY BOTANICAL SOC},
