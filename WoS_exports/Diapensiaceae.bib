@article{ WOS:A1985AUV7800001,
Author = {FRIIS, EM},
Title = {ACTINOCALYX GEN-NOV SYMPETALOUS ANGIOSPERM FLOWERS FROM THE UPPER
   CRETACEOUS OF SOUTHERN SWEDEN},
Journal = {REVIEW OF PALAEOBOTANY AND PALYNOLOGY},
Year = {1985},
Volume = {45},
Number = {3-4},
Pages = {171-183},
Abstract = {Small sympetalous flowers, Actinocalyx bohrii gen. et sp. nov. are
   described from the Upper Cretaceous (Santonian/Campanian) of Scania,
   southern Sweden. They are actinomorphic, hypogynous, and pentamerous,
   except for the tricarpellate gynoecium. The calyx is persistent, and
   upturned in the flowering stage. In the fruiting stage the calyx is
   enlarged, spreading and star-shaped. Comparison with extent plants
   indicates a close relatiohship to some members of the Ericales,
   especially the Diapensiaceae. The fossil flowers are the earliest
   sympetalous flowers in the fossil record, and provide the first floral
   evidence for an initial adaptation to specialized insect pollinators
   before the end of the Cretaceous.},
