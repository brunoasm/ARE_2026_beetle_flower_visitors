@article{ WOS:000077495000005,
Author = {Ishida, K and Hiura, T},
Title = {Pollen fertility and flowering phenology in an androdioecious tree,
   <i>Fraxinus lanuginosa</i> (Oleaceae), in Hokkaido, Japan},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {1998},
Volume = {159},
Number = {6},
Pages = {941-947},
Month = {NOV},
Abstract = {Fraxinus lanuginosa Koidz. is a tree species distributed in Japan and in
   southern Korea. In central Hokkaido, northern Japan, hermaphrodites and
   males commonly coexist in populations of the species. Hermaphrodites and
   males have identical flowering phenologies and pollen morphologies.
   However, the mean germination rate for pollen from hermaphrodites, on
   agar culture media, is 2.8-3.4 times lower than that for pollen from
   males. The mean seed set of inflorescences cross-pollinated by pollen
   from hermaphrodites is similarly 2.7 times lower than that by pollen
   from males. In contrast, the mean seed set of hermaphrodite-pollinated
   inflorescences is 12-19 times more than that of self-pollinated
   inflorescences. These results indicate that E lanuginosa is functionally
   androdioecious and exhibits strong self-sterility. The findings help
   explain the maintenance of androdioecy in F. lanuginosa.},
Publisher = {UNIV CHICAGO PRESS},
Address = {5801 S ELLIS AVENUE, CHICAGO, IL 60637 USA},
