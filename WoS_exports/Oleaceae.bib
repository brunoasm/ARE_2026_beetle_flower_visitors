@article{ WOS:A1979HD64900006,
Author = {HESSE, M},
Title = {DEVELOPMENT AND ULTRASTRUCTURE OF POLLENKITT AND EXINE IN CLOSELY
   RELATED ENTOMOPHILOUS AND ANEMOPHILOUS ANGIOSPERMS IN OLEACEAE,
   SCROPHULARIACEAE, PLANTAGINACEAE, AND ASTERACEAE},
