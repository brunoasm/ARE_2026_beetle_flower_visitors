ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {androdioecy; Fraxinus excelsior; male reproductive success;
   microsatellites; Oleaceae; paternity assignment; pollen competition;
   polygamous mating system; trioecy},
Keywords-Plus = {FUNCTIONAL ANDRODIOECY; MICROSATELLITE LOCI; SPERM COMPETITION;
   SEX-RATIOS; FERTILIZATION; IDENTIFICATION; GROWTH; PLANTS; TREE; L.},
