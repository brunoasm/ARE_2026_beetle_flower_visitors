Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {UNIV OXFORD, DEPT PLANT SCI, OXFORD OX1 3RB, ENGLAND.},
DOI = {10.2307/2960627},
ISSN = {0022-0477},
EISSN = {1365-2745},
Keywords = {androdioecy; dioecy; reproductive assurance; trade-off; wind pollination},
