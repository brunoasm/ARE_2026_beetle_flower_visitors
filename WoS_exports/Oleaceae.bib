ISSN = {0098-0331},
Keywords = {flower-visiting; floral scent; Pieris rapae; Pieridae; Osmanthus
   fragrans; Oleaceae; proboscis extension reflex; EAG; repellent;
   gamma-decalactone; linalool oxide},
