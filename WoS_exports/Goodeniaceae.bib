ISSN = {0367-2530},
Keywords = {CAMPANULALES-ASTERALES; RUBIACEAE; SECONDARY POLLEN PRESENTATION;
   PORTIONED POLLEN RELEASE; POLLINATION SYNDROMES; PHYLOGENY},
Keywords-Plus = {FLORAL DEVELOPMENT; FLOWERING PLANTS; CLASSIFICATION; ASTERACEAE;
