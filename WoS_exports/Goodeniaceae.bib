Language = {English},
Affiliation = {LADD, PG (Corresponding Author), MURDOCH UNIV,SCH BIOL \& ENVIRONM SCI,MURDOCH,WA 6150,AUSTRALIA.},
DOI = {10.1016/S0254-6299(16)30690-1},
ISSN = {0254-6299},
Keywords = {POLLEN PRESENTERS; POLLINATION BIOLOGY; FLORAL MORPHOLOGY},
