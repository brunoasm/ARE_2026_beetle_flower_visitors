@article{ WOS:000073708300010,
Author = {Cox, AV and Abdelnour, GJ and Bennett, MD and Leitch, IJ},
Title = {Genome size and karyotype evolution in the slipper orchids
   (Cypripedioideae: Orchidaceae)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1998},
Volume = {85},
Number = {5},
Pages = {681-687},
Month = {MAY},
Abstract = {Nuclear DNA contents (4C) were estimated by Feulgen microdensitometry in
   27 species of slipper orchids. These data and recent information
   concerning the molecular systematics of Cypripedioideae allow an
   interesting re-evaluation of karyotype and genome size variation among
   slipper orchids in a phylogenetic context. DNA amounts differed
   5.7-fold, from 24.4 pg in Phragmipedium longifolium to 138.1 pg in
   Paphiopedilum wardii. The most derived clades of the conduplicate-leaved
   slipper orchids have undergone a radical process of genome fragmentation
   that is most parsimoniously explained by Robertsonian changes involving
   centric fission. This process seems to have occurred independently of
   genome size variation. However, it may reflect environmental or
   selective pressures favoring higher numbers of linkage groups in the
   karyotype.},
