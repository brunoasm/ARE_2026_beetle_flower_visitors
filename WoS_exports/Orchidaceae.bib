@article{ WOS:A1985AEQ7500004,
Author = {STORT, MNS and PAVANELLI, EAD},
Title = {FORMATION OF MULTIPLE OR ADVENTIVE EMBRYOS IN EPIDENDRUM-NOCTURNUM JACQ
   (ORCHIDACEAE)},
Journal = {ANNALS OF BOTANY},
Year = {1985},
Volume = {55},
Number = {3},
Pages = {331-336},
Abstract = {Under greenhouse conditions, E. nocturnum Jacq. plants produce fruits by
   both self-fertilization and cleistogamy. Although adapted to these
   reproductive processes the species respond also to cross-pollination.
   Seeds without embryos and with 1 embryo are usual but occasionally seeds
   with 2, 3 or 4 embryos are produced. Multiple embryos are formed by
   polyembryony and apomixis.},
Publisher = {OXFORD UNIV PRESS},
