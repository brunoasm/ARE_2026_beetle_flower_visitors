@article{ WOS:000229084100001,
Author = {Shipunov, AB and Bateman, RM},
Title = {Geometric morphometrics as a tool for understanding <i>Dactylorhiza</i>
   (Orchidaceae) diversity in European Russia},
Journal = {BIOLOGICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {2005},
Volume = {85},
Number = {1},
Pages = {1-12},
Month = {MAY},
Abstract = {Geometric morphometric techniques were employed to assess the diversity
   of lip shapes (305 samples from 83 populations) in flowers of European
   Russian Dactylorhiza (Orchidaceae: Orchidinae). We found significant
   agreement between the results from geometric morphometrics, classic
   morphometrics and the distribution of certain nuclear DNA markers. The
   lip shapes from Arctic Dactylorhiza samples occupied an intermediate
   position between D. maculata and D. fuchsii samples from Central Russia,
   supporting a hybrid origin of `northern tetraploids'. Lip shapes of the
   taxonomically controversial allotetraploid D. baltica were found to form
   a distinct group, with members having definite relationships with
   diploid D. incarnata samples from the same localities, indicating either
   their local origin or introgression with D. incarnata. In addition to
   demonstrating the value of geometric morphometric methods in studies of
   plant taxonomy and hybridizatibn, we suggest future applications
   designed to explore pollinator-driven directional selection,
   developmental constraints and fluctuating asymmetry. (c) 2005 The
   Linnean Society of London.},
