@article{ WOS:A1983RC45000006,
Author = {STOUTAMIRE, WP},
Title = {WASP-POLLINATED SPECIES OF CALADENIA (ORCHIDACEAE) IN SOUTHWESTERN
   AUSTRALIA},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1983},
Volume = {31},
Number = {4},
Pages = {383-394},
Abstract = {Twelve of the 40 Caladenia spp. of Western Australia have been observed
   to attract male wasps (Tiphiidae; subfamily Thynninae) by visual and
   pheromonal mechanisms. Floral colors are predominantly combinations of
   green, cream and brown. Labella bar dark maroon tips or dark calli on
   the upper surface which are visual wasp equivalents. Glandular areas on
   perianth tips are demonstrated to be sources of sexual attractants in
   some species. Flower form and position are adjusted to the flight
   behavior  of the wasps. Each Caladenia species appears to attract and be
   pollinated by only 1 wasp species at the orchid site although there is
   limited evidence of geographic pollinator replacement in some species.
   Sexually attracting Caladenia spp. form occasional hybrids with
   food-advertizing species. Divergent pollination mechanisms have not
   resulted in complete genetic isolation.},
