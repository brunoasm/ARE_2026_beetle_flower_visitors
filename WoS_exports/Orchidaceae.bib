Month = {MAY 18},
Abstract = {Drakaea livida (Orchidaceae) is pollinated by sexual deception of the
   wasp Zaspilothynnus nigripes (Thynnidae). It is shown that the orchid
   emits the same compound,
   2-hydroxymethyl-3-(3-methylbutyl)-5-methylpyrazine, that females emit
