Year = {2014},
Volume = {158},
Number = {1},
Pages = {1-22},
Month = {JAN 30},
Abstract = {A taxonomic synopsis of Brazilian Chloraeinae (Orchidaceae) is
   presented. Artificial keys to separate the genera and species are
   included. Vegetative and floral features of all species are described
   and illustrated with drawings and photographs, and data on their
   distribution, phenology and ecology are presented. Two lectotypes and
   one neotype are proposed. The presence of Bipinnula biplumata, B.
   montana, B. penicillata and Chloraea membranacea in Brazil is confirmed,
   and Bipinnula gibertii is reported for the first time from this country.},
