   Univ Natal, Sch Bot \& Zool, ZA-3209 Pietermaritzburg, South Africa.},
DOI = {10.1006/bijl.1999.0430},
ISSN = {0024-4066},
Keywords = {foraging behaviour; fly-pollination; geitonogamy; nectar; Orchidaceae;
   Tabanidae; Watsonia},
Keywords-Plus = {FLORAL MIMICRY; FLY POLLINATION; SOUTHERN AFRICA; NECTAR; PLANT;
   GEITONOGAMY; DECEPTION; EVOLUTION; PARADIGM; BIOLOGY},
