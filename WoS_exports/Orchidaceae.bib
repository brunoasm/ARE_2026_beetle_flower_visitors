   Univ Jyvaskyla, Dept Biol \& Environm Sci, FIN-40351 Jyvaskyla, Finland.},
ISSN = {0024-4074},
Keywords = {Dactylorhiza; defoliation; inflorescence; mycorrhiza; photosynthesis;
   resource storage; rosette leaves; shading; terrestrial orchid},
Keywords-Plus = {TIPULARIA-DISCOLOR ORCHIDACEAE; LADYS-SLIPPER ORCHID; GOODYERA-REPENS;
