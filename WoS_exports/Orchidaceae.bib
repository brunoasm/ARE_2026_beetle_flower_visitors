EISSN = {1095-8339},
Keywords = {Orchidaceae; Diplodium; orchid; heliotropism; conversotropism; window
   flowers; trap flowers; fungus gnats; pollinator behaviour},
Keywords-Plus = {SOLAR TRACKING; FUNGUS-GNATS; SNOW BUTTERCUP; USE EFFICIENCY;
   HELIOTROPISM; LIGHT; DROSOPHILA; MYCETOPHILIDAE; RANUNCULACEAE;
   TEMPERATURE},
