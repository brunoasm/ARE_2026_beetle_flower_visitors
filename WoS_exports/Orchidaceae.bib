@article{ WOS:000073011200003,
Author = {Kull, T},
Title = {Fruit-set and recruitment in populations of Cypripedium calceolus L. in
   Estonia},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1998},
Volume = {126},
Number = {1-2},
Pages = {27-38},
Month = {JAN-FEB},
Note = {Meeting on Orchid Population Biology - Conservation and Challenges,
   LINNEAN SOC, LONDON, ENGLAND, NOV, 1995},
Organization = {Botan Soc Brit Isles},
Abstract = {The overall mean percentage of fruiting for over 3500 flowers observed
   in eight Estonian populations of a self-compatible clonal orchid
   Cypripedium calceolus over 11 years was 10.5\%. The larger clones set
   relatively fewer fruits, otherwise the general pattern of fruiting was
   close to random, despite several significant local deviations from
   random pollination. There is no cost associated with the fruit-set at
   the clonal level. The fruit-set which appears pollinator Limited was not
   correlated with the frequency of seedlings in a population. Data
   presented provide information on the relationship between fruit and
   seedling production in orchids. The sites suitable for seedling
   establishment are characterized as having relatively more extensive moss
   cover, less vascular plant cover, more moisture and better light
   conditions. Recruitment is concluded to be microsite limited, and the
   fruit-set to be without significant influence on the fitness of
   populations. (C) 1998 The Linnean Society of London.},
