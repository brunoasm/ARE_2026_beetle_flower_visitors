ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {Floral signals; floral scent; floral morphology; floral colour;
   pollination; reproductive success; polyploidization; mixed-ploidy
   populations; floral isolation; Gymnadenia conopsea; orchid; Orchidaceae;
   diploid; tetraploid},
