Affiliation = {Kirillova, IA (Corresponding Author), RAS, Inst Biol, Komi Sci Ctr, Ural Branch, Syktyvkar, Russia.
   Kirillova, Irina A.; Kirillov, Dmitry, V, RAS, Inst Biol, Komi Sci Ctr, Ural Branch, Syktyvkar, Russia.},
DOI = {10.24189/ncr.2023.017},
ISSN = {2500-008X},
Keywords = {climate influence; fruit set; monitoring; orchids; reproductive success},
