@article{ WOS:000437747600005,
Author = {Fateryga, Alexander V. and Popovich, Anton V. and Fateryga, Valentina V.
   and Averyanova, Elena A. and Kreutz, Karel (C. A. J. )},
Title = {New data on the genus <i>Epipactis</i> (Orchidaceae) in the North
   Caucasus with description of a new species},
Journal = {PHYTOTAXA},
Year = {2018},
Volume = {358},
Number = {3},
Pages = {278-288},
Month = {JUL 6},
Abstract = {A new self-pollinating species, Epipactis euxina, is described from
   Gelendzhik District of Krasnodar Territory. The species is closely
   related to E. persica from which it differs by its remarkable long
   pedicel, distinctly longer epichile, and indistinct or absent viscidium.
   It grows in sparse pine forest mixed with oak, on calcareous soils. Four
   other taxa collected in different localities of Krasnodar Territory are
   new for the North Caucasus: E. krymmontana, E. leptochila subsp.
   leptochila, E. leptochila subsp. neglecta, and E. muelleri. A new
   synonymy is proposed for E. persica = E. helleborine subsp.
   transcaucasica. An updated key to the species of the genus Epipactis in
   the North Caucasus is provided. The lectotype of E. muelleri is
   designated.},
