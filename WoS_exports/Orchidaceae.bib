   Peter, Craig I., Rhodes Univ, Dept Bot, ZA-6140 Grahamstown, South Africa.
   Johnson, Steven D., Univ KwaZulu Natal, Sch Biol \& Conservat Sci, ZA-3209 Scottsville, South Africa.},
DOI = {10.1093/aob/mcn218},
ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {Reward; deception; pollen transfer efficiency; pollen tracking;
   geitonogamy; Acrolophia cochlearis; epidendroid orchid; Cape floral
