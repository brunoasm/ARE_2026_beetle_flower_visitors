@article{ WOS:000523702500002,
Author = {Lucca, Diego L. and Sa, Giovanna P. and Polastri, Leonardo R. and
   Ghiraldi, Denise M. B. and Ferreira, Nagela P. and Chiavelli, Lucas U.
   R. and Ruiz, Ana L. T. G. and Garcia, Francielle P. and Paula, Jessica
   C. and Nakamura, V, Celso and Nakamura, Tania U. and Kischkel, Brenda
   and Scariot, Debora B. and Fonseca, Dyenefer P. and Santin, Silvana M.
   O. and Gutierre, Maria A. M. and Negri, Melyssa F. N. and Pomini,
   Armando M.},
Title = {Biphenanthrene from <i>Stanhopea lietzei</i> (Orchidaceae) and its
   chemophenetic significance within neotropical species of the Cymbidieae
   tribe},
Journal = {BIOCHEMICAL SYSTEMATICS AND ECOLOGY},
Year = {2020},
Volume = {89},
Month = {APR},
Abstract = {Orchidaceae are one of the largest families of flowering plants. In this
   work, the first phytochemical study of the non-flowering parts of the
   South American species Starthopea lietzei (Regel) Schltr. is reported.
   It led to the isolation of nine compounds, including the rare dimeric
   compound
   2,2',7,7'-tetramethoxy-4,4',6,6'-tetrahydroxy-(1,1')-biphenanthrene (1).
   This compound was tested for the first time against HeLa human cancer
   cells, with IC50 16.9 +/- 0.9 mu g/mL. Biological assays against
   neotropical parasites, virus and other human cancer cell lines are also
   reported. Finally, the relevance of biphenanthrenes, flavonoids, and
   C-glycosylated phenolic compounds for chemophenetics relationships
   within neotropical species of the Cymbidieae tribe and Oncidiinae,
   Maxillariinae, Cyrtopodiinae and Stanhopeinae subtribes was also
   discussed.},
