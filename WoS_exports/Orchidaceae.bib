   Univ Calabria, Dipartimento Ecol, I-87036 Cosenza, Italy.},
DOI = {10.1111/j.1442-1984.2005.00121.x},
ISSN = {0913-557X},
Keywords = {breeding system; Coleoptera; hand-pollination; pollinator limitation;
   reproductive success},
