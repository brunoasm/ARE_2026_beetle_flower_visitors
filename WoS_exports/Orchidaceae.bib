@article{ WOS:A1979HH83300022,
Author = {DAFNI, A and IVRI, Y},
Title = {POLLINATION ECOLOGY OF, AND HYBRIDIZATION BETWEEN, ORCHIS-CORIOPHORA L
   AND ORCHIS-COLLINA SOL EX RUSS (ORCHIDACEAE) IN ISRAEL},
Journal = {NEW PHYTOLOGIST},
Year = {1979},
Volume = {83},
Number = {1},
Pages = {181-187},
Abstract = {The flower of O. coriophora L. contains free nectar in the spur and is
   very fragant. It attracts a large gallery of pollinators, mainly Apis
   mellifera. The capsule production rate is .apprx. 90\%. O. collina Sol.
   ex Russ. has empty spurs and is scentless. Pollinators are scarce and
   capsule production rate is .apprx. 25\%. The species are sympatric in
   some habitats in Israel and create rare hybrids which seem to be the
   result of common pollinators. Each of the 2 spp. apparently represents
   different pollination strategy in the genus. This view and the
   implications on self and cross pollination are discussed.},
