@article{ WOS:000340876900003,
Author = {Hu, Ai-Qun and Hsu, Tian-Chuan and Liu, Yan},
Title = {<i>Gastrodia damingshanensis</i> (Orchidaceae: Epidendroideae): a new
   myco-heterotrophic orchid from China},
Journal = {PHYTOTAXA},
Year = {2014},
Volume = {175},
Number = {5},
Pages = {256-262},
Month = {AUG 15},
Abstract = {A new fully myco-heterotrophic orchid, Gastrodia damingshanensis, is
   described and illustrated from Damingshan National Nature Reserve in
   Guangxi, China. The new species is significantly distinct from the
   otherwise similar G. uraiensis and G. fontinalis by its much longer
   peduncle, the shortened column hidden by the lip, and the reddish brown,
   rhombic-elliptic lip with a slightly retuse apex. This new species is
   predicted to be obligatory self-pollinated due to the specialized column
   structure which allows the pollinia directly touching the stigma.},
