@article{ WOS:A1977EN00400003,
Author = {ACKERMAN, JD},
Title = {BIOSYSTEMATICS OF GENUS PIPERIA-RYDB (ORCHIDACEAE)},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1977},
Volume = {75},
Number = {3},
Pages = {245-270},
Abstract = {Piperia is a North American segregate of Habenaria consisting of 5 taxa
   {[}P. unalascemsis, P. transversa, P. elongata ssp. elongata, P.
   elongata and P. elegans]. The genus is defined and differentiated from
   other North American genera of the Habenaria alliance by its morphology
   and pollination mechanism. All taxa have n = 21 chromosomes. TLC of
   fresh leaf extracts and a morphological assessment revealed discrete,
   but variable, taxa. All species are partially interfertile. A high
   degree of sympatry suggests these species are reproductively isolated.
   One new combination is proposed: P. elongata ssp. michaelii (H. michaeli
   Greene).},
