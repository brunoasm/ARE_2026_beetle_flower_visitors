@article{ WOS:A1983QN06700009,
Author = {YASUGI, S},
Title = {OVULE AND EMBRYO DEVELOPMENT IN DORITIS-PULCHERRIMA (ORCHIDACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1983},
Volume = {70},
Number = {4},
Pages = {555-560},
Abstract = {The placental ridge began to proliferate 10 days after pollination.
   Megaspore mother cell underwent meiosis to form 2 dyads at 1st division.
   At 50 days, 2 megaspores and a generating dyad were formed by 2nd
   division. The functional megaspore divided successively 3 times to form
   an 8-nucleate embryo sac at 60 days. Double fertilization occurred
   forming the zygote and endosperm initial cell. The endosperm initial
   cell degenerated soon thereafter. The zygote divided to form a terminal
   cell, the middle cell and a suspensor initial cell at 70 days. The
   terminal and middle cells successively divided to form a multi-celled
   embryo up to 120 days after pollination. Histochemical study showed that
   the stainability of DNA, RNA and total proteins was almost constant
   during ovule and embryo development. The stainability of total
   carbohydrates decreased.},
