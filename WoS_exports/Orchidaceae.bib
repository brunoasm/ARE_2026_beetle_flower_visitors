@article{ WOS:A1981LG69400008,
Author = {DAFNI, A and IVRI, Y and BRANTJES, NBM},
Title = {POLLINATION OF SERAPIAS-VOMERACEA BRIQ (ORCHIDACEAE) BY IMITATION OF
   HOLES FOR SLEEPING SOLITARY MALE BEES (HYMENOPTERA)},
Journal = {ACTA BOTANICA NEERLANDICA},
Year = {1981},
Volume = {30},
Number = {1-2},
Pages = {69-73},
Abstract = {In 2 locations in Israel, bees were found to be sleeping in flowers of
   S. vomeracea Briq. Of these bees, Prosopis spp. and Ceratina spp. were
   too small to be pollinators, whereas Eucera spp., Andreana spp., Osmia
   spp. and Tetralonia spp., mostly males, pollinated. Pollination occurs
   when in the afternoon hours the bees waver from flower to flower. The
   bees finally come to rest on a particular flower and remain there for
   the duration of the night. In the morning, the bees which slept in the
   flowers, are warmed up as a result of solar radiation which heats the
   flowers to 3.degree. C above ambient temperature. Since the males of
   many Hymenoptera sleep in holes, the hypothesis is that the flowers
   mimic such holes. The shortness of the flower tube can be held
   responsible for the observed frequent changes from flower to flower,
   which is so important for pollination efficiency.},
