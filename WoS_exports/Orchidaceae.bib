@article{ WOS:000388741500007,
Author = {Martel, Carlos and Collantes, Benjamin and Maire, Anne-Laure and
   Thoerle, Lisa},
Title = {<i>Andinia wayqechensis</i> (Orchidaceae), a new species from southern
   Peru},
