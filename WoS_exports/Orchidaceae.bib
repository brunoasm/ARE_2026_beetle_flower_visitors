@article{ WOS:000381601300010,
Author = {Akbulut, Mustafa Kemal and Seker, Senay Sungu and Senel, Gulcan and
   Akcin, Oznur Ergen},
Title = {A comparative study based on labellum color analysis of certain
   <i>Ophrys</i> (Orchidaceae) species in Turkey},
Journal = {RENDICONTI LINCEI-SCIENZE FISICHE E NATURALI},
Year = {2016},
Volume = {27},
Number = {3},
Pages = {501-507},
Month = {SEP},
Abstract = {The method of color analysis is practicable in many other areas in
   addition to the agricultural area. Color spectrophotometer, which is
   used for color analyzing, is an easy use method yielding results
   rapidly. Freshness of vegetables, purity and quality of seeds can be
   determined rapidly with the help of color analysis in today's
   technology. In our study, three species of the genus Ophrys
   (Orchidaceae) were compared by conducting three-dimensional color
   analyses on their speculum taking place on their labellum and it was
   found that significant differences exist between the species.
   Furthermore, colors of the species in the morphological observations
   were recorded and compared with the results from the color analysis.
   Although there is no significant difference between the species with
   respect to L{*}, highly difference were found with respect to a{*},
   b{*}, C{*} and H{*} values.},
