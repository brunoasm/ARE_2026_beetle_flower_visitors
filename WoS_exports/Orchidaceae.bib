@article{ WOS:A1981LZ49500001,
Author = {DAFNI, A and IVRI, Y},
Title = {THE FLOWER BIOLOGY OF CEPHALANTHERA-LONGIFOLIA (ORCHIDACEAE) - POLLEN
   IMITATION AND FACULTATIVE FLORAL MIMICRY},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1981},
Volume = {137},
Number = {4},
Pages = {229-240},
Abstract = {Solitary bees (Halictus sp.) are the effective pollinators of C.
   longifolia. In the same foraging flight the bees also visit flowers of
   Cistus salviifolius which has a similar color pattern. Cephalanthera
   offers no reward to its pollinators, but orange papillae on its labellum
   successfully imitate pollen of Cistus. As Cephalanthera also attracts
   pollinators in the absence of Cistus, this is regarded as facultative
   floral mimicry.},
