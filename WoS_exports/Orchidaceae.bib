@article{ WOS:A1988M683100002,
Author = {BURNSBALOGH, P and BERNHARDT, P},
Title = {FLORAL EVOLUTION AND PHYLOGENY IN THE TRIBE THELYMITREAE (ORCHIDACEAE,
   NEOTTIOIDEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1988},
Volume = {159},
Number = {1-2},
Pages = {19-47},
Abstract = {The Australian orchid tribe Thelymitreae, composed of Calochilus,
   Epiblema, and Thelymitra, is unique in the Orchidaceae because of the
   presence of a mitra or staminodal complex. Evidence from floral
   structure suggests that Epiblema and Thelymitra are sister genera and
   that Calochilus is derived from a Thelymitra ancestor. A ``Gene Pool
   Vortex{''} model and a hypothetical phylogeny illustrate that
   introgressive hybridization, allopatry, and long distance dispersal have
   played a major role in  the evolution of the tribe. Pollination and
   hybridization in the tribe are discussed in major emphasis on floral
   mimicry.},
