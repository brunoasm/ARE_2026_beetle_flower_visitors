@article{ WOS:A1980JT05900009,
Author = {JANZEN, DH and DEVRIES, P and GLADSTONE, DE and HIGGINS, ML and
   LEWINSOHN, TM},
Title = {SELF-POLLINATION AND CROSS-POLLINATION OF ENCYCLIA-CORDIGERA
   (ORCHIDACEAE) IN SANTA-ROSA-NATIONAL-PARK, COSTA-RICA},
Journal = {BIOTROPICA},
Year = {1980},
Volume = {12},
Number = {1},
Pages = {72-74},
Abstract = {The epiphytic deciduous forest orchid E. cordigera was manually
   self-pollinated, out-crossed against one other parent, and out-crossed
   against a maximum number of other parents in Santa Rosa National Park,
   Costa Rica. There was no difference in the percent inflorescences that
   set fruit between selfed and single-parent out-crossed plants, and on
   the inflorescences that set fruit there was no difference in the percent
   flowers that bore fruit (85-92\% for 119 and 82 flowers). Only 5\% of
   the multiple-fathered inflorescences failed to set some fruit, and 97\%
   of the flowers set fruit; these values are significantly different from
   those for the selfed plants and flowers. The overall percent of
   inflorescences that bore fruit and the percent flowers that bore fruit
   was very much greater on the hand-pollinated plants than on the
   unmanipulated ones growing only a few meters away. Fruit set by E.
   cordigera may be pollinator-limited, but other interpretations are
   given.},
