   Hokkaido Univ, Grad Sch Environm Earth Sci, Sapporo, Hokkaido 0600810, Japan.},
DOI = {10.1007/s00606-005-0391-8},
ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {ant pollination; metapleural glands; orchid; Orchidaceae; Epipactis;
   Camponotus},
