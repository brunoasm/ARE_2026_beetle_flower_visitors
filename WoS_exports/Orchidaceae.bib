ISSN = {0378-2697},
EISSN = {2199-6881},
Keywords = {Dactylorhiza incarnata s.l.; deceptive pollination; early marsh orchid;
   flower colour; in situ germination; hand-pollination; pollinia transfer;
   seed set},
