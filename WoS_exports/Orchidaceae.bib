@article{ WOS:000175345600002,
Author = {Bowles, ML and Jacobs, KA and Zettler, LW and Delaney, TW},
Title = {Crossing effects on seed viability and experimental germination of the
   federal threatened <i>Platanthera leucophaea</i> (Orchidaceae)},
Journal = {RHODORA},
Year = {2002},
Volume = {104},
Number = {917},
Pages = {14-30},
Month = {WIN},
Abstract = {We conducted experimental pollination and seed germination trials with
   Platanthera leucophaea, a threatened north temperate grassland orchid
   species for which propagation and restoration are important conservation
   needs. Our objectives were to determine how the species' breeding system
   and modes of pollination interact to affect production of viable seed
   and seed germination, and how seed germination responds to
   stratification and to inoculation by mycorrhizal fungi. Outcrossing by
   hand pollination produced a higher percentage of viable seed than did
   natural pollination, as did outcrossing between populations in
   comparison to outcrossing or selfing within populations. indicating a
   facultative outcrossing breeding system. Outcrossing also enhanced
   percent germination, which was positively correlated with the
   percentage, but not number, of viable seeds. A 16 wk. stratification
   period resulted in significantly higher percent germination than 8 wk.
   stratification or no stratification. Germination was further enhanced by
   inoculation with a mycorrhizal fungus (Ceratorhiza sp.) isolated from P,
   leucophaea. These results indicate that the breeding system of P.
   leucophaea allows for greater numbers of viable seeds with greater
   germination rates when plants are outcrossed. Thus, hand pollination and
   outcrossing can enhance propagation and restoration efforts. especially
   when coupled with scarification and stratification treatments that
   maximize germination rates.},
Publisher = {NEW ENGLAND BOTANICAL CLUB INC},
Address = {P.O. BOX 368, LAWRENCE, KS 66044 USA},
Type = {Article},
Language = {English},
Affiliation = {Bowles, ML (Corresponding Author), Morton Arboretum, 4100 Illinois ROute 53, Lisle, IL 60532 USA.
   Morton Arboretum, Lisle, IL 60532 USA.},
ISSN = {0035-4902},
Keywords = {Orchidaceae; Platanthera; seed germination; breeding system;
   pollination; conservation},
Keywords-Plus = {INBREEDING DEPRESSION; POPULATIONS},
