Title = {THE POLLINATION ECOLOGY OF ORCHIS-GALILAEA (BORNM ET SCHULZE) SCHLTR
   (ORCHIDACEAE)},
Journal = {NEW PHYTOLOGIST},
Year = {1982},
Volume = {90},
Number = {2},
Pages = {315-319},
Abstract = {The flower of O. galilaea (Bornm. et Schulze) Schltr. does not contain
   nectar. Only the males of Halictus marginatus are attracted and
   pollinate the orchid; females visit the flowers of other plant families.
   Evidently, O. galilaea evolved a pollination mechanism based on a sexual
   attraction specific for the males of H. marginatus. This sexual
   attraction is the result of the strong, musk-like scent.},
