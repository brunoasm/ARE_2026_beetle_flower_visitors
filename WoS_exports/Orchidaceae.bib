@article{ WOS:000290413000069,
Author = {Anthony, J. M. and Phillips, R. D. and Sinclair, E. A. and Dixon, K. W.},
Title = {Characterisation of polymorphic microsatellite markers isolated from
   <i>Drakaea glyptodon</i> Fitz. (Orchidaceae)},
Journal = {CONSERVATION GENETICS RESOURCES},
Year = {2010},
Volume = {2},
Number = {1},
Pages = {291-294},
Month = {SEP},
Abstract = {Drakaea glyptodon is a sexually deceptive terrestrial orchid endemic to
   Western Australia. We developed fourteen polymorphic microsatellite
   markers to assess genetic variability within and among populations.
   Moderate to high levels of variation were detected at most loci. There
   was evidence for inbreeding with high inbreeding coefficients for some
   loci. This suite of markers will be used to assess population genetics
   and investigate the causes of rarity and speciation of Drakaea.},
