@article{ WOS:A1985AJS5600002,
Author = {DAVENPORT, D and LEE, H},
Title = {IMAGE-ANALYSIS IN THE ORCHIDACEAE},
Journal = {JOURNAL OF THEORETICAL BIOLOGY},
Year = {1985},
Volume = {114},
Number = {2},
Pages = {199-222},
Abstract = {In orchids a number of variants of specific parameters of the floral
   image apparently arose from a common ancestral type and became
   established as genetically constant in the determination of subgeneric
   taxa. At present little is known of the genetic basis for their origin
   or establishment. It is not known at present whether perception and
   storage of a complex floral pattern play a role in the determination of
   flower constancy in pollinators (and thus in the genetic isolation of
   variants); as a step toward gaining the ability to test the hypothesis
   that they do, a method is presented for the comparative quantification
   of specific characteristics of floral images, which must bear some
   relation to the level of sophistication necessary in a processor if
   visual recognition is to be effected. A number of parameters in the
   images of orchid flowers were so analyzed. The relation of these results
   to the possibility that the evolution of these images was effected by
   visually mediated natural selection is discussed.},
