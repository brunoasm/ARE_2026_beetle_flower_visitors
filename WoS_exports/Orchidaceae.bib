Address = {OHIO STATE UNIV-DEPT BOTANY 1735 NEIL AVE, COLUMBUS, OH 43210 USA},
Type = {Article},
Language = {English},
Affiliation = {Johnson, SD (Corresponding Author), Univ Natal, Dept Bot, Private Bag X01, ZA-3209 Pietermartizburg, South Africa.
