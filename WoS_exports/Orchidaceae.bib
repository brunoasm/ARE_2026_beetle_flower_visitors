@article{ WOS:000504820000047,
Author = {Qin, Guole and Yua, Quan and Xie, Daizu and Shi, Chenyu},
Title = {Effective Pollinators by Chinese Honeybee and Bumblebee in
   <i>Paphiopedilum malipoense</i>},
Journal = {INTERNATIONAL JOURNAL OF AGRICULTURE AND BIOLOGY},
Year = {2019},
Volume = {22},
Number = {6},
Pages = {1607-1612},
Abstract = {The population distribution and pollination biological characteristics
   of Paphiopedilum malipoense in the Mulun karst forest region were
   studied by recording insect flower visitations, identifying powdered
   species, observing flower morphology and recording flowering plants. The
   primary goal was to reveal the pollen transmission mechanism and
   evolution of P. malipoense, and to provide a basis for protecting P.
   malipoense in the Mulun National Nature Reserve in Guangxi, China. The
   results showed that Chinese bees and bumblebees were effective
   pollinators of P. malipoense, and it was speculated that Paphiopedilum
   might attract Chinese bee and bumblebee to transmit pollen through the
   small purple spots that serves as false honey guides on their lips. It
   is suggested that bees use a food-borne deceptive transmission with a
   success rate of 33.3\%. These results of may provide basic data for the
   formulation of conservation measures of this species in Mulun National
   Nature Reserve of Guangxi. (C) 2019 Friends Science Publishers},
