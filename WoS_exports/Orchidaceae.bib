@article{ WOS:000293158200001,
Author = {Wang, R. X. and Song, X. Q. and He, M. G. and Song, S. Q.},
Title = {Developmental changes of cryo-tolerance associated with stored reserve
   accumulation of <i>Doritis pulcherrima</i> (Orchidaceae) seeds},
Journal = {SEED SCIENCE AND TECHNOLOGY},
Year = {2011},
Volume = {39},
Number = {2},
Pages = {271-281},
Abstract = {Self- and cross-pollinated seeds of Doritis pulcherrima at different
   development stages were used to investigate the changes in seed
   germinability and cryo-tolerance, and the relationship between
   cryo-tolerance and stored reserve accumulation. Self- and
   cross-pollinated seeds gained partial germinability at 45 days after
   pollination (DAP), reaching 91.3 and 91.6\% germination respectively at
   135 DAP. Self- and cross-pollinated seeds started to gain cryo-tolerance
   at 90 DAP, which increased with seed development. Pretreatment with
   plant vitrification solution 2 (PVS2) markedly increased the tolerance
   of self- and cross-pollinated seeds harvested at 45 to 135 DAP to
   subsequent cryopreservation, and the cryo-tolerance was
   pretreatment-time-dependant. A little carbohydrate occurred in the
   embryo at different development stages, while lipids and proteins
   significantly increased from 60 to 120 DAP. These results suggest that
   the cryo-tolerance of D. pulcherrima seeds was related to an increasing
   accumulation of lipids and proteins in the embryo.},
