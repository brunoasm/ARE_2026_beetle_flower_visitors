   Univ Natal, Sch Bot \& Zool, ZA-3209 Scottsville, South Africa.},
DOI = {10.1007/BF00984105},
ISSN = {0378-2697},
Keywords = {Orchidaceae; geitonogamy; gene flow; pollen; pollen discounting; pollen
   : ovule ratio; pollinaria; pollination; pollinium; seed size;
   self-incompatibility},
Keywords-Plus = {REPRODUCTIVE SUCCESS; DISEASE ORCHIDOIDEAE; GENETIC CONSEQUENCES; POLLEN
