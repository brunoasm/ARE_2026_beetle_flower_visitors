   Univ Estadual Campinas, Dept Genet \& Evolucao, Inst Biol, BR-13083970 Campinas, SP, Brazil.},
DOI = {10.2307/2657106},
ISSN = {0002-9122},
Keywords = {isozymes; generic variability; Orchidaceae; Pleurothallis; population
   genetics},
Keywords-Plus = {STARCH-GEL ELECTROPHORESIS; ENZYME ELECTROPHORESIS; ALLOZYME VARIATION;
