@article{ WOS:A1981LZ49500002,
Author = {PAULUS, HF and GACK, C},
Title = {NEW OBSERVATIONS OF POLLINATION IN OPHRYS (ORCHIDACEAE) IN SOUTHERN
   SPAIN, WITH SPECIAL REFERENCE TO THE GROUP OF OPHRYS-FUSCA AGG},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1981},
Volume = {137},
Number = {4},
Pages = {241-258},
Abstract = {An investigation of pseudocopulation behavior in species of Ophrys from
   southern Spain confirms the close relationship between Campsoscolia
   ciliata (Scoliidae) and O. speculum, and between Eucera nigrilabris
   (Apoidea) and O. tenthredinifera. It was demonstrated that E.
   barbiventris is the pollinator of O. scolopax ssp. scolopax, whereas
   other species of Eucera and Tetralonia which are active at the same time
   show no interest at all for the flowers of this species. Special
   attention was paid to the forms of the taxonomically confused O. fusca
   group: O. fusca s. s., O. iricolor, O. omegaifera and O. atlantica.
   While O. fusca s. s. is widespread, small-flowered and has late
   anthesis, O. iricolor has very large flowers and early anthesis. Each of
   the 4 members of O. fusca agg. in southern Spain is pollinated by a
   different bee and selective experiments show that each of these 4 spp.
   of bees is specifically attracted only to 1 of the Ophrys spp. Andrena
   flavipes is the pollinator of O. fusca s.s., Colletes cunicularius
   infuscatus of O. iricolor, Anthphora atroalba of O. omegaifera and
   Chalicodoma parietina of O. atlantica. These 4 pollinators belong to 4
   different bee families (Andrenidae, Colletidae, Anthrophoridae,
   Megachilidae). As this type of pollination represents an effective
   pregamic isolation mechanism, these 4 taxa of O. fusca agg., at least in
   southern Spain, should be regarded as genuine species.},
