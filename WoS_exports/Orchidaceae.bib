@article{ WOS:000448976000007,
Author = {Zanotti, Christian A. and Radins, Jose A. and Keller, Hector A.},
Title = {Two new records of <i>Habenaria</i> (Orchidaceae) for the Argentinian
   flora},
Journal = {BOLETIN DE LA SOCIEDAD ARGENTINA DE BOTANICA},
Year = {2018},
Volume = {53},
Number = {3},
Pages = {435-442},
Month = {SEP},
Abstract = {Habenaria johannensis and H. josephensis, species known up to now with
   the distribution limit in southern Brazil, are cited for the first time
   for northeastern Argentina. A brief description of the species,
   geographical distribution, ecological observations, field photographs, a
   map with the distribution of the two new records in Argentina, as well
   as a key to differentiate the species present in northeastern of
