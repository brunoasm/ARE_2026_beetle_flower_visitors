Language = {English},
Affiliation = {Norwegian Univ Sci \& Technol, Dept Biol, NO-7491 Trondheim, Norway.
   Uppsala Univ, Dept Systemat Bot, Evolutionary Biol Ctr, SE-75236 Uppsala, Sweden.
   Uppsala Univ, Dept Plant Ecol, Evolutionary Biol Ctr, SE-75236 Uppsala, Sweden.},
DOI = {10.1111/j.1095-8312.2004.00406.x},
ISSN = {0024-4066},
EISSN = {1095-8312},
Keywords = {adaptive peak shift; cladogenesis; evolution; female fitness; floral
   morphology; male fitness; moth-pollination; orchids; sexual interference},
Keywords-Plus = {ADAPTIVE PEAK SHIFTS; PHENOTYPIC SELECTION; MOTH POLLINATION; EVOLUTION;
   POLLEN; PLANT; BIFOLIA; ADAPTATION; MORPHOLOGY; PHYLOGENY},
