@article{ WOS:001085483800001,
Author = {Cardoso, J. C. F. and Johnson, S. D. and Oliveira, P. E.},
Title = {Incomplete resupination during floral development leads to pollination
   failure in a slipper orchid},
Journal = {PLANT BIOLOGY},
Year = {2024},
Volume = {26},
Number = {1},
Pages = {34-40},
Month = {JAN},
Abstract = {center dot In many families, plants undergo floral resupination by
   twisting through approximately 180 degrees during floral development so
   that the flower is effectively positioned upside down. In most orchids,
   resupination results in the median petal (i.e., the label-lum) becoming
   lowermost, which plays a crucial role in pollination by serving as a
   landing platform or as a trapping device, or both. Incomplete
   resupination is predictedto lead to reduced pollination, although tests
   of this assumption are still lacking.center dot We investigated the
   effect of resupination using Phragmipedium vittatum, a rare lady's
   slipper orchid whose specialized labellum forms a trapping device.
   First, we surveyed the natural occurrence of incomplete resupination.
   Then we manipulated flowers into non- (0 degrees), half- (90 degrees),
   and fully resupinate (180 degrees) positions to test the effect of
   orientation on pollen smear removal and deposition by pollinators
   (female hoverflies).center dot We found thatca.10\% of flowers in the
   natural population were not fully resupinate, being either non- (upward,
   0-60 degrees) or half-resupinate (sideward, 60-120 degrees). The change
   in orientation prevented the effectiveness of pollination by hoverflies
   since no pollens mear removal or deposition were found in flowers from
   non- and half-resupinate treatments. Although these flowers still
   attracted hoverflies, they were not trapped effectively.center dot As
   this orchid is incapable of autonomous self-pollination, flowers that do
   not resupinate fail to set fruits. These results highlight the
   importance of correct floral orientation provided by resupination to
   ensure pollination in orchids and other resupinate flowers.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Cardoso, JCF (Corresponding Author), Univ Fed Uberlandia, Inst Biol, Uberlandia, MG, Brazil.
   Cardoso, J. C. F.; Oliveira, P. E., Univ Fed Uberlandia, Inst Biol, Uberlandia, MG, Brazil.
   Cardoso, J. C. F., Univ Fed Ouro Preto, Dept Biodiversidade Evolucao \& Meio Ambiente, Ouro Preto, MG, Brazil.
   Johnson, S. D., Univ KwaZulu Natal, Ctr Funct Biodivers, Sch Life Sci, Pietermaritzburg, South Africa.},
