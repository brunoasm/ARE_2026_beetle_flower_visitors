@article{ WOS:A1982NJ51900002,
Author = {GANDAWIDJAJA, D and ARDITTI, J},
Title = {POST-POLLINATION PHENOMENA IN ORCHID FLOWERS .11. AUTOGAMY IN
   PHAJUS-TANKERVILLIAE (AITON) BL, ORCHIDACEAE},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1982},
Volume = {69},
Number = {3},
Pages = {335-338},
Abstract = {In autogamous blossoms of P. tankervilliae, which do not open fully, the
   pollen drops into the stigma while flowers are still in the bud stage or
   as the perianth segments separate lightly. Post-pollination phenomena
   exhibited by autogamous flowers do not differ from those of allogamous
   ones. The naturalization of P. tankervillia in areas to which it was
   brought as a horticultural plant may be due to the introduction of
   autogamous forms.},
