   Macphail, Michael K., Australian Natl Univ, Coll Asia \& Pacific, Dept Archaeol \& Nat Hist, Canberra, ACT 0200, Australia.
   Hill, Robert S., Univ Adelaide, Sch Biol Sci, Adelaide, SA 50005, Australia.
   Hill, Robert S., Univ Adelaide, Inst Environm, Adelaide, SA 50005, Australia.},
DOI = {10.1071/BT18143},
