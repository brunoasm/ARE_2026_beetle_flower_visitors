   Renner, Susanne S., Univ Munich, Dept Biol, D-80638 Munich, Germany.},
DOI = {10.1086/523953},
ISSN = {0003-0147},
EISSN = {1537-5323},
Keywords = {abiotic selection; Davidia involucrata; inflorescence architecture;
   pollinator attraction; pollen viability; pollen protection},
Keywords-Plus = {EVOLUTION; SELECTION; FORM},
Research-Areas = {Environmental Sciences \& Ecology; Evolutionary Biology},
