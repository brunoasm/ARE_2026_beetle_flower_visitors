   Turku Univ, Aerobiol Unit, Dept Biol, FI-20014 Turku, Finland.},
DOI = {10.1080/00173139809362681},
ISSN = {0017-3134},
Keywords-Plus = {BET-V-I; ALN G-I; CRYPTOMERIA-JAPONICA POLLEN; MAJOR ALLERGENS;
