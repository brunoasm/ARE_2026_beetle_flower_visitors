Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {UNIV GOTHENBURG, DEPT SYSTEMAT BOT, CARL SKOTTSBERGS GATA 22, S-41319 GOTHENBURG, SWEDEN.},
DOI = {10.2307/2446267},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {abortion; anemophily; Betula; Betulaceae; brood size; confocal laser
   scanning microscopy; floral longevity; pollen competition; pollen load},
Keywords-Plus = {NORTHERN SWEDEN; OVULE ABORTION; SEED DISPERSAL; POLLINATION; PLANTS;
