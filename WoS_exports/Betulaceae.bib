@inproceedings{ WOS:000357660300001,
Author = {Sathuvalli, V. R. and Mehlenbacher, S. A. and Peterschmidt, B. C. and
   Smith, D. C.},
Editor = {Beretta, PG and Ellena, M},
Title = {Genomic Tools Enhance Power and Precision of Hazelnut Breeding},
Booktitle = {VIII INTERNATIONAL CONGRESS ON HAZELNUT},
Series = {Acta Horticulturae},
Year = {2014},
Volume = {1052},
Pages = {23-25},
Note = {8th International Congress on Hazelnut, Temuco, CHILE, MAR 19-22, 2012},
Organization = {Int Soc Horticultural Sci},
Abstract = {European hazelnut (Corylus avellana L.) is the only economically
   important nut crop in the family Betulaceae. Because of its small genome
   size (similar to 385 Mb/1C), relatively short life cycle, availability
   of a dense linkage map, and amenability to transformation by
   Agrobacterium, the European hazelnut could serve as a model plant for
   the Betulaceae. Genomic resources are being developed and used in the
   hazelnut breeding program at Oregon State University (OSU) to develop
   new cultivars that combine suitability to the blanched kernel market
   with resistance to eastern filbert blight (EFB) caused by the ascomycete
   Anisogramma anomala (Peck) E. Muller. Genetic resistance to EFB was
   first identified in the obsolete pollinizer `Gasaway', and most advanced
   selections carry this resistance. In order to better understand the
   mechanism of resistance, map-based cloning of the `Gasaway' resistance
   gene was initiated by constructing a bacterial artificial chromosome
   (BAC) library for `Jefferson', which is heterozygous for resistance. A
   high-resolution genetic map of the resistance region was created with 51
   markers and the resistance phenotype in a mapping population of 1488
   seedlings. In parallel, a physical map was constructed. The BACs in this
   region were sequenced using Illumina technology and the resistance
   region was identified as a single contig of three overlapping BACs. Ab
   initio gene annotation of the sequence information revealed five
   candidate genes, two of which are reported to have disease resistance
   properties. Additionally, 150 new SSRs were developed from mining the
   transcriptome sequences. Future studies will focus on the S-locus which
   controls sporophytic incompatibility and gene expression in styles after
   pollination.},
Publisher = {INT SOC HORTICULTURAL SCIENCE},
Address = {PO BOX 500, 3001 LEUVEN 1, BELGIUM},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Sathuvalli, VR (Corresponding Author), Oregon State Univ, Dept Hort, 4017 Agr \& Life Sci Bldg, Corvallis, OR 97331 USA.
   Sathuvalli, V. R.; Mehlenbacher, S. A.; Peterschmidt, B. C.; Smith, D. C., Oregon State Univ, Dept Hort, Corvallis, OR 97331 USA.},
