ISSN = {1081-1206},
Keywords-Plus = {AMBROSIA-ARTEMISIIFOLIA L.; AIRBORNE POLLEN; ALLERGIC RHINITIS;
   NEW-JERSEY; CALIFORNIA; COUNTS; CITY; EPIDEMIOLOGY; ASTHMA; FUNGI},
