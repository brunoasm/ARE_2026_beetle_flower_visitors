Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Review},
Language = {English},
Affiliation = {Williams, JH (Corresponding Author), Univ Tennessee, Dept Ecol \& Evolutionary Biol, Knoxville, TN 37996 USA.
   Univ Tennessee, Dept Ecol \& Evolutionary Biol, Knoxville, TN 37996 USA.},
DOI = {10.3732/ajb.0800070},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Amborella; callose plug; carpel; double fertilization; evolution of
   development; heterochrony; novelty; origin of angiosperms; pollen tube
