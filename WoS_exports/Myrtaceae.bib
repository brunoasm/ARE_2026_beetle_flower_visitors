Language = {English},
Affiliation = {Mie Univ, Fac Bioresources, Entomol Lab, Tsu, Mie 5148507, Japan.
   Mie Univ, Fac Bioresources, Entomol Lab, Tsu, Mie 5148507, Japan.
   Kyoto Univ, Fac Agr, Lab Trop Agr, Kyoto 6068502, Japan.},
