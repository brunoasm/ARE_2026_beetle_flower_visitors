Title = {Ornamental Eucalypts: From an Idea to a Commercial Reality},
Booktitle = {VIII INTERNATIONAL SYMPOSIUM ON NEW ORNAMENTAL CROPS AND XII
   INTERNATIONAL PROTEA RESEARCH SYMPOSIUM},
Series = {Acta Horticulturae},
Year = {2015},
