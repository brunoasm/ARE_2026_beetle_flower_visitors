Type = {Proceedings Paper},
Language = {English},
Affiliation = {Pommer, CV (Corresponding Author), UFERSA Univ Fed Rural Semiarido, Dept Ciencias Vegetais Fitotecnia, Mossoro, RN, Brazil.
