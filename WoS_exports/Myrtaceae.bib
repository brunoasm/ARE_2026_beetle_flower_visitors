@article{ WOS:000076355900015,
Author = {Oddie, RLA and McComb, JA},
Title = {Stigma receptivity in Eucalyptus camalduleasis Dehnh.},
Journal = {SILVAE GENETICA},
Year = {1998},
Volume = {47},
Number = {2-3},
Pages = {142-146},
Abstract = {Stigma receptivity of Eucalyptus camaldulensis DEHNH. grown near Perth,
   Western Australia, was assessed by seed production. Pollination three
   days after emasculation, when styles had just turned red and stigmas
   were enlarged, yellow and sticky gave maximum seed set (45 to 55 seeds
   per capsule and 95\% to 100\% capsule set). Reasonably high levels of
   seed (> 25 seed per capsule and > 65\% capsule set) could also be
   produced when flowers were pollinated at the time of emasculation. The
   period of stigma receptivity varied between cultivars. Capsules matured
   14 to 16 weeks after pollination.},
