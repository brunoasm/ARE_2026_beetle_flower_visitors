   Univ Lisbon, Fac Ciencias, Ctr Biotecnol Vegetal, PT-1749016 Lisbon, Portugal.},
DOI = {10.1006/anbo.2000.1359},
ISSN = {0305-7364},
Keywords = {Eucalyptus globulus; one-step pollination; lipids; pollen; fertilization},
