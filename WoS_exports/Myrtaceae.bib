@article{ WOS:000547696600001,
Author = {Smith, Melissa C. and Wright, Susan A. and Brown, Bradley and Purcell,
   Matthew and Pratt, Paul D. and Clark, Philip and Lollis, James A.},
Title = {Fundamental host range of<i>Lophodiplosis indentata</i>(Diptera:
   Cecidomyiidae), the last proposed biological control agent
   for<i>Melaleuca quinquenervia</i>(Myrtaceae) in Florida},
Journal = {BIOCONTROL SCIENCE AND TECHNOLOGY},
Year = {2020},
Volume = {30},
Number = {10},
Pages = {1073-1082},
Month = {OCT 2},
Abstract = {Melaleuca quinquenervia(hereafter melaleuca) was until recently one of
   the worst ecological invaders in Florida. Introduced for horticulture
   and levee stabilisation during the early twentieth century, melaleuca
   spread to cover vast areas of the largest freshwater wetlands ecosystem
   in North America, The Everglades. From 1997 until 2008, four insects and
   an associated nematode were approved and released for control of
   melaleuca, three of which are known to have established. Biological
   control is frequently a slow and incremental process, but with the
   integration of complimentary control methods (e.g. chemical and
   mechanical removal), melaleuca infestations are a fraction of their
   former range. These few persistent infestations are facilitated by
   conditions that prevent one species,Oxyops vitiosa,the melaleuca snout
   weevil, from completing its life cycle, which prompted the testing of
   and application to releaseLophodiplosis indentata(Diptera:
   Cecidomyiidae). This leaf gall forming midge feeds within pea-shaped
   growths distributed throughout the canopy. No-choice host range tests
   suggest thatL. indentatawill occasionally oviposit on unsuitable host
   plants, but gall induction and formation is only accomplished onM.
   quinquenervia.A petition for the release ofL. indentatawas recommended
   by TAG in May 2020. {[}word count: 181]},
