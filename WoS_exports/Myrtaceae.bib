   Murdoch Univ, Sch Environm Sci, Murdoch, WA 6150, Australia.
   Murdoch Univ, Sch Biol Sci \& Biotechnol, Murdoch, WA 6150, Australia.
   Trinity Coll, Sch Bot, Herbarium, Dublin, Ireland.},
DOI = {10.1007/BF01090301},
ISSN = {0378-2697},
Keywords = {Myrtaceae; Verticordia; anther structure; oil glands; pollination;
   evolutionary changes},
Keywords-Plus = {POLLEN; CHAMELAUCIUM},
Research-Areas = {Plant Sciences; Evolutionary Biology},
Web-of-Science-Categories  = {Plant Sciences; Evolutionary Biology},
