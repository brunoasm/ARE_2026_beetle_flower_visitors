@article{ WOS:000503451600001,
Author = {Singh, Sanjay and Singh, A. K. and Saroj, P. L. and Mishra, S.},
Title = {Research status for technological development of jamun (<i>Syzygium
   cumini</i>) in India: A review},
Journal = {INDIAN JOURNAL OF AGRICULTURAL SCIENCES},
Year = {2019},
Volume = {89},
Number = {12},
Pages = {1991-1998},
Month = {DEC},
Abstract = {Jamun, Syzygium cumini (L.) Skeels, belonging to the family Myrtaceae,
   is an important underexploited indigenous fruit with a wide distribution
   reflecting its adaptation to wide range of edapho-climatic conditions.
   It is an important fruit owing to its nutritional, therapeutical,
   postharvest and industrial values. In a bid for better utilization and
   improvement of the current genetic resources, there is a need to
   understand the studies on center of origin and diversity,
   characterization, conservation, taxonomy and systematic phenology,
   floral biology and pollination. In this review; basic biology of jamun
   plant, agro-techniques, propagation, canopy architecture, insect pests,
   and disease and their management have been covered.},
