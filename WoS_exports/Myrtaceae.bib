@inproceedings{ WOS:000467945500120,
Author = {Griffis, Jr., J. L. and McDonald, T. G. and Manners, M. M. and Tuncay,
   O.},
Editor = {Drew, R},
Title = {Advances in the purple-fruited pitanga (<i>Eugenia uniflora</i>)
   long-term breeding program in Hawai'I, USA},
