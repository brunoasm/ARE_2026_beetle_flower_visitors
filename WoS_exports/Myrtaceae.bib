   Tng, D. Y. P.; Bowman, D. M. J. S., Univ Tasmania, Sch Plant Sci, Hobart, Tas 7001, Australia.
   Hopf, F.; Haberle, S. G., Australian Natl Univ, Coll Asia \& Pacific, Canberra, ACT 0200, Australia.},
DOI = {10.1071/BT10095},
ISSN = {0067-1924},
