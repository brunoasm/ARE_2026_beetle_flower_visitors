@article{ WOS:000304153100009,
Author = {Dattilo, Wesley and Martins, Rodrigo L. and Uhde, Vera and Noronha,
   Janaina C. and Florencio, Fernando P. and Izzo, Thiago J.},
Title = {Floral resource partitioning by ants and bees in a jambolan <i>Syzygium
   jambolanum</i> (Myrtaceae) agroforestry system in Brazilian Meridional
   Amazon},
Journal = {AGROFORESTRY SYSTEMS},
Year = {2012},
Volume = {85},
Number = {1, SI},
Pages = {105-111},
Month = {MAY},
Abstract = {The fruit production of flowering plants critically depends on the
   pollination services provided by animals that compete for flower
   resources. The output of competitive interactions between ants and bees
   for inflorescences of jambolan (Myrtaceae) in an agroforestry system in
   Brazilian Meridional Amazonian are an interesting system of
   investigation due the possibility to control variables experimentally.
   In 20 individuals we performed 300 treatments in different
   inflorescences of two strata (upper and lower) as follows: (1) ants
   exclusion, (2) bees exclusion, and (3) control group where ants and bees
   could access the inflorescences. There was no difference in the number
   of inflorescences, volume of nectar and sugar concentration between the
   strata. Also the visitors considered are distributed equally in the
   tree's stratum. When bees were prevented from access the inflorescences,
   ants dominated more inflorescences only in the lower stratum. On the
   contrary, when ants were excluded, bees visited more inflorescences only
   in the upper stratum. We conclude that ants prevent the access to bees
   and vice versa as the result of different ability of resource
   utilization and foraging strategies. Thus, preventing the access of ants
   to the floral nectar could increase the level of nectar available to
   pollinators of , thereby increasing productivity and reducing economic
   losses.},
