DOI = {10.1111/j.1095-8339.2008.00803.x},
ISSN = {0024-4074},
EISSN = {1095-8339},
Keywords = {anatomy; androecium; compitum; core eudicots; gynoecium; histology;
   morphology; ovules; perianth; rosids},
