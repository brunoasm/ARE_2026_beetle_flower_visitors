   Tagawa, Kazuki, Tottori Coll, Dept Early Childhood Educ \& Care, Kurayoshi City, Tottori, Japan.},
DOI = {10.1016/j.aspen.2018.09.006},
ISSN = {1226-8615},
EISSN = {1876-7990},
Keywords = {Antagonist; Ants; Flower; Mcnyanthaccac; Plant-Insect Interactions},
Research-Areas = {Entomology},
Web-of-Science-Categories  = {Entomology},
