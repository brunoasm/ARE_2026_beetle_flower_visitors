@article{ WOS:A19668352400005,
Author = {ORNDUFF, R},
Title = {ORIGIN OF DIOECISM FROM HETEROSTYLY IN NYMPHOIDES (MENYANTHACEAE)},
Journal = {EVOLUTION},
Year = {1966},
Volume = {20},
Number = {3},
Pages = {309+},
Abstract = {Breeding systems associated with distyly and dioecism in 5 species of
   Nymphoides are discussed. It is suggested that because of anomalies in
   incompatibility systems, pollination, and population structure,
   selection has favored the replacement of distyly by dioecism in certain
   evolutionary lines of the genus. The Eurasian N. peltata is utilized as
   an example of a species whose reproductive biology most closely
   parallels that which probably initiated the breakdown of heterostyly in
   the genus in the direction of increased outbreeding provided by the
   sexual separation of dioecism.},
