@article{ WOS:A1982PC23400013,
Author = {ORNDUFF, R},
Title = {HETEROSTYLY AND INCOMPATIBILITY IN VILLARSIA-CAPITATA (MENYANTHACEAE)},
Journal = {TAXON},
Year = {1982},
Volume = {31},
Number = {3},
Pages = {495-497},
Abstract = {V. capitata, a diploid annual of Western Australia, has distylous
   flowers. Its distyly is associated with an incompatibility system.
   Intramorph pollinations produced 0.4-0.8 seeds/pollination; intermorph
   pollinations produced 10.2 seeds/pollination in pins and 3.3 in thrums.
   About 60\% of pin ovules and 20\% of thrum ovules mature to seed
   following intermorph pollinations. These differences may result from the
   smaller size of thrum stigmas, from greater difficulty in transferring
   pollen to thrum stigmas in artificial pollinations, or from unknown
   causes. V. capitata is a highly specialized member of the genus in its
   capitate, bracteate inflorescences and its annual habit, yet it retains
   a breeding system that is primitive in the Menyanthaceae.},
