@article{ WOS:A1991GY73700024,
Author = {LARDANS, A and TREMOLIERES, A},
Title = {ACCUMULATION OF C20 AND C22 UNSATURATED FATTY-ACIDS IN TRIACYLGLYCEROLS
   FROM DEVELOPING SEEDS OF LIMNANTHES-ALBA},
Journal = {PHYTOCHEMISTRY},
Year = {1991},
Volume = {30},
Number = {12},
Pages = {3955-3961},
Abstract = {In Limnanthes alba seeds, an accumulation of phosphatidic acid (PA)
   occurred during seed development until the day 15 after pollination
   (DAP). Between the 15 and the 20 DAP, a rapid synthesis of
   triacylglycerols (TG) took place with a simultaneous decrease of PA.
   During the same period, very long-chain fatty acids (VLCFA), viz.
   20:1-DELTA-5, 22:1-DELTA-13 and 22:2-DELTA-5,13 were synthesized and
   rapidly channelled into TG. These results suggest the involvement of
   glycerol-3-phosphate in TG biosynthesis. Moreover, TG synthesis appears
   to be a time-compartmentalized event; the first accumulation of PA
   having short-chain acyl moieties then, from the 15 DAP, synthesis of
   VLCFA which are esterified in TG originating from the PA accumulated
   during the first period.},
