Keywords = {ANGIOSPERMS, GERANIALES, LIMNANTHACEAE, CARYOPHYLLACEAE, FLOERKEA,
   LIMNANTHES; FLORAL NECTARIES, SECRETORY TISSUE, STOMATA, DIPLOSTEMONY,
   POLLINATION, BEES},
