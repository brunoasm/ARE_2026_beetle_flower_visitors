Type = {Article},
Language = {English},
Affiliation = {TROPENBOS GUYANA PROGRAMME, 12E GARNETT STH, CAMBELLVILLE, GEORGETOWN, GUYANA.},
DOI = {10.1017/S0266467400010683},
ISSN = {0266-4674},
EISSN = {1469-7831},
Keywords = {Dicymbe altsonii; flower abortion; fruiting; Guyana; Leguminosae;
   litterfall; phosphorus; nutrient dynamics; seed-demography; tropical
   rainforest},
Keywords-Plus = {RAIN-FOREST; FRUIT-SET; PATTERNS; FLOWER; PLANTS; SEED; PHENOLOGY;
   ABORTION},
