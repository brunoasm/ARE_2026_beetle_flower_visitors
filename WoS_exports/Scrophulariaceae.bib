EISSN = {1537-5315},
Keywords-Plus = {TRISTYLOUS EICHHORNIA-PANICULATA; SELF-FERTILIZATION; INBREEDING
   DEPRESSION; COMPLEX SCROPHULARIACEAE; OUTCROSSING RATE; EVOLUTION;
   GUTTATUS; PLANTS; POPULATIONS; DIVERSITY},
Research-Areas = {Plant Sciences},
Web-of-Science-Categories  = {Plant Sciences},
