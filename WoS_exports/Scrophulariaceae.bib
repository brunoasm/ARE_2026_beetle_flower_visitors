@article{ WOS:A1984SE60100017,
Author = {SAFA, SB and JONES, BMG and MUSSELMAN, LJ},
Title = {MECHANISMS FAVORING OUTBREEDING IN
   STRIGA-HERMONTHICA{[}SCROPHULARIACEAE]},
Journal = {NEW PHYTOLOGIST},
Year = {1984},
Volume = {96},
Number = {2},
Pages = {299-305},
Abstract = {Self-incompatibility was demonstrated in 2 samples of the parasitic
   flowering plant, S. hermonthica, originating from Upper Volta and Sudan.
   Compatibility was determined by fluorescence microscopy of stigmastic
   preparations following controlled pollinations. Self-incompatibility was
   associated with floral adaptations favoring pollination by long-tongued
   insects such as butterflies. Outbreeding accounts for the variability of
   S. hermonthica, both in morphology and in host specificity. Genetic
   variation in host specificity imposes limits upon the effectiveness of
   the present methods of testing tropical cereals for resistance to S.
   hermonthica.},
