@article{ WOS:A1986F278500007,
Author = {GREENLEE, JK and RAI, KS},
Title = {POPULATION DIFFERENTIATION IN COLLINSIA-VERNA NUTTAL (SCROPHULARIACEAE)
   - A MULTIFACETED APPROACH},
Journal = {GENETICA},
Year = {1986},
Volume = {71},
Number = {1},
Pages = {51-61},
Month = {NOV 14},
Abstract = {Three species of Collinsia (commonly called Blue-eyed Mary, Innocence,
   Chinese Houses) including 12 populations of C. verna were examined or
   genetic variability and differentiation using three investigative
   techniques: enzyme electrophoresis, chiasma frequencies, and
   morphological measurements. Analysis of isozyme data showed higher
   heterozygosity was maintained in the C. verna populations (previosly
   reported to be self pollinating) than in C. heterophylla and C.
   tinctoria, which are outcrossers. C. heterophylla and C. tinctoria were
   separated b significant genetic distance from each other and especially
   from C. verna. Within C. verna isozyme, morphological, and chiasma
   frequency analyses separated the populations into subsets showing some
   geographical trends, possibly influenced by water dispersal of seeds.
   High genetic variability was maintained and differentiated has occurred
   in the C. verna populations. The explanation may lie in a combination of
   factors associated with the `'heterozygosity paradox'' including
   microgeographical influence and inappropriate mating system
   classification.},
