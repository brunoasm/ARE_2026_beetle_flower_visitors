ISSN = {0906-7590},
Keywords-Plus = {ST-JOHN-RIVER; BARTSIA-ALPINA; BREEDING SYSTEMS; SEED PREDATION;
   LIFE-HISTORY; R-SELECTION; K-SELECTION; PLANTS; FURBISHIAE; MAINE},
Research-Areas = {Biodiversity \& Conservation; Environmental Sciences \& Ecology},
