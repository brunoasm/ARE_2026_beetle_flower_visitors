@article{ WOS:A19679133900001,
Author = {CROSSWHITE, FS},
Title = {REVISION OF PENSTEMON SECTION HABROANTHUS (SCROPHULARIACEAE) .1.
   CONSPECTUS},
Journal = {AMERICAN MIDLAND NATURALIST},
Year = {1967},
Volume = {77},
Number = {1},
Pages = {1+},
Abstract = {A new subgenus of Penstemon, HABROANTHUS, is named to receive all
   Penstemon species in which the anffieirsacs ehisce from the base toward
   the apex, usually incompletely. The subgenus is divisible into two
   sections, Habroanthus (type: P. cyananthus Hook.) and Elmigera (type: P.
   barbatus (Cav.) Roth). Section Habroanthus is further divided into four
   series (Speciosi, Virgati, Stricti and Habroanthus), using characters of
   the anther sacs. Taxonomy is discussed in historical perspective, this
   being terminated with a key to the series within section Habroanthus and
   an enumeration of the species within each series. Geography, chromosome
   number, pollinators, and hybridization are discussed briefly.},
