@article{ WOS:000180234400007,
Author = {Yang, CF and Guo, YH and Gituru, RW and Sun, SG},
Title = {Variation in stigma morphology -: How does it contribute to pollination
   adaptation in <i>Pedicularis</i> (Orobanchaceae)?},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2002},
Volume = {236},
Number = {1-2},
Pages = {89-98},
Abstract = {Stigma morphology in Pedicularis and its role in pollination have not
   been evaluated. This paper reports for the first time the relationship
   between stigma morphology and other aspects of floral design. 17 species
   of Pedicularis representing all the different types of corolla structure
   in the genus were studied in the field and in the laboratory. Results
   indicate that the stigmatic surface morphology of Pedicularis species is
   related to the type of corolla structure occurring in the species.
   Pollination studies in eight Pedicularis species demonstrated adaptation
   between stigmatic surface morphology and other aspects of floral
   biology. Species with larger, more corrugated stigmatic surfaces always
   possess a subsidiary construction ({''}tooth{''} or ``beak{''}) on the
   galea. In addition, they have relatively longer flower tubes, higher
   stigmatic pollen loads, bigger pollen size and a shorter blooming period
   for individual flowers. Finally, the authors discuss the evolutionary
   significance of floral design in genus Pedicularis.},
