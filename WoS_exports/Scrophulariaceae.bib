@article{ WOS:A1959XE17400002,
Author = {VICKERY, RK},
Title = {BARRIERS TO GENE EXCHANGE WITHIN MIMULUS-GUTTATUS (SCROPHULARIACEAE)},
Journal = {EVOLUTION},
Year = {1959},
Volume = {13},
Number = {3},
Pages = {300-310},
Abstract = {On the basis of the assumption that seed set depends upon the number of
   ovules and the amount of pollen present in the flowers of M. guttatus, 6
   of 15 cultures of wild populations analyzed contain sterility barriers.
   Five of these barriers are correlated with the only cytological
   abnormalities observed in the populations. The barriers carry over into
   the interpopulation combinations and hybrids. Also, 9 additional
   barriers appear at these later stages. The cumulative effect of all the
   different barriers is to produce a strong downward trend in
   intraspecific fertility from that of the self-pollinated parental
   cultures (64 seeds per capsule) to that of the interpopulation
   combinations (44 seeds per capsule) to that of the F1 hybrids (29 seeds
   per capsule). This trend tends to level off in the F2 hybrids. Gene
   exchange was still potentially possible between all the populations
   although most of them were separated by moderate to strong crossing
   barriers. These facts suggest to the author that this widely scattered,
   highly polymorphic species may well be on its way towards evolving into
   a host of closely related new species.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
