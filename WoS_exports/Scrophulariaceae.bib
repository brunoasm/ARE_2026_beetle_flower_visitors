@article{ WOS:A1984TT95800010,
Author = {VOGEL, S},
Title = {THE DIASCIA FLOWER AND ITS BEE - AN OIL-BASED SYMBIOSIS IN
   SOUTHERN-AFRICA},
Journal = {ACTA BOTANICA NEERLANDICA},
Year = {1984},
Volume = {33},
Number = {4},
Pages = {509-518},
Abstract = {The double-spurred flowers of the South African genus Diascia
   (Scrophulariaceae) produce fatty oil as a primary attractant. Their
   oil-collecting pollinators have so far remained unknown. Morphology and
   direct evidence of flower visitation indicate that the recently
   established Melittid genus Rediviva represents the co-evolved pollinator
   group of these plants, at the same time demonstrating the presence of
   manual oil collectors in Southern Africa. The bees must introduce their
   especially equipped forelegs into the paired spurs of Diascia for
   harvesting the oil, therby pollinating the flower. In the described
   case, a new species, R. emdeorum, has extremely elongated front legs
   which perfectly fit the spurs of D. longicornis.},
