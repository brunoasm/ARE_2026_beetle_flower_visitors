Language = {English},
Affiliation = {Scott, PE (Corresponding Author), Indiana State Univ, Dept Life Sci, Terre Haute, IN 47809 USA.
   Indiana State Univ, Dept Life Sci, Terre Haute, IN 47809 USA.},
DOI = {10.1086/314244},
ISSN = {1058-5893},
Keywords = {breeding system; hummingbird; nectar; Penstemon barbatus; Penstemon
   pinifolius; pollination},
