   Natl Bot Inst, Compton Herbarium, ZA-7735 Claremont, South Africa.},
DOI = {10.2307/2446351},
ISSN = {0002-9122},
Keywords = {beetle pollination; Ceratandra; floral shifts; Lepithrix; oil-collecting
   bees; Orchidaceae; rendezvous pollination},
Keywords-Plus = {TONGUED FLY POLLINATION; OIL FLOWERS; SCROPHULARIACEAE; DIVERGENCE;
   ADAPTATION; BIOLOGY; COLOR; DALECHAMPIA; HYMENOPTERA; ECOTYPES},
