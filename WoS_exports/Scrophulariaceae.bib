@article{ WOS:000226577300004,
Author = {Bi, IZ and Maquet, A and Baudoin, JP},
Title = {Mating system of wild <i>Phaseolus lunatus</i> L. and its relationship
   to population size},
Journal = {HEREDITY},
Year = {2005},
Volume = {94},
Number = {2},
Pages = {153-158},
Month = {FEB},
Abstract = {Using isozyme variation in a naturally pollinated seed family for 10
   wild Phaseolus lunatus L. ( Lima bean) populations, ranging in sizes
   from 10 to 60 reproductive individuals, we estimated levels of
   outcrossing (t) and parental inbreeding coefficient ( F). We also
   examined the relationship between outcrossing rate and population size.
   Average estimates of the single-locus outcrossing rate (t(s)) ranged
   from 0.024 to 0.246 ( mean = 0.091 +/- 0.065). Estimates of the
   multilocus outcrossing rate (t(m)) ranged from 0.027 to 0.268, and
   averaged 0.096 +/- 0.071. Inbreeding coefficients based on genotypic
   frequencies of maternal plants were positive and significantly greater
   than zero ( F = 0.504), suggesting an excess of homozygotes in all the
   populations studied. There was indirect evidence of nonrandom mating for
   outcrosses and this was mainly attributed to self-fertilisation since
   the averaged difference between t(m) and t(s), which provides a measure
   of biparental inbreeding, represents only 1\% of the autogamy rate. No
   significant correlation was observed between outcrossing rate and
   population size. Estimates of t showed significant heterogeneity among
   populations and factors explaining this tendency are suggested.},
Publisher = {NATURE PUBLISHING GROUP},
Address = {MACMILLAN BUILDING, 4 CRINAN ST, LONDON N1 9XW, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Univ Abobo Adjame, UFR Sci Nat, 02 BP 801, Abidjan 02, Cote Ivoire.
   Univ Abobo Adjame, UFR Sci Nat, Abidjan 02, Cote Ivoire.
   Commiss European Communities, DG Joint Res Ctr, IRMM, Food Safety \& Qual Unit, B-2440 Geel, Belgium.
   Fac Univ Sci Agron Gembloux, Unite Pytotech Trop \& Hort, B-5030 Gembloux, Belgium.},
DOI = {10.1038/sj.hdy.6800527},
