@article{ WOS:A1994NY13800005,
Author = {DIERINGER, G and WERTH, CR},
Title = {POPULATION GENETIC-STRUCTURE OF AGALINIS-STRICTIFOLIA (SCROPHULARIACEAE)},
Journal = {BULLETIN OF THE TORREY BOTANICAL CLUB},
Year = {1994},
Volume = {121},
Number = {2},
Pages = {148-153},
Month = {APR-JUN},
Abstract = {Agalinis strictifolia (Benth.) Penn. (Scrophulariaceae) is a
   self-incompatible annual distributed from central Texas south into
   northern Mexico. In central Texas, flowering can begin in mid-July and
   continue through mid-October. Pollinators are Bombus pennsylvanicus and
   Apis mellifera. Previous field experiments have shown that two
   populations differ in seed production from single bee visit experiments
   (Wellhouse population with a high seed production and Firefly Meadow
   population with a low seed production). An isozyme study was undertaken
   to discern whether any differences in genetic structure existed between
   the two populations that might be associated with the difference in seed
   production. Populations of A. strictifolia maintain high levels of
   genetic diversity with values ranging from 0.200 to 0.233. Values of
   F(ST) showed significant genetic structure among subpopulations at the
   Wellhouse (WH) population but not at Firefly Meadow (FM). Most of the
   variation occurred between subpopulations rather than between
   populations. Inbreeding coefficients (F(IS)) and outcrossing rates (t)
   differed only slightly between populations and suggested that both were
   primarily outcrossing. Estimated migration rates (Nm) based on F(ST)
   values differed greatly between populations with FM having a migration
   rate that was 4.6 x greater than at WH. At FM, annual variability in
   density and a requirement for multiple bee visits for full seed
   production may account for the high migration rate. The Mantel's Z test
   for correlation between matrices of Rogers' genetic similarity and
   interplant distance was significant for both populations. The
   relationship was negative as expected at the WH population but positive
   at FM. A positive relationship between these has not been previously
   reported. Despite the genetic differences detected, no clear distinction
   was noted that could easily be connected with the previously observed
   difference in seed production from single bee visits.},
