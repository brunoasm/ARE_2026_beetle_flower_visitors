   Univ Extremadura, Fac Ciencias, Unidad Bot, Dept Biol \& Prod Vegetal, E-06071 Badajoz, Spain.},
ISSN = {0024-4074},
EISSN = {1095-8339},
Keywords = {abortion; dichogamy; ecology; geiotonogamy; karyology; longevity;
   nectar; pollen; seed/ovule ratio; seed set},
Keywords-Plus = {SELF-INCOMPATIBILITY; REPRODUCTIVE SUCCESS; FLOWERING PLANTS; POLLEN;
   LONGEVITY; SIZE},
Research-Areas = {Plant Sciences},
Web-of-Science-Categories  = {Plant Sciences},
Affiliations = {Universidad de Extremadura},
