@article{ WOS:A1980KQ86700003,
Author = {KWAK, MM},
Title = {ARTIFICIAL AND NATURAL HYBRIDIZATION AND INTROGRESSION IN RHINANTHUS
   (SCROPHULARIACEAE) IN RELATION TO BUMBLEBEE POLLINATION},
Journal = {TAXON},
Year = {1980},
Volume = {29},
Number = {5-6},
Pages = {613-628},
Abstract = {Flowers of plants obtained after artificial crosses between R. minor L.
   and R. serotinus (Schonh.) Oborny are compared with flowers in field
   samples of mixed populations. Hybridization and introgression in
   different degrees occur in the field. Arguments are given that the
   occurrence of both is influenced by the behavior of lower visiting
   bumblebees and their numbers. In the field seed, set in open-pollinated
   hybrid plants was reduced compared with that of the parents. Variance in
   seed production is related to hybrid index value in open-pollinated
   plants and to stigma position in caged ones. Stigma position is an
   important character for the direction of hybridization and
   introgression.},
