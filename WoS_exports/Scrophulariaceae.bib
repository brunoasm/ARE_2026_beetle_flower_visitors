Year = {2001},
Volume = {114},
Number = {1114},
Pages = {187-191},
Month = {JUN},
Abstract = {We analyzed the nectar features in a hummingbird-pollinated
   Scrophulariaceae. Nectar production is constant during the first days of
   anthesis and ceases after this period. Removals carried during the first
   days may decrease sugar production. Esterhazya macrodonta is scarcely
   visited by hummingbirds, a fact that may be related to its low flower
