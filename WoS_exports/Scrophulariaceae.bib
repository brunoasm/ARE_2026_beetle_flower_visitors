DOI = {10.1038/hdy.1993.123},
ISSN = {0018-067X},
Keywords = {GENETIC CORRELATION; HERITABILITY; MAXIMUM-LIKELIHOOD; NECTAR;
   PENSTEMON-CENTRANTHIFOLIUS; REPRODUCTION},
Keywords-Plus = {QUANTITATIVE GENETICS; POLEMONIUM-VISCOSUM; ASCLEPIAS-EXALTATA; NECTAR
