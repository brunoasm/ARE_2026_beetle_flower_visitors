Address = {RUDIGERSTR 14, D-70469 STUTTGART, GERMANY},
Type = {Article},
Language = {English},
Affiliation = {Wagner, J (Corresponding Author), Univ Innsbruck, Inst Bot, Sternwartestr 15, A-6020 Innsbruck, Austria.
   Univ Innsbruck, Inst Bot, A-6020 Innsbruck, Austria.},
DOI = {10.1111/j.1438-8677.1998.tb00691.x},
ISSN = {0932-8629},
Keywords = {Gentianella germanica; climate change; embryology; flowering phenology;
   monocarpic life cycle; reproductive biology; seed development; seed set},
Keywords-Plus = {SCOPOLI POLLICH SCROPHULARIACEAE; GRASSLAND MANAGEMENT; FLOWERING
   PHENOLOGY; ECOTYPIC VARIATION; LIFE-HISTORY; PLANTS; SIZE; GENTIANACEAE;
   CALIFORNIA; DURATION},
