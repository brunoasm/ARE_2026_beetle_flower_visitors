   Blackmore, S., Royal Bot Garden Edinburgh, Edinburgh EH3 8BZ, Midlothian, Scotland.},
DOI = {10.1007/s00606-008-0112-1},
ISSN = {0378-2697},
EISSN = {2199-6881},
Keywords = {Pedicularis; Aperture; Floral diversification; Pollination syndrome;
