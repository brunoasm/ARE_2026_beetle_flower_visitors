Affiliations = {Chinese Academy of Sciences; Kunming Institute of Botany, CAS; Nanjing
   University},
ResearcherID-Numbers = {Yu, Wen-Bin/H-8339-2014},
ORCID-Numbers = {Yu, Wen-Bin/0000-0002-7643-2112},
Funding-Acknowledgement = {National Basic Research Program of China {[}2007CB411603]; National
   Natural Science Foundation of China {[}30570115]; Keynote Project of the
   Knowledge Innovation Program, Chinese Academy of Sciences
   {[}KSCX2-YW-Z-034]; Royal Botanic Garden Edinburgh (the Scottish
   Executive Environment and Rural Affairs Department)},
Funding-Text = {We would like to thank the herbaria at Royal Botanic Garden Edinburgh
