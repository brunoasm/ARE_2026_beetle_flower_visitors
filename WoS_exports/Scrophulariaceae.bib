ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Antirrhinum; development; evolution; flower morphology; MADS box genes;
   ndhF; phylogeny; rbcL; Scrophulariaceae},
Keywords-Plus = {MADS-BOX GENE; FLORAL HOMEOTIC GENE; CHALCONE SYNTHASE GENE; FLOWER
