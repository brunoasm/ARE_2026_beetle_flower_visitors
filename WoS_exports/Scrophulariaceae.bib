Address = {5801 S ELLIS AVENUE, CHICAGO, IL 60637 USA},
Type = {Article},
Language = {English},
Affiliation = {Canne-Hilliker, JM (Corresponding Author), Univ Guelph, Dept Bot, Guelph, ON N1G 2W1, Canada.
