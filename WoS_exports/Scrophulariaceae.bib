ISSN = {0378-2697},
Keywords-Plus = {SUGAR COMPOSITION; FLORAL NECTAR; SEED SET; IMPATIENS-CAPENSIS;
   CUCURBITA-PEPO; FLOWERS; REABSORPTION; POLLINATION; SECRETION; VOLUME},
Research-Areas = {Plant Sciences; Evolutionary Biology},
