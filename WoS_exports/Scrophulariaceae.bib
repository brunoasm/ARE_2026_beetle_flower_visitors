Keywords = {adaptive radiation; flora of southern Africa; nectar; Nemestrinidae;
   phylogeny; self-incompatibility; Sphingidae},
Keywords-Plus = {EVOLUTION; SYSTEMS; PHYLOGENY; HYPOTHESES; SELECTION; TESTS},
