DOI = {10.1890/02-0519},
ISSN = {0012-9658},
EISSN = {1939-9170},
Keywords = {autonomous selfing; Collinsia verna; competing selfing; delayed selfing;
   mating-system evolution; mixed mating; pollen limitation; pollinator
   failure; reproductive assurance; resource limitation; selection on
   floral traits; self-pollination},
