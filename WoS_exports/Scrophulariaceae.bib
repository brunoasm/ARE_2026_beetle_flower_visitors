@article{ WOS:A1990EU62900006,
Author = {DELPH, LF},
Title = {THE EVOLUTION OF GENDER DIMORPHISM IN NEW-ZEALAND HEBE
   (SCROPHULARIACEAE) SPECIES},
Journal = {EVOLUTIONARY TRENDS IN PLANTS},
Year = {1990},
Volume = {4},
Number = {2},
Pages = {85-97},
Month = {DEC},
Abstract = {The sexual conditions of a variety of New Zealand species of Hebe and
   Chionohebe are reported, along with information on fruit set, sex
   ratios, and the inheritance of male sterility.  All observed species
   (49) of Hebe exhibited herkogamy.  Autogamous or geitonogamous
   pollination of the cosexual flowers was still possible, however, as Hebe
   is self-compatible.  the ancestral sexual condition for Hebe was
   cosexuality, with male sterility arising four separate times within the
   genus.  Male sterility is under at least partial nuclear control in the
   one species examined in this respect.  A wide and continuous range of
   gender dimorphism has evolved autochthonously in New Zealand, from
   various grades of gynodioecy to strict dioecy.  Dimorphism is positively
   correlated with altitude and the pollinator fauna changes with
   altitudes, to flies and beetles at the higher altitudes.  It is
   therefore suggested that separate sexes were selected to enforce
   outcrossing in the higher altitudes where the pollinators are less
   efficient at cross-pollination.},
