@article{ WOS:A1982PR02100011,
Author = {ARNOLD, RM},
Title = {FLORAL BIOLOGY OF CHAENORRHINUM-MINUS (SCROPHULARIACEAE) A
   SELF-COMPATIBLE ANNUAL},
Journal = {AMERICAN MIDLAND NATURALIST},
Year = {1982},
Volume = {108},
Number = {2},
Pages = {317-324},
Abstract = {The floral biology of C. minus (L.) Lange (Scrophulariaceae) was studied
   at 2 sites in central New York {[}USA]. Individual flowers are
   short-lived (.apprx. 24 h). Small plants generally produce flowers
   intermittently. More vigorous individuals produce many flower-bearing
   branches, which increases the probability that they will have at least 1
   flower open when a pollinator visits the patch. C. minus is
   self-compatible, though it has adaptations for insect pollination. The
   only insect pollinators observed during 2 seasons were halictid bees.
   These visited infrequently. Accordingly, most of the flowers in the
   population of C. minus were self-fertilized.},
