Address = {290 LIFE SCIENCE MUSEUM, PROVO, UT 84602 USA},
Type = {Article},
Language = {English},
Affiliation = {Stevens, MR (Corresponding Author), Brigham Young Univ, Dept Plant \& Wildlife Sci, Provo, UT 84602 USA.
   Crump, W. Wesley; Stettler, Jason M.; Anderson, Chris D.; Harrison, Sarah; Meservey, Lindsey M.; Stevens, Mikel R., Brigham Young Univ, Dept Plant \& Wildlife Sci, Provo, UT 84602 USA.
