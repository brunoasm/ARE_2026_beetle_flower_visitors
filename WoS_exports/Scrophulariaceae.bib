   Univ Calif Riverside, Dept Biol, Riverside, CA 92521 USA.},
DOI = {10.1111/j.1420-9101.2007.01374.x},
ISSN = {1010-061X},
Keywords = {comparative methods; correlated evolution; hummingbirds; independent
