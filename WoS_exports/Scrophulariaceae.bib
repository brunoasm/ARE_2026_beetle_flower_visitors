Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Rocky Mt Biol Labs, Crested Butte, CO 81224 USA.
   Rocky Mt Biol Labs, Crested Butte, CO 81224 USA.},
DOI = {10.1111/j.0030-1299.2004.12641.x},
