   Univ Kansas, Dept Ecol \& Evolutionary Biol, Lawrence, KS 66045 USA.},
DOI = {10.1086/423876},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {Bombus impatiens; bumblebees; monkey flower; Mimulus guttatus;
   phenotypic manipulation; pollen-collecting hairs},
