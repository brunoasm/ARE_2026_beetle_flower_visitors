@article{ WOS:A1991FX28300010,
Author = {ROBERTSON, AW and LLOYD, DG},
Title = {HERKOGAMY, DICHOGAMY AND SELF-POLLINATION IN 6 SPECIES OF MYOSOTIS
   (BORAGINACEAE)},
Journal = {EVOLUTIONARY TRENDS IN PLANTS},
Year = {1991},
Volume = {5},
Number = {1},
Pages = {53-63},
Month = {JUN},
Abstract = {The herkogamy (spatial separation of anthers and stigmas) of six species
   of Myosotis is described.  All species are protogynous but the stigma
   remains functional throughout the life of a flower.  Three species pairs
   are recognized-(i) always herkogamous, where the stigma is initially
   exserted beyond the anthers and remains so, (ii) initially herkogamous,
   where the stigma initially protrudes but corolla extension lifts the
   anthers above the stigma during anthesis and (iii) never herkogamous,
   where the anthers and stigmas are in close contact throughout. 
   Associated with these differences in herkogamy, there are trends towards
   decreased pollen allocation, increased auto-fertility and a breakdown in
   dichogamy, and less regular trends in flower size and open-pollinated
   seed set.  It is postulated that these pairs of species represent
   different positions on an outcrossing-selfing continuum.  The initially
   herkogamous pair may represent a mixed-mating strategy as these species
   display an extended female phase which allows a greater opportunity for
   cross-pollination, but if this fails there is a later chance of
   self-pollination.  The system described represents a dual herkogamy -
   dichogamy interaction and represents a class of dichogamy overlooked in
   recent reviews.  The essential feature is that the overtopping of the
   stigmas by anthers is caused by the continuing growth of the corolla and
   associated epipetalous filaments after the style has largely stopped
   elongating.  Similar dual systems involving anther overtopping of
   stigmas exist in a number of other sympetalous dicots.},
