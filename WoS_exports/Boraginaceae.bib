@article{ WOS:A1995QZ67200006,
Author = {OBERRATH, R and ZANKE, C and BOHNINGGAESE, K},
Title = {TRIGGERING AND ECOLOGICAL SIGNIFICANCE OF FLORAL COLOR-CHANGE IN
   LUNGWORT (PULMONARIA SPEC)},
Journal = {FLORA},
Year = {1995},
Volume = {190},
Number = {2},
Pages = {155-159},
Month = {MAY},
Abstract = {During flowering time lungwort (Pulmonaria spec.) changes its corolla
   color from red to blue. Flowers last six to eight days, with color
   change taking place approximately in the middle of the flowering time.
   Color change does not seem to be triggered by pollinators and probably
   occurs with proceeding age of the flower. Pollinators, mostly bees of
   the species Anthophora acervorum, preferably visit young red flowers
   which contain significantly more nectar than old blue flowers. Most
   probably, floral colors function as signals directing potential
   pollinators to rewarding flowers.},
