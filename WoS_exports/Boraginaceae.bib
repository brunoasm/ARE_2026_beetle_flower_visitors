@article{ WOS:000080969400013,
Author = {Klinkhamer, PGL and van der Veen-van Wijk, CAM},
Title = {Genetic variation in floral traits of <i>Echium vulgare</i>},
Journal = {OIKOS},
Year = {1999},
Volume = {85},
Number = {3},
Pages = {515-522},
Month = {JUN},
Abstract = {We estimated the genetic basis for variation in floral traits and the
   phenotypic and genetic correlations between these traits using clonal
   propagation in Echium vulgare (Boraginaceae). For all floral traits
   measured (nectar volume, nectar sugar concentration, sugar production.
   corolla size, style length, stamen length) we found significant clonal
   repeatabilities in a greenhouse experiment. Variation among clonal
   families in nectar volume rr;as surprisingly high (seven-fold difference
   between the highest and lowest family mean) and not correlated with
   flower size. Variation among clonal families in pollen production was
   el;en higher (28-fold) and correlated to flower size traits. Corolla
   length, style length and stamen length were all highly correlated.
   Flower size is not a good predictor for nectar production rate. while it
   is for the number of pollen grains produced.},
