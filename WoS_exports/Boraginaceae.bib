@article{ WOS:A1984ST28900011,
Author = {CASPER, BB and LAPINE, TR},
Title = {CHANGES IN COROLLA COLOR AND OTHER FLORAL CHARACTERISTICS IN
   CRYPTANTHA-HUMILIS (BORAGINACEAE) - CUES TO DISCOURAGE POLLINATORS},
Journal = {EVOLUTION},
Year = {1984},
Volume = {38},
Number = {1},
Pages = {128-141},
Abstract = {The loss of yellow color in the coronas of Cryptantha humilis var. nana
   occurs .apprx. 3 days after anthesis, is a time dependent event, and
   takes place even if the flower has not received a visit from a
   pollinator. White corollas remain on the plant at least one full day
   before withering. This variety of C. humilis is visited by a diversity
   of insects but most commonly by a species in the family Empididae and
   several species of beeflies. Insects visit flowers with yellow coronas
   significantly more often than flowers with totally white corollas.
   Presumably this is because only flowers with yellow coronas produce
   nectar. The 2 flower types also produce different odors, and their
   corollas may differ in patterns of UV reflectance. The changes in
   corolla color and/or the changes in other floral characteristics
   apparently serve as signals to discourage pollinators. Hand pollination
   experiments revealed that the flowers are self-incompatible and that the
   viability of the pollen and the receptivity of the stigma are
   substantially less in flowers with totally white corollas. Thus, to
   maximize reproductive potential, flowers must be outcrossed before the
   color change occurs. An adaptive function of maintaining corollas that
   have changed color was not identified. White corollas do not appear to
   increase the overall attractiveness of the plants to pollinators.},
