   Univ Tsukuba, Inst Biol Sci, Tsukuba, Ibaraki 305, Japan.},
DOI = {10.2307/2446328},
ISSN = {0002-9122},
Keywords = {emasculation; heterostyly; Persicaria japonica; polygonaceae; reciprocal
   herkogamy; self-pollen interference; stigmatic pollen load},
