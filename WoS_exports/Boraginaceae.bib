@article{ WOS:A1979GZ33600014,
Author = {OLESEN, JM},
Title = {FLORAL MORPHOLOGY AND POLLEN FLOW IN THE HETEROSTYLOUS SPECIES
   PULMONARIA-OBSCURA DUMORT (BORAGINACEAE)},
Journal = {NEW PHYTOLOGIST},
Year = {1979},
Volume = {82},
Number = {3},
Pages = {757+},
Abstract = {Pollen flow in the heterostylous species of P. obscura was studied in 2
   localities in Denmark. Various floral characters of the 2 morphs were
   measured, but differences were found only in height of stamens and
   stigma and size of pollen. In studies with a scanning electron
   microscope, pollen was discovered to have a continuous, equatorial
   girdle formed by the transverse furrows extending laterally from the
   ora. The stigmatic papillae were composed of a stalk with a many-armed
   crown. The ratio of number of thrum to pin plants was approximately 1:1
   fulfilling theoretical expectations. Six different Bombus spp. {[}B.
   pascuorum, B. hortorum, B. hypnorum, B. lapidarius, B. pratorum and B.
   terristris] and a specimen of Psithyrus bohemicus were observed as
   visitors to P. obscura, which displays a range of adaptations to Bombus
   pollination. Of the Bombus specimens 30\% had corbicular pollen loads,
   which were almost 100\% pure Pulmonaria pollen. Pollen flow was revealed
   by analyzing the pollen loads on stigmas and proboscides. Both stigma
   types had more illegitimate pollen than expected on the basis of the
   ratio of production of the 2 pollen types. This could be caused by a
   high degree of intrafloral pollen flow. Since heterostyly does not
   apparently enhance the transport of legitimate pollen the adaptive role
   of the system is unclear.},
