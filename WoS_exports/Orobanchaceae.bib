   Xia, J.; Sun, S. G.; Guo, Y. H., Wuhan Univ, Coll Life Sci, Lab Plant Systemat \& Evolut Biol, Wuhan 430072, Peoples R China.},
DOI = {10.1055/s-2007-965259},
ISSN = {1435-8603},
