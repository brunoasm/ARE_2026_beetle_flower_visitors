Keywords = {Pedicularis lanceolata; hemiparasitic plants; host plants; non-native
   plants; regionally rare plants},
Keywords-Plus = {PERIPHERAL-POPULATIONS; PARASITIC PLANT; HOST; CONSERVATION; POLLINATION},
