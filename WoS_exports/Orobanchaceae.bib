DOI = {10.3159/1095-5674(2006)133{[}560:IIHCTT]2.0.CO;2},
ISSN = {1095-5674},
EISSN = {1940-0616},
Keywords = {Agalinis auriculata; Endothenia hebesana; florivory; folivory;
