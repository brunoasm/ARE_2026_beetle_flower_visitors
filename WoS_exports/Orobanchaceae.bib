@article{ WOS:000862465000001,
Author = {Dieringer, Gregg and Cabrera, R. Leticia},
Title = {Phenotypic Selection on Staminal Trichomes of <i>Agalinis auriculata</i>
   (Orobanchaceae) in Relation to Pollen Transfer by Bumble Bees},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {2022},
Month = {2022 NOV 1},
Abstract = {Premise of research. How pollen is transferred, both its removal from
   stamens and its deposition on stigmas, plays an important role in the
   reproductive success of plants. Pollen transfer models typically depend
   on pollinator visitation rate where a single visit is sufficient for
   pollen deposition but multiple visits enhance pollen removal. Frequently
   visited flowers may be structured so as to restrict the amount of pollen
   released per visit (pollen presentation hypothesis). However,
   alternative models predict rapid loss of pollen if the probability of
   fertilization is time limited. Here we present an experimental study on
   a staminal trait, filament trichomes, and its role in pollen transfer
   (pollen removal and deposition).Methodology. Agalinis auriculata flowers
   are short-lived and possess trichomes along the longer abaxial stamens.
   Bombus impatiens vibrated stamens and foraged sternotribically, whereas
   Bombus pensylvanicus foraged nototribically without vibrating.
   Experiments involving single bee visits to unvisited flowers were used
   to estimate pollen transfer dynamics as related to filament trichome
   number. Selection differentials were calculated for both transfer
   processes and compared between the two types of foraging
   behaviors.Pivotal results. We found significant differentials for both
   types of foraging for pollen removal but not pollen deposition. Contrary
   to our expectation, the number of trichomes along the filament had a
   significant positive effect on pollen removal for sternotribic,
   vibrating visits but had a significant negative effect for nototribic
   visits.Conclusions. We conclude that the short-lived flowers result in
   time-dependent fertilization favoring rapid pollen loss for vibrating
   visits. Filament trichomes seem to facilitate grasping of trichomes by
   the pollinator, which most likely explains the contrasting influence
   trichomes had on pollen removal by differing bee foraging behaviors.},
Publisher = {UNIV CHICAGO PRESS},
Address = {1427 E 60TH ST, CHICAGO, IL 60637-2954 USA},
Type = {Article; Early Access},
Language = {English},
Affiliation = {Dieringer, G (Corresponding Author), Northwest Missouri State Univ, Dept Nat Sci, 800 Univ Dr, Maryville, MO 64468 USA.
   Dieringer, Gregg; Cabrera, R. Leticia, Northwest Missouri State Univ, Dept Nat Sci, 800 Univ Dr, Maryville, MO 64468 USA.},
