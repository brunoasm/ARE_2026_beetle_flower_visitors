@article{ WOS:A1983RW48100006,
Author = {SUZUKI, K},
Title = {BREEDING SYSTEM AND CROSSABILITY IN JAPANESE EPIMEDIUM (BERBERIDACEAE)},
Journal = {BOTANICAL MAGAZINE-TOKYO},
Year = {1983},
Volume = {96},
Number = {1044},
Pages = {343-350},
Abstract = {A series of experimental pollinations involving 6 spp. of Epimedium
   provided strong evidence for an outbreeding system and no internal
   (postmating, postpollination) barrier to hybridization in the taxa
   concerned. Self-pollinations of 4 spp., E. diphyllum, E.
   trifoliatobinatum, E. grandiflorum and E. sempervirens, indicated high
   self-incompatibility (at most 5.4\%, usually 0\% in capsule-set). Field
   experiments in a population revealed the occurrence of
   cross-pollination. Interspecific cross-pollinations showed high
   crossability at any combination of species (33.3-100\% in capsule-set).
   The interspecific F1s obtained germinated at a high rate (usually >
   20\%) and 3, which bloomed, are highly fertile (> 68.6\% in pollen
   viability). The results were discussed in connection with the isolating
   mechanisms between the species of Epimedium. The other species studied
   were E. koreanum and E. sagittatum.},
