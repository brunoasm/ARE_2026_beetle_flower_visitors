@article{ WOS:A1996VP30700006,
Author = {Hannan, GL and Prucher, HA},
Title = {Reproductive biology of Caulophyllum thalictroides (Berberidaceae), an
   early flowering perennial of eastern North America},
Journal = {AMERICAN MIDLAND NATURALIST},
Year = {1996},
Volume = {136},
Number = {2},
Pages = {267-277},
Month = {OCT},
Abstract = {Reproductive biology of two varieties of Caulophyllum thalictroides was
   studied in southeastern Michigan to identify insect visitors to flowers,
   to estimate pollination success in natural populations and to determine
   the degree of intervarietal compatibility in this species. Insect
   visitors were primarily dipterans (78\%) with a few hymenopterans.
   Caulophyllum thalictroides var. thalictroides experienced consistently
   higher reproductive success, measured as both fruit set and seed set,
   than did C. t. var. giganteum. Self-pollination resulted in 25\% seed
   set in C. t. var. thalictroides and only 3.5\% seed set in C. t. var,
   giganteum. Reciprocal intervarietal crosses produced ten times more seed
   with C. t. var. thalictroides as female parent than when C. t. var.
   giganteum was the female parent (81\% vs. 8\%, respectively).
   Differences in reproductive biology and the observed unilateral
   incompatibility may account for differences in seed set between the two
   varieties and may function as barriers to intervarietal hybridization
   during overlapping flowering times. This closely related, sympatric
   taxon pair may be useful in studying both the evolution of differences
   in reproductive characteristics and the effects of changes in
   reproductive characteristics on population-level phenomena.},
