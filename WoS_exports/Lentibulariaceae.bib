ISSN = {0012-9658},
Keywords = {carnivorous plant; Lentibulariaceae; Mediterranean ecosystem;
   microclimate; mucilage retention; Pinguicula vallisneriifolia; plant
   reproductive ecology; pollen limitation; pollinator-prey conflict;
