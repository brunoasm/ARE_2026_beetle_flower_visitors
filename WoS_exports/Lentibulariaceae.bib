   Miranda, Vitor F. O., Univ Estadual Paulista Unesp, Fac Ciencias Agr \& Vet, Dept Biol Aplicada Agr, Jaboticabal, SP, Brazil.},
DOI = {10.1007/s00709-019-01433-8},
ISSN = {0033-183X},
EISSN = {1615-6102},
