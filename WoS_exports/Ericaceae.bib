@article{ WOS:A1982NC56400015,
Author = {WILLIAMS, EG and KNOX, RB and ROUSE, JL},
Title = {POLLINATION SUBSYSTEMS DISTINGUISHED BY POLLEN-TUBE ARREST AFTER
   INCOMPATIBLE INTERSPECIFIC CROSSES IN RHODODENDRON (ERICACEAE)},
Journal = {JOURNAL OF CELL SCIENCE},
Year = {1982},
Volume = {53},
Number = {FEB},
Pages = {255-277},
Abstract = {The cytology of compatible and interspecific incompatible pollinations
   was followed in 22 selected species of the genus Rhododendron
   (Ericaceae). Pollinated pistils were fixed, cleared, stained in
   decolorized aniline blue and observed by epifluorescence microscopy. Ten
   different abnormalities of arrested pollen tube tips were detected,
   including burst, tapered, swollen, coiled, spiraling, spiky and variable
   diameter syndromes. A series of 5 errors of callose deposition in
   incompatible tubes was defined. Six different regions in the pistil for
   expression of pollen tube arrest were found, including the stigmatic
   exudate, the mucilage of the upper and lower style canal, the ovary
   loculus, the micropyle. There may be abnormal behavior after entry into
   the embryo sac. The site of pollen tube arrest within the pistil and the
   error syndrome of tip growth and callose deposition anomalies, are
   characteristic of each interspecific cross. The genetic control of
   reproduction is discussed.},
