@article{ WOS:000792358700004,
Author = {Xie, Weijia and El-Tantawy, A. A. and Li, Shifeng and Wang, Jihua and
   Song, Jie and Peng, Lvchun and Chen, Suiyun},
Title = {Pollen germination, structures, and morphologic characters after anthers
   cryopreservation of <i>Rhododendron delavayi</i> Franch},
Journal = {EUROPEAN JOURNAL OF HORTICULTURAL SCIENCE},
Year = {2022},
Volume = {87},
Number = {2},
Month = {APR},
Abstract = {Rhododendron delavayi Franch is an important ornamental woody species in
   China. It has an excellent breeding value for its scarlet flowers, the
   early bloom time and tolerance to drought. But its breeding programme is
   restricted due to the problem of asynchronised bloom period. Pollen
   storage plays an essential role in plant breeding and genetic resource
   conservation which will increase the possibility of cross pollination
   between R. delavayi and the other Rhododendron species. The aim of
   present work is to conduct a protocol for long-term pollen storage and
   to evaluate the conservation methodologies for R. delavayi. To achieve
   the best method for pollen storage in our plant, we incubated the pollen
   grain in desiccators with silica gel for 3, 6, 8, 24, and 48 h. After
   that, pollen samples were subjected to storage under four temperatures:
   refrigerator (4 degrees C), freezer (-20 degrees C), ultra-low
   temperature (-80 degrees C), and liquid nitrogen (-196 degrees C), with
   or without desiccation in silica gel. In vitro pollen germination was
   performed at 24 h before and after conservation to test the best
   desiccation period for pollen storage. Besides, we investigated the
   effects of the different low temperatures on pollen grain morphology
   using scanning electron microscope and structure using transmitted
   optical microscope at 7, 14, 30, and 60 days. The experimental design
   was completely randomized in a 5x4+1 factorial design (5 desiccation
   treatments, 4 conservation treatments, and 1 control). We found that
   desiccation at 3 and 6 h followed by storage in liquid nitrogen recorded
   the best results regarding to in vitro pollen germination, pollen tube
   length, and pollen diameter. On the other hand, shrinkage of the pollen
   grains associated with the intine separation was observed. Our findings
   reported the possibility of storing R. delavayi pollen grains
   encouraging the plant breeders to use this species to solve the
   difficulties of cross pollination among Rhododendron species.},
Publisher = {INT SOC HORTICULTURAL SCIENCE-ISHS},
