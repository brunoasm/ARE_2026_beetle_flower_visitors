@article{ WOS:000498558400001,
Author = {Chen, Yi and Li, Yun},
Title = {Intelligent Autonomous Pollination for Future Farming - A Micro Air
   Vehicle Conceptual Framework With Artificial Intelligence and
   Human-in-the-Loop},
Journal = {IEEE ACCESS},
Year = {2019},
Volume = {7},
Pages = {119706-119717},
Abstract = {Food security is one of the societal challenge topics. As one-third of
   all food consumed by humans relies on animal pollination currently, this
   research provides an emerging solution to food supply reduction caused
   by population shrinking of natural pollinators, so as to reduce its
   impact on ecological relationships, ecosystem conservation and
   stability, genetic variation in the crop plant community, floral
   diversity, specialisation and evolution. This paper develops a
   conceptual technical roadmap of autonomous pollination for future
   farming using robotic micro air vehicle pollinators (MPrs). The research
   provides new insights into autonomous design and manufacture and into
   possible ways to increase the production efficiency which shortens the
   time from lab to market. The autonomous MPrs are realized using
   artificial intelligence and human expertise in the loop for smart
   agricultural industry. Further, this work identifies scientific and
   technological advances that are expected to translate, within proposed
   regulatory frameworks, into the pervasive use of MPrs for agricultural
