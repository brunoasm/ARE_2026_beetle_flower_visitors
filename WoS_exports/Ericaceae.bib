   Filigenzi, Mike; Poppenga, Robert, Univ Calif Davis, Sch Vet Med, Calif Anim Hlth \& Food Safety Lab, Davis, CA 95616 USA.},
DOI = {10.1016/j.jemermed.2022.05.009},
