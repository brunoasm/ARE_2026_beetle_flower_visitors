Year = {1977},
Volume = {64},
Number = {2},
Pages = {199-206},
Abstract = {The morphological and vascular characteristics of the nectaries of the
   species of the Monotropoideae (Ericaceae) reflect the morphology and
   declination of flowers. These are related to the pollination systems of
   the species. The nectaries of members of the Monotropoideae exhibit a
   range in form from slender, elongate projections, to short, stout ones,
   or to low ridges between the staminal bases. The species studied are:
   Allotropa virgata, Cheilotheca Rhasiana, C. malayana, Hemitomes
   congestum, Monotropa hypopithys, M. uniflora, Monotropastrum humile, M.
   odorata, Pityopus californicus, Pleuricospora fibriolata, Pterospora
   andromedea and Sarcodes sanguinea.},
