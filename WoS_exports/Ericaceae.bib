Keywords = {bumble bee; Ericaceae; mating system variation; nectar volume;
   Phyllodoce aleutica; Phyllodoce caerulea; pollen limitation; pollinator
   preference},
Keywords-Plus = {ARENARIA-UNIFLORA CARYOPHYLLACEAE; PLANT REPRODUCTIVE SUCCESS;
