   Ginsberg, Howard S., Univ Rhode Isl, US Geol Survey, Patuxent Wildlife Res Ctr, Rhode Isl Field Stn, Woodward Hall PSE, Kingston, RI 02881 USA.},
DOI = {10.1093/ee/nvz055},
ISSN = {0046-225X},
