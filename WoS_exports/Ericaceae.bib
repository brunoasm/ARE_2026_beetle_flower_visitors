@article{ WOS:000236101100005,
Author = {Freitas, L and Galetto, L and Sazima, M},
Title = {Pollination by hummingbirds and bees in eight syntopic species and a
   putative hybrid of Ericaceae in Southeastern Brazil},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2006},
Volume = {258},
Number = {1-2},
Pages = {49-61},
Month = {APR},
Abstract = {We report on flowering phenology, floral morphology, pollinators, and
   nectar for eight species and a putative natural hybrid belonging to
   Agarista, Gaultheria and Gaylussacia that occur syntopically in a
   montane area. The campanulate to tubular flowers of eight out of nine
   Ericaceae taxa are primarily pollinated by either hummingbirds or bees.
   Flowering overlaps in all species but slight differences of floral
   shape, colour, and nectar characterize pollination by each pollinator
   group. Differences in. oral traits are not large enough to exclude
   secondary pollinators. Thus, either the main pollinators of a species
   belonging to its syndrome, or secondary pollinators of a species
   belonging to different syndromes, may allow for inter-specific crosses.},
