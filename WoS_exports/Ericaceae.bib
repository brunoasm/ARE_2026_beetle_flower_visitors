@article{ WOS:A1986D609900004,
Author = {WILLIAMS, EG and KAUL, V and ROUSE, JL and PALSER, BF},
Title = {OVERGROWTH OF POLLEN TUBES IN EMBRYO SACS OF RHODODENDRON FOLLOWING
   INTERSPECIFIC POLLINATIONS},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1986},
Volume = {34},
Number = {4},
Pages = {413-423},
Abstract = {Frequent overgrowths of pollen tubes within the embryo sac are
   characteristic of a number of interspecific crosses in the genus
   Rhododendron (Ericaceae). The combined techniques of sectioning,
   squashing and whole-ovule clearing have confirmed that in ovules showing
   this phenomenon the pollen tube fails to terminate growth and release
   sperms on entry into a synrgid; instead it continues to grow beyond the
   synergid and egg cell, often filling the main body of the embryo sac
   with a coiled and distorted mass. Such ovules fail to develop further.
   The occurrence and possible causes of this error syndrome are discussed.},
