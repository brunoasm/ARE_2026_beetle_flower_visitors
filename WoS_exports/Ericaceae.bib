Address = {JOURNALS DEPT, 2001 EVANS RD, CARY, NC 27513 USA},
Type = {Article},
Language = {English},
Affiliation = {Evans, EC (Corresponding Author), Univ Minnesota, Dept Entomol, 219 Hodson Hall,1980 Folwell Ave, St Paul, MN 55108 USA.
   Univ Minnesota, Dept Entomol, St Paul, MN 55108 USA.},
ISSN = {0022-0493},
