   Tuell, Julianna K.; Isaacs, Rufus, Michigan State Univ, Dept Entomol, E Lansing, MI 48824 USA.
   Ascher, John S., Amer Museum Nat Hist, Div Invertebrate Zool, New York, NY 10024 USA.},
DOI = {10.1603/008.102.0209},
ISSN = {0013-8746},
EISSN = {1938-2901},
Keywords = {native bee conservation; pan trapping},
Keywords-Plus = {POLLINATION; ABUNDANCE; BIODIVERSITY; DIVERSITY; ERICACEAE; APIDAE},
Research-Areas = {Entomology},
