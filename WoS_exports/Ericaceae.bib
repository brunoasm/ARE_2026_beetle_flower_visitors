@article{ WOS:A1981MV21500005,
Author = {DORR, LJ},
Title = {THE POLLINATION ECOLOGY OF ZENOBIA (ERICACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1981},
Volume = {68},
Number = {10},
Pages = {1325-1332},
Abstract = {Zenobia is a shrub endemic to the coastal plain of the Carolinas
   {[}North Carolina, South Carolina] and southeastern Virginia {[}USA].
   The sole species, Z. pulverulenta, appears weakly self-compatible and
   partially self-pollinating. Fruit set was reduced, but not eliminated by
   excluding insect floral visitors. Insect visitors were collected and
   their pollen loads examined for Zenobia and foreign pollen. Analysis of
   these pollen loads and observations of insect-foraging behavior indicate
   that workers of 3 spp. of bumblebee (Bombus bimaculatus, B. griseocollis
   and B. impatiens) are the principal pollinators of Zenobia. Pollinator
   density and composition appear strongly influenced by the habitats in
   which Zenobia grows. Pollen and nectar serve as the primary rewards for
   pollinators.},
