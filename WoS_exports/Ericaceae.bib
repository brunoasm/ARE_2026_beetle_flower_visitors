@article{ WOS:A1981MV21500002,
Author = {MIRICK, S and QUINN, JA},
Title = {SOME OBSERVATIONS ON THE REPRODUCTIVE-BIOLOGY OF GAULTHERIA-PROCUMBENS
   (ERICACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1981},
Volume = {68},
Number = {10},
Pages = {1298-1305},
Abstract = {The pollination and fruit production of G. procumbens L. (Ericaceae), an
   evergreen sub-shrub, were studied in 5 woodland sites in New Jersey and
   1 in northeastern Pennsylvania {[}USA]. Pollinator exclusion methods at
   3 of the sites produced no consistent differences in fruit and seed set
   between enclosed plants and controls. Insect pollinators, almost
   exclusively bumblebees, were sparse at all sites; visitation rates were
   .apprx. 0.01 bee visits/flower per h. All fruits examined contained at
   least 35 seeds, but .apprx. 1/2 of the pistils examined, from
   open-pollinated plants, did not contain enough pollen tetrads on their
   stigmatic surfaces to fertilize this number of ovules. The low average
   fruit set of 8.2\% on open-pollinated plants was due more to the high
   mortality of buds prior to anthesis than to inadequate pollination. Bud
   mortality was high and fruit set low in 3 yr of observations at various
   study sites, indicating that this may be a general pattern for the
   species in northeastern USA and adjacent Canada. The amount of sexual
   reproduction showed no consistent relationship to stem density.},
