   Univ Vienna, Inst Bot, A-1030 Vienna, Austria.
   Univ Vienna, Bot Garden, A-1030 Vienna, Austria.},
DOI = {10.1007/BF00984107},
ISSN = {0378-2697},
Keywords = {angiosperms; Echium; Esterhazya; pollination ecology; anthers; pollen;
   secondary pollen presentation; sporopollenin; viscin threads},
Keywords-Plus = {POLLEN-CONNECTING THREADS; STAMEN STRUCTURES; ERICACEAE; PATTERNS;
