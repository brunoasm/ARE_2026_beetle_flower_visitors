@article{ WOS:A1976BM80900001,
Author = {STEVENS, PF},
Title = {ALTITUDINAL AND GEOGRAPHICAL DISTRIBUTIONS OF FLOWER TYPES IN
   RHODODENDRON SECTION VIREYA, ESPECIALLY IN PAPUASIAN SPECIES, AND THEIR
   SIGNIFICANCE},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1976},
Volume = {72},
Number = {1},
Pages = {1-33},
Abstract = {Most species of Rhododendron section Vireya from Papuasia can be
   assigned to well-marked flower types, 127 spp. being placed in 5 of
   these types. Two of the main types may be pollinated mainly by birds, 1
   by sphingid moths and 1 by butterflies. Above 3000 m red-flowered
   species greatly predominate over those with other colors in Papuasia,
   and also through much of Malesia; the relationship between ornithophily
   and this correlation is discussed. The distribution of flower types
   within supraspecific taxa suggests that some rearrangement of the latter
   may be necessary; some flower types are demonstrably polyphyletic. In W
   Malesia psecies with flower color other than red, not or slightly
   zygomorphic flowers and relatively longer corolla lobes are commoner
   than within Papuasia; it appears that section Vireya is, florally at
   least, most specialized in this latter area. Flower type and pollinators
   in section Vireya are related to those in the rest of the genus and the
   adoption of ornithophily has probably been an important factor in the
   success of the Ericaceae as a whole in tropical montane areas.},
