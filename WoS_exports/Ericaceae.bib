@article{ WOS:000235210600016,
Author = {Kjonaas, C and Rengifo, C},
Title = {Differential effects of avian nectar-robbing on fruit set of two
   Venezuelan Andean cloud forest plants},
Journal = {BIOTROPICA},
Year = {2006},
Volume = {38},
Number = {2},
Pages = {276-279},
Month = {MAR},
Abstract = {We quantified nectar-robbing in two ornithophilus plant species by
   marking and monitoring robbed flowers and unrobbed flowers of each plant
   until fruit production. Significantly more marked unrobbed Cavendishia
   pubescens flowers successfully matured fruits than their robbed
   counterparts, while fruit set did not differ significantly between
   robbed and unrobbed flowers of Fuchsia venusta. In C. pubescens, birds
   of species known to be legitimate visitors sometimes behaved as
   secondary nectar robbers; conspecific birds handled flowers of F.
   venusta consistently. This behavioral change may contribute to the
   observed negative effect of nectar-robbing on reproduction of C.
   pubescens.},
