Address = {PO BOX 500, 3001 LEUVEN 1, BELGIUM},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Rao, S (Corresponding Author), Oregon State Univ, Dept Crop \& Soil Sci, Corvallis, OR 97331 USA.
