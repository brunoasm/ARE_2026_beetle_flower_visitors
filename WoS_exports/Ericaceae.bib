@article{ WOS:A1985ADE4500013,
Author = {CANE, JH and EICKWORT, GC and WESLEY, FR and SPIELHOLZ, J},
Title = {POLLINATION ECOLOGY OF VACCINIUM-STAMINEUM (ERICACEAE, VACCINIOIDEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1985},
Volume = {72},
Number = {1},
Pages = {135-142},
Abstract = {Successful fruit set by deerberry, V. stamineum (Ericaceae:
   Vaccinioideae) requires floral visitation by insects, and in particular
   by bees that collect its pollen by sonication of anthers
   (buzz-pollination). A diversity of bees visit deerberry flowers, but
   most species are either infrequent, polylectic (broad host range for
   pollen) or principally nectar-seeking and so are unimportant as pollen
   vectors. Both sexes of the solitary, oligolectic bee Melitta americana
   (Melittidae) are abundant at flowering deerberry bushes in central New
   York State {[}USA]. Female M. americana sonicate the deerberry anthers
   while imbibing nectar and carry virtually pure scopal loads of deerberry
   pollen, unlike the other common visitor, Xylocopa virginica
   (Anthophoridae). Comparative analyses of bee abundances,
   buzz-pollination behaviors, pollen fidelities and pollination
   efficiencies, all indicate that M. americana is the primary pollinator
   of V. stamineum.},
