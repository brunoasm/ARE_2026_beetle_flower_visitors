Type = {Article},
Language = {English},
Affiliation = {Hirao, AS (Corresponding Author), Hokkaido Univ, Grad Sch Environm Earth Sci, Sapporo, Hokkaido 0600810, Japan.
   Hokkaido Univ, Grad Sch Environm Earth Sci, Sapporo, Hokkaido 0600810, Japan.
