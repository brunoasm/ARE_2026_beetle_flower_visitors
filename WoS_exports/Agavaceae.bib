Address = {2-6 BOUNDARY ROW, LONDON, ENGLAND SE1 8HN},
Type = {Article},
Language = {English},
Affiliation = {Ziv, Y (Corresponding Author), UNIV ARIZONA,DEPT ECOL \& EVOLUT BIOL,TUCSON,AZ 85721, USA.},
DOI = {10.1007/BF01239347},
ISSN = {0269-7653},
Keywords = {obligate mutualism; yucca, yucca moth interaction; seed predation;
   resource limitation; pollination},
Keywords-Plus = {WHIPPLEI AGAVACEAE; FRUIT; PREDATION; BEHAVIOR},
Research-Areas = {Environmental Sciences \& Ecology; Evolutionary Biology; Genetics \&
   Heredity},
Web-of-Science-Categories  = {Ecology; Evolutionary Biology; Genetics \& Heredity},
