Volume = {63},
Number = {3},
Pages = {137-140},
Month = {OCT 22},
Abstract = {Fruits of most fleshy-fruited yuccas host non-pollinating bogus yucca
   moths. A peculiar exception has been the widespread and abundant Yucca
   schidigera Roezl ex Ortgies (mojave yucca), where extensive search has
   failed to document a resident species. Here we report on the discovery
