@article{ WOS:A1981LR37200016,
Author = {AKER, CL and UDOVIC, D},
Title = {OVIPOSITION AND POLLINATION BEHAVIOR OF THE YUCCA MOTH,
   TEGETICULA-MACULATA (LEPIDOPTERA, PRODOXIDAE), AND ITS RELATION TO THE
   REPRODUCTIVE-BIOLOGY OF YUCCA-WHIPPLEI (AGAVACEAE)},
Journal = {OECOLOGIA},
Year = {1981},
Volume = {49},
Number = {1},
Pages = {96-101},
Abstract = {The adult behavior of the yucca moth, T. maculata Riley, is finely tuned
   to the reproductive biology of its specific host plant. Y. whipplei
   Torr. The female moths oviposit in the ovaries of the yucca flowers and
   actively pollinate the same flowers with pollen which they have
   collected previously. The selective pressures imposed on the moths by
   the plant''s need for pollen transfer via an insect pollinating agent,
   its partial self-incompatibility and its ability to regulate seed set by
   aborting excess fruits, have molded the pollinator''s behavior in such a
   way that its offspring have the greatest possible chance of surviving
   through the early larval stages. The evolutionary responses of the
   pollinator include the following: the female moths consistently fly to a
   different plant after collecting pollen, thus insuring
   cross-fertilization of the flowers; they always pollinate after
   depositing the 1st egg in a flower but not necessarily after subsequent
   ovipositions; and females emerging near the end of the flowering season
   frequently oviposit in developing seed pods, as opposed to open flowers
   which are more likely to be aborted by the plants.},
Publisher = {SPRINGER},
Address = {ONE NEW YORK PLAZA, SUITE 4600, NEW YORK, NY, UNITED STATES},
