@article{ WOS:A1981LT48300017,
Author = {UDOVIC, D and AKER, C},
Title = {FRUIT ABORTION AND THE REGULATION OF FRUIT NUMBER IN YUCCA-WHIPPLEI},
Journal = {OECOLOGIA},
Year = {1981},
Volume = {49},
Number = {2},
Pages = {245-248},
Abstract = {Flowering and fruiting patterns of Y. whipplei (Agavaceae), a monocarpic
   perennial of the southern California {[}USA] chaparral, were studied to
   determine the role of fruit abortion in the regulation of seed yield.
   Data on reproductive expenditure, fruit abortion and fruit maturation
   were obtained for 108 flowering individuals at 2 sites. The proportion
   of flowers maturing fruits was less than 10\% at both sites.
   Inflorescences produced an average of 2045 .+-. 111 and 1743 .+-. 77
   flowers at the 2 sites, initiated an average of 439 .+-. 48 and 304 .+-.
   21 fruits and matured an average of 194 .+-. 16 and 162 .+-. 10 fruits,
   respectively. Overall, 51\% of the fruits which initiated development
   were aborted and abscized in an early stage of development. The
   hypothesis that fruit abortion serves to regulate seed yield, matching
   fruit production to the available resources, yields 3 predictions which
   are borne out by our findings: the proportion of initiated fruits which
   abort is an increasing function of the number of fruits initiated, the
   number of fruits matured is an increasing function of estimates of the
   amount of resources available to support fruits and on any
   inflorescence, fruits initiated early have a lower probability of
   aborting than fruits initiated late. Low fruit set in Y. whipplei may be
   caused by shortage of resources to support developing fruits, rather
   than by a shortage of pollinators. Possible explanations of the adaptive
   significance of regulating maternal investment via fruit abortion are
   mentioned but experimentation is required before any conclusions can be
   drawn.},
