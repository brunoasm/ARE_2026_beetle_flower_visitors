@article{ WOS:000179835500002,
Author = {Slauson, LA},
Title = {Insights on the pollination biology of <i>Agave</i> (Agavaceae)},
Journal = {HASELTONIA},
Year = {2001},
Number = {8},
Pages = {10-23},
Abstract = {Despite the fact that agaves, or ``century plants,{''} have long been
   suspected as key-stone species in many ecological communities, few
   studies have been published regarding their pollination biology. This
   paper provides an overview of our current knowledge of Agave pollination
   biology, reviewing floral characteristics, breeding systems, pollination
   syndromes, pollinators, and pollinator effectiveness. Although it has
   commonly been assumed that particulate agaves (subgenus Agave) coevolved
   with bats, few species appear to be strictly adapted to bats. Instead,
   most agaves, including spicate species (subgenus Littaea), appear to
   have evolved floral traits that are general enough to allow for multiple
   pollinators. This may be a distinct advantage in semel-parous species
   that occur in a variety of habitats, have large geographical ranges, and
   experience pollinator variability.},
