EISSN = {1558-5646},
Keywords = {Agavaceae; breeding structure; correlated mating; mutualism; paternity
   analysis; Tegeticula yuccasella; Yucca filamentosa; yucca moth},
Keywords-Plus = {GENE FLOW; PATERNITY ANALYSIS; MUTUALISM; POLLEN; MOTHS; CONSEQUENCES;
   DISPERSAL; GLAUCA; PLANT},
