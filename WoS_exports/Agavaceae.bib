Title = {DIET OVERLAP IN LEPTONYCTERIS-CURASOAE AND GLOSSOPHAGA-LONGIROSTRIS
   (MAMMALIA, CHIROPTERA)},
Journal = {REVISTA DE BIOLOGIA TROPICAL},
Year = {1993},
Volume = {41},
Number = {3A},
Pages = {529-532},
Month = {DEC},
Abstract = {The assessment of fecal samples and microscopic slides made from pollen
   taken from the fur of 53 specimens of Leptonycteris curasoae captured in
   a semiarid shrub area in Merida State, Venezuela, show that this bat
   eats polen of Cactaceae and Agavaceae, and fruits of the columnar cacti
   Stenocereus griseus and Subpilocereus repandus. Although L. curasoae
   highly overlaps diet with Glossophaga longirostris (Sq=82\%), capture
   data suggest that L. curasoae occurrs in the area only when food
   availability is highest. Thus no significant interspecific competition
   seems to exist. Possibly. L. curasoae migrate locally according to S.
   griseus flower availability and the flowering of Agavaceae in other
   sites of the arid zone of Lagunillas, where these am most abundant.},
