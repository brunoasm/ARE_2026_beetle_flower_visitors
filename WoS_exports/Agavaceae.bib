   Univ Miami, US Geol Survey, Biol Resources Div, Dept Biol, Coral Gables, FL 33124 USA.},
DOI = {10.1006/tpbi.2001.1571},
ISSN = {0040-5809},
Keywords = {pollinating seed-eaters; fruit abortion; adaptive dynamics; mutualism;
   evolutionarily stable strategy; benefits; costs; population size},
