DOI = {10.1111/j.1420-9101.2010.02120.x},
ISSN = {1010-061X},
EISSN = {1420-9101},
Keywords = {codivergence; coevolution; insects; plants; pollination; speciation},
Keywords-Plus = {YUCCA-BREVIFOLIA; JOSHUA TREE; COEVOLUTION; DIVERGENCE; SPECIATION;
