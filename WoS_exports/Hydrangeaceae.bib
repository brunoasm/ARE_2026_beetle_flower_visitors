@inproceedings{ WOS:000378634700043,
Author = {Wiedemann, M. and Meinl, K. and Samain, M. S. and Klocke, E. and Abel,
   S. and Wanke, S.},
Editor = {VanHuylenbroeck, J and Dhooghe, E},
Title = {Intergeneric Hybrids between Species of <i>Hydrangea</i> and
   <i>Dichroa</i> - Their Germination In Vivo and In Vitro and Molecular
   Verification by RAPD Analysis},
Booktitle = {XXV INTERNATIONAL EUCARPIA SYMPOSIUM SECTION ORNAMENTALS: CROSSING
   BORDERS},
Series = {Acta Horticulturae},
Year = {2015},
Volume = {1087},
Pages = {333-338},
Note = {25th International EUCARPIA Symposium Section on Ornamentals - Crossing
   Borders, Melle, BELGIUM, JUN 28-JUL 02, 2015},
Organization = {Int Soc Hort Sci; EUCARPIA},
Abstract = {Hydrangea macrophylla (Thunb.) Ser. is a very popular pot plant with a
   long breeding history. The genetic background of today's hundreds of
   cultivars is rather narrow because they originate from only a few
   progenitors. In the past, H. serrata (Thunb.) Ser. was used to widen the
   gene pool of H. macrophylla for breeding initiatives as well as to
   increase the phenotypic diversity. Molecular phylogenetic studies
   demonstrated the close relationship of Dichroa Lour. and H. macrophylla
   as well as the paraphyly of Hydrangea s.l. (Hydrangeaceae tribe
   Hydrangeeae), which is opening new research avenues by widening the gene
   pool and phenotypic variability through hybridization. We realized first
   crossings between H. macrophylla as well as H. serrata cultivars with D.
   febrifuga (Lour.) or D. yunnanensis (S.M. Hwang.). Hand pollination was
   performed in late spring and summer 2013 and seeds were harvested from
   September 2013 to January 2014. The seed set varied depending on the
   parental partners. Macroscopically normal developed seeds and seeds
   where the seed number exceeded 30 per cross-combination were sown in
   peat soil in the first week of February 2014. In vitro germination was
   applied to few seeds obtained from eight cross-combinations. The best
   germination rate was observed with sterilized seeds after a treatment
   with 1.3 mg/L GA(3) and 1.0 mg/L KNO3 followed by germination on 1/2
   Gamborg B5-medium supplemented with 10 g/L sucrose and 0.13 mg/L GA(3).
   Plants originating from in vitro germination were successfully
   transferred to greenhouse cultivation. RAPD analysis performed on plants
   showing peculiar morphology confirmed that intergeneric hybrids between
   Dichroa and Hydrangea ssp. have been successfully generated by
   cross-breeding.},
Publisher = {INT SOC HORTICULTURAL SCIENCE},
Address = {PO BOX 500, 3001 LEUVEN 1, BELGIUM},
