ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {Butomus umbellatus; flowering rush; sexual reproduction; developmental
   assessment; developmental irregularities; abnormal embryo sacs; CLSM},
Keywords-Plus = {OVULE ABORTION; INBREEDING DEPRESSION; ARABIDOPSIS-THALIANA; LETHAL
   MUTANTS; SEED ABORTION; GENETIC LOAD; EMBRYO SAC; EVOLUTION; PLANTS;
   POLLINATION},
