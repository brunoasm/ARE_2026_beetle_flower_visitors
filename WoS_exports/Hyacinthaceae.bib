Title = {First record of pollination in the Afro-Eurasian <i>Dipcadi</i> Medik.
   (Hyacinthaceae): pollination of <i>D. brevifoliumi</i> by the owlet moth
   <i>Syngrapha circumflexa</i> (Noctuidae)},
