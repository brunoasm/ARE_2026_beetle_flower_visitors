   Celeste and Vujic, Ante},
Title = {DNA barcoding applied: identifying the larva of <i>Merodon avidus</i>
   (Diptera: Syrphidae)},
Journal = {ACTA ENTOMOLOGICA MUSEI NATIONALIS PRAGAE},
Year = {2014},
Volume = {54},
Number = {2},
Pages = {741-757},
Abstract = {The immature stages of phytophagous hoverflies and their plant hosts are
   mostly unknown. This paper describes the larva of Merodon avidus Rossi,
   1790 (Diptera: Sylphidae), based on material collected from Derdap
   National Park in Serbia. Larvae were found in the bulbs of Ornithogalum
   L. (Hyacinthaceae) and in the surrounding soil. DNA barcoding was used
   to identify the species and scanning electron microscopy was used to
   describe the morphological characteristics of Merodon avidus. Reared
   material previously identified as Merodon constans (Rossi, 1794) is
   shown to belong to M. hurkmansi Marcos-Garcia, Vujie \& Mengual, 2007.},
