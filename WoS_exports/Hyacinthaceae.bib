@article{ WOS:000082048800010,
Author = {Corbet, SA},
Title = {Spatiotemporal patterns in the flowering of bluebell, <i>Hyacinthoides
   non-scripta</i> (Hyacinthaceae)},
Journal = {FLORA},
Year = {1999},
Volume = {194},
Number = {3},
Pages = {345-356},
Month = {JUL},
Abstract = {It has been suggested that systematic upward foraging by pollinators may
   sometimes help to reduce the geitonogamy: xenogamy ratio on a
   protandrous raceme with a large daily inflorescence size. This effect
   will depend on the spatiotemporal distribution of floral gender on the
   raceme. This paper describes the spatiotemporal patterns of male and
   female floral gender, in relation to pollinator movement patterns on a
   raceme, in bluebell, Hyacinthoides non-scripta (Hyacinthaceae), a
   species in which apical drooping reverses the vertical sequence of
   flower age on a raceme.
   Individual flowers began to fade about seven days after bud opening, but
   remained blue for about 21 days, offering nectar and pollen for most of
   that time. A typical raceme bore flowers for about 40 days. Flowers were
   present in the valley woodland population for more than 60 days.
   Stigmatic receptivity and release of viable pollen began before the
   corolla was fully open. Experiments indicated that stigmatic receptivity
   ended soon after the perianth colour began to fade, but that some viable
   pollen remained available for much longer; and that viable pollen was
   present in all stages of a flower's life. As the wave of flowering
   proceeds up a raceme, the flowers at the leading edge exhibit both male
   and female function. At the trailing (normally lower) edge, male-phase
   flowers probably extend beyond female-phase flowers. The implications
   for geitonogamy of the large `daily inflorescence size' and the reversal
   of the flower-age/height sequence on the drooping raceme tips are
   discussed in the context of probable movement patterns of potential
   pollinators.
   The terminal flowers on a raceme had smaller gynoecia with fewer ovules
   than basal flowers, and a lower probability of fruit set, attributed to
   resource preemption by basal flowers. They probably also had a lower
   probability of paternity because of the declining proportion of
   functionally female flowers in the population and perhaps because of
   reduced pollinator activity due to canopy closure in the wood.
   Spatiotemporal patterns of male and female reproductive success may vary
   with site and season in accord with weather-dependent fluctuations in
   pollinator activity.},
