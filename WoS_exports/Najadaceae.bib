   Natl Sci Museum, Tsukuba Bot Garden, Tsukuba, Ibaraki 3050005, Japan.
   Chiba Univ, Fac Hort, Lab Plant Morphol, Chiba, Japan.
   Univ Tokyo, Grad Sch Sci, Bot Gardens, Tokyo, Japan.},
DOI = {10.1007/s10265-004-0155-5},
ISSN = {0918-9440},
EISSN = {1618-0860},
Keywords = {exine; hydrocharitaceae; hydrophily; phylogeny; pollen; pollination},
