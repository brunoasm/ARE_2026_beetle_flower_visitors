@article{ WOS:000173005800003,
Author = {Kocyan, A and Endress, PK},
Title = {Floral structure and development and systematic aspects of some `lower'
   Asparagales},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2001},
Volume = {229},
Number = {3-4},
Pages = {187-216},
Abstract = {Floral structure and development of representatives of Asteliaceae,
   Blandfordiaceae, Boryaceae, Doryanthaceae, and Hypoxidaceae, all members
   of the `lower' Asparagales, were studied comparatively. The results arc
   discussed in the light Of new molecular Systematic Studies, but also
   with regard to established morphological characters in related groups.
   Stamen shape varies considerably within and between taxa: the shape of
   anthers is from X-shaped, sagittate to non-sagittate, they are either
   latrorse or introrse, basifixed, centrifixed or dorsifixed. Gynoccia are
   syncarpous up to the stigmatic region in all taxa. Ovaries of
   Doryanthaccae and Hypoxidaceae are inferior, but they are superior in
   Asteliaceae, Blandfordiaceae and Boryaceae. All ovaries have at least it
   short synascidiate zone. With the exception of Astelia alpina
   (Asteliaceae), the ovaries are trilocular. Ovaries of Asteliaceae
   contain Mucilage, which is secreted from trichomes on the funicle and on
   the placenta. Although flowers are polysymmetric at anthesis, they are
   monosymmetric in earliest stages with a developmental gradient from
   adaxial to abaxial. Perianth organs arise individually from either a
   concave (taxa with inferior ovary) or convex (taxa with superior ovary)
   apex. Hypoxidaceae have pollen flowers with free stamens. One species,
   Curculigo capitulata, has Solanum-type flowers with postgenitally united
   stamens, It is most probably pollinated by buzzing bees. All other taxa
   have nectariferous flowers with internal or external septal nectaries.},
Publisher = {SPRINGER WIEN},
Address = {SACHSENPLATZ 4-6, PO BOX 89, A-1201 WIEN, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {Univ Zurich, Inst Systemat Bot, Zollikerstr 107, CH-8008 Zurich, Switzerland.
   Univ Zurich, Inst Systemat Bot, CH-8008 Zurich, Switzerland.},
DOI = {10.1007/s006060170011},
ISSN = {0378-2697},
EISSN = {2199-6881},
Keywords = {Asparagales; Asteliaceae; Blandfordiaceae; Boryaceae; Doryanthaceae;
   Hypoxidaceae; floral structure; floral development; septal nectaries;
   ovary position},
Keywords-Plus = {ORCHID FLOWERS; ANATOMY; MICROSPOROGENESIS; MORPHOLOGY; PHYLOGENY;
   DIVERSITY; ECOLOGY; NECTAR},
