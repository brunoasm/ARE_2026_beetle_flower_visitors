
@article{ WOS:A1996UL99900016,
Author = {Beever, RE and Parkes, SL},
Title = {Self-incompatibility in Cordyline australis (Asteliaceae)},
Journal = {NEW ZEALAND JOURNAL OF BOTANY},
Year = {1996},
Volume = {34},
Number = {1},
Pages = {135-137},
Month = {MAR},
Abstract = {Controlled pollination among four individuals of Cordyline australis
   (cabbage tree, ti kouka) demonstrate that this species is
   self-incompatible, setting little or no seed when self-pollinated. Seed
   production per fruit in wild trees was less than half that observed
   following artificial pollination. Parthenocarpic fruit production is
   recorded in some wild populations.},
