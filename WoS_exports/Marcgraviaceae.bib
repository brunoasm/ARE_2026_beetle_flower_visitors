@article{ WOS:000240232200007,
Author = {Tschapka, Marco and Dressler, Stefan and von Helversen, Otto},
Title = {Bat visits to <i>Marcgravia pittieri</i> and notes on the inflorescence
   diversity within the genus <i>Marcgravia</i> (Marcgraviaceae)},
Journal = {FLORA},
Year = {2006},
Volume = {201},
Number = {5},
Pages = {383-388},
Abstract = {We report bat visits to the inflorescences of Marcgraviapittieri. The
   animals were videotaped visiting the nectaries of the inflorescences in
   short hovering flight. Nectarivorous bats caught in front of the
   inflorescences were Anoura cultrata and Hylonycteris underwoodi (both
   Phyllostomidae: Glossophaginae). Furthermore, we provide a short
   overview on inflorescence architecture within the genus Marcgravia with
   a special focus on functional morphology in chiropterophilous species.
