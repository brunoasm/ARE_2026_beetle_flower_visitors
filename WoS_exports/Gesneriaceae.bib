Affiliation = {Wang, YQ (Corresponding Author), South China Normal Univ, Sch Life Sci, Guangdong Prov Key Lab Biotechnol Plant Dev, Guangzhou 510631, Peoples R China.
   Fu, Qiong; Lu, Guo-Hui; Fu, Yu-Hui; Wang, Ying-Qiang, South China Normal Univ, Sch Life Sci, Guangdong Prov Key Lab Biotechnol Plant Dev, Guangzhou 510631, Peoples R China.
   Wang, Ying-Qiang, South China Normal Univ, Guangzhou Key Lab Subtrop Biodivers \& Biomonitori, Sch Life Sci, Guangzhou, Peoples R China.},
