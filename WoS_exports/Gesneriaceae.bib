@article{ WOS:000575854000007,
Author = {De Bastiani, Aline and Nervo, Michelle Helena and Singer, Rodrigo B. and
   Buzatto, Cristiano Roberto},
Title = {One or two species? Floral characteristics and pollination biology aid
   in <i>Sinningia</i> (Gesneriaceae) species circumscription},
Journal = {FLORA},
Year = {2020},
Volume = {271},
Month = {OCT},
Abstract = {Plant species are mostly delimited solely by morphological
   characteristics, but this method has drawbacks and may result in
   identification errors. Pollination and ecological speciation studies may
   serve as additional tools for species delimitation. Sinningia lutea and
   S. allagophylla are species hitherto considered synonyms, and recent
   accounts suggest that the taxa present overlapping morphological
   features. Here we seek to improve the taxonomic circumscription of both
   taxa through the comparative study of floral traits, pollination and
   breeding systems. Our results indicate significant differences in
   morphological characters and confirm that the two species are pollinated
   by different animals. Therefore, both species are ecologically isolated
   and can be considered independent species. Our results highlight the
   potential of supplementing morphological analyses with ecological data
   to establish correct taxonomic relationships.},
Publisher = {ELSEVIER GMBH},
Address = {HACKERBRUCKE 6, 80335 MUNICH, GERMANY},
Type = {Article},
Language = {English},
Affiliation = {Buzatto, CR (Corresponding Author), Univ Passo Fundo, Inst Ciencias Biol, Programa Posgrad Ciencias Ambientais, Campus1,BR 285, BR-99052900 Passo Fundo, RS, Brazil.
