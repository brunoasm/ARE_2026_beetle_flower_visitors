DOI = {10.2307/2388301},
ISSN = {0006-3606},
Keywords-Plus = {FORSK DEN HARTOG; SUBMARINE POLLINATION; PACHYRHIZUM DENHARTOG;
   CONVERGENT EVOLUTION; POLLEN DEVELOPMENT; HYDROCHARITACEAE; MORPHOLOGY;
   REPRODUCTION; AUSTRALIA; ECOLOGY},
Research-Areas = {Environmental Sciences \& Ecology},
