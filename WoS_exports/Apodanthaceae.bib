ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Apodanthaceae; dioecy; field observations; fly pollination; phylogeny;
   sexual system},
Keywords-Plus = {SEED DISPERSAL; PLASTID GENOME; DNA-SEQUENCES; PHYLOGENY; DIOECY;
   CUCURBITALES; CYNOMORIUM; ORIGINS; CUSCUTA; DIVERSIFICATION},
