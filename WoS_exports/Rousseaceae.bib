   Hansen, Dennis M.; Mueller, Christine B., Univ Zurich, Inst Environm Sci, CH-8057 Zurich, Switzerland.},
DOI = {10.1086/593050},
ISSN = {1058-5893},
Keywords = {Mauritius; Phelsuma; gecko; plant-lizard interactions; aggregated
   pollen; conservation},
