   Univ Mainz, Inst Spezielle Bot \& Bot Garten, D-55099 Mainz, Germany.
   Landesamt Umweltschutz Sachsen Anhalt, D-06116 Halle Saale, Germany.},
DOI = {10.1034/j.1600-0587.2002.250604.x},
ISSN = {0906-7590},
Keywords-Plus = {MYRMICA-SABULETI HYMENOPTERA; FOOD RECRUITMENT; MARKERS;
   DIFFERENTIATION; FORMICIDAE; ANT; CONSEQUENCES; CONSERVATION;
   BIODIVERSITY; BEHAVIOR},
