DA = {2024-12-22},
}

@article{ WOS:A1978EZ51700002,
Author = {HESSE, M},
Title = {DEVELOPMENT AND ULTRASTRUCTURE OF POLLENKITT IN TILIA (TILIACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1978},
Volume = {129},
Number = {1-2},
Pages = {13-30},
Abstract = {Transfer of fresh pollen either by wind or by insects is strongly
   related to its degree of stickiness. The sticky substances involved
   should be understood as pollenkitt. Ultrastructural investigations
   indicate that the sticky pollen of entomophilous angiosperms (Hamamelis
   vernalis and H. virginiana and Corylopsis platypetala) results from the
   deposition of usually electron-dense, homogeneous pollenkitt mainly on
   the outside layer of the exine. In contrast, the pollen of anemophilous
