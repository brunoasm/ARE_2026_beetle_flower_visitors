Keywords = {reproductive success; seed set; seed abortion; Triumfetta semitriloba;
   Tiliaceae; weed},
Keywords-Plus = {FLOWERING PHENOLOGY; PROTEACEAE; POLEMONIUM; PATTERNS; PLANTS; SIZE},
