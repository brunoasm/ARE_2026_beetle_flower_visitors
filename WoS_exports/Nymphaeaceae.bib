@article{ WOS:A1983RC45000005,
Author = {SCHNEIDER, EL},
Title = {GROSS MORPHOLOGY AND FLORAL BIOLOGY OF ONDINEA-PURPUREA DENHARTOG},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1983},
Volume = {31},
Number = {4},
Pages = {371-382},
Abstract = {The floral biology of O. purpurea, consisting of an apetalous subspecies
   and a newly discovered petaloid subspecies, was investigated. Anthesis
   occurs over a 3-day period. First-day flowers are protogynous and
   characterized by colorful reflexed perianth and staminal parts. The
   pollen-receptive stigmas of 1st-day flowers secrete a fluid that fills
   the small stigmatic cup. As potential pollinators are attracted and
   attempt to land on the distally exposed gynoecium, they contact the
   stigmatic fluid which loosens pollen from the insect''s body and
   pollination is achieved. Second- and 3rd-day flowers are functionally
   staminate. On the basis of comparative reproductive anatomy and
   pollination syndromes the placement of Ondinea in the Nymphaeaceae s.s.
   is supported.},
