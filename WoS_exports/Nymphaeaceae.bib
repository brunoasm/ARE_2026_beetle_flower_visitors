@article{ WOS:000309556300012,
Author = {Lima de Sousa, Danilo Jose and Matias, Ligia Queiroz},
Title = {SYNOPSIS OF GENUS Nymphaea L. (Nymphaeaceae) IN STATE OF CEARA},
Journal = {REVISTA CAATINGA},
Year = {2012},
Volume = {25},
Number = {3},
Pages = {72-78},
Abstract = {The family Nymphaeaceae is represented by aquatic rhizomatic herbs,
   rooted in the substrate, with floating long petiolate leaves. Its
   flowers are solitary, and anthesis can be nocturnal and diurnal,
   pollinated by beetles. The family has six genus, of which Nymphaea and
   Victoria occurs in the neotropical region. Victoria predominates in the
   Brazilian Amazon and Pantanal and the Nymphaea is represented by 18
   species distributed throughout the country. The floristic study included
   the analysis of specimens collected on expeditions and materials
   deposited in Herbariums, in a total of 69 specimens. The identification
   was made by consulting specific bibliography. The information obtained
   enabled the preparation of an identification key, illustrations of
   important morphological characters, significant as evidence Taxonomy,
   commentaries on the geographical distribution and discussion of relevant
   issues to taxons identification. For the state of Ceara were found six
   species: N. amazonum, N. pulchella, N. Jamesoniana, N. lasiophylla, N.
   lingulata, N. rudgeana and N. tenerinervia. The last two populations
   presented only in coastal environments. N. lingulata, N. pulchella and
