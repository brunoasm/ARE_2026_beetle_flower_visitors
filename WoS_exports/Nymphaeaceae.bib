@article{ WOS:A1982NB89400005,
Author = {SCHNEIDER, EL},
Title = {NOTES ON THE FLORAL BIOLOGY OF NYMPHAEA-ELEGANS (NYMPHAEACEAE) IN TEXAS},
Journal = {AQUATIC BOTANY},
Year = {1982},
Volume = {12},
Number = {2},
Pages = {197-200},
Abstract = {Various aspects of the pollination biology and floral behavior of N.
   elegans Hooker (Nymphaeaceae) are described. Flowers open each morning
   for 3 successive days. First-day flowers are protogynous with the
   stigmata secreting a fluid which fills the perigynous cup. As potential
   pollen-covered pollinators are attracted and enter 1st-day flowers, they
   land on the vertical, but flexible, inner stamens which bend and the
   insects fall into the stigmatic fluid. The stigmatic fluid washes pollen
   from the insects and pollination is achieved. Second- and 3rd-day
   flowers are functionally staminate, lacking the stigmatic fluid. The
   pollination biology of N. elegans is compared to the pollination
   syndromes described in other species of Nymphaea. {[}N. stellata, N.
   citrina, N. colorata, N. gigantea, N. micrantha, N. zanzibariensis, N.
   capensis, N. ampla, N. tuberosa, N. odorata, N. tetragona, N. blanda
   var. fenzliana, N. rudgeana and N. amazonum].},
