DOI = {10.1007/BF00984392},
ISSN = {0378-2697},
Keywords = {Nymphaeaceae; Nuphar lutea; N-pumila; Donacia; Hydrellia; Notophila;
   Scatophagidae; Ephydridae; pollination; sympatry; allopatry;
   self-compatibility},
