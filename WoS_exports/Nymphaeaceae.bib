Year = {1991},
Volume = {19},
Number = {7},
Pages = {535-539},
Abstract = {Four esters, together with free benzyl alcohol were recognized as the
   main components of the fragrance of Victoria. The compounds were methyl
   2-methylbutyrate, methyl tiglate, benzyl 2-methylbutyrate and benzyl
   tiglate. A number of other methyl and benzyl esters were recognized but
   at much lower concentrations. There were quantitative differences in the
   levels of some compounds from intact flowers in contrast with those
   detached from the plant.},
