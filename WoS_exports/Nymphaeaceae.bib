@article{ WOS:A1980JG94900007,
Author = {SCHNEIDER, EL and BUCHANAN, JD},
Title = {MORPHOLOGICAL-STUDIES OF THE NYMPHAEACEAE .11. FLORAL BIOLOGY OF
   NELUMBO-PENTAPETALA},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1980},
Volume = {67},
Number = {2},
Pages = {182-193},
Abstract = {The floral biology of N. pentapetala (Walter) Fernald, the American
   lotus, native to Texas {[}USA], was investigated. Anthesis occurs over 3
   consecutive days with flowers opening each morning and closing around
   noon. First-day flowers are protogynous with the perianth parts
   partially expanded so that pollen-covered insects which are attracted by
   floral color and the intense fruity odor (diffused with the aid of
   increased floral temperature) are directed on to flattened receptacle (=
   carpellary receptacle) from which the receptive stigmas protrude, thus
   accomplishing pollination. During the 2nd morning anther dehiscence
   begins and insects which visit and forage within the flower become
   covered with pollen and typically crawl over the still receptive stigmas
   achieving facilitated self-pollination (indirect autogamy). By
   mid-morning of the 2nd day the stigmas dry and become non-receptive to
   pollen. During the 3rd day of anthesis perianth and staminal parts
   quickly abscise and over the period of a few weeks the receptacle and
   enclosed fruits mature. In most populations studied, Hymenoptera (e.g.,
   Lasioglossum spp. and Apis mellifera) were the most abundant and
   effective pollinators. In some populations Coleoptera (e.g.,
   Chauliognathus) were also numerous and effective pollinators. The
   overall floral structure (e.g., large numbers of stamens, masses of
   pollen, staminal appendages) are adaptations which facilitate the
   pollination of Nelumbo by beetles.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
