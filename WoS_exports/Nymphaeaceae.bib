@article{ WOS:A1991GW44600002,
Author = {KITE, G and REYNOLDS, T and PRANCE, GT},
Title = {POTENTIAL POLLINATOR-ATTRACTING CHEMICALS FROM VICTORIA (NYMPHAEACEAE)},
