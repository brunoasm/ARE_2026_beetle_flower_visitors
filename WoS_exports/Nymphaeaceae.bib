DOI = {10.1093/aob/mcp173},
ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {Nelumbo nucifera; beetle pollinated; pollination syndrome; effective
   pollinator; generalized flower; thermoregulation; Nelumbonaceae},
Keywords-Plus = {FLOWERS; BIOLOGY; NYMPHAEACEAE; SYSTEMS; POLLEN; SPECIALIZATION;
   EVOLUTION; BEETLES; BEES; TEMPERATURE},
Research-Areas = {Plant Sciences},
