   Univ Copenhagen, Inst Bot, Bot Lab, DK-1123 Copenhagen K, Denmark.
   Smithsonian Inst, Natl Museum Nat Hist, Washington, DC 20560 USA.},
DOI = {10.1007/BF00985098},
ISSN = {0378-2697},
Keywords = {Heliconia; Foulehaio; honeyeaters; pollination; plant reproductive
   biology; nectar; breeding systems; Samoa; Fiji},
Keywords-Plus = {RAIN-FOREST; NECTAR; BIRDS},
Research-Areas = {Plant Sciences; Evolutionary Biology},
Web-of-Science-Categories  = {Plant Sciences; Evolutionary Biology},
