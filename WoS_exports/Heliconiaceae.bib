   Bacci, Jr., Mauricio and Pagnocca, Fernando C.},
Title = {<i>Candida heliconiae</i> sp nov., <i>Candida picinguabensis</i> sp nov
   and <i>Candida saopaulonensis</i> sp nov., three ascomycetous yeasts
   from <i>Heliconia velloziana</i> (<i>Heliconiaceae</i>)},
Journal = {INTERNATIONAL JOURNAL OF SYSTEMATIC AND EVOLUTIONARY MICROBIOLOGY},
