Keywords-Plus = {FLORAL NECTAR; ECOLOGICAL INTERACTIONS; REPRODUCTIVE-BIOLOGY; SECRETION
   PATTERN; ASCLEPIAS-SYRIACA; FRUIT PRODUCTION; ROBBERS; TRAITS; POLLEN;
   SCROPHULARIACEAE},
Research-Areas = {Environmental Sciences \& Ecology},
Web-of-Science-Categories  = {Ecology},
