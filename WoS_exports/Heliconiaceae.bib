@article{ WOS:000394429600003,
Author = {Missagia, Caio C. C. and Alves, Maria Alice S.},
Title = {Florivory and floral larceny by fly larvae decrease nectar availability
   and hummingbird foraging visits at <i>Heliconia</i> (Heliconiaceae)
   flowers},
Journal = {BIOTROPICA},
Year = {2017},
Volume = {49},
Number = {1},
Pages = {13-17},
Month = {JAN},
Abstract = {Insect larvae inhabit the corolla tubes of some Heliconia species
   (Heliconiaceae). In this study, we present the first evidence of the
   influence of these larvae on the pollination ecology of Heliconia
   plants. We provide experimental evidence that the flowers of Heliconia
   spathocircinata infested by flies have less nectar for pollinators and
   received fewer visits by hummingbird pollinators, in comparison with
   uninfested flowers.},
