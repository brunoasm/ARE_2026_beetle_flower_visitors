@article{ WOS:A1995QZ14900004,
Author = {ROSE, MJ and BARTHLOTT, W},
Title = {POLLEN-CONNECTING THREADS IN HELICONIA (HELICONIACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1995},
Volume = {195},
Number = {1-2},
Pages = {61-65},
Abstract = {In Heliconia thread-like structures connecting the pollen grains are
   described. These threads are decay products of the walls separating the
   pollen chambers, and products of the rupture of the mature anthers in
   the stomium region. The pliable cell threads mix with the pollen and
   entangle individual grains to form aggregates. This ensures that the
   pollen becomes embedded in the feathers or attached to the smooth,
   unsculptured beak of pollinating hummingbirds (Trochilidae).-Structure
   and origin of the Heliconia threads differ from those of the related
   genus Strelitzia (Strelitziaceae).},
