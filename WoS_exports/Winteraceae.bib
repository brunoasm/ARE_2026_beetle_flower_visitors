DOI = {10.1007/BF02214235},
ISSN = {0269-7653},
Keywords = {BET-HEDGING; DICHOGAMY; ENVIRONMENTAL FACTORS; FLOWERING; GENDER;
   PSEUDOWINTERA; WINTERACEAE},
Research-Areas = {Environmental Sciences \& Ecology; Evolutionary Biology; Genetics \&
