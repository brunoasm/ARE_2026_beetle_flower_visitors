Address = {OHIO STATE UNIV-DEPT BOTANY 1735 NEIL AVE, COLUMBUS, OH 43210},
Type = {Article},
Language = {English},
Affiliation = {Waycott, M (Corresponding Author), UNIV WESTERN AUSTRALIA,DEPT BOT,NEDLANDS,WA 6907,AUSTRALIA.},
DOI = {10.2307/2445898},
ISSN = {0002-9122},
Keywords = {genetic variation; hydrodynamics; hydrophily; mating system; Posidonia
   australis; Posidoniaceae; seagrass},
Keywords-Plus = {EICHHORNIA-PANICULATA PONTEDERIACEAE; POPULATION-STRUCTURE; OUTCROSSING
   RATES; INBREEDING DEPRESSION; GENETIC-VARIATION; EVOLUTION;
   POLYMORPHISMS; DIVERSITY; PROGRAMS; PLANTS},
Research-Areas = {Plant Sciences},
Web-of-Science-Categories  = {Plant Sciences},
