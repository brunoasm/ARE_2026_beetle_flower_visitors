@article{ WOS:000220490600005,
Author = {Bhattacharya, A and Mandal, S},
Title = {Pollination, pollen germination and stigma receptivity in <i>Moringa
   oleifera</i> Lamk},
Journal = {GRANA},
Year = {2004},
Volume = {43},
Number = {1},
Pages = {48-56},
Abstract = {Pollination, pollen germination and stigma receptivity of Moringa
   oleifera Lamk. (Moringaceae) arc examined. The zygomorphic gullet type
   flowers show a forenoon (6.00 h-12.00 h) pattern of anthesis after which
   pollen anthesis takes place (7.00 h-13.00 h). Each flower produces an
   average of 23525 pollen grains with an average 523 pollen grains per
   ovule. Natural populations yield an average of 10.28\% fruit and
   successful pollination of the flowers require a large number of insect
   (Orders Thysanoptera, Hymenoptera, Lepidoptera and Coleoptera)
   visitations. Among these Xylocopa is most Common. Flowers favour Cross
   pollination due to a delayed stigma receptivity. Biochemical studies of
   stigmas reveal that some extra proteins and esterases contribute towards
   its receptivity. The best medium for pollen viability test through in
   vitro pollen germination is 10\% sucrose Supplemented with 200 mug/ml
   H3BO3, where 94+/-2\% germination generates a Pollen tube with an
   average length of 1692 mum.},
