Language = {English},
Affiliation = {Decraene, LPR (Corresponding Author), Katholieke Univ Leuven, Inst Bot, Lab Plant Systemat, Kardinaal Mercierlaan 92, B-3001 Heverlee, Belgium.
   Katholieke Univ Leuven, Inst Bot, Lab Plant Systemat, B-3001 Heverlee, Belgium.},
DOI = {10.1139/b99-026},
ISSN = {0008-4026},
Keywords = {Adenia; Caricaceae; Moringa anatomy; calcium oxalate packages; dioecy;
   floral structure; nectaries; ontogeny; pollination; systematic
   relationships},
Keywords-Plus = {GLUCOSINOLATE-PRODUCING PLANTS; NUCLEOTIDE-SEQUENCES; TAXONOMIC
