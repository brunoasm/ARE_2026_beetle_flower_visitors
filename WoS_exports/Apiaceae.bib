@article{ WOS:000236756000011,
Author = {Kolodziejska-Degórska, I and Zych, M},
Title = {Bees substitute birds in pollination of ornitogamous climber <i>Campsis
   radicans</i> (L.) Seem. in Poland},
Journal = {ACTA SOCIETATIS BOTANICORUM POLONIAE},
Year = {2006},
Volume = {75},
Number = {1},
Pages = {79-85},
Abstract = {Campsis radicans is an attractive climber with typical omitogamous
   flowers, native to North America. In natural conditions this out-crossed
   plant is pollinated mostly by hummingbirds. In Poland, where C. radicans
   is cultivated as ornamental, it rarely sets seeds. The questions
   addressed in the present study were: (1) What animals pollinate its
   flowers in Poland?, and (2) What is the reason for infrequent fruit set?
   Field studies conducted in five localities in Poland showed that the
   principal pollinator is Apis mellifera, and the lack of seeds is usually
   caused by pollinator Limitation or absence of genetically different
   pollen donor plants.},
