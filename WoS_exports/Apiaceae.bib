Type = {Article},
Language = {English},
Affiliation = {Zych, M (Corresponding Author), Univ Warsaw, Bot Garden, Aleje Ujazdowskie 4, PL-00478 Warsaw, Poland.
   Stpiczynska, Malgorzata; Zych, Marcin, Univ Warsaw, Bot Garden, Fac Biol, PL-00478 Warsaw, Poland.
   Nepi, Massimo, Univ Siena, Dept Life Sci, I-53100 Siena, Italy.
   Zych, Marcin, Univ Warsaw, Bot Garden, PL-00478 Warsaw, Poland.},
DOI = {10.1007/s00606-014-1152-3},
ISSN = {0378-2697},
EISSN = {2199-6881},
Keywords = {Dichogamy; Fly pollination; Nectar secretion; Nectary structure; Sexual
   selection; Stylopodium},
