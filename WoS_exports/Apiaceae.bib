@article{ WOS:000835974600001,
Author = {Cortes-Fernandez, Ivan and Cerrato, Marcello Dante and Ribas-Serra,
   Arnau and Ferra, Xavier Canyelles and Gil-Vives, Lorenzo},
Title = {The role of <i>E. maritimum</i> (L.) in the dune pollination network of
   the Balearic Islands},
Journal = {ECOLOGY AND EVOLUTION},
Year = {2022},
Volume = {12},
Number = {8},
Month = {AUG},
Abstract = {Eryngium maritimum L. (Apiaceae) is a geophyte that inhabits in the
   dunes of the Mediterranean and Atlantic. Although it is a highly
   entomophilous species, there is little literature on its pollinator
   assemblage. The aim of this study is to analyze the role played by E.
   maritimum in the dune pollination network of the Balearic Islands, where
   there is an intense anthropogenic impact in its habitat. For this
   purpose, two populations located in the North and South of Mallorca were
   chosen, in which diurnal transects were carried out to observe and
   capture pollinators on 15 plant species during the anthesis period of E.
   maritimum. The flowering period of 10 plant species flowering at the
   same period than E. maritimum was analyzed to identify periods of
   competition. A total of 71 pollinator species were found, belonging to
   30 different families. Eryngium maritimum is a strongly generalist
   species, with a total of 45 pollinator species. Two new species, Odice
   blandula and Leucospis gigas, were found for the first time in Mallorca.
   In terms of pollinators, Teucrium dunense and Helichrysum stoechas are
   the most similar species to E. maritimum. However, analysis of phenology
   suggests that these three species have been able to decouple their
   blooms to avoid competition. The present study shows that E. maritimum
   plays an important role in the dune pollination network, being its
   anthesis located at the end of the dune flowering season, when there are
   no functionally similar species in flower.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Cortés-Fernández, I (Corresponding Author), Univ les Illes Baleares, Interdisciplinary Ecol Grp, Carretera Valldemossa, Palma de Mallorca 07122, Spain.
   Cortes-Fernandez, Ivan; Cerrato, Marcello Dante; Ribas-Serra, Arnau; Ferra, Xavier Canyelles; Gil-Vives, Lorenzo, Univ les Illes Baleares, Interdisciplinary Ecol Grp, Carretera Valldemossa, Palma de Mallorca 07122, Spain.},
DOI = {10.1002/ece3.9164},
Article-Number = {e9164},
ISSN = {2045-7758},
Keywords = {connectance; dune; Eryngium maritimum; pollination network; resilience},
Keywords-Plus = {FLOWER-VISITOR NETWORKS; MUTUALISTIC NETWORKS; VISITATION NETWORKS;
