ISSN = {0305-7364},
Keywords = {conservation biology; Eryngium alpinum; Apiaceae; breeding system.
   phenology; pollen/ovule ratio; pollination ecology; pollen limitation;
   pollen and seed dispersal; reproductive success; resource allocation;
   molecular markers},
