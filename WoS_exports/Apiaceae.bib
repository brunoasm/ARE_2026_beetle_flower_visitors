@article{ WOS:A1994PU70600001,
Author = {TOLLSTEN, L and OVSTEDAL, DO},
Title = {DIFFERENTIATION IN FLORAL SCENT CHEMISTRY AMONG POPULATIONS OF
   CONOPODIUM-MAJUS (APIACEAE)},
Journal = {NORDIC JOURNAL OF BOTANY},
Year = {1994},
Volume = {14},
Number = {4},
Pages = {361-367},
Abstract = {The floral scent of Conopodium majus was trapped by head-space
   adsorption, and analysed by GC-MS. Two chemotypes of flower scent could
   be distinguished, both differing from a background of leaves.
   Characteristic of one chemotype were 4-oxoisophorone and
   pyridin-3-carboxaldehyde, and characteristic of the other were some
   sesquiterpenes. In addition, samples of infructescences emitted none or
   lower amounts of the compounds above. The difference in scent
   composition was large enough to distinguish three studied populations
   from each other, and from the blanks, in a principal component analysis.
   It was concluded that despite its sexually `'promiscuous'' flowers, C.
   majus shows differentiation in scent chemistry that might reflect an
   ecotypic response to local faunae of pollinators of major importance.
   Whether pollination ecotypes occur deserves further studies.},
