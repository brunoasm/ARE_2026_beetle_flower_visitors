@inproceedings{ WOS:000711321200021,
Author = {Amirov, B.},
Editor = {Grzebelus, D and Baranski, R},
Title = {Carrot production and prospects of breeding research in Kazakhstan},
Booktitle = {PROCEEDINGS OF THE II INTERNATIONAL SYMPOSIUM ON CARROT AND OTHER
   APIACEAE},
Series = {Acta Horticulturae},
Year = {2019},
Volume = {1264},
Pages = {175-181},
Note = {2nd International Symposium on Carrot and Other Apiaceae, Krakow,
   POLAND, SEP 19-22, 2018},
Organization = {Int Soc Horticultural Sci; Int Soc Horticultural Sci Div Vegetables
   Roots \& Tubers; Int Soc Horticultural Sci Working Grp Carrot \& Other
   Apiaceae},
Abstract = {Carrots are one of the most important vegetables in Kazakhstan; it
   occupies the third position after tomato and onion in terms of the
   occupied area. In 2017, the harvested area of carrots amounted up to
   20,000 ha, and the volume of production 546,300 t of root crops - were
   mainly from hybrid and cultivar seeds of foreign breeding. In the
   country, the main planting areas of carrot (77.4\%) are concentrated in
   the northeast (Pavlodar - 25.1\%) and the eastern (East Kazakhstan -
   6.7\%), southern (South Kazakhstan - 11.5\%, Zhambyl - 15.6\%) and the
   southeastern (Almaty - 18.4\%) regions. Western, south-western and
   northern regions are traditionally considered less suitable for
   commercial carrot production. In the production of carrots, the share of
   agricultural enterprises accounts for 5.9\%, individual entrepreneurs
   and peasants or private farms have 61.5\%, while the rest 932.6\%) falls
   on the householders. On plantations, hybrid and cultivar seeds of
   `Chantenay' and `Nantes' types of foreign companies are mainly used,
   which are most preferable both for the producer and for the consumer,
   thanks to the blunt-ended conical and cylindrical shape of roots,
   homogeneous and bright orange color of the core and pulp with a smooth
   surface. Carrots in Kazakhstan are mostly consumed fresh and delivered
   to the market year-round: from the middle of summer, it begins to come
   from the fields and from late autumn until the middle of next summer it
   comes from from storage. Despite the considerable sown areas of carrots
   in Kazakhstan, only in the last 10-12 years efforts have been made to
   develop breeding research. During the Soviet era, scientific works on
   carrots in Kazakhstan were mainly related to its seed production. Since
   gaining independence, the studies have been expanded with the deepening
   of studies on the integrated assessment of the available gene pool,
   which included local forms, foreign hybrids and open-pollinated
   cultivars. Based on the methods of individual and pedigree selection,
   pair and group crossings, new biotypes of carrot were formed. At the
   present moment, three cultivars of carrots have been developed and
   released, which have high productivity and good commodity indicators.
   Along with the creation of open-pollinated cultivars, a work has begun
   on the formation of a genetic base for heterosis breeding. It has been
