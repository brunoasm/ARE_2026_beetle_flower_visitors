   Zych, Marcin; Goldstein, Jan; Roguz, Katarzyna; Stpiczynska, Malgorzata, Univ Warsaw Bot Garden, PL-00478 Warsaw, Poland.},
DOI = {10.1007/s11829-013-9246-3},
