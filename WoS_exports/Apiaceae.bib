   Simone, P. W. and Grzebelus, D.},
Editor = {Grzebelus, D and Baranski, R},
Title = {A genome-wide association study reveals a genomic region associated with
   the carrot root shape},
Booktitle = {PROCEEDINGS OF THE II INTERNATIONAL SYMPOSIUM ON CARROT AND OTHER
   APIACEAE},
Series = {Acta Horticulturae},
Year = {2019},
Volume = {1264},
