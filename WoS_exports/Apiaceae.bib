@article{ WOS:000359445600013,
Author = {Velazquez, Nadia Jimena and Burry, Lidia Susana and Fugassa, Martin
   Horacio},
Title = {Palynological analysis of extinct herbivore dung from Patagonia,
   Argentina},
Journal = {QUATERNARY INTERNATIONAL},
Year = {2015},
Volume = {377},
Pages = {140-147},
Month = {AUG 7},
Abstract = {Dung pollen studies can contribute information to the paleodiet and
   paleoenvironmental knowledge during the Pleistocene-Holocene transition.
   In this study, pollen analysis of extinct megaherbivore dung dated at
   10,530 +/- 620 BP was performed. Random samples from extinct herbivore
   dung, level 18, were collected from the archaeological excavation Cerro
   Casa de Piedra 7 (CCP7) (Argentine Patagonia). These samples were
   ascribed to ground sloths, Family Mylodontidae. Pollen extraction was
   carried out by acetolysis. The results were compared with
   microhistological analyses of feces and with sedimentary pollen analysis
   of the site. The diet items mainly consisted of Poaceae together with
   Apiaceae, Caryophyllaceae, Apiaceae Azorella type, Asteraceae subf.
   Asteroideae, Nassauvia, Perezia, Acaena, Ericaceae/Empetrum and Ephedra.
   A taxonomic coincidence between the palynological and microhistological
   analyses that permitted the determination of diet items was observed.
   The Poaceae and Apiaceae dominance allows supposing the grass steppe and
   the Nothofagus undergrowth as food areas for megaherbivores. The greater
   diversity of pollen grains in feces than in sediments due to the
   contribution of taxa with zoophilous pollination (regularly scarce or
   absent in sedimentary studies) demonstrates the value of dung analysis
   to paleoenvironmental reconstructions. (C) 2015 Elsevier Ltd and INQUA.
   All rights reserved.},
