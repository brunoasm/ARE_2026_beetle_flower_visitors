@article{ WOS:A1985AFV3700009,
Author = {LINDSEY, AH and BELL, CR},
Title = {REPRODUCTIVE-BIOLOGY OF APIACEAE .2. CRYPTIC SPECIALIZATION AND FLORAL
   EVOLUTION IN THASPIUM AND ZIZIA},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1985},
Volume = {72},
Number = {2},
Pages = {231-247},
Abstract = {The classification of specialized floral syndromes imposed a bias in the
   intepretation of pollination systems which may be either more
   generalized, or more specialized, than is universally acknowledged. An
   analysis of floral biology in 2 umbellifer genera, Thaspium and Zizia,
   was undertaken in order to determine the extent to which cryptic floral
   or inflorescence variations determine pollination specialization despite
   a broad visitor spectrum and open reward system. Separate analyses were 
   made of the primary attractants, nectar and pollen, and the secondary
   attractants, floral color and floral and inflorescence structure in
   conjunction with analyses of pollinator movements, stigmatic pollen
   loads and fruit set. Cryptic variation in floral and inflorescence
   characters enhance specialization for pollination by solitary bees or
   syrphid flies. The importance of the oligolectic relationship between
   taxa of Thaspium and Zizia and the solitary bee, Andrena zizae was
   evident. The  need for more experimental work to further define the
   oligolectic relationship and to understand how floral and inflorescence
   color and structure affect insect movements was especially revealed. The
   degree of pollination specialization in Thaspium and Zizia is not
   uncommon in Apiaceae and has important implications for floral evolution
   in this family and other plant groups with pollination systems
   categorized as promiscuous.},
