@article{ WOS:A1995RY89300004,
Author = {WEBER, M and FROSCH, A},
Title = {THE DEVELOPMENT OF THE TRANSMITTING TRACT IN THE PISTIL OF
   HACQUETIA-EPIPACTIS (APIACEAE)},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {1995},
Volume = {156},
Number = {5},
Pages = {615-621},
Month = {SEP},
Abstract = {Hacquetia epipactis has a wet, nonpapillate stigma. Stigmatic cells are
   moribund at maturity and become disrupted because of accumulated and
   ascending stylar secretion. The stigmatic surface coating is produced
   completely by the stylar transmitting tissue. The style is a half-solid
   type, with large secretion-filled schizogenous channels. The secretion
   mainly contains polysaccharides mixed with a small amount of lipids.
   Pollen grains germinate within the stigmatic secretion and the pollen
   tubes grow directly into the stylar channels.},
