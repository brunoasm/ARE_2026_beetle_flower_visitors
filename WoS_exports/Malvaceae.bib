@article{ WOS:A1992HZ26900011,
Author = {KRABEL, D},
Title = {INFLUENCE OF SOURCE-LIMITATIONS ON FRUIT-DEVELOPMENT OF
   HIBISCUS-ROSA-SINENSIS L},
Journal = {JOURNAL OF PLANT PHYSIOLOGY},
Year = {1992},
Volume = {140},
Number = {1},
Pages = {56-60},
Month = {MAY},
Abstract = {Flowering cultivars of Hibiscus rosa-sinensis (Malvaceae) L. were either
   self-pollinated (283 flowers) or cross-pollinated (349 flowers). From
   microautoradiographic studies it is assumed that the developing seeds of
   cross-fertilized Hibiscus are the major sinks for photoassimilates,
   whereas structural elements, for example, are minor (less strong) sinks.
   Additional anatomical observations and histochemical starch measurements
   in the peduncle of the flower and fruit showed the development of a
   starch depot in the vicinity of the phloem. This starch is consumed
   during the growth of cross-fertilized fruits. Until the abscission
   process has finished this starch pool is hydrolyzed in self-fertilized
   flowers as well.
   Source limiting experiments give evidence that a completely defoliated
   and partly darkened plant is able to produce fruits from these
   previously stored assimilates. A model for the source-sink relations in
   self-and cross-fertilized Hibiscus is suggested.},
