@article{ WOS:001282111300003,
Author = {Sosa, Claudio A.},
Title = {Use of floral resources by Andrenidae, Colletidae and Megachilidae
   (Hymenoptera: Apoidea) in the Chaco Serrano of Córdoba (Argentina)},
