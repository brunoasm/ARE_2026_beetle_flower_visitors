@inproceedings{ WOS:000333738300043,
Author = {Kim, J. H. and Suh, J. K.},
Editor = {Facciuto, G and Sanchez, MI},
Title = {Evaluation of <i>Abutilon</i> Hybrids as Potted Plant},
Booktitle = {VII INTERNATIONAL SYMPOSIUM ON NEW FLORICULTURAL CROPS},
Series = {Acta Horticulturae},
Year = {2013},
Volume = {1000},
Pages = {319-326},
Note = {7th International Symposium on New Floricultural Crops, Buenos Aires,
   ARGENTINA, NOV 22-25, 2011},
Organization = {Int Soc Hort Sci},
Abstract = {Abutilon is related to the genus Hibiscus and belongs to the Malvaceae.
   It is native to the tropics and sub-tropics. There are more than 150
   species and many hybrid cultivars are available in the US and other
   countries but Abutilon cultivars of hybrid origin are not yet available
   in Korea. Abutilon hybrids with bronze and yellow flowers were open
   pollinated and several seedlings with different flower color and growth
   habits were selected: No. 1 (bronze-yellow flower), No. 2 (red flower),
   and No. 3 (yellow flower). Two experiments were carried out to study the
   effect of controlled release fertilizer (CRF) treatment and forcing
   temperatures on growth and flowering. Rooted cuttings were planted and
   grown in a 21 degrees C greenhouse and received 0, 0.5, 1.0, and 1.5 g
   of CRF per pot at planting. The number of days to flower of the first
   and second flower buds was affected by CRF treatment. Hybrid No. 2 and
   No. 3 produced more flowers than No. 1 when CRF was applied. Leaf
   nitrogen content was affected by hybrids and the rate of CRF. The level
   of manganese was higher than the recommended foliar concentration;
   hybrid No. 3 contained levels greater than 457 ppm of Mn. However, no
   toxicity symptoms were observed in any of the plants when CRF was
   applied. Cuttings were propagated and grown at 16 degrees, 21 degrees,
   and 26 degrees C (night temperatures) with 2-5 degrees C higher day
   temperatures. At planting, 1.5 g of CRF was surface applied. Flowering
   of the first flower buds was accelerated when forced at >21 degrees C
   and also the number of total and lateral shoots were increased. From our
   results, we recommend to force Abutilon hybrids at >21 degrees C with
   0.5 - 1.0 g CRF surface applied in 10 cm pot at planting.},
Publisher = {INT SOC HORTICULTURAL SCIENCE},
Address = {PO BOX 500, 3001 LEUVEN 1, BELGIUM},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Kim, JH (Corresponding Author), Dankook Univ, Dept Environm Hort, Yongin, Gyeonggi Do, South Korea.
   Kim, J. H.; Suh, J. K., Dankook Univ, Dept Environm Hort, Yongin, Gyeonggi Do, South Korea.},
