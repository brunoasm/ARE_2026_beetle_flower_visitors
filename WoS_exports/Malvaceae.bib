@article{ WOS:001189868000001,
Author = {Torquato, Isabella Hevily Silva and de Souza, Camila Silveira and
   Castro, Cibele Cardoso},
Title = {Pollinating insects form different modules with Malvaceae crops in a
   global meta-network},
Journal = {AGROECOLOGY AND SUSTAINABLE FOOD SYSTEMS},
Year = {2024},
Volume = {48},
Number = {5},
Pages = {647-659},
Month = {MAY 27},
Abstract = {This study aims to build a global meta-network of interactions between
   Malvaceae crops (cocoa, cupuassu, cotton and okra) and their
   pollinators. The network structure was described by connectivity and
   modularity, and centrality metrics were used to analyze the role of
   species. A total of 217 pollinator species was recorded, distributed in
   four orders. The network has four modules, low connectance (C = 26\%)
   and a high modularity (Q = 0.58). Apis mellifera was the only network
   connector species. Each crop is pollinated by a very specific group of
   species, indicating that productivity maintenance may be favored by the
   conservation of pollinators diversity.},
