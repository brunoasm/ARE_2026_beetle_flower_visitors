@article{ WOS:A1977EB39400009,
Author = {BUTTROSE, MS and GRANT, WJR and LOTT, JNA},
Title = {REVERSIBLE CURVATURE OF STYLE BRANCHES OF HIBISCUS-TRIONUM L A
   POLLINATION MECHANISM},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1977},
Volume = {25},
Number = {5},
Pages = {567-570},
Abstract = {H. trionum, like several other members of the Malvaceae, has flowers
   with prominent styles which can reflex during the first few hours after
   opening so that stigmas make contact with the anthers. This
   self-pollination mechanism can be interrupted if stigmas are pollinated
   before or during bending. They then maintain or regain the erect
   position and selfing cannot occur. Various treatments which can affect
   this reversal of bending are described.},
