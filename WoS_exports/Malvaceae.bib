   Bianchi, MB (Corresponding Author), Univ Nacl Rosario, Consejo Invest, RA-2000 Rosario, Santa Fe, Argentina.
   Beatriz Bianchi, Marta, Univ Nacl Rosario, Fac Ciencias Agr, RA-2125 Zavalla, Santa Fe, Argentina.
   Beatriz Bianchi, Marta, Univ Nacl Rosario, Consejo Invest, RA-2000 Rosario, Santa Fe, Argentina.
   Gibbs, Peter Edward, Univ St Andrews, Sch Biol, St Andrews KY16 9TH, Fife, Scotland.},
DOI = {10.1590/0102-33062020abb0270},
ISSN = {0102-3306},
EISSN = {1677-941X},
Keywords = {bud self-pollination; Ceiba chodatii; late-acting self-incompatibility;
