@article{ WOS:000351320000018,
Author = {Melo Junior, Afranio Farias and Carvalho, Dulcineia and Brandao, Murilo
   Malveira and Sousa, Ligiany Gravoche and Vieira, Fabio de Almeida and
   Menezes, Elytania Veiga and Royo, Vanessa Andrade and Oliveira, Dario
   Alves},
Title = {Spatial genetic structure of <i>Cavanillesia arborea</i> K. Schum.
   (Malvaceae) in seasonally dry Tropical forest: Implications for
   conservation},
Journal = {BIOCHEMICAL SYSTEMATICS AND ECOLOGY},
Year = {2015},
Volume = {58},
Pages = {114-119},
Month = {FEB},
Abstract = {Worldwide, Seasonally Dry Tropical Forests (SDTF) are among the least
   known and most degraded vegetation types. Cavanillesia arborea
   (Malvaceae) is an endemic dry forest tree that is bat-pollinated and the
   seeds are wind-dispersed. The present study sought to characterize the
   spatial genetic structure (SGS) in natural populations of C arborea
   growing in SDTF fragments in Minas Gerais State, Brazil, using ISSR
   molecular markers. Seven ISSR primers generated 81 polymorphic loci in
   175 individuals. In three populations (FU, MO and PC), we found random
   distributions of genotypes, while two populations (JAN and MV) showed
   SGS in their first distances classes (171 m and 17 m, respectively),
   with significant kinship (Sp) values (0.0189 and 0.0005 respectively; P
   < 0.05). Sp values for these populations indicate that the effects of
   kinship can be minimized by collecting seeds from distance classes
   beyond the species' first distance class. The continuous anthropogenic
   impacts on remnant tree populations, low species densities, and the
   observed genetic structure, all indicate the need to preserve large
   areas of dry forest vegetation for conservation purposes. (C) 2014
   Elsevier Ltd. All rights reserved.},
