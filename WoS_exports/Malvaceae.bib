@article{ WOS:000315643900005,
Author = {Lobo, Jorge and Solis, Silvia and Fuchs, Eric J. and Quesada, Mauricio},
Title = {Individual and Temporal Variation in Outcrossing Rates and Pollen Flow
   Patterns in Ceiba pentandra (Malvaceae: Bombacoidea)},
Journal = {BIOTROPICA},
Year = {2013},
Volume = {45},
Number = {2},
Pages = {185-194},
Month = {MAR},
Abstract = {Ceiba pentandra is a tropical tree with high rates of selfing in some
   populations. In mixed-mating species, variation in selfing is due to
   changes in adult density or variability of incompatibility systems. The
   effect of spatial isolation and phenology on selfing rates and pollen
   flow distances was analyzed using microsatellites in a fragmented
   population of Ceiba pentandra, in southern Costa Rica. Adult trees
   within a heterogeneous landscape were classified as grouped or isolated.
   We compared selfing rates at the individual level, between isolation
   conditions and 2yr (2007, 2009), which differed in the number of
   flowering individuals. Mixed mating was estimated in both years
   (tm=0.6240.759). Trees mated predominantly by outcrossing, while only a
   few trees reproduced through selfing. Spatial isolation did not
   significantly affect outcrossing rates. The progeny of grouped trees was
   mostly sired by near-neighbors (<1km) and by long-distance pollen flow
   events in isolated trees. A reduction in the number of flowering
   individuals in 2009 reduced near-neighbor matings, increased selfing in
   grouped trees, and decreased the number of unsampled sires in the
   progeny. Comparing selfing rates on individuals that flowered in both
   reproductive periods suggests a flexible mating system. Variation in
   self-fertilization rates in this population appears to depend on
   variation of individual traits, such as genetic variability in
   self-incompatibility genes, but it is independent of landscape
   heterogeneity. In contrast, pollen flow distances depend on local tree
   density as bats concentrate their foraging between near individuals to
   maximize energy efficiency. Resumen Ceiba pentandra es uno de los raros
   ejemplos de arboles tropicales de dosel en los cuales se ha determinado
   altas tasas de selfing en algunas poblaciones. Analisis de plantas con
   sistema de apareamiento mixto ha mostrado que la frecuencia de selfing
   es variable entre individuos, poblaciones y periodos reproductivos, y en
   algunos casos esa variacion ha sido asociada a cambios en la densidad de
   individuos reproductivos, agentes polinizadores, variacion genetica o
   flexibilidad del sistema de incompatibilidad. En este estudio se analiza
   la variacion de las tasas de selfing y la distancia de dispersion de
   polen en una poblacion fragmentada de Ceiba pentandra en el SO de Costa
   Rica, con el fin de determinar el efecto del aislamiento espacial y
   fenologico sobre su sistema de apareamiento. Muestras de tejido adulto y
   semillas fueron obtenidas de una poblacion de arboles distribuidos en un
   area extensa de bosques fragmentados y pastizales durante dos anos
   reproductivos que mostraron diferencias en la frecuencia de individuos
   en floracion. Algunos individuos se encontraban en condicion agrupada y
   otros aislada, lo que permitio determinar el efecto de aislamiento sobre
   la tasas de autofecundacion y flujo genico por polen. Se determinaron
   las tasas de selfing por individuo, condicion de aislamiento y ano
   reproductivo, asi como la paternidad de las semillas con base a modelos
   de asignacion que consideran la presencia de individuos no muestreados.
   La poblacion estudiada mostro un sistema de apareamiento mixto en los
   dos anos estudiados (tm=0.7590.624). La mayoria de los arboles mostraron
   altas tasas de exocruzamiento, con una fraccion menor mostrando valores
   intermedios o bajos. Arboles con valores altos y bajos de la tasa de
   exocruzamiento se observaron tanto en condicion agrupada como aislada.
   La fraccion exocruzada de la progenie provino en su mayor parte de
   arboles cercanos (<1km) en el caso de las semillas de individuos en
   grupos, y de arboles distantes en el caso de los arboles aislados. La
   menor floracion del segundo ano de estudio provoco una disminucion en la
   frecuencia de apareamientos con individuos cercanos, un aumento en la
   tasa de selfing en algunos arboles agrupados, asi como una disminucion
   del numero de donadores de polen no muestreados. La comparacion de
   individuos muestreados en dos anos mostro flexibilidad del sistema de
   apareamiento en algunos de los individuos muestreados. La variacion de
   la tasa de selfing en esta poblacion parece depender de la variacion de
   caracteristicas individuales de los arboles no asociadas al grado de su
   grado de aislamiento espacial o fenologico, como por ejemplo variacion
   en genes del sistema de incompatibilidad. Al contrario de esto, los
   patrones de flujo de polen de la fraccion exocruzada de las semillas
   depende de la densidad local de la especie, ya que los murcielagos
   concentran su forrajeo en individuos cercanos como estrategia
   energeticamente mas favorable.},
