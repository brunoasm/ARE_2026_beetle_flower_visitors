EISSN = {1618-0860},
Keywords = {Aquifoliales; Embryology; Phyllonoma; Phyllonomaceae},
Keywords-Plus = {FLORAL MORPHOLOGY; PHYLOGENY; CARDIOPTERIS; GENES},
