Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Morimoto, J (Corresponding Author), Univ Aberdeen, Sch Biol Sci, Zool Bldg,Tillydrone Ave, Aberdeen AB24 2TZ, Scotland.
   Morimoto, Juliano, Univ Aberdeen, Sch Biol Sci, Zool Bldg,Tillydrone Ave, Aberdeen AB24 2TZ, Scotland.
   Pietras, Zuzanna, Linkoping Univ, Dept Phys Chem \& Biol IFM, Linkoping, Sweden.},
DOI = {10.1002/ece3.6981},
EarlyAccessDate = {NOV 2020},
ISSN = {2045-7758},
Keywords = {diet breadth; ecological specialization; niche; polyphagy; range shift},
