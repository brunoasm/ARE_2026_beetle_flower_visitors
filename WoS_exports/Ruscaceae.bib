   and Kuznetsova, Svetlana P.},
Title = {<i>Aspidistra globosa</i> (Asparagaceae, Nolinoideae), a new species
   with erect stem from southern Vietnam},
Journal = {PHYTOTAXA},
Year = {2016},
Volume = {282},
Number = {1},
Pages = {46-52},
Month = {OCT 26},
Abstract = {Aspidistra globosa is described and illustrated as a new species from
   southern Vietnam (Gia Lai province, Kon Ka Kinh National Park). The new
   species has long erect stem, which is a rare feature in the genus
   Aspidistra. Aspidistra globosa resembles A. khangii and A. locii in
   globoid perigone and erect stem, but differs in smaller flowers, color
   of perigone, position of anthers and orientation of flower.},
