   Nat Hist Museum, Dept Entomol, London SW7 5BD, England.
   Ctr Int Forestry Res, JKPWB, Jakarta 10065, Indonesia.},
DOI = {10.1046/j.1365-2745.1998.00270.x},
ISSN = {0022-0477},
