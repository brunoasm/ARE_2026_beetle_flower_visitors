@article{ WOS:000248968200010,
Author = {Carneirol, Francimary da Silva and Sebbenn, Alexandre Magno and
   Kanashiro, Milton and Degen, Bernd},
Title = {Low interannual variation of mating system and gene flow of <i>symphonia
   globulifera</i> in the Brazilian Amazon},
Journal = {BIOTROPICA},
Year = {2007},
Volume = {39},
Number = {5},
Pages = {628-636},
Month = {SEP},
Abstract = {Six microsatellite loci were used to compare the mating system and gene
   flow in two consecutive years of a natural, unlogged population of
   Symphonia globulifera in a 500 ha experimental plot in the Brazilian
   Amazon (Flona Tapajos). The species had a low density of reproductive
   trees per hectare (d= 0.46 trees/ha). We analyzed 205 trees and 261 and
   487 open-pollinated seeds from 26 and 30 mother-trees in the years 2002
   and 2003, respectively. A significant spatial genetic structure was
   detected for the adult trees for distances up to 100 m. We observed only
   small interannual differences in multilocus outcrossing rate V,(2002) =
   1,000, (2003) = 0.998), biparental inbreeding (, -, (2002) = 0-093,,
   -,(2003) = 0.063), and paternity correlation r(p)(2002) = 0.414, p(2003)
   = 0.386). The number of pollen donors contributing to mating of each
   tree in both years was estimated to be low = 2.4 - 4.0). Using TwoGENER
   analysis to calculate the density of reproductive trees and the distance
   of pollen dispersal for normal and exponential models, the lowest error
   was detected for exponential model. For this model, the estimated
   density of reproductive trees was lower in 2002 (d(e),(2oo2) = 0.03
   trees/ha) than 2003 (d(e),(2003) = 0.19 trees/ha), resulting in a higher
   distance of pollen dispersal in 2002 ( (2002) = 444 m) than 2003 (
   (2003) = 154 m), although these changes did not affect the outcrossing
   and correlated mating rates.},
