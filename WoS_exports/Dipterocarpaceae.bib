Type = {Article},
Language = {English},
Affiliation = {van der Ent, A (Corresponding Author), Univ Queensland, Sustainable Minerals Inst, Ctr Mined Land Rehabil, St Lucia, Qld 4072, Australia.
   van der Ent, Antony; Mulligan, David, Univ Queensland, Sustainable Minerals Inst, Ctr Mined Land Rehabil, St Lucia, Qld 4072, Australia.},
