DOI = {10.1007/BF02703079},
ISSN = {0250-5991},
EISSN = {0973-7138},
Keywords = {MASS FLOWERING; DIPTEROCARPS; POLLINATORS; THRIPS; SEQUENTIAL FLOWERING;
   ENVIRONMENTAL CUE},
