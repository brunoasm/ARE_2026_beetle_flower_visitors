Address = {SACHSENPLATZ 4-6, PO BOX 89, A-1201 WIEN, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {Tal, O (Corresponding Author), Univ Leipzig, Leipzig, Germany.
   Univ Leipzig, Leipzig, Germany.},
DOI = {10.1007/s00606-008-0141-9},
ISSN = {0378-2697},
Keywords = {Acer pseudoplatanus; Canopy research; Flowering ecology;
   Heterodichogamy; LAK; Leipzig's floodplain forest; Sapindaceae; Thrips
   pollination},
Keywords-Plus = {EVOLUTION; PLANTS; GENDER; DIOECY; MUTUALISM; PATHWAY; SYSTEMS; FUNGUS},
