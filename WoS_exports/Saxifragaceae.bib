EISSN = {2162-4372},
Keywords = {atpB-rbcL noncoding spacer; Begonia X taipeiensis; B. formosana; B.
   aptera; chloroplast DNA; cytology; directional hybridization; natural
   hybrid; Taiwan},
Keywords-Plus = {HOMOPLOID RETICULATE EVOLUTION; CHLOROPLAST DNA; MULTIPLE ORIGINS;
