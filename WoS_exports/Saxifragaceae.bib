@article{ WOS:A1994QB43900020,
Author = {SIMONICH, MT and MORGAN, MD},
Title = {ALLOZYMIC UNIFORMITY IN IRIS-LACUSTRIS (DWARF LAKE IRIS) IN WISCONSIN},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1994},
Volume = {72},
Number = {11},
Pages = {1720-1722},
Month = {NOV},
Abstract = {Iris lacustris Nutt. is a federally listed threatened species in Canada
   and the United States and is currently under consideration for active
   conservation management. The species is restricted to the shores of the
   western Great Lakes region and to a very narrow habitat type.
   Reproduction is almost exclusively by vegetative ramets. Limited sexual
   reproduction occurs after primarily geitonogamous pollination, although
   the plant is primarily selfed. Enzyme electrophoresis was used to
   determine the extent of genetic variation within and between Wisconsin
   populations. Ten enzymes coded by 22 putative genetic loci were
   examined. All nine populations were found to be monomorphic at the 22
   loci for the same suite of isozymes. Heterozygosity was not detected at
   any loci. The apparent genetically depauperate nature of the species is
   addressed with regard to life history and reproductive biology.
   Implications for conservation management are addressed.},
