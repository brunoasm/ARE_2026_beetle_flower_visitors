   WASHINGTON STATE UNIV,DEPT ZOOL,PULLMAN,WA 99164.},
ISSN = {0012-9658},
Keywords = {geographic mosaic of coevolution; Greya politella; herbivory; Heuchera;
   Lithophragma; mutualism; pollinating floral parasites; pollination;
   Prodoxidae; Saxifragaceae},
Keywords-Plus = {YUCCA MOTH LINEAGE; MUTUALISM; LEPIDOPTERA; PRODOXIDAE; PHYLOGENY},
