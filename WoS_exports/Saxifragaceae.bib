   SW Missouri State Univ, Dept Biol, Springfield, MO 65804 USA.
   Univ Connecticut, Dept Ecol \& Evolutionary Biol, Storrs, CT 06269 USA.
   Univ New Hampshire, Dept Plant Biol, Durham, NH 03824 USA.},
DOI = {10.2307/2656779},
