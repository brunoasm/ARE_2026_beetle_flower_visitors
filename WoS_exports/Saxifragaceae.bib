@article{ WOS:A1984SF36500006,
Author = {GORNALL, RJ and BOHM, BA},
Title = {BREEDING SYSTEMS AND RELATIONSHIPS AMONG SPECIES OF BOYKINIA AND RELATED
   GENERA (SAXIFRAGACEAE)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1984},
Volume = {62},
Number = {1},
Pages = {33-37},
Abstract = {Self- and cross-pollinations were made within and between selected
   species belonging to Boykinia, Peltoboykinia, Bolandra, Suksdorfia,
   Sullivantia and Jepsonia (Saxifragaceae). Self-incompatibility is
   reported for the 1st time in Boykinia. No intergeneric hybrids were
   produced, supporting the separate integrities of the genera involved,
   particularly the segregation of Peltoboykinia. Intrageneric hybrids were
   made in Boykinia and Peltoboykinia. In the case of Boykinia, this
   supports the retention within it of the often segregated Telesonix.
   Crosses between the 2 North American Suksdorfia species failed, but for
   various reasons, this was taken to reflect the existence of 2 biological
   species rather than 2 separate genera.},
