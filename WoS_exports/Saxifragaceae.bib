ISSN = {0002-9122},
Keywords = {insect pollination; intergeneric hybridization; late-acting
   self-incompatibility; plant mating systems; reproductive isolating
   mechanisms; Saxifragaceae; Tellima; Tolmeia},
Keywords-Plus = {CHLOROPLAST-DNA VARIATION; TOLMIEA-MENZIESII; INTERGENERIC HYBRID;
