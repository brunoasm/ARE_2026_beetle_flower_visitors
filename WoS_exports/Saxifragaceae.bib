Keywords-Plus = {SILENE-ACAULIS CARYOPHYLLACEAE; GRANULATA L SAXIFRAGACEAE; HERB
   GLECHOMA-HEDERACEA; SEXUAL DIMORPHISM; GENDER VARIATION; SEED
