   Pellmyr, Olle, Univ Idaho, Dept Biol Sci, Moscow, ID 83844 USA.},
DOI = {10.1016/j.ympev.2007.09.020},
ISSN = {1055-7903},
EISSN = {1095-9513},
Keywords = {ancestral state reconstruction; Gnoriste; Heucherina; mycetophilidae;
   myiophily; pollination specialization; pollination syndrome;
   Saxifragaceae},
Keywords-Plus = {ANCESTRAL CHARACTER STATES; PHYLOGENETIC-RELATIONSHIPS; KARYOTYPIC
   RELATIONSHIPS; EVOLUTION; HEUCHERA; MUTUALISM; SYSTEMS; HETEROGENEITY;
   HYBRIDIZATION; LITHOPHRAGMA},
