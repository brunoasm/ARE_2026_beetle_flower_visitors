@article{ WOS:A1988M648100022,
Author = {LEVY, F},
Title = {EFFECTS OF POLLEN SOURCE AND TIME OF POLLINATION ON SEED PRODUCTION AND
   SEED WEIGHT IN PHACELIA-DUBIA AND PHACELIA-MACULATA (HYDROPHYLLACEAE)},
Journal = {AMERICAN MIDLAND NATURALIST},
Year = {1988},
Volume = {119},
Number = {1},
Pages = {193-198},
Month = {JAN},
Abstract = {Seed production in Phacelia dubia var. dubia and P. maculata, members of
   the subgenus Cosmanthus, is not affected by pollen source (self or
   outcross) during the entire period of stigma receptivity. Both species
   are protandrous and most receptive to pollination the 3rd day a flower
   is open. Phacelia maculata has a longer period of stigma receptivity and
   produces more seeds per capsule than P. dubia var. dubia. In P.
   maculata, seed weight was not affected by pollen source but was  highly
