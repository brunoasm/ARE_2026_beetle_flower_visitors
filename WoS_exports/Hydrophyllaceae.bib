@article{ WOS:A1984TT72300001,
Author = {TYRL, RJ and ERTEEB, FB and BRUNER, JL and EZELL, WL and ESTES, JR and
   GRUMMER, B},
Title = {A BIOSYSTEMATIC STUDY OF THE RELATIONSHIP OF NAMA-HISPIDUM AND
   NAMA-STEVENSII (HYDROPHYLLACEAE)},
Journal = {SOUTHWESTERN NATURALIST},
Year = {1984},
Volume = {29},
Number = {4},
Pages = {367-375},
Abstract = {Biosystematic studies of the morphology, reproductive biology, karyology
   and flavonoid composition of N. hispidum and N. stevensii indicate that
   the 2 taxa should be recognized as distinct species. Although the 2 taxa
   differ consistently only in the nature of their pubescence, other
   morphological characters when combined do permit differentiation. The
   taxa have similar phenological and genetic patterns; both are obligate
   outcrossers. N. hispidum is pollinated by halictid bees of the genus
   Sphecodosoma, whereas N. stevensii is pollinated by the andrenid bee
   Nomadopsis beamerorum. Both taxa form 7 bivalents at meiotic metaphase
   I, and disjunction is regular. Gene exchange between the 2 taxa is
   limited; seed set in interspecific crosses is .apprx. 18\%.
   Chromatographic data indicate differences; plants of N. hispidum have an
   array of 4 flavonoids, whereas plants by N. stevensii have the same
   array plus an additional 5. The widely distributed and variable N.
   hispidum may have given rise to the gypsophilic N. stevensii.},
