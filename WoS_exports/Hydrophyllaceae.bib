Keywords = {SPATIAL VARIABILITY; POLLINATOR ASSEMBLAGE; POPULATION SIZE; BLACK
   MUSTARD; BRASSICA NIGRA},
Keywords-Plus = {PHACELIA-LINEARIS HYDROPHYLLACEAE; PATCH SIZE; SPATIOTEMPORAL VARIATION;
