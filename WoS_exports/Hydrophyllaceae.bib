Affiliation = {Conner, JK (Corresponding Author), UNIV ILLINOIS,DEPT ECOL ETHOL \& EVOLUT,SHELFORD VIVARIUM,606 E HEALEY ST,CHAMPAIGN,IL 61820, USA.},
DOI = {10.1007/BF00330014},
