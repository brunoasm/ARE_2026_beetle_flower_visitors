@incollection{ WOS:000608998400004,
Author = {Teixeira, Simone Padua and Marinho, Cristina Ribeiro and Leme, Flavia
   Maria},
Editor = {Nawrot, R},
Title = {Structural diversity and distribution of laticifers},
Booktitle = {LATEX, LATICIFERS AND THEIR MOLECULAR COMPONENTS: FROM FUNCTIONS TO
   POSSIBLE APPLICATIONS},
Series = {Advances in Botanical Research},
Year = {2020},
Volume = {93},
Abstract = {The present chapter deals with the concept as well as the structure,
   ultrastructure and development of laticifer in plants. The morphological
   aspects of the laticifer development are used to better support the
   laticifer current classification. Some general functions attributed to
   the laticifer are discussed, especially those related to the plant
   protection. As a novelty we cited a role of laticifer presence and
   distribution in the pollination of the fig trees. An extensive
   bibliographic survey on taxonomic distribution of laticifers in plants
   is presented. Illustrations of anatomy, histochemistry and
   ultrastructure of laticifers are presented to exemplify the treated
   aspects. Unpublished or recently published aspects are highlighted in
   each topic. We showed that there is a great diversity of morphological
   types of laticifers and developmental processes involving the laticifer
   formation in plants.},
