@article{ WOS:A1989CG87700012,
Author = {DEVALL, MS and THIEN, LB},
Title = {FACTORS INFLUENCING THE REPRODUCTIVE SUCCESS OF IPOMOEA-PES-CAPRAE
   (CONVOLVULACEAE) AROUND THE GULF OF MEXICO},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1989},
Volume = {76},
Number = {12},
Pages = {1821-1831},
Month = {DEC},
Abstract = {The reproductive biology of Ipomoea pes-caprae, a pantropical beach
   morning glory, was studied at five sites around the Gulf of Mexico. The
   primary pollinators were Xylocopa species (carpenter bees) which
   dispersed pollen up to 90 m. Exclusion experiments demonstrated that
   ants feeding an extrafloral nectaries increased seed set but did not
   protect seeds from predation by the bruchid beetle Megacerus. The
   water-dispersed seed and long-range dispersal of pollen may function to
   counter the  sporophytic incompatibility mechanism of the plant;
   populations exhibit a large neighborhood size. Key productive factors in
   the life cycle of I. pes-caprae are the long-range pollen flow and mass
   germination of water-dispersed seeds.},
