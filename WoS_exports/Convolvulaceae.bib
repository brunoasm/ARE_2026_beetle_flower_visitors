@article{ WOS:A1981MW75100003,
Author = {ENNOS, RA},
Title = {QUANTITATIVE STUDIES OF THE MATING SYSTEM IN 2 SYMPATRIC SPECIES OF
   IPOMOEA (CONVOLVULACEAE)},
Journal = {GENETICA},
Year = {1981},
Volume = {57},
Number = {2},
Pages = {93-98},
Abstract = {The rates of outcrossing in sympatric populations of I. purpurea and I.
   hederacea were estimated (using electrophoretic markers) at 70\% and
   7\%, respectively. The difference in outcrossing rate is not apparently
   due to differences in pollinator service received by the species, but is
   associated with differences in anther-stigma distance. In I. purpurea
   stigmas are generally exserted and there is much genetic variation for
   anther-stigma distance. Variation in this character has a significant
   effect on the ease with which self-pollination occurs. In contrast there
   is no variation for the character in the I. hederacea population, the
   anthers being invariably held at the same level as the stigma, an
   arrangement promoting self-pollination.},
