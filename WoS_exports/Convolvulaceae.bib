
@article{ WOS:000296670100001,
Author = {Zillikens, Anne and Oliveira, Eliana de Medeiros and Steiner, Josefina},
Title = {Diversity of Flower Visitors of Ipomoea pes-caprae (Convolvulaceae) at a
   Dune Habitat in southern Brazil},
Journal = {ENTOMOLOGIA GENERALIS},
Year = {2011},
Volume = {33},
Number = {3},
Pages = {137-148},
Abstract = {The species richness of flower visitors of Ipomoea pes-caprae (L) R Br
   was studied in a restinga area in southern Brazil to identify its
   possible pollinators. Among the 40 species/morphospecies of flower
   associates, bees were the most diverse and abundant taxon. Based on
   morphological features (medium to large size, long tongue), visitation
   frequency and flower constant behaviour, five apid bee and one scoliid
   wasp species are likely able to pollinate the flowers. Using a range of
   hymenopteran pollinators successful reproduction of Ipomoea pes-caprae
   is ensured throughout the whole flowering period of about four months in
   southern Brazil.},
