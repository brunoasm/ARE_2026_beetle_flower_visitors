ISSN = {0305-7364},
Keywords = {POLLINATION; NECTAR SUGAR COMPOSITION; FRUCTOSE; GLUCOSE; SUCROSE; HPLC;
   POLYSCIAS SAMBUCIFOLIA; ELDERBERRY PANAX; ARALIACEAE},
