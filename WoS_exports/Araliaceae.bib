@article{ WOS:000596589000002,
Author = {Xiao, Xiao and Chen, Lanying and Xiao, Juan},
Title = {Pollination Ecology of <i>Eleutherococcus trifoliatus</i> (Araliaceae):
   A Wild Medicinal and Edible Species in Southwest Asia},
Journal = {INTERNATIONAL JOURNAL OF AGRICULTURE AND BIOLOGY},
Year = {2020},
Volume = {24},
Number = {5},
Pages = {1053-1060},
Abstract = {The relationships between pollination ecology and plant-pollinator are
   major topics in the studies of floral evolution and plant reproduction.
   The pollination biology of Eleutherococcus frifoliatus (L.) S.Y. Hu
   (Araliaceae), a wild medicinal and edible species, has been poorly
   documented. This is because the vegetative propagation is more popular
   than seed reproduction that is affected by various factors. E.
   trifoliatus showed extensive intraspecific morphological variations,
   including differences in flower traits, flowering phenology, and
   reproductive characteristics. We explored the pollination ecology of E.
   trifoliatus in three different field sites that have significantly
   different relative light intensities, while other environmental factors
   had no significant difference. The flowering period of three E.
   frifoliatus populations started in September and ranged from 20 to 37
   days long; there was no significant difference in flowering period
   between the three field sites. The number of flowers per inflorescence,
   flowering times, pollen viability, stigma receptivity, and fruit set
   were highest in site II, where the population size was significantly
   larger than the other two sites. Pollination experiments revealed that
   E. trifoliatus was self-incompatible and depended on pollinators for
   fruit production. Observations of floral visitors suggested that the
   effective pollinator species of E. frifoliatus were Syrphidae (Diptera:
   Syrphidae), tachina fly (Diptera: Tachinidae), and bees Apis sp.
   (Hymenoptera: Apidae), which accounted for 45\% of recorded insect
   visits. The visiting frequency was highest in site II and lowest at site
   I (P<0.05). A correlation analysis between the reproduction factors and
   environmental factors showed that the pollination ecology of E.
   trifoliatus was greatly influenced by environmental light intensity. (C)
   2020 Friends Science Publishers},
