DOI = {10.1007/s00606-011-0474-7},
ISSN = {0378-2697},
Keywords = {Araliaceae; Dichogamy; Hermaphroditism; Phenology; P/O ratios; Protandry},
Keywords-Plus = {HISPIDA VENT ARALIACEAE; PANAX-QUINQUEFOLIUM; AMERICAN GINSENG;
