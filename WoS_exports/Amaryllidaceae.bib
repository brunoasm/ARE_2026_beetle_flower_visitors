@article{ WOS:A1982NX49300019,
Author = {DAFNI, A and WERKER, E},
Title = {POLLINATION ECOLOGY OF STERNBERGIA-CLUSIANA (KER-GAWLER) SPRENG
   (AMARYLLIDACEAE)},
Journal = {NEW PHYTOLOGIST},
Year = {1982},
Volume = {91},
Number = {3},
Pages = {571-577},
Abstract = {S. clusiana is pollinated by 2 main types of pollinators, Apis mellifera
   and various Syrphidae. The honey bees collect nectar and pollen from the
   shorter inner whorl of stamens and from the lowermost part of the
   funnel-shaped perianth tube. The hover flies visit mainly the appendages
   on the outer perigone and the longer stamen whorl. These appendages
   secrete a sugar solution as well as polysaccharides and lipids. The
   latter probably attract the flies. Evidently, each pollinator is
   attracted by a different nectary type and the modes of pollination
   prevent competition between the different pollinators and are to be
   interpreted as maximixing the floral attraction in the harsh season of
   flowering (Sept. to Dec.).},
