Address = {525 B ST, STE 1900, SAN DIEGO, CA 92101-4495 USA},
Type = {Article},
Language = {English},
Affiliation = {Sosa, V (Corresponding Author), Inst Ecol, Carretera Antigua Coatepec 351, Xalapa 91070, Veracruz, Mexico.
   Gandara, Etelvina; Sosa, Victoria, Inst Ecol, Xalapa 91070, Veracruz, Mexico.
   Specht, Chelsea D., Univ Calif Berkeley, Jepson Herbaria, Berkeley, CA 94270 USA.},
