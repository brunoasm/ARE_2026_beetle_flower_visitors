ISSN = {0002-9122},
Keywords = {Amaryllidaceae; assortative and disassortative mating, founder events;
   heterostyly, Narcissus papyraceus; outcrossing rates;
   self-incompatibility, stigma-height dimorphism, style-morph ratios},
Keywords-Plus = {EICHHORNIA-PANICULATA PONTEDERIACEAE; SELF-POLLINATION; TRIANDRUS
