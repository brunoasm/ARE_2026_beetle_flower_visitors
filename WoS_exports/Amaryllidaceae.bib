Language = {English},
Affiliation = {UNIV TORONTO, DEPT BOT, TORONTO, ON M5S 3B2, CANADA.
   UNIV SEVILLE, DEPT BIOL VEGETAL \& ECOL, SEVILLE 41080, SPAIN.
   UNIV TENNESSEE, DEPT BOT, KNOXVILLE, TN 37996 USA.
   UNIV CANTERBURY, DEPT PLANT \& MICROBIAL SCI, CHRISTCHURCH 1, NEW ZEALAND.},
