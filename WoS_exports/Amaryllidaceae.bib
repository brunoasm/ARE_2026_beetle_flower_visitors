@article{ WOS:000436630100006,
Author = {Afroz, Sumona and Rahman, M. Oliur and Hassan, Md. Abul},
Title = {TAXONOMY AND REPRODUCTIVE BIOLOGY OF THE GENUS <i>ZEPHYRANTHES </i>HERB.
   (LILIACEAE) IN BANGLADESH},
Journal = {BANGLADESH JOURNAL OF PLANT TAXONOMY},
Year = {2018},
Volume = {25},
Number = {1},
Pages = {57-69},
Month = {JUN},
Abstract = {The genus Zephyranthes Herb. is revised along with its pollination
   mechanism, seed germination and vegetative propagation. Detailed
   taxonomy of four Zephyranthes species occurring in Bangladesh, namely,
   Z. atamasco (L.) Herb., Z. candida (Lindl.) Herb., Z. carinata Herb. and
   Z. tubispatha (L'Her.) Herb. ex Traub. was studied with their updated
   nomenclature, important synonyms, phenology, specimens examined,
   habitat, distribution, economic value and mode of propagation. A
   dichotomous bracketed key is provided for easy identification of the
   species. Pollination investigation reveals that all studied species of
   Zephyranthes are self-pollinated Minimum five days were required for
   germination of seeds in Z. atamasco, and three days each in Z. candida,
   Z. carinata and Z. tubispatha. Pseudovivipary type of germination has
   been reported in Z. candida and Z. carinata for the first time. The
   maximum number of seeds (30) per fruit are produced in Z. tubispatha,
   whereas the minimum seeds (2) per fruit are found in Z. atamasco.
   Vegetative propagation through bulb was found more suitable than seeds
   in Z. atamasco, Z. candida and Z. carinata. Pollen viability has been
   found 100\% in Z. candida, and Z. tubispatha, whereas, Z. atamasco and
   Z. carinata have shown 80\% and 98\% viability, respectively.},
