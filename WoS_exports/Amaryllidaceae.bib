@article{ WOS:000753167400007,
Author = {Fishchuk, O. S.},
Title = {Comparative flower morphology of <i>Agapanthus africanus</i> and
   <i>A</i>. <i>praecox</i> (Amaryllidaceae)},
Journal = {REGULATORY MECHANISMS IN BIOSYSTEMS},
Year = {2021},
Volume = {12},
Number = {4},
Pages = {620-627},
Abstract = {The structure of Agapanthus africanus and A. praecox flowers was studied
   on permanent cross-sectional and longitudinal sections using a light
   microscope. The genus Agapanthus belongs to the subfamily
   Agapanthoideae, the family Amarylliclaceae, which is characterized by
   the presence of the upper ovary, septal nectaries and fruit - fleshy
   capsule. Miciumorphological studies of the flower are considered as a
   way for detection of unknown plant features, adjustment of plants to
   specialized ways of pollination and determining the first stages of
   morphogenesis of fruit, and further use these features in taxonomy. 10
   flowers of A africanus and A. praecox were sectioned using standard
   methods of Paraplast embedding and serial sectioning at 20 micron
   thickness. Sections were stained with Safranin and Astra Blau and
   mounted in Eukitt. It was found that in the studied species the tepals
   have single-bundle traces. The vascular system of the superior ovary
   consists of a three bundle dorsal vein, of the ventral roots complex,
   which are reorganized into paired ventral bundles of the carpel, which
   form traces to ovules. For the first time, the following gynoecium zones
   were detected in A. africanus : a synascidiate structural zone with a
   height of about 560 mu m and a fertile symplicate structural zone with a
   height of about 380 mu m and a hemisymplicate zone of 2580 mu m. In A.
   africanus gynoecium, there is a synascidiate structural zone with a
   height of 200 am and a symplicate structural zone of 600 mu m and a
   hemisymplicate zone of 620 mu m Septal nectaries appear in the
   hemisymplicate zone and open with nectar fissures at the base of the
   column, with a total septal nectar height of 2880 mu m in A africanus
   and 820 mu m in A. praecox. The ovary roof is 300 mu m in A. africanus
   and 200 mu m in A. praecox. Triple dorsal bundles of carpels in A.
   africanus have been identified, which could be considered as adaptation
   of different stages of morphogenesis of fruit to dehiscence. The new
   data obtained by the vascular anatomy of the flower and the presence of
   different ovary zones significantly add to the information about
   anatomical and morphological features of the studied species, which can
   be further used in the taxonomy of the family Amaryllidaceae.},
Publisher = {OLES HONCHAR DNIPROPETROVSK NATL UNIV},
