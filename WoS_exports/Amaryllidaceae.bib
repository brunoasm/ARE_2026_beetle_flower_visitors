ISSN = {0018-067X},
Keywords = {disassortative mating; female fertilty; mating system; plant sexual
   polymorphism; self-sterility; stigma-height dimorphism},
Keywords-Plus = {EICHHORNIA-PANICULATA PONTEDERIACEAE; TRIANDRUS AMARYLLIDACEAE;
   POLYMORPHISMS; POLLINATION},
