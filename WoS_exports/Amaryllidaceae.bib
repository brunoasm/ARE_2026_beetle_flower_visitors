@article{ WOS:A1991FW83600006,
Author = {MANASSE, RS and STANTON, ML},
Title = {THE INFLUENCE OF THE MATING SYSTEM ON SEED SIZE VARIATION IN
   CRINUM-ERUBESCENS (AMARYLLIDACEAE)},
Journal = {EVOLUTION},
Year = {1991},
Volume = {45},
Number = {4},
Pages = {883-890},
Month = {JUN},
Abstract = {We present evidence that extreme seed size variation in fruits of Crinum
   erubescens (range:  0.1 to 66.5 g per seed) occurs when mating pairs are
   inbred, either from selfing or biparental inbreeding.  Several
   relatively uniform seeds of intermediate size are produced when pollen
   from several pollen donors is applied simultaneously to a flower. 
   Selfed fruits and some fruits pollinated with a single pollen donor
   produce both large and small seeds, although selfed fruits produce fewer
   seeds than outcrossed fruit.  These results are contrary to the
   hypothesis that variation in seed size is attributable to either pollen
   competition or differential allocation of maternal resource to seeds of
   different genotypes.},
