DOI = {10.3732/ajb.90.12.1751},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {attraction; bumble bee behavior; floral color change; geitonogamous
   pollination; successive flower visits},
Keywords-Plus = {SELF-FERTILIZATION; ECHIUM-VULGARE; PLANT SIZE; CONSEQUENCES;
   VISITATION; FLOWERS; BORAGINACEAE; ATTRACTION; EVOLUTION; FABACEAE},
