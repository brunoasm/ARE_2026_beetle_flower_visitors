@article{ WOS:A1985ALF6300015,
Author = {THOMSON, JD},
Title = {POLLINATION AND SEED SET IN DIERVILLA-LONICERA (CAPRIFOLIACEAE) -
   TEMPORAL PATTERNS OF FLOWER AND OVULE DEPLOYMENT},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1985},
Volume = {72},
Number = {5},
Pages = {737-740},
Abstract = {Ovule development in D. lonicera (Caprofoliaceae) is limited by
   insufficient pollination early in the blooming period and during
   extensive rainy periods. Production of flowers is skewed in time; an
   initial burst of flowering is followed by a long period of sparse flower
   production. Ovule number per flower increases though the blooming
   period. The interactions of fruit and seed set, ovule number, and bumble
   bee pollinator visitation patterns are discussed. When certain flowers
   have a higher a priori probability of successful pollination, it may be
   advantageous for plants to put more ovules in those flowers. Selective
   ovule deployment may be a general adaptive phenomenon.},
