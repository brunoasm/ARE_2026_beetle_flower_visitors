@article{ WOS:001104092000003,
Author = {Sasamori, Marcio Hisayuki and Endres Junior, Delio and do Amaral,
   Silvana Vargas and Droste, Annette},
Title = {Translocation of the epiphytic bromeliad<i> Vriesea</i><i>
   incurvata:</i> an efficient tool for biodiversity restoration in the
   Atlantic Forest},
Journal = {REVISTA BRASILEIRA DE CIENCIAS AMBIENTAIS},
Year = {2022},
Volume = {57},
Number = {4},
Pages = {677-688},
Month = {DEC},
Abstract = {Micropropagation of epiphytic bromeliads associated to translocation may
   act as an important tool for conservation, restauration or mitigation
   initiatives. Vriesea incurvata is an epiphytic tank-forming bromeliad
   endemic to the Atlantic Forest, being an important species in gallery
   forest environments. Seeds of V. incurvata were germinated in vitro ,
   and plants were acclimatized and translocated to each of two
   microhabitats (gallery forest and forest interior) of an Atlantic Forest
   fragment in South Brazil that harbors few individuals of the species.
   The 152 plants (76 per microhabitat) were monitored for survival and
   development, and abiotic data were recorded. There was increased
   development of morphometric parameters of the plants in the gallery
   forest, and survival rate ensured an 800\% increase in the original
   population of V. incurvata in the study area. Plant survival and
   development parameters were positively related to light and relative air
   humidity. In gallery forest, plants flowered and set fruit, indicating
   their relationship with pollinators, since V. incurvata provides food
   for fauna. Further, the establishment of the individuals increased the
   availability of water in the canopy by accumulation in the rosettes, as
   well as the complexity of the canopy structure, providing a site for the
   occurrence of detritivorous, predatory and herbivorous arthropods. Thus,
   based on the method applied to V. incurvata , inserting epiphytic
   species into forest environments can be an efficient tool for artificial
   habitat regeneration, incrementing functional diversity and improving
   environmental quality.},
Publisher = {ASSOCIACAO BRASILEIRA DE ENGENHARIA SANITARIA E AMBIENTAL},
Address = {AVENIDA BEIRA-MAR 216, 13 ANDA, RIO DE JANEIRO, 00000, BRAZIL},
Type = {Article},
Language = {English},
Affiliation = {Droste, A (Corresponding Author), Univ Feevale, Programa Posgrad Qual Ambiental, Rodovia 239 2755, BR-93525075 Novo Hamburgo, RS, Brazil.
   Sasamori, Marcio Hisayuki; Endres Junior, Delio; do Amaral, Silvana Vargas; Droste, Annette, Univ Feevale, Novo Hamburgo, RS, Brazil.
   Droste, Annette, Univ Feevale, Programa Posgrad Qual Ambiental, Rodovia 239 2755, BR-93525075 Novo Hamburgo, RS, Brazil.},
DOI = {10.5327/Z2176-94781450},
ISSN = {1808-4524},
EISSN = {2176-9478},
Keywords = {Bromeliaceae; conservation; ecosystem integrity; population
   reinforcement; tropical rainforest},
Keywords-Plus = {RAIN-FOREST; REINTRODUCTION; CONSERVATION; GERMINATION; DIVERSITY;
   HERBIVORY; COMMUNITY; SURVIVAL; ORCHIDS; HISTORY},
