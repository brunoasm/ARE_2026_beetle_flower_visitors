ISSN = {2167-8359},
Keywords = {Spatiotemporal variation; Effectiveness; Generalist pollination system
   Pollen limitation; Floral reflectance; Nectar; Bromeliaceae;
   Self-incompatibility; Tropical forest; Pollen robber},
