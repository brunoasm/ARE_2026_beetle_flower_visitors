EarlyAccessDate = {SEP 2022},
ISSN = {0019-1019},
EISSN = {1474-919X},
Keywords = {Atlantic Forest; biodiversity amplifier; Bromeliaceae; habitat quality;
   hummingbirds; ornithochory; trophic interactions},
Keywords-Plus = {ATLANTIC RAIN-FOREST; MONTANE FOREST; REPRODUCTIVE-BIOLOGY; FLOWERING
   PHENOLOGY; POLLINATION SYSTEM; ADAPTIVE RADIATION; DRINKING PATTERNS;
