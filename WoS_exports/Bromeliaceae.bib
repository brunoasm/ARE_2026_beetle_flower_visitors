@inproceedings{ WOS:000234185300001,
Author = {Savolainen, V and Forest, F},
Editor = {Bakker, FT and Chatrou, LW and Gravendeel, B and Pelser, PB},
Title = {Species-level phylogenetics from continental biodiversity hotspots},
Booktitle = {PLANT SPECIES-LEVEL SYSTEMATICS: NEW PERSPECTIVES ON PATTERN \& PROCESS},
Series = {Regnum Vegetabile},
Year = {2005},
Volume = {143},
Pages = {17-30},
Note = {Conference on Plant Species-level Systematics, Leiden, NETHERLANDS, NOV,
   2002},
Organization = {Linnean Soc London; Int Assoc Plant Taxon; Natl Herbarium Nederland},
Abstract = {The discovery of the causes of adaptive radiation is a challenge for
   explaining the origin of biodiversity. Adaptive radiations are
   characterized by clear ecological and/or morphological diversification
   in relation to the environment and a possible high species production.
   Such radiations are found in many animal and plant groups either with
   high numbers of species such as in cichlid fishes and angiosperms or in
   smaller groups such as Danvin's finches (Geospiza spp.), Pontederiaceae
   (water hyacinth), and the genus Brocchinia (Bromeliaceae). Cases from
   two continental biodiversity hotspots are discussed: (i) an example
   using species-level phylogeny to determine if pollinator shifts could
   have triggered the radiation observed in the genus Sinningia, a member
   of the gesneriad family from the coastal rainforests of Brazil; and (ii)
   we present a brief overview of the phylogenetic efforts in progress
   aimed at understanding the amazing species richness found in the Cape
   Floristic Region Of South Africa with a focus on the most speciose
   genera of this region.},
