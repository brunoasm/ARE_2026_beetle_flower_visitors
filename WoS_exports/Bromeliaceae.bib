@inproceedings{ WOS:000175932100001,
Author = {Vervaeke, I and Parton, E and Deroose, R and De Proft, MP},
Editor = {VanHuylenbroeck, J and VanBockstaele, E and Debergh, P},
Title = {Controlling prefertilization barriers by in vitro pollination and
   fertilization of Bromeliaceae},
Booktitle = {PROCEEDINGS OF THE TWENTIETH INTERNATIONAL EUCARPIA SYMPOSIUM - SECTION
   ORNAMENTALS: STRATEGIES FOR NEW ORNAMENTALS II},
Series = {ACTA HORTICULTURAE},
Year = {2002},
Number = {572},
Pages = {21-28},
Note = {20th International EUCARPIA Symposium - Section Ornamentals, MELLE,
   BELGIUM, JUL 03-06, 2001},
Organization = {EUCARPIA},
Abstract = {Prefertilization barriers between different Bromeliaceae are mostly
   confined within the style. To control these barriers cut style,
   placental and placental grafted style pollination were studied. After
   cut style pollination the fertilization rate increased when a longer
   style part was left on the ovary of Vriesea C. Possibly less factors
   that control pollen tube guidance to the ovules are present in the lower
   style part. After placental pollination pollen germinated on the ovules
   but only rarely penetration of the micropyle by a pollen tube occurred.
   No difference in fertilization rate between compatible and incongruent
   pollination was found. Semi in vivo pollination resulted in a higher
   pollen tube growth out of the isolated style in comparison to semi in
   vitro pollination. However for Vriesea C, even after semi in vivo
   pollination pollen tube growth was inhibited at the stylar end. Grafting
   a style containing actively growing pollen tubes to the ovules on the
   placenta (placental grafted style pollination) resulted in a
   fertilization percentage, which was comparable to this after a classical
   pollination on the stigma for Aechmea A. Pollen tube growth through the
   style seems to be necessary for guiding pollen tubes to the ovule
   micropyle.},
