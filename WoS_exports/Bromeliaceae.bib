Affiliation = {Inst Ecol AC, Dept Ecol \& Comportamiento Anim, Km 2-5 Carretera Antigua Coatepec 351,Congregac H, Xalapa 91070, Veracruz, Mexico.
   Inst Ecol AC, Dept Ecol \& Comportamiento Anim, Xalapa 91070, Veracruz, Mexico.},
DOI = {10.1007/s00442-004-1597-0},
