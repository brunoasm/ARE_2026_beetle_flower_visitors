@article{ WOS:A1991HA71000020,
Author = {FELINER, GN},
Title = {BREEDING SYSTEMS AND RELATED FLORAL TRAITS IN SEVERAL ERYSIMUM
   (CRUCIFERAE)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1991},
Volume = {69},
Number = {11},
Pages = {2515-2521},
Month = {NOV},
Abstract = {The breeding system of 13 populations belonging to eight species of
   Erysimum (Cruciferae) was studied and its relation with the life-span of
   the plants is discussed. To assess the breeding system of each
   population, greenhouse tests for apomixis, self-compatibility, and
   self-pollination were carried out, morphological characters like petal
   size and anther length were measured and pollen to ovule ratios were
   computed. The evidence gathered supports the selfing behavior of the
   three annuals, E. cheiranthoides L., E. incanum G. Kunze, and E.
   repandum L., and the outcrossing behavior of the perennials E.
   linifolium (Pers.) Gay, E. asperum (Nutt.) DC., and E. menziesii (Hook.)
   Wettst. Among those two groups, E. inconspicuum (S. Wats.) MacMillan and
   E. suffruticosum Sprengel apparently occupy an intermediate position,
   although the former tends more towards autogamy, whereas the latter
   tends towards allogamy. The importance of the breeding system data in
   the systematics of this genus, particularly, in studying the apparent
   links between the Mediterranean annuals and the temperate E.
   hieracifolium L. group is briefly discussed.},
