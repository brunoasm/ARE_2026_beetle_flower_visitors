Language = {English},
Affiliation = {HEBREW UNIV JERUSALEM, DEPT BOT, IL-91904 JERUSALEM, ISRAEL.
   HEBREW UNIV JERUSALEM, DEPT EVOLUT ECOL \& SYSTEMAT, IL-91904 JERUSALEM, ISRAEL.},
DOI = {10.1007/BF00316956},
ISSN = {0029-8549},
Keywords = {CRUCIFERAE BRASSICACEAE; REPRODUCTIVE EFFORT; MEDITERRANEAN VERSUS
   DESERT PLANTS; TRENDS OF ECONOMY},
Keywords-Plus = {POLLEN-OVULE RATIOS; IPOMOPSIS-AGGREGATA POLEMONIACEAE; BREEDING SYSTEM
   EVOLUTION; ENERGY ALLOCATION; PHENOTYPIC PLASTICITY; HERMAPHRODITIC
   PLANT; BIOMASS ALLOCATION; FLOWERING PLANTS; SELF-POLLINATION; FEMALE
   FUNCTIONS},
