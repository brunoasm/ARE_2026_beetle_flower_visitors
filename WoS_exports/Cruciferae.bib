Keywords = {Cruciferae; ephemeral plant; Diptychocarpus strictus; floral syndromes;
   breeding system; sex-expression},
Keywords-Plus = {POLLEN-OVULE RATIOS; FLOWERING PLANTS; SCROPHULARIACEAE; POLYMORPHISM},
