@article{ WOS:000185012300008,
Author = {Liu, F and Zhao, H and Yao, L and Zhang, JJ and Cao, MQ},
Title = {Gene flow from transgenic chinese cabbage (<i>Brassica campestris</i>
   ssp <i>chinensis</i> var. <i>utilis</i>) to related <i>Cruciferae</i>
   species through outcrossing},
Journal = {ACTA BOTANICA SINICA},
Year = {2003},
Volume = {45},
Number = {6},
Pages = {681-687},
Month = {JUN},
Abstract = {It was substantiated by morphological observation, chromosome and DNA
   identification that the bar gene, conferring the resistance to herbicide
   basta in transgenic Chinese cabbage ( Brassica campestris ssp. chinensis
   var. utilis Tsen et Lee), could intrude into the genomes of turnip ( B.
   campestris ssp. rapifera), heading Chinese cabbage B. campestris ssp.
   pekinensis) and other non-heading Chinese cabbage ( B. campestris ssp.
   chinensis in a relatively high frequency while into genome of B. napus
   at a low frequency via natural cross-pollination in open field.
