@article{ WOS:A1983RW48100003,
Author = {KIMATA, M},
Title = {COMPARATIVE STUDIES ON THE REPRODUCTIVE SYSTEMS OF CARDAMINE-FLEXUOSA,
   CARDAMINE-IMPATIENS, CARDAMINE-SCUTATA, AND CARDAMINE-LYRATA, CRUCIFERAE},
Journal = {BOTANICAL MAGAZINE-TOKYO},
Year = {1983},
Volume = {96},
Number = {1044},
Pages = {299-312},
Abstract = {C. flexuosa ssp. flexuosa, a self-pollinated winter annual in fallow
   paddy fields, produces numerous small seeds. C. flexuosa spp. fallax, a
   self-pollinated year-long annual in gardens and roadsides, also produces
   many small seeds. C. impatiens, a self-pollinated annual in forest
   margins, similarly produces numerous small seeds. C. scutata is a
   self-pollinated perennial in poorly drained paddy fields and creeks; its
   vegetative reproduction is not predominant, and it produces relatively
   many seeds. C. lyrata, a cross-pollinated perennial with
   self-incompatibility in poorly drained paddy fields and creeks, produces
   fewer and heaver seeds, but produces many ramets. Seed dispersal
   mechanisms and germination behavior of these Cardamine species reveal
   several adaptive characteristics to their habitats. These observations
   on the reproductive systems of 4 Cardamine species apparently present
   different characteristics of life history strategy for each of them.},
