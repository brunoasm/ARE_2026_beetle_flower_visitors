   ORYZA-SATIVA},
Journal = {EUPHYTICA},
Year = {1993},
Volume = {69},
Number = {1-2},
Pages = {129-134},
Abstract = {Comparative study with fluorescence microscopy revealed that the pollen
   tubes of the self-pollinated rice variety BR-9 reached the ovary within
   75 min after pollination. In P. coarctata it took 150 min. In the cross
   between P. coarctata and BR-9, pollen tubes reached the ovary in 165 min
   but seed setting was not observed. In the cross between BR-9 and P.
   coarctata, small and deformed pollen tubes were formed and they failed
   to grow through the stylodium.},
