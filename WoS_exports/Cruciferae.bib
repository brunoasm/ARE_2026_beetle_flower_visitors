Year = {1977},
Volume = {9},
Number = {2},
Pages = {211-215},
Abstract = {One hundred and thirty-eight visits by Phyllotreta albionica (Lec.)
   (Coleoptera: Chrysomelidae) were observed at the flowers of T. alpestre
   L. (Cruciferae) in early June on the Colorado {[}USA] alpine tundra.
