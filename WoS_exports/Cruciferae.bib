@article{ WOS:A1977CY12400002,
Author = {VERMA, SC and MALIK, R and DHIR, I},
Title = {GENETICS OF INCOMPATIBILITY SYSTEM IN CRUCIFER ERUCA-SATIVA L},
Journal = {PROCEEDINGS OF THE ROYAL SOCIETY SERIES B-BIOLOGICAL SCIENCES},
Year = {1977},
Volume = {196},
Number = {1123},
Pages = {131-159},
Abstract = {The oleiferous crucifer, E. sativa, is self-sterile. The trinucleate
   pollen grains, simultaneous cytokinesis, stigmatic surface as the site
   of pollen inhibition (self as well as incompatible pollen), and the
   successful selfing in the bud and after decapitating the stigma provide
   positive evidence in favor of sporophytic control of pollen reaction
   (cf. Narsingdas 1958). It conforms to the sporophytic system of
   incompatibility characteristic of Cruciferae. There is a high degree of
   cross-compatibility in families derived from crosses, and, contrary to
   expectation, it is retained up to F3 generation, which suggests a
   complex incompatibility system. Intrafamilial pollination studies from
   F1 to F3 generation invariably revealed more than 4 mating groups,
   thereby discarding the 1-locus system. The F2 and F3 families contained
   almost as many phenotypic groups as the number of plants tested in each
   family. As the F3 families comprised more than 16 plants, the Eruca
   system involves at least 3 loci. Confirmation of at least 3 loci
   controlling the incompatibility system follows from the diallel crosses
   in 2 F4 families of selfing origin. Reciprocal differences are common in
   all the families of the 3 generations (and also in F4 families from
   selfing), which are possible on differential dominance relations of
   alleles in pollen and style (including stigma). At least 2 of the 3 loci
   operate like the S and Z loci in grasses except that there is
   sporophytic control and dominance. The loci are complementary and for an
   incompatibility reaction to occur the action of alleles at the S and Z
   loci must be matched in pollen and style (stigma in this case). The data
   on the number of reciprocally compatible crosses, incompatible crosses,
   and the reciprocal compatible (i.e., with reciprocal difference) crosses
   resemble the expectations based on some theoretical families with 2
   genes. The alleles exhibit both dominance and co-dominances depending on
   the alleles and pollen reaction is independent of reaction on the
   stigma. The data give a good fit with the 3 gene system. The 3 gene
   system operating in sporophytic and complementary manner would be
   adaptive for maximum cross-compatibility, when compared with 1 gene
   systems.},
Type = {Article},
Language = {English},
Affiliation = {PANJAB UNIV, DEPT BOT, CHANDIGARH 160014, INDIA.},
DOI = {10.1098/rspb.1977.0034},
ISSN = {0080-4649},
Research-Areas = {Life Sciences \& Biomedicine - Other Topics},
Web-of-Science-Categories  = {Biology},
