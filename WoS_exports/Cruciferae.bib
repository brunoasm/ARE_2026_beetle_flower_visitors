   APS UNIV,SCH ENVIRONM BIOL,REWA 486001,MP,INDIA.},
DOI = {10.2307/2996775},
ISSN = {0040-9618},
Keywords = {Alliaria petiolata; breeding system; facultative xenogamy; fruit set;
   seed set; nectar constituents; pollination; pollinators},
Keywords-Plus = {CRUCIFERAE; NECTAR},
Research-Areas = {Plant Sciences},
