@article{ WOS:A1987J193600010,
Author = {EGUIARTE, L and DELRIO, CM and ARITA, H},
Title = {NECTAR AND POLLEN AS RESOURCES, AS SEEN IN THE ECOLOGICAL ROLE OF
   VISITORS TO THE FLOWERS OF PSEUDOBOMBAX-ELLIPTICUM (HBK) DUGAND},
Journal = {BIOTROPICA},
Year = {1987},
Volume = {19},
Number = {1},
Pages = {74-82},
Month = {MAR},
Abstract = {The floral biology of P. ellipticum and the foraging patterns of its
   visitors were studied near Tlayacapan, Morelos, Mexico (at 1950 m
   altitude). P. ellipticum (Bombacaceae) presents big flowers (red or
   white) that produce nectar during the night and the following morning.
   At night three species of bats (Leptonycteris sanborni, Choeronycteris
   mexicana, and Glossophaga leachtt. Family Phyllostomidae) visited the
   flowers rapidly and always carried mixed pollen loads (of P. ellipticum 
   and Ipomoea sp.). During the day the flowers were visited by three
   oriole species (Icterus wagleri, I. pustulatus, and I. galbula
   bullocki), two hummingbird species (Amazilia violiceps and Cynanthus
   sordidus), and by four species of bees. The foraging patterns of the
   birds are affected by the total amount of available nectar and by inter-
   and intraspecific agonistic interactions, whereas the foraging patterns
   of the bees depend on the availability of pollen. The visitors can be 
   classified in three categories: main pollinators (bats), minor
   pollinators (orioles), and parasites (hummingbirds and bees). Bees play
   a very important negative role by reducing oriole pollination.},
