@article{ WOS:000614939300001,
Author = {Duffy, Karl J. and Mdlalose, Zwelibanzi M. and Johnson, Steven D.},
Title = {Sexual Conflict in Hermaphroditic Flowers of an African Aloe},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {2021},
Volume = {182},
Number = {3},
Pages = {238-243},
Month = {MAR 1},
Abstract = {Premise of research. In hermaphroditic plants, pollen production can
   enhance fitness through siring success by attracting pollen-seeking
   pollinators. However, pollen production can also decrease female fitness
   if ovules penetrated by self-pollen tubes are usurped, thereby limiting
   opportunities for seed production. Methodology. We investigated the
   hermaphroditic aloe Aloe pruinosa, which is pollinated by birds and
   native bees. We performed manual crossed and selfed hand-pollinations
   and examined pollen tube growth rates to locate the self-incompatibility
   (SI) barrier. To quantify the effects of pollen production on pollinator
   visitation and fecundity, we compared experimentally emasculated plants
   with intact controls. Pivotal results. Pollen tubes grew into the
   ovaries and penetrated the ovules of both crossed and selfed flowers,
   indicating a putative late-acting SI system. Experimental emasculation
   resulted in reduced bee visitation but had no effect on bird visitation.
   Emasculation led to reduced pollen deposition on stigmas and slightly
   reduced fruit production but also led to marked increases in the number
   of seeds per fruit and overall seed production. Conclusions. These
   results demonstrate that hermaphroditism can involve trade-offs between
   the quantity of visiting pollinators and the quality of pollen transfer
   between plants, thus highlighting the roles of sexual conflict and
   fitness compromise in flowering plants.},
