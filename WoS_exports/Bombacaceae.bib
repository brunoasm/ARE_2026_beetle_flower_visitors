   Universeum AB, S-40020 Gothenburg, Sweden.},
DOI = {10.1111/j.1095-8312.2004.00317.x},
ISSN = {0024-4066},
Keywords = {Ceiba pentandra; chiropterophilous species; Ivory coast; Megachiroptera;
   Senegal; sulphur compounds},
Keywords-Plus = {FRUIT-EATING BATS; RAIN-FOREST; CONVERGENT EVOLUTION; CEIBA-PENTANDRA;
   FLOWER; PLANTS; PHENOLOGY; CHEMISTRY; AMAZONIA; BIOLOGY},
