   Hernandez-Montero, Jesus R.; Sosa, Vinicio J., Inst Ecol AC, Red Ecol Func, Apdo Postal 63, Xalapa 91000, Veracruz, Mexico.},
DOI = {10.1111/1442-1984.12096},
ISSN = {0913-557X},
EISSN = {1442-1984},
Keywords = {bees; breeding system; chiropterophily; floral biology; Malvaceae;
