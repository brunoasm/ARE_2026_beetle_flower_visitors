   Antonio Caballero-Martinez, Luis; Medellin, Rodrigo A., Univ Nacl Autonoma Mexico, Inst Ecol, Mexico City 04510, DF, Mexico.},
DOI = {10.1017/S0266467410000714},
ISSN = {0266-4674},
EISSN = {1469-7831},
Keywords = {bat assemblages; chiropterophily; community ecology; Glossophaginae;
   Musonycteris harrisoni; Phyllostomidae; seasonality},
Keywords-Plus = {ANOURA-GEOFFROYI CHIROPTERA; LEPTONYCTERIS-CURASOAE; FORAGING BEHAVIOR;
