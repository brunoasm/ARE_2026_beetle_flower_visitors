DOI = {10.1590/0102-33062019abb0141},
ISSN = {0102-3306},
EISSN = {1677-941X},
Keywords = {adventitious embryo precursor cells; Handroanthus serratifolius;
   polyploidy; self-sterility; Tabebuia serratifolia},
