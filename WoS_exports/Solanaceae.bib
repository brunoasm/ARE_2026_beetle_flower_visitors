@article{ WOS:000697087700001,
Author = {Alves de Deus, Jean Pablo and Pinto da Luz, Cynthia Fernandes and Tunes
   Buschini, Maria Luisa},
Title = {Bees on the flowers of <i>Solanum mauritianum</i> Scop. (Solanaceae) in
   Southern Brazil: visitation frequency and topological networks from body
   and leg pollen analysis},
Journal = {ARTHROPOD-PLANT INTERACTIONS},
Year = {2021},
Volume = {15},
Number = {6},
Pages = {907-916},
Month = {DEC},
Abstract = {Considering the worldwide decline of pollinators, the ecological
   services provided by bees have been compromised. Therefore, studying
   this mutualistic relationship can be critical to understanding these
   communities. One way to study this relationship is by studying the
   pollen found on bees. To transport the pollen to their larvae, bees need
   to manipulate and store it in specialized transport structures. In this
   process, the pollen viability may be lost, and only those passively
   trapped in the bees' bodies will be available for pollination. Here, we
   identify the pollen present on the body and legs of bees that visit
   Solanum mauritianum and its interaction network to understand if the
   abundance, richness, composition and interaction network of the pollen
   types change when we analyze the pollen that comes from bee bodies and
   legs separately. We obtained different information about the pollens
   that would be available for pollination and which bee species would most
   likely carry out the pollination of plants. In this study, we did not
   find a significant difference in the richness and composition of pollen
   in the body and legs of bees; however, we observed a difference in the
   abundance and structure of the species interaction network. Different
   ways to analyze the interactions between species can be considered good
   strategies to better understand the pollination process. In this study,
   palynology showed us that different types of information can be found
   depending on the methodology used and the origin of the pollen (body or
   legs).},
