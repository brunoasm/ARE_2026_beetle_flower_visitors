@article{ WOS:001282111300003,
Author = {Sosa, Claudio A.},
Title = {Use of floral resources by Andrenidae, Colletidae and Megachilidae
   (Hymenoptera: Apoidea) in the Chaco Serrano of Córdoba (Argentina)},
Journal = {REVISTA CHILENA DE ENTOMOLOGIA},
Year = {2024},
Volume = {50},
Number = {3},
Pages = {415-436},
Month = {JUL-SEP},
Abstract = {The diversity of Andrenidae, Colletidae and Megachilidae in a section of
   the Bosque Serrano in C \& oacute;rdoba, Argentina (31 degrees 10' S, 64
   degrees 20' W) was determined and the utilization of floral resources by
   them in this area was analyzed. Eight samples monthly were made between
   September 2018 to March 2020. The diversity of plants presents, number
   of available flowers, diversity of bees and their activity patterns,
   search mechanisms and obtaining resources from the visited flowers were
   registered. About 192 specimens corresponding to Andrenidae (3.12\%,
   n=6, species: 1), Colletidae (17.88\%, n=34, species: 5) and
   Megachilidae (79.16\%, n=152, species: 5) were sampled. Angiosperms
   including 11 families and 28 species (principally Apiaceae, Asteraceae,
   Fabaceae, Lamiaceae, Malvaceae, and Solanaceae), were used by bees as
   floral resources. During the study, there were no differences in the
   diversity of plant species available to bees at different years.
   Differences were identified between the years of the study, concerning
   the use of floral resources by bees. The dominant species to select the
   resources were the most generalist bees.},
