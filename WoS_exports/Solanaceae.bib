@article{ WOS:A1993MC77000022,
Author = {BOAVENTURA, YMS and PIEDADE, LH},
Title = {FLORAL BIOLOGY AND CYTOLOGICAL ANALYSIS OF BRUNFELSIA-NITIDA BENTH
