   Simon Fraser Univ, Dept Biol Sci, Burnaby, BC V5A 1S6, Canada.},
ISSN = {0008-347X},
Keywords-Plus = {HONEY-BEE; HYMENOPTERA; APIDAE; POLLEN; POLLINATION; APIS; WORKERS; SIZE},
Research-Areas = {Entomology},
