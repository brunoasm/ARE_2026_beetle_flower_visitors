@article{ WOS:000085956600005,
Author = {Motten, AF and Stone, JL},
Title = {Heritability of stigma position and the effect of stigma-anther
   separation on outcrossing in a predominantly self-fertilizing weed,
   <i>Datura stramonium</i> (Solanaceae)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2000},
Volume = {87},
Number = {3},
Pages = {339-347},
Month = {MAR},
Abstract = {A polymorphism for anthocyanin production was used as a generic marker
   to document the relationship between antherstigma separation and
   outcrossing rate in the predominantly self-fertilizing weed Datura
   stramonium. White-flowered plants that differed in anther-stigma
   separation were placed into populations consisting exclusively of
   purple-flowered plants. Self vs, outcross origin of progeny was evident
   in the hypocotyl color of the seedlings. Outcrossing rates measured for
   single flowers were significantly positively correlated with
   anther-stigma separation, albeit with some scatter around the regression
   line, especially for flowers with exserted stigmas. We also performed an
   8 x 8 diallel cross to determine whether antherstigma separation is
   genetically determined. Heritability in two field plots was similar to
   0.3 and in the greenhouse was similar to 0.2. Maternal effects,
   epistasis, and dominance appeared to be relatively unimportant.
   Genotypes performed consistently across the three environments, although
   total plant size varied more than fivefold. It appears that the
   mixed-mating system of D. stramonium has a heritable basis and would be
   capable of responding to selection.},
Publisher = {BOTANICAL SOC AMER INC},
Address = {OHIO STATE UNIV-DEPT BOTANY 1735 NEIL AVE, COLUMBUS, OH 43210 USA},
