Volume = {16},
Number = {3},
Pages = {785-792},
Month = {SEP},
Abstract = {The floral biology, the breeding system and cytology of Brunfelsia
   nitida is described. Flowers are tubulous, yellow and have diurnal
   anthesis. B. nitida is self-compatible, though cross-pollination is
   considerably more effective. An agent is required to promote
   pollination.  The chromosome number is 2n = 22. The karyotype formula is
   1M + 8m + 2sm, with a satellite in the sixth pair. The microsporogenesis
   analysis showed normal meiosis, and pollen viability was high (73.2\%).},
