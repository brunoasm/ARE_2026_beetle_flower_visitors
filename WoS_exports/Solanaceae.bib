Title = {Pollen Load and Flower Constancy of Stingless Bees <i>Tetragonula
   laeviceps</i> (Smith) and <i>Heterotrigona itama</i> (Cockerell)
   (Apidae: Meliponinae)},
Booktitle = {PROCEEDINGS OF THE INTERNATIONAL CONFERENCE AND THE 10TH CONGRESS OF THE
   ENTOMOLOGICAL SOCIETY OF INDONESIA (ICCESI 2019)},
