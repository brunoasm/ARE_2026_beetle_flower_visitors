Affiliation = {Cappadocia, M (Corresponding Author), Univ Montreal, Inst Rech Biol Vegetale, Dept Sci Biol, 4101 Sherbrooke Est, Montreal, PQ H1X 2B2, Canada.
   Liu, Bolin; Boivin, Nicolas; Morse, David; Cappadocia, Mario, Univ Montreal, Inst Rech Biol Vegetale, Dept Sci Biol, Montreal, PQ H1X 2B2, Canada.},
DOI = {10.1007/s00497-012-0192-5},
