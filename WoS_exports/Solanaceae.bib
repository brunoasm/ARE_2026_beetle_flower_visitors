Affiliations = {University of Colorado System; University of Colorado Boulder},
Funding-Acknowledgement = {National Science Foundation {[}NSF-DEB 1413855, CNS-0821794]; Direct For
   Biological Sciences; Division Of Environmental Biology {[}1413855]
   Funding Source: National Science Foundation},
Funding-Text = {We thank D. Jackson, H. Biagini-Lee and L. Nalezny for their help in
