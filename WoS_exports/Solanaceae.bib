@article{ WOS:A1992HB90600009,
Author = {MURRAY, BG and HAMMETT, KRW and GRIGG, FDW},
Title = {SEED SET AND BREEDING SYSTEM IN THE PEPINO SOLANUM-MURICATUM AIT,
   SOLANACEAE},
Journal = {SCIENTIA HORTICULTURAE},
Year = {1992},
Volume = {49},
Number = {1-2},
Pages = {83-92},
Month = {JAN},
Abstract = {Several cultivars and selections of the pepino were found to be
   self-compatible, but the rate of self-pollen tube growth in the style
   was found to be variable. The suggested wild progenitor, Solanum
   caripense, is self-incompatible and all the features of its
   incompatibility suggest that it is gametophytically controlled by a
   single gene. A variety of pollination treatments have shown that there
   is a variable expression of vegetative parthenocarpy amongst cultivars
   of the pepino. One selection shows obligate parthenocarpy, whereas the
   others show facultative parthenocarpy. Under commercial conditions, the
   cultivars that were studied needed to be pollinated to set fruit. Using
   a fruit colour gene it was possible to show that some of this pollen was
   cross-pollen.},
