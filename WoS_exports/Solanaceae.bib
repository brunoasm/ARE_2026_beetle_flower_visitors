Type = {Article},
Language = {English},
Affiliation = {Univ Guelph, Dept Bot, 50 Stone Rd E,Axelrod Bldg,Rm 115, Guelph, ON N1G 2W1, Canada.
   Simon Fraser Univ, Dept Biol Sci, Burnaby, BC V5A 1S6, Canada.
