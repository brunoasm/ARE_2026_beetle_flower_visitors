@article{ WOS:000166805500019,
Author = {Laportte, MC and Jáuregui, D and de Torres, EC},
Title = {Anatomical and histochemical characterization of the stigma and style of
   five Cestrum species (Solanaceae) in Venezuela},
Journal = {PHYTON-INTERNATIONAL JOURNAL OF EXPERIMENTAL BOTANY},
Year = {2000},
Volume = {67},
Pages = {139-149},
Abstract = {The structure and histochemistry of stigma and style was studied in five
   species of Cestrum (Solanaceae) of Venezuela in samples from blossoms
   and open flowers subjected to natural pollination and which were
   observed by light and scanning microscopy. The five species are similar
   in the stigma and style anatomy, with a stigmatic exudate rich in
   lipids, that probably contributes to the adhesion of pollen grains. The
   secretions of the transmitting tissue have abundant starch, that
   possibly helps nourish the growing pollen tubes. Cell-walls of the style
   are lignified, a feature that seems common to all members of
   Cestroideae.},
