DOI = {10.1111/evo.12419},
ISSN = {0014-3820},
EISSN = {1558-5646},
Keywords = {Embryonic inbreeding depression; mating system; pollen discounting;
   reproductive assurance; seed discounting; self-fertilization;
   self-incompatibility},
Keywords-Plus = {TRISTYLOUS EICHHORNIA-PANICULATA; LEAVENWORTHIA-ALABAMICA BRASSICACEAE;
