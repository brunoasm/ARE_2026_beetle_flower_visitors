   Heidelberg Univ, Inst Pharm \& Mol Biotechnol, D-69120 Heidelberg, Germany.},
DOI = {10.1016/S0031-9422(03)00300-5},
ISSN = {0031-9422},
EISSN = {1873-3700},
Keywords = {secondary metabolites; ecological function; defence; attraction;
   molecular phylogeny; Fabaceae; Lamiaceae; Solanaceae; chemotaxonomy},
Keywords-Plus = {PAPILIONOIDEAE FAMILY LEGUMINOSAE; NUCLEOTIDE-SEQUENCES; RBCL GENE;
   CLASSIFICATION; SYSTEMATICS; PATHOGENS; ALKALOIDS; LABIATAE; PATTERNS;
   PLANTS},
