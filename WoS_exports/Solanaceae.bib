@article{ WOS:A1988P418700011,
Author = {GRIGG, FDW and SMITH, PR and STENERSEN, MA and MURRAY, BG},
Title = {VARIABLE POLLEN FERTILITY AND ABNORMAL CHROMOSOME BEHAVIOR IN THE PEPINO
   (SOLANUM-MURICATUM AIT, SOLANACEAE)},
Journal = {SCIENTIA HORTICULTURAE},
Year = {1988},
Volume = {35},
Number = {3-4},
Pages = {259-268},
Month = {JUN},
Abstract = {Large differences in pollen stainability was observed for 7 cultivars of
   the pepino (Solanum muricatum Ait.). Viability was measured by staining
   pollen with cotton blue or fluorescein diacetate and for 4 cultivars by
   seed set after compatible pollinations. Comparable results were obtained
   from the two staining methods, although cotton blue over-estimated
   viability in most cases. Temperature had only a small effect on pollen
   stainability, although temperatures above 25.degree. C caused high
   levels of bud and flower drop. Abnormal meiotic behaviour with the
   formation of variable numbers of univalents was found to be associated
   with the observed levels of infertility, but other, as yet unknown,
   factors must also influence pollen fertility in the pepino.},
