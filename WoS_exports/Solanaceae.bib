@article{ WOS:001139283700001,
Author = {Corti, Camila and Arcerito, Facundo R. Meroi and Landa, Gregorio
   Fernandez de and Mazzei, Mariana Paola and Landa, Mateo Fernandez de and
   Maggi, Matias and Galetto, Leonardo},
Title = {Tomato production under greenhouse conditions: Bumblebees or hormones?},
Journal = {SCIENTIA HORTICULTURAE},
Year = {2024},
Volume = {326},
Month = {FEB 15},
Abstract = {An auxin hormone regulator (Tomatosa) usually stimulates tomato
   production under greenhouse conditions. However, its use usually
   produces fruit abnormalities and adverse environmental effects. An
   alternative practice is promoting insect pollination, and Bombus species
   are efficient and reliable pollinators for tomato flowers. The present
   work assesses tomato fruit set and fruit quality under pollination
   service provided of the native bumblebee (Bombus pauloensis) compared to
   fruit production with Tomatosa and analized the pollination efficiency
   of the bumblebee in different frequency of visits. The positive effect
   of B. pauloensis on fruit set rate and fruit quality of tomatoes grown
   under greenhouse conditions is highlighted. The hormone regulator did
   not even show positive effects on fruit production. According to our
   results, an intermediate intensity of pollination by B. pauloensis is
   desirable to achieve the highest transfer of pollen on the stigma.},
