EISSN = {1537-2197},
Keywords = {interspecific reproductive barriers; pollen-pistil interactions;
   self-incompatibility; SI x SC rule; Solanaceae; Solanum; tomato clade;
   unilateral incompatibility; unilateral incongruity; wide hybridization;
