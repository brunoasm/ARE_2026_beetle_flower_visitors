@article{ WOS:A1996UQ26000011,
Author = {Cane, JH},
Title = {Nesting resins obtained from larrea pollen host by an oligolectic bee,
   Trachusa larreae (Cockerell) (Hymenoptera: Megachilidae)},
Journal = {JOURNAL OF THE KANSAS ENTOMOLOGICAL SOCIETY},
Year = {1996},
Volume = {69},
Number = {1},
Pages = {99-102},
Month = {JAN},
Abstract = {A nesting aggregation of the bee Trachusa (Heteranthidium) larreae
   (Ckll.) is described from the Sonoran desert near Tucson, Arizona. The
   bees' shallow subterranean nest cells were lined and capped with a thick
   layer of hardened resin. Females were observed collecting the resin from
   new shoots of creosote bush, Larrea tridentata (Zygophyllaceae), which
   is this bee's sole pollen and nectar host. This extreme obligatory host
   association of T. larreae is rare among bees, and yet has apparently
   arisen in relatively recent evolutionary time.},
Publisher = {KANSAS ENTOMOLOGICAL SOC},
Address = {PO BOX 368, LAWRENCE, KS 66044 USA},
Type = {Article},
Language = {English},
