@article{ WOS:001353587800001,
Author = {Khanduri, Priyanka and Chandra, Atika and Roy, Sudip Kumar and Tandon,
   Rajesh},
Title = {Reproductive biology of <i>Podostemum subulatum</i> (Podostemaceae)
   reveals pre-anthesis cleistogamy},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2024},
Volume = {310},
Number = {6},
Month = {DEC},
Abstract = {Podostemaceae is the largest family of freshwater angiosperms. Unlike
   other aquatic plants, those belonging to Podostemaceae are known to
   undergo only sexual reproduction. However, due to their challenging
   habitats, there is limited information available on the reproductive
   biology in the family. In the present investigation, aspects of
   reproductive biology of an endemic species of Podostemaceae, Podostemum
   subulatum, were studied. Flowering shoots bearing floral primordia
   appear under submerged conditions in the species in early December. Each
   flowering shoot consists of 2-8 flowers in the axils of alternate leaves
   which have a sheathing base and an awn-like tip. Flowers lie prostrate
   on the substratum. Each flower is asepalous, apetalous and is enclosed
   by a membranous structure called spathella. Flower emerges from the
   envelopment of spathella once the water level recedes, and by this
   stage, the stigma is already loaded with self-pollen (autogamy). Thus,
   pre-anthesis cleistogamy under water, i.e. self-pollination, occurs
   before the emergence of flowers from spathella occurs in the species.
   Juxtaposition of the stigma and anthers, overlapping of the timings of
   stigma receptivity and anther dehiscence and self-compatibility
   facilitates spontaneous autogamy. Semi-vivo breeding experiments
   confirmed the occurrence of obligate autogamy in the species, which is
   also supported by low pollen: ovule ratio (similar to 25). In the
   absence of any form of asexual reproduction, reproductive success of P.
   subulatum is solely dependent on sexual reproduction. As the species
   occurs in aquatic habitat and flowers are dorsiventral or parallel to
   the substratum at the time of anthesis, there are increased chances of
   pollen loss. Therefore, pre-anthesis cleistogamy works as a strategy of
   reproductive assurance under conditions which otherwise are not
   conducive to ensure male fitness.},
