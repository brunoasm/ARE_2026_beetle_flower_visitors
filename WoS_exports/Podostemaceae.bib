@article{ WOS:000641447200001,
Author = {da Silva-Batista, Inara Carolina and Cardoso Machado da Costa, Filipe
   Gomes and de Assuncao, Tamires Silva and Koschnitzke, Cristiana and
   Vieira, Ricardo Cardoso and Bove, Claudia Petean},
Title = {First report of osmophores and wet stigma in Podostemaceae with notes on
   floral biology and pollination of<i> Weddellina</i><i> squamulosa</i>
   Tul.},
Journal = {FLORA},
Year = {2021},
Volume = {278},
Month = {MAY},
Abstract = {Weddellina squamulosa floral morphology, anthesis and pollination were
   investigated. Anatomical and histochemical analyses were carried out to
   clarify the stigma type and location of putative osmophores. Although
   bracts, tepals, stamens, and stigmas were stained after immersion in
   neutral red, osmophores were detected only in the tepals. The presence
   of osmophores is supported by the positive test for starch, and unique
   micromorphology of the tepals when compared with others floral
   structures, such as the presence of idioblasts with lipophilic contents.
   These results indicated the importance of a combined approach using
   floral biology and anatomy to determine the presence of osmophores.
   Stamen movement had an important function in delaying self-pollination
   in the early stages of anthesis, improving the opportunity for
   cross-pollination and promoting self-pollination in the last hour of
   anthesis in case of cross-pollination failure. Halictid bees were
   observed collecting pollen from anthers of W. squamulosa flowers, which
   may promote pollination. Some attributes of W. squamulosa flowers can
   attract floral visitors, and others contribute to spontaneous
   self-pollination. There is no evidence for anemophily in this species.
   This is the first report of wet stigmas and description of osmophores in
   Podostemaceae.},
