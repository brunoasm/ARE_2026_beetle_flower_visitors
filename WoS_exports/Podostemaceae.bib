@article{ WOS:000861008800005,
Author = {Rodriguez-Vieyra, Arantza and Castillo, Guillermo and Rosas, Ulises and
   Collazo-Ortega, Margarita},
Title = {Uncharted waters: Inbreeding negatively affects germination performance
   in <i>Marathrum foeniculaceum</i> (Podostemaceae)},
Journal = {AQUATIC BOTANY},
Year = {2022},
Volume = {182},
Month = {OCT},
Abstract = {In outcrossing species, inbreeding reduces fitness because homozygous
   deleterious alleles increase their fre-quency in what is called
   inbreeding depression. The theory well predicts this phenomenon;
   however, it is often unclear what proxies of fitness inbreeding might
   affect. Inbreeding depression in aquatic plants is not extensively
   studied. To fill this gap, we evaluated the effect of inbreeding trough
   experimental crosses (inbreeding vs. selfing) on parameters of seed
   germination performance (i.e., final germination percentage, germination
   speed and seed size) of the riverweed Marathrum foeniculaceum
   (Podostemaceae), using seeds collected in two locations of Me ` xico. We
   found that the final percentage of germination is affected negatively by
   inbreeding, but its effect on the speed of germination and seed size
   were dependent on the river location. This indicates that, even when
   evaluating the seed germination of the same species, the population
   dynamics of each location can be different, which might be the result of
   their evolutionary history and local environmental conditions. These
   results are important for the design of effective in situ conservation
   strategies of Podostemaceae in their natural habitat.},
