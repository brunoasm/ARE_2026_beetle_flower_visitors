ISSN = {0304-3770},
EISSN = {1879-1522},
Keywords = {Autogamy; Autopollination; Aquatic angiosperm; Endemic},
Keywords-Plus = {BREEDING SYSTEM; POLLINATION; SHOOT; SEED; CLEISTOGAMY; ANGIOSPERMS;
