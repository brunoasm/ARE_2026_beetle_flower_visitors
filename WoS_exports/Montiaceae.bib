   Eggli, Urs, Sukkulenten Sammlung Zurich, Mythenquai 88, Zurich, Switzerland.
   Giorgetta, Mario, Oberfeldstr 87, CH-8408 Winterthur, Switzerland.},
ISSN = {0265-086X},
Keywords = {Bolivia; Montiaceae; Phemeranthus; ecology; pollination; Formicidae},
