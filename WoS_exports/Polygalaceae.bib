@article{ WOS:A1991GL42900001,
Author = {JOHNSON, CT and WEITZ, FM},
Title = {A REEVALUATION OF NYLANDTIA (POLYGALACEAE)},
Journal = {SOUTH AFRICAN JOURNAL OF BOTANY},
Year = {1991},
Volume = {57},
Number = {5},
Pages = {229-233},
Month = {OCT},
Abstract = {A re-evaluation of the monotypic genus Nylandtia Dumort. is presented in
   which two varieties, N. spinosa(L.) Dumort. var. spinosa and var.
   scoparia (Eckl. \& Zeyh.) Johnson \& Weitz, are recognized. 
   Descriptions, synonymy, distribution data, and a key to the varieties
   are provided.  Variation in the two varieties is covered and pollination
   ecology is discussed.},
