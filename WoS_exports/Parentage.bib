   Cisneros, Aroldo; Tel-Zur, Noemi, Ben Gurion Univ Negev, Jacob Blaustein Inst Desert Res, French Associates Inst Agr \& Biotechnol Drylands, IL-84990 Midreshet Ben Gurion, Israel.},
DOI = {10.1007/s10681-013-0979-y},
ISSN = {0014-2336},
EISSN = {1573-5060},
