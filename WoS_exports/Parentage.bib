@inproceedings{ WOS:000343859900026,
Author = {Medina-Mora, C. and Fulbright, D. W. and Jarosz, A. M.},
Editor = {Double, ML and MacDonald, WL},
Title = {SSR Genotyping of Progeny from a Chestnut Orchard in Michigan},
Booktitle = {V INTERNATIONAL CHESTNUT SYMPOSIUM},
Series = {Acta Horticulturae},
Year = {2014},
Volume = {1019},
Pages = {173-178},
Note = {5th International Chestnut Symposium, Shepherdstown, WV, SEP 04-08, 2012},
Organization = {Int Soc Hort Sci},
Abstract = {The proper selection of cultivars for commercially successful orchards
   in Michigan is crucial to ensure good nut production with regard to
   size, quality and quantity. In 2007, we began using simple sequence
   repeats (SSRs) to genetically characterize chestnut trees currently
   growing in Michigan. From this evaluation, we selected five
   CsCAT/EMCs/QrZAG loci that were helpful in the genetic characterization
   of chestnut cultivars and their progeny. Because chestnut trees
   (Castanea spp.) must outcross to produce nuts, orchards must be planted
   where the maximum amount of pollen move from pollen-producing cultivars
   to trees with receptive flowers. In the summer of 2010, a
   cross-pollination study was performed where a single `Okei' (C. crenata
   x C. pumila var. pumila) tree and a single `Benton Harbor' (C.
   mollissima) tree were pollen sources to four `Colossal' (C. sativa. C.
   crenata) trees. We focused on `Colossal' because of its relative
   abundance in Michigan orchards. In this study, a total of 70 nuts were
   harvested from the 180 monitored female `Colossal' flowers. Paternity
   was tested by inserting a bone marrow sampling instrument through the
   shell of each nut and removing a small amount of kernel tissue. The DNA
   of the biopsied tissue was isolated and genotyped with the EMCs15 locus.
   Amplicon size ranged from 70 to 88 base pairs and the number of alleles
   observed was four. This genetic variability proved to be enough to
   identify the cultivars involved in each cross. In this limited study, we
   found that the cultivar `Okei' pollinized twice as many nuts on
   `Colossal' as did the cultivar `Benton Harbor'.},
Publisher = {INT SOC HORTICULTURAL SCIENCE},
Address = {PO BOX 500, 3001 LEUVEN 1, BELGIUM},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Medina-Mora, C (Corresponding Author), Michigan State Univ, Dept Plant Soil \& Microbial Sci, E Lansing, MI 48824 USA.
   Medina-Mora, C.; Fulbright, D. W., Michigan State Univ, Dept Plant Soil \& Microbial Sci, E Lansing, MI 48824 USA.
   Jarosz, A. M., Michigan State Univ, Dept Plant Biol \& Ecol, Evolutionary Biol \& Behav Program, E Lansing, MI USA.},
DOI = {10.17660/ActaHortic.2014.1019.26},
