   species},
Keywords-Plus = {SEED DISPERSAL; GOMORTEGA-KEULE; FOREST FRAGMENTATION; POLLEN DISPERSAL;
   WOODY-PLANTS; DISTANCE; CONSEQUENCES; POPULATION; PATTERNS; FLOW},
