   Garris, Amanda; Cousins, Peter; Baldo, Angela, USDA ARS, Grape Genet Res Unit, Geneva, NY 14456 USA.
   Ramming, David, USDA ARS, San Joaquin Valley Agr Sci Ctr, Parlier, CA 93648 USA.},
ISSN = {0002-9254},
Keywords = {grapevine; microsatellite; rootstock; parentage},
