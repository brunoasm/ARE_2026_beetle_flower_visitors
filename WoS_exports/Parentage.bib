DOI = {10.1007/BF00220870},
ISSN = {0040-5752},
Keywords = {MICROSATELLITE; OAK; POLYMORPHISM; POPULATION BIOLOGY; QUERCUS},
Keywords-Plus = {POLYMERASE CHAIN-REACTION; DNA; POLYMORPHISMS; PARENTAGE; MARKERS;
   PLANTS; PINE},
