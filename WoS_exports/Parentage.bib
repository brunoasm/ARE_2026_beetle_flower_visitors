@article{ WOS:000200615700002,
Author = {Jenkin, TJ},
Title = {Self and cross-fertilisation in <i>Lolium perenne</i> L},
Journal = {JOURNAL OF GENETICS},
Year = {1926},
Volume = {17},
Number = {1},
Pages = {11-17},
Month = {AUG},
Abstract = {As compared with self-pollination, cross-fertilisation in L.perenne
   increases seasonal productivity 37-224\%. A comparison of F1 families
   suggests that certain plants are more valuable than others as parents
   when total productivity is primarily considered. Progenies respond
   differently to treatment according to parentage, and some plants used as
   parents appear to possess a dominating influence in a certain direction
   as shown by the behavior of their progeny from various crosses. Low
   self-fertility and extreme loss of vigor in the 1st generation from
   selfing may prove an important difficulty in breeding work, and
   selection by means of the influence of parents upon their hybrid progeny
   is suggested.},
