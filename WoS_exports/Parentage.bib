ORCID-Numbers = {Stoeckel, Solenn/0000-0001-6064-5941},
Funding-Acknowledgement = {INRA (EFPA department); Cemagref; Office National des Forets},
Funding-Text = {We thank Laurent Leveque and Benedicte Le Guerroue for field sampling
