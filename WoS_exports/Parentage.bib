Title = {The inheritance of seedless SCC8-SCAR and SSRS loci alleles in progeny
   of `Muscat Hamburg' x `Bidane Qermez' grapes},
Booktitle = {PROCEEDINGS OF THE 1ST INTERNATIONAL SYMPOSIUM ON GRAPEVINE GROWING,
   COMMERCE AND RESEARCH},
Series = {ACTA HORTICULTURAE},
Year = {2004},
Number = {652},
Pages = {329-335},
Note = {1st International Symposium on Grapevine Growing, Commerce and Research,
   Lisbon, PORTUGAL, JUN 30-JUL 02, 2003},
Abstract = {A progeny obtained from crossing between seedless `Bidane Qermez' and
   seeded `Muscat Hamburg' grape cultivars was studied to investigate the
   inheritance of seedless SCC8-SCAR and 6 SSRs loci alleles. DNA was
   extracted from 46 seedlings as well as corresponding parents.
   Amplification of DNA was carried out using different colored fluorescent
   primers at 6 SSRs loci (VVS2, VVMD5, VVMD32, VVMD36, ssrVrZAG47, and
   ssrVrZAG79) in which the parents were completely polymorphic. Allele
   sizing was determined using ABI Prism 3100 DNA analyzer with Capillary
   Electrophoresis System. SCAR Primer also amplified and half of PCR
   product digested by Bgl II restriction enzyme, then electrophoresed with
   original PCR product side by side on agarose gel. Results showed that
   94\% of the seedlings shared one allele at each locus with parents
   indicating their hybrid nature, while 6\% of the progeny having only the
   female parent alleles were the result of self-pollination. Allele
   distribution among the progeny determined their co-dominant inheritance,
   and no significant difference with Mendelian co-dominant ratio (1:1:1:1)
   was observed Using chi(2) test. Three offspring resulting from
   self-pollination showed only the presence of maternal alleles either as
   homozygous or heterozygous. Cultivars `Bidane Qermez' and `Muscat
   Hamburg' were homozygous and heterozygous parent for SSC8 locus
   respectively. Twenty seedlings showed three bands after digestion, a
   sign of heterozygousity, while 23 with producing only one band were
   homozygous at SCC8 locus.},
