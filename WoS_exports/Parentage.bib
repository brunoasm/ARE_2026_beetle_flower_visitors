Affiliation = {Bydgoszcz Univ, Dept Genet, Inst Biol \& Environm Protect, Ul Chodkiewicza 30, PL-85064 Bydgoszcz, Poland.
   Bydgoszcz Univ, Dept Genet, Inst Biol \& Environm Protect, PL-85064 Bydgoszcz, Poland.
