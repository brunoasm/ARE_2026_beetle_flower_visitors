@article{ WOS:000200582600007,
Author = {Smith, CO},
Title = {A pistillate Prunus},
Journal = {JOURNAL OF HEREDITY},
Year = {1927},
Volume = {18},
Number = {12},
Pages = {537-541},
Month = {DEC},
Abstract = {Some 20 seedlings of P. umbellata Elliot have shown uniform
   characteristics that vary markedly from those of the species in foliage,
   in method of branching, and most noticeably in the flowers. The petals
   are much reduced in size, and are so concealed by the calyx lobes that
   the flowers appear to be apetalous. The calyx lobes are broader, brown
   instead of green, with a round tip, and have a smooth instead of a
   tomentose inner surface. The stamens are replaced with 10-20 tomentose
   pistils which are attached to the calyx cup and deciduous with it. One
   pistil is attached to the receptacle. Many flowers were artificially
   pollinated but were apparently sterile. These seedlings are believed to
   be accidental species, hybrids of the same parentage which would be
   expected to produce uniform plants in the Fi progeny. P. mume was
   probably the {[}male] parent, judging by certain characteristics in the
   seedlings.},
