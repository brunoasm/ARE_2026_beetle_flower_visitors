Affiliation = {Bydgoszcz Univ, Dept Genet, Inst Biol \& Environm Protect, PL-85064 Bydgoszcz, Poland.
   Bydgoszcz Univ, Dept Genet, Inst Biol \& Environm Protect, PL-85064 Bydgoszcz, Poland.
   Oregon State Univ, Dept Forest Sci, Corvallis, OR 97331 USA.
   CSIRO, Kingston, ACT 2604, Australia.
