@article{ WOS:A1991HA11800046,
Author = {ROMANO, B and BRICCHI, E and FORNACIARI, M and FRENGUELLI, G and
   MINCIGRUCCI, G},
Title = {ONE YEAR OF POLLEN MONITORING IN AN URBAN NETWORK, PERUGIA, CENTRAL
   ITALY},
Journal = {GRANA},
Year = {1991},
Volume = {30},
Number = {1},
Pages = {242-247},
Abstract = {Pollen monitoring at three locations in the area of Perugia is reported
   for the period November 1988-October 1989.  A meteorological station
   which automatically provided data (temperature, precipitation, relative
   humidity, direction and velocity of wind), was located beside each trap.
   The study was correlated with a phenological investigation in urban and
   rural areas surrounding the traps in order to test the validity of using
   the results as indicators in a monitoring network.  The aerobiological
   data of the three monitoring stations allows the following conclusions: 
   1) no notable differences were recorded during the principal period of
   pollination considering the flowering trends of the local anemophilous
   flora are taking into account, 2) from a quantitative point of view,
   values from Central Perugia and West Perugia were higher than those from
   East Perugia, 3) from a qualitative point of view, the station located
   in the old city area was characterized by a significant presence of
   Urticaceae pollen, while pollen of the Gramineae was prevalent in the
   two stations located in the recently built areas.},
