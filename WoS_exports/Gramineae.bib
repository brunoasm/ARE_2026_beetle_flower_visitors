@article{ WOS:A1989CK79000011,
Author = {CONNOR, HE and CHARLESWORTH, D},
Title = {GENETICS OF MALE-STERILITY IN GYNODIOECIOUS CORTADERIA (GRAMINEAE)},
Journal = {HEREDITY},
Year = {1989},
Volume = {63},
Number = {3},
Pages = {373-382},
Month = {DEC},
Abstract = {Male-sterility, the only character essential to gynodioecism in
   Cortaderia is under recessive genic control, the double recessive at any
   locus producing the syndrome in C. selloana. There is evidence that
   alleles at up to three loci may occur in C. selloana giving rise to
   ratios such as 3H:13F and 3H:5F in families from the pollination of
   females by hermaphrodites. No solution is offered to account for the
   segregation ratios from cross- and self-pollination in C. richardii, but
   control  there is genic and probably recessive.},
