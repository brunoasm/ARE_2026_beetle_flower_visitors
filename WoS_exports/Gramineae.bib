
@article{ WOS:A19611600800003,
Author = {CLIFFORD, HT},
Title = {FLORAL EVOLUTION IN FAMILY GRAMINEAE},
Journal = {EVOLUTION},
Year = {1961},
Volume = {15},
Number = {4},
Pages = {455+},
Abstract = {Accepting that the Arundinaria-type flower is primitive in the
   Gramineae, the number of bilaterally symmetrical floral types that can
   be derived from it is readily calculated. There are 126 of these of
   which only 27 are known. The most conspicuous missing group are those
   flowers which would possess an adaxial but no abaxial lodicules. This
   suggests that many of the missing forms are developmentally impossible,
   others may yet evolve or may have already become extinct. There may be
   some that have not yet been described but they are probably few. It is
   suggested that the strong development of vegetative reproduction,
   apomixis and cleistogamy in the family has evolved to off-set the risks
   associated with wind pollination in a group whose flowers have mostly
   suffered considerable reduction in stamen number.},
