Type = {Article},
Language = {English},
Affiliation = {137 Bargates, Leominster HR6 8QS, Hereford, England.},
DOI = {10.1006/anbo.1999.1063},
ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {pollen micro-ecology; stigma micro-ecology; stigma/style maturation;
   gates and pollination; prophylaxis},
Keywords-Plus = {ACTIN CYTOSKELETON; CYTOPLASMIC NUCLEOLOIDS; INTRACELLULAR MOTILITY;
   EMBRYO SAC; ORGANIZATION; GERMINATION; LEGUMINOSAE; PHYSIOLOGY;
