   Univ Illinois, Dept Plant Biol, Urbana, IL 61801 USA.},
ISSN = {0025-6153},
Keywords = {restorers-of-fertility; Zea; maize; teosinte},
Keywords-Plus = {CYTOPLASMIC MALE-STERILITY; MITOCHONDRIAL-DNA VARIATION; RF2 NUCLEAR
   RESTORER; ISOZYME VARIATION; ZEA GRAMINEAE; LATIN-AMERICA; RACES; GENES;
