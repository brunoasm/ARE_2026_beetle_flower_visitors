@article{ WOS:A1946UE97900005,
Author = {STEBBINS, GL and VALENCIA, JI and VALENCIA, RM},
Title = {ARTIFICIAL AND NATURAL HYBRIDS IN THE GRAMINEAE, TRIBE HORDEAE I-ELYMUS,
   SITANION, AND AGROPYRON},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1946},
Volume = {33},
Number = {5},
Pages = {338-351},
Abstract = {Natural hybrids of the following combinations were found in California:
   Elymus glaucus X Sitanion jubatum, Agropyron pauciflorum X S. jubatum,
   A. parishii X S. jubatum, and A. pauciflorum X E. glaucus. Artificial
   hybrids, as a result of controlled cross pollination, were obtained as
   follows: A. pauciflorum X E. glaucus, A. sp. aff. parishii X A.
   pauciflorum, A. sp. aff. parishii X S. hystrix, and A. sp. aff. parishii
   X E. glaucus. All of these F1 hybrids are intermediate between their
   parents and completely sterile. Elymus glaucus X Sitanion jubatum agrees
   in external morphology with Sitanion hanseni (Scribn.) J. G. Smith,
   while Agropyron pauciflorum X S. jubatum resembles A. saundersii (Vasey)
   Hitch. All of the species and hybrids are tetraploids with 2n = 28
   chromosomes, and the external morphology of the chromosomes is the same
   in all of them. In the species, meiosis is regular, with 14 bivalents
   present, but differences occur with respect to chiasma frequency and
   distribution. In E. glaucus X S. jubatum meiosis is nearly regular, but
   indirect evidence suggests that these species differ by small
   rearrangements of chromosome segments, and that this is the cause of the
   hybrid sterility. In all of the other hybrids meiosis is more irregular,
   and chiasma frequently is relatively low. In addition, ring or chain
   configurations are found, involving 3 to 6 chromosomes. These are
   evidently due to structural hybridity for interchanged segments. All of
   the cytological evidence indicates that E. glaucus and 5. jubatum are as
   closely related to each other as species belonging to the same section
   or subgenus. A. pauciflorum is more distantly related to these two,
   while A. parishii is intermediate in its relationships.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
