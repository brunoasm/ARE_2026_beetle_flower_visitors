@article{ WOS:A1985AJV0400005,
Author = {KENRICK, J and KNOX, RB},
Title = {SELF-INCOMPATIBILITY IN THE NITROGEN-FIXING TREE, ACACIA-RETINODES -
   QUANTITATIVE CYTOLOGY OF POLLEN-TUBE GROWTH},
Journal = {THEORETICAL AND APPLIED GENETICS},
Year = {1985},
Volume = {69},
Number = {5-6},
Pages = {481-488},
Abstract = {A 10 .times. 10 diallel of crosses involving trees in 2 natural
   populations of A. retinodes (Leguminosae: Mimosoideae) showed a high
   level of self-incompatibility, with ISI (Index of Self-Incompatibility)
   of 0.08. In self- and cross pollinations, pollen tubes grew through the
   style to the ovules within 11 h. Tube growth rate is approximately
   similar in both types of mating: 3.3-4.5 .mu.m/min for the first 6 h and
   1.2-2.0 .mu.m/min for the succeeding 5 h. Three potential explanations
   for self incompatibility are proposed: an S-gene controlled system in
   which pollen tubes are arrested in the nucellus of the ovule, sperm:egg
   interactions at fertilization and action of post-zygotic lethal genes.},
