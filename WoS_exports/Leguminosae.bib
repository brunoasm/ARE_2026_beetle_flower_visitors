@article{ WOS:000231620400008,
Author = {Elaine, B and Miotto, STS and Schifino-Wittmann, MT and De Castro, B},
Title = {Cytogenetics and cytotaxonomy of Brazilian species of <i>Senna</i>
   Mill.: (Cassieae - Caesalpinioideae - Leguminosae).},
Journal = {CARYOLOGIA},
Year = {2005},
Volume = {58},
Number = {2},
Pages = {152-163},
Month = {APR-JUN},
Abstract = {Chromosome numbers, meiotic behaviour, meiotic indexes and pollen
   fertility are reported for 17 Senna Mill. species occurring in Southern
   Brazil. Haploid numbers were n=11, 12, 13, 14 and 28. No intraspecific
   variability was detected; n=14 predominated. The only accession of S.
   rugosa showed to be tetraploid, in contrast to the a previous reference
   for this species. Meiotic behaviour was generally regular for all
   species and accessions, but some irregularities such as uni and
   multivalents and unequal segregation were occasionally observed. Meiotic
   indexes were high, over 95 \%. Mean pollen fertility was over 81 \% for
   all species, but in some taxa much lower values were found in some
   accessions. All species had prolate-spheroidal pollen grains. No
   relation between grain size, taxonomic position and chromosome number
   could be established. Our results, together with literature data,
   suggest that x=14 is the basic number for the genus, probably a
   secondary number derived from the x=7 suggested for all
   Caesalpinioideae, and that the other numbers in the genus represent a
   disploid series. A broader cytogenetic survey of a more representative
   number of species, along the geographic distribution of the genus,
   should be done addressing questions such as the extent of intra and
   inter-specific variability in chromosome number, occurrence of
   polyploidy and the real role of disploidy in Senna evolution.},
Publisher = {FIRENZE UNIV PRESS},
Address = {JOURNALS DIVISION, BORGO ALBIZI, 28, FIRENZE, 50122, ITALY},
Type = {Article},
Language = {English},
Affiliation = {Univ Fed Rio Grande do Sul, Fac Agron, Dept Plantas Forrageiras \& Agrometeorol, Caixa Postal 15100, BR-91501970 Porto Alegre, RS, Brazil.
   Univ Fed Rio Grande do Sul, Fac Agron, Dept Plantas Forrageiras \& Agrometeorol, BR-91501970 Porto Alegre, RS, Brazil.
   Univ Fed Rio Grande do Sul, Dept Bot, Inst Biociencias, Programa Posgrad Bot, BR-91501970 Porto Alegre, RS, Brazil.},
DOI = {10.1080/00087114.2005.10589445},
ISSN = {0008-7114},
EISSN = {2165-5391},
Keywords = {chromosome numbers; disploid chromosome evolution; meiotic behaviour;
