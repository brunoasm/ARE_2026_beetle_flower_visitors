Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Danieli-Silva, A (Corresponding Author), Univ Fed Parana, Post Grad Program Ecol \& Conservat, POB 19031, BR-81531980 Curitiba, Parana, Brazil.
