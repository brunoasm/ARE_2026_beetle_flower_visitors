@article{ WOS:000302963000003,
Author = {Ojeda, Isidro and Santos-Guerra, Arnoldo and Caujape-Castells, Juli and
   Jaen-Molina, Ruth and Marrero, Aguedo and Cronk, Quentin C. B.},
Title = {COMPARATIVE MICROMORPHOLOGY OF PETALS IN MACARONESIAN <i>LOTUS</i>
   (LEGUMINOSAE) REVEALS A LOSS OF PAPILLOSE CONICAL CELLS DURING THE
   EVOLUTION OF BIRD POLLINATION},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {2012},
Volume = {173},
Number = {4},
Pages = {365-374},
Month = {MAY},
Abstract = {Bird pollination has evolved in four species of Macaronesian Lotus from
   a bee-pollinated ancestor. The transition is associated with the
   modification of several floral traits, including flower color and size,
   relative size and orientation of the petals, and nectar composition and
   quantity. Here, we examine petal surface micromorphology in relation to
   pollination type, using SEM and LM. In the bee-pollinated Lotus (the
   majority of the genus), papillose conical cells (PCS) are the most
   abundant epidermal type on dorsal and lateral petals. However,
   bird-pollinated species completely lack PCS on their dorsal petals and
   have only a small patch of PCS in a highly localized region of the
   lateral petal. In the bee-pollinated species (including those most
   closely related to the bird-pollinated species), PCS develop early in
   floral development. In contrast, the small amount of residual PCS in
   bird-pollinated species forms later in development, after the other two
   major epidermal types have been formed. The almost complete elimination
   of PCS during the shift of pollination syndrome from bee to birds may be
   adaptively driven as a both probird and antibee trait.},
