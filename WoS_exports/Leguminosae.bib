@article{ WOS:A1995RF64100048,
Author = {ZHANG, X and MOSJIDIS, JA},
Title = {BREEDING SYSTEMS OF SEVERAL VICIA SPECIES},
Journal = {CROP SCIENCE},
Year = {1995},
Volume = {35},
Number = {4},
Pages = {1200-1202},
Month = {JUL-AUG},
Abstract = {Information on the breeding system of plants is crucial for maintenance
   of accessions in germplasm banks. Controlled pollination experiments
   were conducted in the field to determine the breeding systems of several
   Vicia species. Vicia articulata Hornem., V. benghalensis L., V. ervilia
   (L.) Willd., V. lutea L., and V. sativa L. were automatic
   self-fertilizing species. Vicia pannonica Crantz was nonautomatic
   self-fertilizing. Vicia villosa Roth ssp. villosa and V. villosa Roth
   ssp. varia (Host) Corbiere were cross-fertilizing. Therefore,
   regeneration of the accessions of the latter two species requires the
   use of procedures that provide isolation from foreign pollen.},
