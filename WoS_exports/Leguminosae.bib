   Miguel-Penaloza, Ara; Jimenez-Duran, Karina, Univ Nacl Autonoma Mexico, Fac Quim, USAII, Lab H-21,Edificio Mario Molina La Cueva, Mexico City 04510, DF, Mexico.
   Delgado-Salinas, Alfonso, Univ Nacl Autonoma Mexico, Inst Biol, Dept Bot, Mexico City 04510, DF, Mexico.},
DOI = {10.1007/s00606-019-01603-4},
ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {Desmodium; Explosive pollination; Foraging behaviour; Proboscis
   extension reflex in bees; Secondary pollen presentation},
Keywords-Plus = {LARGE CARPENTER BEES; LEGUMINOSAE; POLLEN; MORPHOLOGY; BEHAVIOR},
