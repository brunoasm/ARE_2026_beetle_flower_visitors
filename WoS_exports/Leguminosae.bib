ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {buzz pollination; enantiomorphy; enantiostyly; floral asymmetry; floral
   development; functional morphology; homology; petal venation},
Keywords-Plus = {PHYLOGENETIC-RELATIONSHIPS; CAESALPINIOIDEAE; EVOLUTION; POLLINATION;
