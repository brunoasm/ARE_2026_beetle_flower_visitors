Number = {4703},
Pages = {1087-1089},
Abstract = {The legumes are an important group of flowering plants with a poorly
   documented evolutinary history. New fossil evidence provides data on the
   timing of the origin of the 2 derived subfamilies of legumes (the
   Mimosodeae and Papilionoideae). These data strongly suggest the
   importance of bee pollinators during a major period of angiosperm
   diversification.},
