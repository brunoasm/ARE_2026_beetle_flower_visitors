Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Joly, S (Corresponding Author), Montreal Bot Garden, 4101 Sherbrooke East, Montreal, PQ H1X 2B2, Canada.
   Bilbao, Gonzalo; Bruneau, Anne; Joly, Simon, Univ Montreal, Inst Rech Biol Vegetale, 4101 Sherbrooke East, Montreal, PQ H1X 2B2, Canada.
   Joly, Simon, Montreal Bot Garden, 4101 Sherbrooke East, Montreal, PQ H1X 2B2, Canada.},
DOI = {10.1002/ajb2.1735},
EarlyAccessDate = {SEP 2021},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {flower evolution; geometric morphometrics; Leguminosae; morphological
   convergence; ornithophily; Ornstein-Uhlenbeck (OU) models; petal shape},
Keywords-Plus = {HUMMINGBIRD POLLINATION; GEOMETRIC MORPHOMETRICS; REPRODUCTIVE-BIOLOGY;
