ISSN = {1095-5674},
EISSN = {1940-0616},
Keywords = {Albizia; Fabaceae; late-acting self-incompatibility; Mimosa;
   Mimosoideae; pollen:ovule ratios; polyads; polycarpelly; restricted
   stigmas; tetrads},
Keywords-Plus = {SELF-INCOMPATIBILITY; BREEDING SYSTEM; FRUIT-SET; ACACIA-RETINODES;
   POLLEN; LEGUMINOSAE; POLLINATION; ASCLEPIAS; TREE; APOCYNACEAE},
