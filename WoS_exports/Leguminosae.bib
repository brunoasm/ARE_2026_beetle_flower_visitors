DOI = {10.2307/2656772},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Astragalus australis var. olympicus; endangered species; conservation;
   Fabaceae; ovule fate; pollination; seed predation; Tychius;
   spatio-temporal variability},
Keywords-Plus = {SEED PREDATION; INBREEDING DEPRESSION; GERMINATION CHARACTERISTICS;
   SELF-FERTILIZATION; FRUIT ABORTION; YUCCA-WHIPPLEI; POLLINATION;
