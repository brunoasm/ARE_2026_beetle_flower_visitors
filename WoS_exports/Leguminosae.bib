ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {Plant gender; Andromonoecy; Breeding systems; Afromontane forests; Fruit
   abortion},
Keywords-Plus = {FLORAL-SEX RATIO; CAESALPINIA-CALYCINA; NATURAL-SELECTION; BREEDING
