@article{ WOS:000074257900007,
Author = {Gibbs, P and Sassaki, R},
Title = {Reproductive biology of Dalbergia miscolobium Benth.
   (Leguminosae-Papilionoideae) in SE Brazil: The effects of pistillate
   sorting on fruit-set},
Journal = {ANNALS OF BOTANY},
Year = {1998},
Volume = {81},
Number = {6},
Pages = {735-740},
Month = {JUN},
Abstract = {The breeding system of Dalbergia miscolobium Benth. was investigated by
   means of controlled pollinations and studies of post-pollination events
   in pistils. This species does not have homomorphic self incompatibility,
   but crossed flowers always have higher fruit set than selfs, despite the
   fact that embryo development may be initiated in selfed pistils. It is
   suggested that deleterious recessive alleles, which lead to abortion of
   most selfed seeds, together with some maternal resource limitation,
   result in low fruiting success. (C) 1998 Annals of Botany Company.},
