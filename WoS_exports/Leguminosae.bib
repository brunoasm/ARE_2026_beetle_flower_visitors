   Teixeira, Simone Padua, Univ Sao Paulo, Dept Ciencias Farmaceut, Fac Ciencias Farmaceut Ribeirao Preto, BR-14040903 Ribeirao Preto, SP, Brazil.},
DOI = {10.1093/botlinnean/boy006},
ISSN = {0024-4074},
EISSN = {1095-8339},
