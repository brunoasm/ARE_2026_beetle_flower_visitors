   Marinho, C. R.; Souza, C. D.; Barros, T. C.; Teixeira, S. P., Univ Sao Paulo, Fac Ciencias Farmaceut Ribeirao Preto, BR-14040903 Ribeirao Preto, SP, Brazil.},
DOI = {10.1111/plb.12000},
