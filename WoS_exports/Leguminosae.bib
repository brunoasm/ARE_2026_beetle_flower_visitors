Language = {English},
Affiliation = {Sinjushin, AA (Corresponding Author), Lomonosov Moscow State Univ, Fac Biol, Moscow, Russia.
   Sinjushin, Andrey A., Lomonosov Moscow State Univ, Fac Biol, Moscow, Russia.},
