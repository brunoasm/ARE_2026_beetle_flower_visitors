@article{ WOS:A1979HL67000001,
Author = {CRUDEN, RW and JENSEN, KG},
Title = {VISCIN THREADS, POLLINATION EFFICIENCY AND LOW POLLEN-OVULE RATIOS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1979},
Volume = {66},
Number = {8},
Pages = {875-879},
Abstract = {Some Onagraceae {[}Epilobium ciliatum ssp. ciliatum, Oenothera biennis,
   Calylophus serrulatus, E. angustifolium, Clarkia amoena and Guara
   drummondii] are characterized by low pollen-ovule ratios. They may be an
   evolutionary response to highly efficient pollination, mediated through
   viscin threads, which hold large numbers of pollen grains together, and
   by stigmas, which are large relative to the area of the pollinator over
   which the pollen is spread. The pollen grains of some Leguminosae
   {[}Delonix elata, Bauhinia spp., Caesalpinia pulcherrima, C. pannosa, C.
   gilliesii, C. japonica, C. mexicana, C. eriostachys and C. cassiodes]
   are joined by exinal connections which are chemically and
   morphologically similar to viscin threads. In the legumes the area of
   the stigma is small relative to the area of pollen on the pollinator
   {[}bumblebee or butterfly] and pollination is facilitated by short
   connections which hold small numbers of pollen grains together.},
