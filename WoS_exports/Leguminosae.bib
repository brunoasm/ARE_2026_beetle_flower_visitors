Language = {English},
Affiliation = {Martínez-Bauer, AE (Corresponding Author), Monash Univ, Sch Biol Sci, Melbourne, Vic 3800, Australia.
   Martinez-Bauer, Angelica E.; Martinez, Gerardo Ceron; Burd, Martin, Monash Univ, Sch Biol Sci, Melbourne, Vic 3800, Australia.
   Murphy, Daniel J., Royal Bot Gardens Melbourne, Natl Herbarium Victoria, Melbourne, Vic 3141, Australia.
   Burd, Martin, Natl Evolutionary Synth Ctr, Durham, NC 27514 USA.},
DOI = {10.1007/s00442-014-3215-0},
ISSN = {0029-8549},
EISSN = {1432-1939},
Keywords = {Conflict; Exclusion experiment; Extrafloral nectaries; Fruit set;
   Pollination},
