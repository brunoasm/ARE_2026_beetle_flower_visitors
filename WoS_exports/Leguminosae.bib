@inproceedings{ WOS:000170231900027,
Author = {Viegi, L},
Editor = {Brundu, G and Brock, J and Camarda, I and Child, L and Wade, M},
Title = {Investigations on some reproductive features of invasive alien plants in
   Italy},
Booktitle = {PLANT INVASIONS: SPECIES ECOLOGY AND ECOSYSTEM MANAGEMENT},
Year = {2001},
Pages = {255-262},
Note = {5th International Conference on Ecology of Invasive Alien Plants,
   SARDINIA, ITALY, OCT 13-16, 1999},
Abstract = {The current state of knowledge on the occurrence and reproductive
   pathway of invasive alien plants in Italy is discussed. A total of 214
   species were analysed and categorised as: escaped from cultivation and
   permanently established, naturalized adventive, casual adventive and
   doubtful. Sexual expression. life form, flowering period, type of
   pollination. type of fruits. fruit dispersal and vegetative reproduction
   of these species were studied. Most were found to belong to the
   Asteraceae, Amaranthaceae. Graminaceae, Leguminosae and Cruciferae. They
   included a preponderance of hermaphrodites; monoecious being more
   numerous than dioecious species. Therophytes are the most numerous and
   widespread, followed by hemicryptophytes and geophytes. Most bloom in
   Summer. There were more entomophilous species than anemophilous ones and
   more dry fruited than fleshy ones. The most frequent type of dry fruits
   is the capsule in dicots and the caryopse in monocots; the most frequent
   fleshy fruit is the berry. Passive dispersal of seeds is predominant,
   followed by anemochorous and zoochorous. The results are discussed on
   the basis of quantitative/qualitative comparison with data for native
   species (i.e. Italy, Mediterranean and Apuan Alps). Knowledge of the
   type of reproductive structures and mode of dispersal of aliens may be
   useful for control strategies.},
Publisher = {BACKHUYS PUBLISHERS},
Address = {PO BOX 321, 2300 AH LEIDEN, NETHERLANDS},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Viegi, L (Corresponding Author), Dept Bot Sci, Via L Ghini 5, I-56126 Pisa, Italy.
   Dept Bot Sci, I-56126 Pisa, Italy.},
ISBN = {90-5782-080-3},
