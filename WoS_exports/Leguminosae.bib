@article{ WOS:000882236600001,
Author = {Gogoi, Jahnabi and Rana, Tikam Singh},
Title = {Prisniparni (<i>Uraria picta</i> (Jacq.) Desv. ex DC.): a potential
   medicinal plant},
Journal = {NUCLEUS-INDIA},
Year = {2022},
Volume = {65},
Number = {3, SI},
Pages = {473-485},
Month = {DEC},
Abstract = {Uraria picta known as Prisniparni is an important leguminous plant
   possessing various medicinal properties. U. picta has great demand in
   traditional as well as in modern medicine. There is a growing concern
   for its conservation as it is reported to be locally endangered in many
   regions of India. It is traditionally used in treating gonorrhoea,
   malaria, hypertension, sore throat, spermatorrhoea, bleeding piles, bone
   fracture, cough, cold, fever, wounds and to expel tapeworms. With its
   growing rarity, the plant is easily substituted by other close relatives
   and thus the medicines using this plant as an ingredient may get
   adulterated. Therefore, an effort is made to provide an updated account
   on this important Dashamoola plant for its uses, taxonomy, morphology,
   cytology, anatomy, pollination, propagation, chemistry, genetic
   variation, phylogeny, diseases to elucidate comprehensive understanding
   of its botany and phytopharmaceutical nitty-gritty in order to motivate
   further research on its biology, conservation, improvement and trade.},
