   Teixeira de Moraes, Mario Luiz, FEIS UNESP, Dept Fitotecnia Tecnol Alimentos \& Socioecon, Sao Paulo, Brazil.},
DOI = {10.1111/j.1744-7429.2010.00679.x},
ISSN = {0006-3606},
