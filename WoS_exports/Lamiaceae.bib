@article{ WOS:000088205500004,
Author = {Suzuki, K and Akazome, Y},
Title = {Flexibility of pollinator-flower relationship in <i>Isodon umbrosus</i>
   and <i>I-effusus</i> (Lamiaceae) and its relation to fruit-set and
   seed-set},
Journal = {JOURNAL OF PLANT RESEARCH},
Year = {2000},
Volume = {113},
Number = {1110},
Pages = {149-155},
Month = {JUN},
Abstract = {Isodon umbrosus was pollinated by two bumblebee pollinators, Bombus
   honshuensis and a diversus. a diversus was a secondary pollinator when
   both pollinators were present, but in the absence of B. honshuensis, a.
   diversus pollinated I. umbrosus, and the resulting seed production was
   comparable to when visited by Be two bumblebee species together. Not
   only the high visitation frequency of a diversus but also the low ratio
   of seed to ovules (= average seed setXfruit set) of I. umbrosus
   compensated for the low pollination efficiency of B. diversus. Since,
   the low pollination efficiency of a diversus, based on the finding that
   the low average seed set of I. umbrosus did not require a definite
   morphological match between flowers and pollinators, and did not require
   very frequent visitations to each flower. In other words, Isodon
   umbrosus could briefly maintain constant seed production under the
   condition of the low ratio of seeds to ovules (the low seed set and the
   low fruit set) and a large number of flowers without B. honshuensis as
   legitimate pollinator. On the other hand, I. effusus was exclusively
   pollinated by B. diversus and produced almost the same volume of seeds
   as I. umbrosus. Isodon effusus had fewer flowers than I. umbrosus, but
   this smaller number of flowers was compensated for by the high ratio of
   seeds to ovules in I. effusus, which was maintained by frequent
   visitations of the morphologically matched pollinator, a diversus.},
Publisher = {SPRINGER JAPAN KK},
Address = {CHIYODA FIRST BLDG EAST, 3-8-1 NISHI-KANDA, CHIYODA-KU, TOKYO, 101-0065,
   JAPAN},
