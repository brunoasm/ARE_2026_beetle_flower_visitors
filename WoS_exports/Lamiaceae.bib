EISSN = {1442-1984},
Keywords = {Clerodendrum infortunatum; dichogamy; movement-assisted dichogamy;
   sporophyll dynamics; transition phase},
Keywords-Plus = {INBREEDING DEPRESSION; POLLEN; INTERFERENCE; POLLINATION; SIZE;
