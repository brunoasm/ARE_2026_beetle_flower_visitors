Type = {Article},
Language = {Spanish},
Affiliation = {Grases, C (Corresponding Author), Cent Univ Venezuela, Inst Expt Biol, Ctr Bot Trop, Reprod Biol Lab, Apartado 20513, Caracas, Venezuela.
