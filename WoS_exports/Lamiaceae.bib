@article{ WOS:A1997YH84000005,
Author = {Milberg, P and Bertilsson, A},
Title = {What determines seed set in Dracocephalum ryuschiana L. an endangered
   grassland plant},
Journal = {FLORA},
Year = {1997},
Volume = {192},
Number = {4},
Pages = {361-367},
Month = {NOV},
Abstract = {We studied seed set in the endangered land plant Dracocephalum
   ryuschiana L. (Lamiaceae) in 20 populations ranging in size from 1 to
   450 genets. Bumblebees appear to be the only important pollinator and,
   despite self-compatibility, very few seeds were produced in their
   absence. Therefore, seed set may be determined by bumblebee abundance
   and their foraging behaviour. Seed set in the populations varied from 3
   to 40\% of the ovules produced, indicating that the reproductive ability
   of individuals will vary substantially between sites and, hence, that
   the populations differ in their viability. Seed set was not
   significantly correlated with population size, and including other
   enviromental variables in the model did not improve the ability to
   predict seed set (stepwise multiple regression; size and degree of
   isolation of the habitat, species-richness of the vegetation, frequency
   of bumblebee visits). We conclude that although population size is
   important, several other factors can interact to determine a
   population's seed set and vitality.},
