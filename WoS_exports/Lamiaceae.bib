@article{ WOS:000323914500010,
Author = {Cuevas-Garcia, Eduardo and Alcala-Guerra, Aaron and Banos-Bravo, Yunuhen
   E. and Flores-Palacios, Alejandro},
Title = {REPRODUCTIVE BIOLOGY AND THEFT OF NECTAR IN <i>SALVIA GESNERIFLORA</i>
   (LAMIACEAE) AND ITS CONSEQUENCES IN REPRODUCTIVE SUCCESS},
Journal = {BOTANICAL SCIENCES},
Year = {2013},
Volume = {91},
Number = {3},
Pages = {357-362},
Month = {SEP},
Abstract = {Nectar robbers perforate generally tubular flowers to access nectar. The
   flowers of Salvia gesneriflora are robbed by birds and insects that
   might decrease the reproductive success of this plant. In this study we
   evaluated several aspects of the reproductive biology of S. gesneriflora
   and the effect of nectar robbing on different components of female
   reproductive success. In three populations, flowers were protected from
   nectar robbers. We found that S. gesneriflora is a self-compatible
   species, although autonomous selfing did not occur, probably because
   their flowers showed herkogamy and dichogamy. Manual self-pollinated
   flowers produced 75\% fewer seeds than cross-pollinated flowers. Nectar
   robbing mainly affected seed mass (29\%) and germination rate (31\%),
   while fruit set and seed number were not significantly different between
   robbed and unrobbed flowers.},
