Type = {Article},
Language = {English},
Affiliation = {Rowe, L (Corresponding Author), Michigan State Univ, Dept Entomol, E Lansing, MI 48824 USA.
   Rowe, Logan; Gibson, Daniel; Landis, Douglas; Gibbs, Jason; Isaacs, Rufus, Michigan State Univ, Dept Entomol, E Lansing, MI 48824 USA.
   Gibbs, Jason, Univ Manitoba, Dept Entomol, Winnipeg, MB R3T 2N2, Canada.},
