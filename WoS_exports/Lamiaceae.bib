@article{ WOS:000182202900004,
Author = {Classen-Bockhoff, R and Wester, P and Tweraser, E},
Title = {The staminal lever mechanism in <i>Salvia</i> L. (Lamiaceae) -: a review},
Journal = {PLANT BIOLOGY},
Year = {2003},
Volume = {5},
Number = {1},
Pages = {33-41},
Month = {JAN},
Abstract = {The genus Salvia encompasses about 900 species distributed world-wide.
   It is characterized by the famous staminal lever mechanism of the flower
   which is one of the best known examples of a nototribic pollination
   mechanism. We hypothesize that structure and functioning of the staminal
   levers play a major role as key structures in speciation. To cope with
   the complex evolutionary processes involved, a number of different
   methodological approaches are needed. The present paper summarizes the
   literature referring to structural and functional diversity, breeding
   systems, systematics and evolution in Salvia.},
