@article{ WOS:000166133400008,
Author = {Torke, BM},
Title = {A revision of Salvia sect. Ekmania (Lamiaceae)},
Journal = {BRITTONIA},
Year = {2000},
Volume = {52},
Number = {3},
Pages = {265-302},
Month = {JUL-SEP},
Abstract = {Torke, B. M. (The New York Botanical Garden, Bronx, NY 10358-5126,
   U.S.A.). A revision of Sah,ia sect. Ekmania (Lamiaceae). Brittonia 52:
   265-302. 2000.-A taxonomic treatment of Salvia sect. Ekmania, a group of
   tall shrubs endemic to the Caribbean island of Hispaniola, is provided.
   Morphology, phenology, pollination biology, habitats, and distributions
   are discussed. Species boundaries are examined using phenetic analysis
   of morphological data. Eight species are here accepted as belonging to
   the section. Two recently described species, S. lavendula and S.
   paryskii, are considered for inclusion in the section, but only the
   latter appears to be a member. Salvia lachnaiclada and S. ottoschulzii
   are treated as conspecific. Salvia bahorucona is recognized as a
   distinct species.},
