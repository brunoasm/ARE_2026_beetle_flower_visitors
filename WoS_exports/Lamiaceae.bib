@article{ WOS:000343383600021,
Author = {Kriebel, Ricardo},
Title = {Sexual Dimorphism in the Flowers of <i>Aegiphila odontophylla</i>
   (Lamiaceae)},
Journal = {SYSTEMATIC BOTANY},
Year = {2014},
Volume = {39},
Number = {4},
Pages = {1204-1207},
Month = {OCT-DEC},
Abstract = {Little is known about the sexuality of the woody Neotropical genus
   Aegiphila. For a long time species of Aegiphila were thought to be
   heterostylous, but more recently it has been reported that a few species
   are dioecious and suggested that likely most Aegiphila are functionally
   dioedous. In this note, dioecy is confirmed in Aegiphila odontophylla
   from live plants in the Talamanca mountains in Costa Rica. Further,
   comparison of total flower size revealed that male and female
   reproductive structures are displayed at similar heights, likely
   resulting in accurate pollen uptake and delivery by pollinators. The
   length of the corolla tube as an estimate of flower showiness on the
   other hand was significantly different between male and female
   individuals. Male individuals had longer corolla tubes, suggesting a
   possible role for sexual selection in the evolution of floral dimorphism
   in this species.},
Publisher = {AMER SOC PLANT TAXONOMISTS},
Address = {UNIV WYOMING, DEPT BOTANY 3165, 1000 E UNIVERSITY AVE, LARAMIE, WY 82071
   USA},
Type = {Article},
Language = {English},
Affiliation = {Kriebel, R (Corresponding Author), Univ Wisconsin, Dept Bot, Madison, WI 53706 USA.
   Kriebel, Ricardo, New York Bot Garden, Bronx, NY 10458 USA.
   Kriebel, Ricardo, CUNY, New York, NY USA.},
DOI = {10.1600/036364414X683930},
ISSN = {0363-6445},
EISSN = {1548-2324},
Keywords = {Costa Rica; dioecy; Labiatae; sexual selection},
