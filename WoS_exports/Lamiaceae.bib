@article{ WOS:000255472700006,
Author = {Daskalova, Tzvetana},
Title = {Polygamy in <i>Lamium maculatum</i> L.},
Journal = {COMPTES RENDUS DE L ACADEMIE BULGARE DES SCIENCES},
Year = {2008},
Volume = {61},
Number = {3},
Pages = {327-334},
Abstract = {This is the first announcement of polygamy of monoecious type in the
   limits of Lamium maculatum and genus Lamium. It was expressed in
   enormous formation of hermaphrodite, functional female and male flowers
   on the same plant with very variable proportions during the
   florogenesis. Gynomonoecy coexists simultaneously with hermaphroditism
   and andromonoecy. The possibility of existence of one more way of
   pollination in the breeding system was stated. The embryological
   characteristic of L. maculatum allows to trace the evolution of
   micromorphological processes - transition from hermaphrodite to the most
   advanced functional female and male flowers.},
