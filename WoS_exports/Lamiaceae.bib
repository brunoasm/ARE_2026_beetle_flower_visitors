EISSN = {1558-5646},
Keywords = {gynodioecy; inbreeding depression; Lamiaceae; outcrossing rate; seed
   production; sex ratio},
Keywords-Plus = {NUCLEAR-CYTOPLASMIC INTERACTIONS; SPECIES TRIFOLIUM-HIRTUM; SHRUB
