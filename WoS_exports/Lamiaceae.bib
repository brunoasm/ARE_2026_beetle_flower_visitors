@article{ WOS:000259871400001,
Author = {Sanchez, A. M. and Albert, M. J. and Escudero, A.},
Title = {Female reproductive output in a Mediterranean shrub:: effects from
   inflorescence to population},
Journal = {PLANT BIOLOGY},
Year = {2008},
Volume = {10},
Number = {6},
Pages = {675-683},
Month = {NOV},
Abstract = {Inflorescence effects have been poorly studied, in spite of the
   functional relevance of the inflorescence in fruit and seed ecology. The
   present study focused on the effects of inflorescence size and
   phenology, and flower position within the inflorescence, in relation to
   fruit and seed production of the Mediterranean shrub Ononis fruticosa.
   Variability in fruit and seed production, seed weight and germination
   were estimated and modelled. Results confirmed that the most important
   predictors in seed production were inflorescence flowering time and
   flower position within the inflorescence. Thus, the number of mature
   seeds per fruit was higher in earlier inflorescences and in basal
   positions. On the other hand, predation was higher in fruits in basal
   positions. In fact, seed predation seemed to be the most important
   factor controlling final seed production. Models at the plant level
   suggested a negative incidence of geitonogamous pollination and resource
   limitation, which were also observed at the fruit level. This study
   confirmed the relevance of inflorescence effects on the reproductive
   output of O. fruticosa. Although the underlying processes could not be
   identified, our results provide several hypotheses for future
   experimental studies.},
