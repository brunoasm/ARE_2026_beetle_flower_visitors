@article{ WOS:A1981LJ98000016,
Author = {WHITTEN, WM},
Title = {POLLINATION ECOLOGY OF MONARDA-DIDYMA, MONARDA-CLINOPODIA, AND HYBRIDS
   (LAMIACEAE) IN THE SOUTHERN APPALACHIAN MOUNTAINS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1981},
Volume = {68},
Number = {3},
Pages = {435-442},
Abstract = {M. didyma L. and M. clinopodia L. occasionally form introgressive
   populations in the mountains of eastern Tennessee and western North
   Carolina USA. M. didyma produces large red scentless nectar-rich flowers
   and is pollinated primarily by the ruby-throated hummingbird
   (Archilochus colubris {[}Linnaeus]). The smaller, white, scented flowers
   of M. clinopodia produce small amounts of nectar and are pollinated
   mainly by bumblebees (Bombus spp.). The 2 sp. are highly interfertile
   and have strongly overlapping flowering periods. Differences in
   pollinator sets and pollinator constancy appears to be only partial
   barriers to hybridization. Lack of suitable habitats for the
   establishment of hybrid progeny might be the most important isolating
   mechanism between the 2 spp.},
