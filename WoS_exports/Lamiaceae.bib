Language = {English},
Affiliation = {Silló, N (Corresponding Author), Johannes Gutenberg Univ Mainz, Inst Organism \& Mol Evolut iomE, Saarstr 21, D-55099 Mainz, Germany.
   Sillo, Noel; Classen-Bockhoff, Regine, Johannes Gutenberg Univ Mainz, Inst Organism \& Mol Evolut iomE, Saarstr 21, D-55099 Mainz, Germany.},
DOI = {10.1016/j.flora.2024.152461},
EarlyAccessDate = {FEB 2024},
Article-Number = {152461},
ISSN = {0367-2530},
EISSN = {1618-0585},
Keywords = {Ecological generalization; Flower -bee fitting; Foraging behavior;
   Functional specialization; Phenotypic specialization; Salvia pratensis},
Keywords-Plus = {STAMINAL LEVER MECHANISM; SALVIA L. LAMIACEAE; FLOWER VISITATION;
