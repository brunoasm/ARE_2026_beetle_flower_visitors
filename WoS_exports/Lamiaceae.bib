@article{ WOS:000288070800021,
Author = {Kulloli, Shrishail K. and Chandore, Arun N. and Aitawade, Makarand M.},
Title = {Nectar dynamics and pollination studies in three species of Lamiaceae},
Journal = {CURRENT SCIENCE},
Year = {2011},
Volume = {100},
Number = {4},
Pages = {509-516},
Month = {FEB 25},
Abstract = {The nectar dynamics and pollination study of three species, viz.
   Leonotis nepetifolia (L.) R. Br., Leucas aspera (Willd.) Link and
   Orthosiphon thymiflorus (Roth) Sleesen were studied in their natural
   habitat. Little information is available on the nectar dynamics and
   pollinator preference of these medicinally important plants of the
   family Lamiaceae. There is wide array of floral foragers comprising
   honey bees, butterflies, flies, ants, birds and hawk moths. The nectar
   is dominated by sucrose-glucose and fructose in all species. Insects
   accounted for a majority of the visits (96\%). Their nectar shows marked
   temporal fluctuations in volume and concentration of total sugars. These
   changes are interrupted in terms of removal by visitors and evaporation
   or condensation. Foraging behaviour of most of the insects and birds
   indicated that they are genuine pollen-transferring agents. However,
   infrequent visits by butterflies and sunbirds show that they use these
   plants only as a transient source of food. Honey bees accounted for
   similar to 66\% visits in all three species and thus could be the major
   pollinator of these species.},
