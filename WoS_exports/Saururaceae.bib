   Univ Toronto, Dept Bot, Toronto, ON M5S 3B2, Canada.},
DOI = {10.1006/anbo.1999.0947},
ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {SI evolution; dry stigma; exudates; pollen-carpel signalling;
   Saururaceae},
