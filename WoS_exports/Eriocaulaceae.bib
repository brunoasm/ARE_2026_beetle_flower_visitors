@article{ WOS:000200455000005,
Author = {Uphof, JCT},
Title = {The floral behavior of some Eriocaulaceae},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1927},
Volume = {14},
Number = {1},
Pages = {44-48},
Month = {JAN},
Abstract = {Flowers of Eriocaulon decangulare and E. septangulare remain open 3-8
   hrs. and the flowering of each head lasts 3-4 weeks. Many flowers
   produce no seed. Being without nectar glands and without vivid colors,
   the flowers are visited by few flying insects, but are often visited by
   Acarina attracted by the pollen. These mites accomplish pollination when
   both staminate and ovulate flowers are open at the same time, although
   they are unable to pass from one inflorescence to another. The
   conditions are similar in Lachnocaulon anceps.},
