@article{ WOS:000336696000014,
Author = {Balachandran, C. and Chandran, M. D. Subash and Ramachandra, T. V.},
Title = {Keystone food resources for honey bees in South Indian west coast during
   monsoon},
Journal = {CURRENT SCIENCE},
Year = {2014},
Volume = {106},
Number = {10},
Pages = {1379-1386},
Month = {MAY 25},
Abstract = {The low level, denuded, laterite landscape of coastal Uttara Kannada has
   a rich diversity of monsoon herbs, including threatened and newly
   discovered ones. Our study reveals that honey bees congregate on the
   ephemeral herb community of Utricularias, Eriocaulons and Impatiens
   during their gregarious monsoon flowering period. Apis dorsata had
   highest visitations on Utricularias, Impatiens and Flacourtia indica,
   whereas Trigona preferred Eriocaulons. Laterite herb flora merits
   conservation efforts as a keystone food resource for the insect
   community, especially for honey bees.},
