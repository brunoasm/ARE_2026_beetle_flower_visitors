Address = {Prinz-Eugen-Strasse 8-10, A-1040 Vienna, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {ROYAL BOT GARDENS, JODRELL LAB, KEW TW9 3DS, SURREY, ENGLAND.},
