ISSN = {0002-9122},
Keywords = {buzz pollination; Commelinaceae; Dichorisandra; embryology; floral
   development; floral vasculature; gametophyte development; poricidal
   anthers},
Keywords-Plus = {SEED; POLLINATION; OVULE},
