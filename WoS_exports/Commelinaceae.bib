@article{ WOS:A1982NY58200004,
Author = {OWENS, SJ and HORSFIELD, NJ},
Title = {A LIGHT AND ELECTRON-MICROSCOPIC STUDY OF STIGMAS IN ANEILEMA AND
   COMMELINA SPECIES (COMMELINACEAE)},
Journal = {PROTOPLASMA},
Year = {1982},
Volume = {112},
Number = {1-2},
Pages = {26-36},
Abstract = {The stigmas of species in Aneilema {[}A. aequinoctiale] and Commelina
   {[}C. kurzii, C. erecta, C. diffusa and C. purpurea] are trifid and
   comprise elongate papillae. Progressive degeneration of papillar cells
   occurs in stigmas from open flowers and at anthesis papillae may be
   moribund and collapsed. Fluid emanating from the hollow style flows onto
   the surface through ruptures in the cuticle at the iterpapillary
   junctions into the interstices at maturity. This secretion stains
   positively for protein. Stigmas are of the wet type. The cuticle
   overlying the papillar cells is ridged and at the final stages prior to
   flowering this cuticle becomes detached from the underlying cellulosic
   wall. The sub-cuticular space so formed is filled with secretion. In
   Aneilema spp. detachment of cuticle is at the papillar tip and along the
   lateral walls. In Commelina spp. the anticlinal walls of adjacent
   papillae are strongly attached for much of their length and thus
   detachment of cuticle is restricted to the papillar tip. The cell wall
   at the tip in both genera may proliferate forming a rudimentary
   transfer-cell type wall. The secretion is considered to be produced by
   the papillar cells. It is PAS {[}periodic acid-Schiff] positive but
   fails to stain for protein and in the light and electron microscopes,
   appears heterogenous. Pollen attachment, hydration, germination and
   early tube growth are very rapid following self-pollination, the pollen
   tubes enterig the neck of the style within 10 min of attachment. A
   unique character combination involving pollen and stigmas in these
   genera indicates a monophyletic origin.},
