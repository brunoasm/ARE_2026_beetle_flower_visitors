   Poinar, George, Jr., Oregon State Univ, Dept Integrat Biol, Corvallis, OR 97331 USA.
   Kevan, Peter G., Univ Guelph, Sch Environm Sci, Guelph, ON N1G 2W1, Canada.
   Jackes, Betsy R., James Cook Univ, Coll Marine \& Environm Sci, Townsville, Qld 4811, Australia.},
DOI = {10.1139/cjb-2016-0006},
