@article{ WOS:A1992HV70400003,
Author = {NIESENBAUM, RA},
Title = {SEX-RATIO, COMPONENTS OF REPRODUCTION, AND POLLEN DEPOSITION IN LINDERA
   BENZOIN (LAURACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1992},
Volume = {79},
Number = {5},
Pages = {495-500},
Month = {MAY},
Abstract = {Sex ratio; flower, pollen, ovule, and fruit production; pollen
   deposition; and pollinator abundance were measured in populations of the
   dioecious shrub Lindera benzoin occurring in sun and shade habitats. Sex
   ratio was 1:1 in both the sun and shade. Flower production was greater
   in the sun than in the shade, and greater for male plants than for
   females in both habitat types. The population level ratio of pollen to
   ovules (P/O) was greater in the shade than in the sun, but pollinator
   abundance was a more important determinant of pollen deposition than
   P/O. Although 30\%-70\% of stigmas received no pollen, an even larger
   proportion of flowers did not set fruit, and fruit set was greater in
   the sun than in the shade. Increased illumination due to periodic gap
   formation may play an important role in the reproductive ecology of this
   understory shrub by affecting patterns of allocation toward reproduction
   in male and female plants.},
