@article{ WOS:001135292500001,
Author = {Toledo, Pedro F. S. and Araujo, Sabrina Helena da Cruz and Afanador,
   Javier Guilhermo Mantilla and Silva, Ana Carolina Fernandes and Machado,
   Francisco Paiva and Rocha, Leandro M. and Oliveira, Eugenio E.},
Title = {Potential of <i>Ocotea indecora</i> Essential Oil for Controlling
   <i>Drosophila suzukii</i>: Molecular Predictions for Toxicity and
   Selectivity to Beneficial Arthropods},
Journal = {NEOTROPICAL ENTOMOLOGY},
Year = {2024},
Volume = {53},
Number = {2},
Pages = {189-199},
Month = {APR},
Abstract = {The protection of soft-skinned fruits against Drosophila suzukii has
   relied primarily on the efficacy of a few synthetic molecules. Despite
   their short-term efficacy, these molecules can cause environmental
   pollution, unintendedly affect non-target organisms, and fail to provide
   sustainable control. The shortfalls of using synthetic pesticides
   warrant the search for alternatives, such as essential oils extracted
   from plants, with greater eco-friendlier properties. Here, we chemically
   characterized and evaluated the toxicity of the essential oil extracted
   from leaves of Ocotea indecora (Schott) Mez (Lauraceae) against D.
   suzukii via two exposure pathways (ingestion and contact). We also
   assessed the selectivity of the essential oil to two predatory natural
   enemies, Eriopis connexa and Chrysoperla externa and two pollinator
   bees, Apis mellifera and Partamona helleri. In addition, we conducted in
   silico predictions to investigate potential interactions between the
   major compound of the essential oil and the insects' transient receptor
   potential (TRP) channels. Our chromatographic analysis revealed
   sesquirosefuran (87\%) as the major compound. Higher toxicity to adults
   of D. suzukii was observed in contact exposure (LC50 = 0.43 mu L mL(-1))
   compared to ingestion (LC50 = 0.72 mu L mL(-1)). However, the essential
   oil did not cause mortality to the non-target organisms tested here,
   even when applied at 2.20 mu L mL(-1). Molecular predictions
   demonstrated that sesquirosefuran binds more stably to the TRP channels
   of D. suzukii than to those expressed in beneficial arthropods.
   Collectively, our findings provide the initial framework for the
   potential use of O. indecora essential oil as a sustainable alternative
   for managing D. suzukii infestations.},
