   Juergens, Andreas; Witt, Taina, Univ KwaZulu Natal, Sch Life Sci, ZA-3209 Pietermaritzburg, South Africa.},
DOI = {10.1016/j.jaridenv.2014.05.004},
ISSN = {0140-1963},
EISSN = {1095-922X},
Keywords = {Aizoaceae; Conophytum; Masarinae; Moth pollination; Pollen-ovule ratios},
Keywords-Plus = {WINTER RAINFALL REGION; BREEDING SYSTEMS; POLLINATION BIOLOGY;
   MASARINAE; DIVERSITY; CARYOPHYLLOIDEAE; ASSOCIATIONS; NAMAQUALAND;
