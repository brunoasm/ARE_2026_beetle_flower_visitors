   Brunet, Johanne, Univ Wisconsin, Dept Entomol, VCRU, USDA ARS, Madison, WI 53706 USA.
   Zalapa, Juan, Univ Wisconsin, Dept Hort, USDA ARS, VCRU, Madison, WI 53706 USA.
   Guries, Raymond, Univ Wisconsin, Dept Forest \& Wildlife Ecol, Madison, WI 53706 USA.},
DOI = {10.1007/s10592-016-0838-1},
