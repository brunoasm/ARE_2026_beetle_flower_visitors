Address = {PO BOX 299, ST LOUIS, MO 63166-0299 USA},
Type = {Article},
Language = {English},
Affiliation = {Friedman, J (Corresponding Author), Syracuse Univ, Dept Biol, 110 Coll Pl, Syracuse, NY 13244 USA.
   Friedman, Jannice; Hart, Katherine S.; den Bakker, Meghan C., Syracuse Univ, Dept Biol, 110 Coll Pl, Syracuse, NY 13244 USA.},
