   Rivera and Balangcod, Teodora D. and Peng, I, Ching- and Chung, Kuo-Fang},
Title = {<i>Begonia balangcodiae sp</i>. <i>nov</i>. from northern Luzon, the
   Philippines and its natural hybrid with <i>B</i>. <i>crispipila</i>,
   <i>B</i>. x <i>kapangan nothosp</i>. <i>nov</i>.},
Journal = {PHYTOTAXA},
Year = {2019},
Volume = {407},
Number = {1},
Pages = {5-21},
Month = {JUN 26},
Abstract = {The pantropically distributed Begonia (Begoniaceae) is one of the most
   species-rich genera. Philippines is one of the diversity centers of
   Southeast Asian Begonia. In our 2012 field survey, three species of
   Begonia section Petermannia were collected in Barangay Sagubo,
   Municipality of Kapangan, Province of Benguet in the northern Luzon
   Island, Philippines. Our study on literatures and herbarium specimens
   suggests that these collections consist of B. crispipila, an unknown new
   species hereby we named B. balangcodiae, and the natural hybrid between
   them. Molecular analyses confirm that the former contributed the
   maternal genome while the latter provided the paternal genome. We name
   the natural hybrid B. x kapangan, which is the first natural hybrid
   reported in sect. Petermannia.},
