@article{ WOS:A1996UN50700010,
Author = {Brandizzi, F and Caiola, MG},
Title = {Calcium variation in pistil of Crocus cartwrightianus Herb and Crocus
   sativus L},
Journal = {JOURNAL OF TRACE AND MICROPROBE TECHNIQUES},
Year = {1996},
Volume = {14},
Number = {2},
Pages = {415-426},
Abstract = {Ca2+ distribution along unpollinated, self- and out-pollinated pistils
   and in pollen grains of the fertile Crocus cartwrightianus Herb. and the
   sterile C. sativus L. (Iridaceae) plants has been studied by means of
   Ca2+ selective microelectrodes and the fluorochrome chlorotetracycline.
   A different Ca2+ distribution along pistils of both Crocus species has
   been revealed with a higher concentration in style before the
   pollination and in the ovary of pollinated flowers of C. cartwrightianus
   at the seventh day after pollination. Ungerminated pollen of C.
   cartwrightianus appeared uniformly rich of membrane bound Ca2+ compared
