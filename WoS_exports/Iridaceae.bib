@article{ WOS:A1981NF31300002,
Author = {GOLDBLATT, P},
Title = {SYSTEMATICS AND BIOLOGY OF HOMERIA (IRIDACEAE)},
Journal = {ANNALS OF THE MISSOURI BOTANICAL GARDEN},
Year = {1981},
Volume = {68},
Number = {3},
Pages = {413-503},
Abstract = {Homeria is native to southern Africa, where its center of speciation and
   variation is the western Cape coastal mountain belt and immediate
   interior, an area of mediterranean climate. Only 1 spp., H. pallida
   occurs exclusively outside the winter rainfall area of the Cape Province
   and it ranges widely across the winter dry highland grassveld of
   southern Africa. Homeria belongs to a group of corm-bearing,
   bifacial-leafed genera of Old World Iridoideae-Irideae and is closely
   related to the African genus Moraea. It comprises mainly large-flowered
   outcrossing species adapted either to fly or bee pollination, but a few
   species are self-compatible and autogamous, including 3 in which complex
   heterozygosity occurs. In this study, the 1st revision of the genus
   since Flora Capensis (1896), in which 6 spp. were admitted, Homeria is
   divided into 4 sections. Thirty-one species are recognized of which 10
   are described here for the 1st time. Basic chromosome number is n = 6
   and the genus comprises mostly diploid species, with a few polyploids; 3
   spp. exhibit aneuploidy, 2n = 10, 9, and 8. First chromosome counts for
   a few species are presented, as well as new counts for several others.
   {[}The following sections are new: NAMAQUANA, STIPANTHERA, and
   CONANTHERA. The other new taxa described include the following: H.
   bolusiae, sp. nov. H. Cookii, sp. nov., H. O. ssp. anomala ssp. nov., H.
   autumnalis sp. nov., H. longistyla sp. nov., H. patens sp. nov., H.
   vallisbelli sp. nov., H. flavescens sp. nov., H. pendula sp. nov., H.
   fenestratal sp. nov., H. fuscomontana sp. nov.].},
