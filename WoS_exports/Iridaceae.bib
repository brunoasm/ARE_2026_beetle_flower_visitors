@article{ WOS:000172797600012,
Author = {Wilson, CA},
Title = {Floral stages, ovule development, and ovule and fruit success in <i>Iris
   tenax</i>, focusing on var. <i>gormanii</i>, a taxon with low seed set},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2001},
Volume = {88},
Number = {12},
Pages = {2221-2231},
Month = {DEC},
Abstract = {Ovule development and ovule and fruit success were investigated in Iris
   tenax var. tenax and 1. tenax var. gormanii. Ovule development.
   including megasporogenesis and initial stages of megasporogenesis,
   occurred while flowers were still in bud. Final maturation of the
   seven-celled embryo sac occurred during the male phase of flowering. An
   earlier report that synergids persist after fertilization, and that
   nucellar nuclei migrate into the developing megagametophyte in L tenax
   var. tenax, was not supported in the present study. Reproductive studies
   used two pollination treatments: outcrossing and selfing. Treatment
   results were compared with results from open pollination. Both varieties
   of L tenax are self-compatible. Results showed that <5\% of L tenax var.
   gormanii ovules develop into seeds with open pollination, supporting
   earlier reports of low seed set. Hand pollinations improved reproductive
   success, suggesting that pollen may be limiting in nature.},
