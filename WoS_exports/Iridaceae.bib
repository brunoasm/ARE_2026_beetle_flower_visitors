Keywords = {Iridaceae; Geraniaceae; Diptera; Nemestrinidae; Moegistorhynchus
   longirostris; Keystone species; pollination guild},
Keywords-Plus = {IRIDACEAE; ADAPTATION; EVOLUTION; BIOLOGY},
