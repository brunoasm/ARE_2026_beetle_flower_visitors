   Manning, John C., Natl Bot Res Inst, ZA-7735 Claremont, South Africa.},
DOI = {10.3417/0026-6493(2007)94{[}709:FBOBIC]2.0.CO;2},
ISSN = {0026-6493},
Keywords = {Babiana; Crocoideae; Iridaceae; pollination; southern Africa;
