   Manning, J. C., Univ KwaZulu Natal, Sch Life Sci, Res Ctr Plant Growth \& Dev, ZA-3209 Scottsville, South Africa.},
DOI = {10.4102/abc.v42i2.11},
ISSN = {0006-8241},
