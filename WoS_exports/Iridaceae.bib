Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Barrett, SCH (Corresponding Author), Univ Toronto, Dept Ecol \& Evolutionary Biol, 25 Willcocks St, Toronto, ON M5S 3B2, Canada.
   de Waal, Caroli; Barrett, Spencer C. H., Univ Toronto, Dept Ecol \& Evolutionary Biol, Toronto, ON M5S 3B2, Canada.
   Anderson, Bruce, Univ Stellenbosch, Dept Bot \& Zool, ZA-7602 Matieland, South Africa.},
DOI = {10.1093/aob/mcr172},
