@article{ WOS:000292444600027,
Author = {Manning, J. C. and Mannheimer, C. and Goldblatt, P.},
Title = {Back from the brink: <i>Gladiolus halophila</i> (Iridaceae: Crocoideae),
   a remarkable new species from southern Namibia escapes imminent
   extinction},
Journal = {SOUTH AFRICAN JOURNAL OF BOTANY},
Year = {2011},
Volume = {77},
Number = {3},
Pages = {790-794},
Month = {AUG},
Abstract = {The new species Gladiolus halophila Goldblatt \& J.C.Manning from near
   Keetmanshoop in southern Namibia is described and illustrated. It is
   closely allied to G. longicollis and G. tristis from southwestern and
   eastern South Africa but is distinguished by its lilac flowers with
   shorter perianth tube, 35-40 mm long. The flowers last just one day and
   are self-compatible. The species, which is restricted to saline
   seepages, is known from just two populations, one of which is due to be
   inundated by a planned dam, and it is therefore classified as
   Endangered. The action of the Namibian Government in commissioning a
   search for additional localities serves as a valuable example in similar
   instances. (C) 2011 SAAB. Published by Elsevier B.V. All rights
   reserved.},
Publisher = {ELSEVIER SCIENCE BV},
Address = {PO BOX 211, 1000 AE AMSTERDAM, NETHERLANDS},
