Month = {OCT},
Abstract = {Three new species of the largely Western Cape genus Tritoniopsis L.Bolus
   are described, bringing the number of species in ale genus to 24,
   Tritoniopsis bicolor and T flava are newly discovered, narrow endemic,
   of the Bredasdorp Mountains and the Kogelberg Biosphere Reserve,
