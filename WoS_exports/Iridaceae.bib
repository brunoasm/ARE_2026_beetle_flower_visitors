@article{ WOS:000230948700008,
Author = {Goldblatt, P and Manning, JC and Bernhardt, P},
Title = {The floral biology of <i>Melasphaerula</i> (Iridaceae: Crocoideae):: Is
   this monotypic genus pollinated by march flies (Diptera: Bibionidae)?},
Journal = {ANNALS OF THE MISSOURI BOTANICAL GARDEN},
Year = {2005},
Volume = {92},
Number = {2},
Pages = {268-274},
Abstract = {Bibio longirostris, a small (ca. 5 rum long) nectar-feeding fly
   (proboscis ca. I rum long) was found to be the only visitor to the
   small, zygomorphic flowers (8-10 mm long) of Melasphaerula ramosa, a
   species endemic to the southern African winter-rainfall zone. Each
   captured fly carried the pollen of M. ramosa exclusively, with grains
   deposited oft the dorsal part of the thorax. Observations showed that
   these insects contacted both dehisced anthers and stigmatic surfaces of
   style branches while evidently foraging off nectar secreted from septal
   nectaries into the base of the floral tube. Experimental hand
   pollinations showed that M. ramosa is self-compatible, and some flowers
   undergo mechanical self-pollination (autogamy) in the absence of insect
   visitors. Pollination of this genus of Iridaceae by bibionids represents
   a new syndrome within the broad category of fly pollination and expands
   the range of pollination mechanisms reported in this family. As there is
   comparatively little scientific literature confirming bibionid
   pollination throughout the World. we compare the floral biology of M.
   ramosa with available litrerature on pollination by other microdipterans
   in the Araceae, Hydrophyllaceae, Saxifragaceae, Orchidaceae, and
   Sterculiaceae.},
Publisher = {MISSOURI BOTANICAL GARDEN},
Address = {2345 TOWER GROVE AVENUE, ST LOUIS, MO 63110 USA},
Type = {Article},
Language = {English},
Affiliation = {Goldblatt, P (Corresponding Author), Missouri Bot Garden, BA Krukoff Curator African Bot, Pob 299, St Louis, MO 63166 USA.
   Missouri Bot Garden, BA Krukoff Curator African Bot, St Louis, MO 63166 USA.
   Natl Bot Inst, Compton Herbarium, ZA-7735 Claremont, South Africa.
   St Louis Univ, Dept Biol, St Louis, MO 63103 USA.},
ISSN = {0026-6493},
Keywords = {Bibionidae; Iridaceae; microdipteran flies; pollination biology;
   southern Africa},
Keywords-Plus = {SOUTHERN AFRICA; FLY POLLINATION; ADAPTIVE RADIATION; SPECIES IRIDACEAE;
   SYSTEM; MECHANISMS; EVOLUTION; FLOWERS; GUILD},
Research-Areas = {Plant Sciences},
