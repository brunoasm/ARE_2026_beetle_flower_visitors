DOI = {10.1007/BF00989053},
ISSN = {0378-2697},
Keywords = {Iridaceae, Crocus; pistil transmitting tract, intra-interspecific
   pollination, pregamic-postgamic barriers},
Keywords-Plus = {SELF-INCOMPATIBILITY; POLLEN; RECOGNITION; PLANTS},
Research-Areas = {Plant Sciences; Evolutionary Biology},
Web-of-Science-Categories  = {Plant Sciences; Evolutionary Biology},
Number-of-Cited-References = {20},
