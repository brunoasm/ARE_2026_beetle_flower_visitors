@article{ WOS:A1982NL20400013,
Author = {TARODA, N and GIBBS, PE},
Title = {FLORAL BIOLOGY AND BREEDING SYSTEM OF STERCULIA-CHICHA ST HIL
   (STERCULIACEAE)},
Journal = {NEW PHYTOLOGIST},
Year = {1982},
Volume = {90},
Number = {4},
Pages = {735-743},
Abstract = {The neotropical, monoecious forest species, S. chicha, has flowers which
   are adpated for pollination by Diptera, such as medium-sized species of
   the sapromyophilous genera Acroglossa, Cochliomya, Gaemnochaetopsis,
   Ornidia and Parasarcophaga. The species is self-incompatible. The fact
   that pollen tube growth proceeds to the ovule following compatible and
   incompatible pollinations suggests that the incompatibility mechanism is
   based on the non-fusion of gametes in the embryo sac, as in the
   Theobroma-type, originally known only in the related T. cacao.},
