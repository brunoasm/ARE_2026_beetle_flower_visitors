@article{ WOS:000659932300044,
Author = {Akoa, Simon Perrez and Onomo, Pierre Effa and Ndjaga, Jude Manga and
   Ondobo, Martine Louise and Djocgoue, Pierre Francois},
Title = {Impact of pollen genetic origin on compatibility, agronomic traits, and
   physicochemical quality of cocoa (Theobroma cacao L.) beans},
Journal = {SCIENTIA HORTICULTURAE},
Year = {2021},
Volume = {287},
Month = {SEP 20},
Abstract = {Incompatibility within and between cocoa trees or cocoa clones is
   incontestably one of those factors which reduce cocoa yield in fields.
   Indeed, the traceability of raw materials is one of the major challenges
   that agro-industries face today. Improvement of cocoa and cocoa
   products' quality passes through the identification of cocoa genetic and
   geographic origin as well as the farm where cocoa is produced and
   harvested. Hand-pollination was used to assess compatibility between
   clones, to select interested agronomic traits (pod length, pod cortex
   thickness, average beans number, average beans weight, average weight of
   fresh or dry beans) and to improve specific cocoa beans quality through
   physicochemical parameters after post-harvest practices. Three different
   parents were used as female-clones: ICS40 (higher Trinitario), SNK16
   (Trinitario), SCA12 (Lower Amazon Forastero) and four clones added to
   the female ones as pollen donors: SNK16, SNK13 (Trinitario), UPA134
   (Upper Amazon Forastero), T79/467 (Amelado, Forastero), T60/877
   (Amelado, Forastero), ICS40 and SCA12. Crosses within Trinitario clones
   showed a low level of compatibility (0-18\%) whereas the general
   combination ability between TrinitarioxForastero (59-81\%) and within
   Forastero (84-88\%) and between ForasteroxTrinitaro (78-88\%) was very
   promising. SCA12 showed a high level of compatibility efficiency
   compared to the two Trinitario female-clones studied. The pollen grains
   from SCA12 increased the pod length and average weight of fresh beans in
   ICS40 female-clone meanwhile those of T60/877 also increased the pod
   cortex thickness and average weight of fresh/dry beans in SNK16
   female-clone. The genetic description of each pollen clone donor played
   a key role in the resulting hybrids. The pH values of fermented dried
   beans, ranged from 5.31 to 6.26 and was female-clone dependent. A strong
   negative correlation was observed between the average beans weight
   (fresh or dry) and pH. These results highlighted that the genetic origin
   of pollen grains could increase compatibility between clones, agronomic
   traits and consequently the physicochemical parameters of beans.},
