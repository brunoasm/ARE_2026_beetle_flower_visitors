@article{ WOS:A1985AGE4200013,
Author = {HARVEY, CF and BRAGGINS, JE},
Title = {REPRODUCTION IN THE NEW-ZEALAND TAXA OF POMADERRIS LABILL (RHAMNACEAE)},
Journal = {NEW ZEALAND JOURNAL OF BOTANY},
Year = {1985},
Volume = {23},
Number = {1},
Pages = {151-156},
Abstract = {The diploid, P. kumerako (2n = 24), is self fertile and reproduces
   sexually, whereas 2 triploid taxa, P. hamiltonii and P. phylicifolia
   var. ericifolia reproduce by agamospermy. The origin of the embryo sac
   in the latter is diplosporous. Although breeding experiments indicate
   that pollination improves seed set, endosperm chromosome counts in P.
   hamiltonii show that fertilization of the endosperm nucleus does not
   occur. Endosperm is derived from one or both polar nuclei separately. In
   the tetraploid P. phylicifolia var. polifolia, reproduction is mainly
   sexual, but there is some indication that plants may be facultative
   apomicts.},
