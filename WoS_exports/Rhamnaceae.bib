@article{ WOS:A1995TJ86600005,
Author = {GUITIAN, P},
Title = {REPRODUCTIVE-BIOLOGY OF RHAMNUS-LEGIONENSIS ROTHM, A DIOECIOUS SPECIES
   ENDEMIC TO THE NORTHWEST IBERIAN PENINSULA},
Journal = {FLORA},
Year = {1995},
Volume = {190},
Number = {4},
Pages = {345-352},
Month = {NOV},
Abstract = {Various aspects of the reproductive biology of Rhamnus legionensis were
   investigated during three years in two populations of this species in
   northwest Spain. My results indicate that in most respects, R.
   legionensis conforms to general models of dioecy. The population sex
   ratio was about fifty-fifty. The population ratio of male to female
   flowers was about 2.7. Male flowers were, on average, larger than female
   flowers. The pollen-to-ovule ratio was high (about 13,700). Unlike in
   most dioecious species, however, the male and female flowering periods
   were broadly synchronous. Pollination is strictly entomophilous and
   apomixis was not recorded. Both fruit-initiation and fruit-completion
   (i.e. attainment of full size) levels were low (maximum values of 38\%
   and 10\%, respectively, over the three years of study), probably largely
   as a result of inadequate pollination. A number of the above
   characteristics differed significantly between the two populations, but
   this is probably attributable to environmental differences.},
