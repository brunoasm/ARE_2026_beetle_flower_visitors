   Univ Seville, Dept Biol Vegetal \& Ecol, E-41080 Seville, Spain.},
DOI = {10.1007/s00442-004-1811-0},
ISSN = {0029-8549},
EISSN = {1432-1939},
Keywords = {global change; hydric stress; Mediterranean climate; phenology; pollen
