@article{ WOS:000173188900005,
Author = {Tosaki, Y and Renner, SS and Takahashi, H},
Title = {Pollination of <i>Sarcandra glabra</i> (Chloranthaceae) in natural
   populations in Japan},
Journal = {JOURNAL OF PLANT RESEARCH},
Year = {2001},
Volume = {114},
Number = {1116},
Pages = {423-427},
Month = {DEC},
Abstract = {The pollination biology of Sarcandra glabra was investigated in its
   natural habitat in Japan. Flowers were protogynous and stigma
   receptivity dropped off significantly following anther dehiscence.
   Female-stage and bisexual-stage flowers were visited by beetles, bees,
   hemiptera, flies, and rarely ants that foraged for pollen and/or small
   droplets of liquid that occasionally were secreted by the carpels and
   inflorescence axes. At least the beetles, bees, and hemiptera commonly
   touched the stigmas and likely effected pollination. Flowers were
   self-compatible, and automatic selfing sometimes occurred when pollen
   fell from apical flowers onto the stigmas of lower flowers.},
