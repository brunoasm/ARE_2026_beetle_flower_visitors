Keywords = {SANTALACEAE, OSYRIS-ALBA; PHENOLOGY, DIOECY, FLORAL MORPHOLOGY, FLORAL
   MIMICRY, POLLINATION BIOLOGY; MEDITERRANEAN SHRUBLANDS},
