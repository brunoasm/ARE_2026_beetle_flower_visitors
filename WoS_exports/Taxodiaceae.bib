@article{ WOS:000596605800006,
Author = {Herting, Julian and Stuetzel, Thomas},
Title = {Morphogenesis of the seed cone of <i>Araucaria araucana</i> (MOLINA) K.
   KOCH and the evolution of the coniferous seed scale},
Journal = {FLORA},
Year = {2020},
Volume = {273},
Month = {DEC},
Abstract = {The incorporation of ontogenetic studies into the study of the evolution
   of the coniferous `seed scale' over the past decades has yielded novel
   interpretation of the same. In this context the development of the `seed
   scale' of Araucariaceae is especially interesting because they have an
   extensive fossil record dating back to the Mesozoic. Therefore, we
   report the development of the Araucaria araucana `seed scale' and
   discuss the evolutionary implications of our findings. We used
   scanning-electron microscopy to observe and report the development of
   the `seed scale'. We collected the material from October to June, from
   the bud to the seed cone at pollination. The development of the bract
   precedes that of the `seed scale'. During the development of the latter,
   the nucellus and the integument arise independently. In later
   developmental stages, an additional bulge emerges on the distal part of
   the `seed scale'. This additional bulge partly envelopes the ovule. The
   comparison with development of Podocarpaceae shows striking similarities
   and from that we infer the homology of the araucariaceous `seed scale'
   and the epimatium. The comparison with the development of other conifers
   leads to the novel theory of interpreting the `seed scale' as a modified
   funiculus. Additionally, we propose that the `seed scales' of all extant
   conifers can be derived from a Cunninghamia-like morphology.},
