Keywords = {ovulate cone; pollen; pollination drop; Sequoiadendron; Taxodiaceae},
Keywords-Plus = {MORPHOLOGY; MECHANISM; PODOCARPACEAE; SECRETIONS; NUCELLUS; CEDRUS;
   CELLS},
