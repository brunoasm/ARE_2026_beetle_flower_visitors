Month = {JAN-JUN},
Abstract = {Echeandia flavescens (Asparagaceae) is reported for the first time for
   South America (Colombia and Venezuela), while Echeandia denticulata and
   Echeandia durangensis are synonymized under Echeandia flavescens.
   Echeandia flavescens is a polyploid taxon exhibiting a highly variable
   morphology and broad geographic distribution. The disjunct distribution
   of this species and morphological relationships with similar species are
   discussed. Information on the ecology of the species and possible
   pollinators in Colombia are provided.},
