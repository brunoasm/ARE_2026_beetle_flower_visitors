@article{ WOS:000590566500075,
Author = {Aelenei, Ruxandra Ileana and Petra, Sorina and Toma, Florin},
Title = {STUDIES AND RESEARCH ON THE SPECIES AND VARIETIES OF HOSTA IN
   CULTIVATION},
