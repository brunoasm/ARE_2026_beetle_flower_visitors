@article{ WOS:000257900200005,
Author = {Feinstein, Julie and Purzycki, Kenneth L. and Mori, Scott and Hequet,
   Vanessa and Berkov, Amy},
Title = {Neotropical soldier flies (Stratiomyidae) reared from <i>Lecythis
   poiteaui</i> in French Guiana:: Do bat-pollinated flowers attract
   saprophiles?},
Journal = {JOURNAL OF THE TORREY BOTANICAL SOCIETY},
Year = {2008},
Volume = {135},
Number = {2},
Pages = {200-207},
Month = {APR-JUN},
Abstract = {Two species of Stratiomyidae, Ptecticus nigrifrons Enderlein and
   Ptecticus sp., were reared from fallen androecia of Lecythis poiteaui
   Berg (Lecythidaceae) at rain forest sites in French Guiana. Floral
   aromas were collected by headspace adsorption from the night-blooming
   flowers. Gas chromatography-mass spectrometry analysis (GC-MS)
   identified several sulfur-containing compounds that contribute to the
   characteristic foul odor of the flowers. Although stratiomyids are
   thought to be generalist associates of decaying matter of plant and
   animal origin, we suggest that fetid floral attractants may make L.
   poiteaui flowers especially attractive to certain flies. This is the
   First report of Lecythidaceae flowers hosting stratiomyid flies.},
