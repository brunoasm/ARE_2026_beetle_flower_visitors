@article{ WOS:A1981NJ94600002,
Author = {ORMOND, WT and PINHEIRO, MCB and DECASTELLS, ARC},
Title = {A CONTRIBUTION TO THE FLORAL BIOLOGY AND REPRODUCTIVE-SYSTEM OF
   COUROUPITA-GUIANENSIS AUBL (LECYTHIDACEAE)},
Journal = {ANNALS OF THE MISSOURI BOTANICAL GARDEN},
Year = {1981},
Volume = {68},
Number = {4},
Pages = {514-523},
Abstract = {Studies of the reproductive system and pollination syndrome of
   cultivated trees of C. guianensis Aubl. are presented. The 1st report of
   the internal morphology of the stigma is included. In the stigmatic area
   2 parts are distinguished; one is hydrophobic and is composed of
   conspicuous collector hairs and the other is hydrophilic and is formed
   by the top of the transmission tissue; both parts have important
   functions in fertilization. The flower are odoriferous, nectarless and
   are visited by bees for their pollen. Osmophores are more evident in the
   top of the filaments of the hood anthers. The pollen is morphologically
   and physiologically dimorphic. The fertility of the pollen was tested in
   vivo and in vitro; under both conditions, only the staminal ring pollen
   germinated. The species is self-compatible. Pollen tubes begin to
   develop in 45 min and arrive at the ovules in 24 h. Field observations
   and tests demonstrate that the species studied, although allogamous, is
   self-compatible.},
