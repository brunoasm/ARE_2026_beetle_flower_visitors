@article{ WOS:A1981LN62800012,
Author = {MORI, SA and PRANCE, GT},
Title = {THE SAPUCAIA GROUP OF LECYTHIS (LECYTHIDACEAE)},
Journal = {BRITTONIA},
Year = {1981},
Volume = {33},
Number = {1},
Pages = {70-80},
Abstract = {Four previously much confused species of Lecythis {[}L. ampla, L.
   lanceolata, L. tumefacta and L. pisonis], which form a coherent group of
   species collectively known in Brazil South America as sapucaias, are
   described and differentiated in a key. A summary of their pollination
   and dispersal and of their present-day distributions in relation to past
   geological and climatological events, is presented. Fruit variability,
   the cause of name proliferation in this group, is described and related
   to the problem of species concepts in the Lecythidaceae.},
