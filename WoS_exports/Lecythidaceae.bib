@article{ WOS:A1976DE38100003,
Author = {PRANCE, GT},
Title = {POLLINATION AND ANDROPHORE STRUCTURE OF SOME AMAZONIAN LECYTHIDACEAE},
Journal = {BIOTROPICA},
Year = {1976},
Volume = {8},
Number = {4},
Pages = {235-241},
Abstract = {Pollination observations were made for 6 Amazonian spp. of Lecythidaceae
   {[}Gustavia hexapetala, Couroupita subsessilis, Eschweilera decolorans,
   E. longipes and Couratari atrovinosa]. Large bees were pollinators in 5
   spp. and wasps in 1 spp., C. subsessilis Pilg. The species studied were
   allogamous, and flowers lasted only 1 day. The diversity of androphore
   structure is discussed. The complex androphore structure is probably
   evolved to protect the fertile stamens and to increase efficiency of
   pollination rather than as an adaptation to new pollinators.},
