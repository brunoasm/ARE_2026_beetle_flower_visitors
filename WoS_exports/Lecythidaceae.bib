@article{ WOS:A1978FA62300001,
Author = {MORI, SA and PRANCE, GT and BOLTEN, AB},
Title = {ADDITIONAL NOTES ON FLORAL BIOLOGY OF NEOTROPICAL LECYTHIDACEAE},
Journal = {BRITTONIA},
Year = {1978},
Volume = {30},
Number = {2},
Pages = {113-130},
Abstract = {Observations on the floral biology of 7 spp. of New World Lecythidaceae
   {[}Gustavia superba, G. hexapetala, Couroupita subsessilis, Lecythis
   alba, L. corrugata, Eschweilera longipes and L. poiteaui] including the
   first report of bat pollination for neotropical members of the family,
   are presented. The shift from actinomorphic flowers with many stamens to
   zygomorphic flowers with fewer stamens and the concomitant change from
   pollen to nectar as the pollinator reward are discussed and related to
   the respective pollinators {[}Melipona quinquefasciata, Trigona spp.,
   Bombus spp., Eulaema spp., Paratetrapedia spp., Xylocopa sp., Halictus
   hesperus, Polybia spp., Chartergus sp. and Megachile sp.]. Several
   mechanisms which operate to reduce competition for pollinators between
   sympatric species of the family are suggested.},
