@article{ WOS:000337090400011,
Author = {de Potascheff, Carolina de Moraes and Mori, Scott A. and Lombardi, Julio
   Antonio},
Title = {Pollination ecology of the Cerrado species <i>Eschweilera nana</i>
   (Lecythidaceae subfam. Lecythidoideae)},
Journal = {BRITTONIA},
Year = {2014},
Volume = {66},
Number = {2},
Pages = {191-206},
Month = {JUN},
Abstract = {Eschweilera nana is pollinated by a guild of pollinators consisting of
   mostly bees. Effective pollinators are large bees able to force their
   way into the closed androecium to access nectar. The morphology of the
   flowers diminishes self pollination and promotes cross-pollination.
   Although many pollinators make diurnal visits to the flowers, fruit set
   was very low in comparison with the number of flowers produced. Breeding
   system tests yielded only two fruits, one produced by xenogamy and
   another one in the control test. The results of this study are
   consistent with studies of other Cerrado plants pollinated by guilds of
   insects and support the conclusion of other pollination studies of
   Lecythidaceae that fruit set is low in comparison with the high numbers
   of flowers produced.},
