Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Ruane, LG (Corresponding Author), Christopher Newport Univ, Dept Organismal \& Environm Biol, 1 Ave Arts, Newport News, VA 23606 USA.
   Moeller, DA (Corresponding Author), Univ Minnesota, Dept Plant \& Microbial Biol, 1479 Gortner Ave, St Paul, MN 55108 USA.
   Ruane, Lauren G.; Mangum, Samantha M.; Horner, Kaitlyn M., Christopher Newport Univ, Dept Organismal \& Environm Biol, 1 Ave Arts, Newport News, VA 23606 USA.
   Moeller, David A., Univ Minnesota, Dept Plant \& Microbial Biol, 1479 Gortner Ave, St Paul, MN 55108 USA.},
