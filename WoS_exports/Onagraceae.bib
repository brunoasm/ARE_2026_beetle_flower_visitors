@article{ WOS:A1984TT78400006,
Author = {GOTTLIEB, LD},
Title = {ELECTROPHORETIC ANALYSIS OF THE PHYLOGENY OF THE SELF-POLLINATING
   POPULATIONS OF CLARKIA-XANTIANA},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1984},
Volume = {147},
Number = {1-2},
Pages = {91-102},
Abstract = {Electrophoretic variation in isozymes coded by 40 loci was examined in 2
   self-pollinating populations, one with white and the other with pink
   flowering plants, and 4 outcrossing populations of C. xantiana
   (Onagraceae) native to California {[}USA]. The study was carried out to
   test the Moore and Lewis (1965) hypothesis that the pink selfer
   originated from the sympatric outcrossing population and then gave rise
   to the white selfer. The hypothesis could be rejected if one or the
   other selfer was more similar genetically to an allopatric population
   than to the sympatric one. Both selfers were monomorphic at all loci
   whereas the outcrossing populations were polymorphic at nearly half of
   them. The 2 selfers had the same genes at 32 loci but had different ones
   at 8 loci. The pink selfer was not more similar to the allopatric
   populations than to the sympatric one, consistent with the Moore and
   Lewis model. The evidence also supported their proposal that the white
   selfer originated from the pink one and not independently. The
   electrophoretic evidence was valuable because it permitted qualitative
   comparisons (presence vs. absence of particular alleles) between the
   selfer and the several outcrossing populations; such analysis was not
   previously possible because the latter populations are morphologically
   and cytologically similar.},
