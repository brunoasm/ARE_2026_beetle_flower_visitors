ISSN = {0032-0889},
Keywords-Plus = {POLEMONIUM-VISCOSUM; LIGNIN BIOSYNTHESIS; BRASSICA-OLERACEA; LINALOOL
   SYNTHASE; PURIFICATION; EXPRESSION; POLLINATION; ZINNIA},
