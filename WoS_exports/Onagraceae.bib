Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Lankinen, Å (Corresponding Author), Swedish Univ Agr Sci, Plant Protect Biol, POB 102, SE-23053 Alnarp, Sweden.
   Lankinen, Asa; Hydbom, Sofia, Swedish Univ Agr Sci, Plant Protect Biol, POB 102, SE-23053 Alnarp, Sweden.
   Hydbom, Sofia, Lund Univ, Dept Biol, Ecol Bldg, Lund, Sweden.},
