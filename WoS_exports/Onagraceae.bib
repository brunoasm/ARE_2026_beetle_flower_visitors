Keywords = {fireweed; reproductive isolation; pollinator constancy; pollen
   deposition; polyploidy},
Keywords-Plus = {FLORAL TRAITS; REPRODUCTIVE ISOLATION; ESTABLISHMENT; POLYPLOIDY;
