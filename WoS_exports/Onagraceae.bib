Title = {ELECTROPHORETIC EVIDENCE FOR THE INDEPENDENT ORIGINS OF 2
   SELF-POLLINATING SUBSPECIES OF CLARKIA-CONCINNA (ONAGRACEAE)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1991},
Volume = {69},
Number = {10},
Pages = {2299-2301},
Month = {OCT},
Abstract = {Electrophoretic variation in 20 isozyme loci was examined in populations
   of Clarkia concinna, a spring-flowering annual plant native to the Coast
   Ranges of California.  Clarkia concinna includes one outcrossing
   subspecies (ssp. concinna) and two allopatric self-pollinated subspecies
   (sspp. automixa and raichei).  The two selfing subspecies contain
   different subsets of the alleles found in the outcrossing subspecies and
   possess few or no unique alleles (one rare allele in ssp. automixa, none
   in ssp. raichei).  The two self-pollinated subspecies appear to have
   arisen independently from the outcrossing ssp. concinna.},
