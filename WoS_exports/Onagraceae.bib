@article{ WOS:A1996TV09700009,
Author = {Moller, AP},
Title = {Developmental stability of flowers, embryo abortion, and developmental
   selection in plants},
Journal = {PROCEEDINGS OF THE ROYAL SOCIETY B-BIOLOGICAL SCIENCES},
Year = {1996},
Volume = {263},
Number = {1366},
Pages = {53-56},
Month = {JAN 22},
Abstract = {Fluctuating asymmetries in morphology originate from developmental
   errors during ontogeny, and a general failure of the same developmental
   programme may in outcrossing plants give rise to high levels of embryo
   abortion caused by developmental failure in early stages of cell
   differentiation. I tested whether developmental errors expressed in
   flower asymmetry are associated with early embryo abortion caused by
   developmental failure in hand-pollination experiments on rosebay
   willowherb (Epilobium angustifolium) (Onagraceae). Floral symmetry
   reliably reflects pollinator rewards of individual plants. Pollinators
   prefer symmetrical flowers over asymmetrical ones, visit flowers
   assortatively with respect to symmetry, and avoid flowers with
   experimentally increased asymmetry. Embryo abortion rates are strongly
   positively related to floral asymmetry of both pollen donor and
   recipient, implying that both maternal and paternal plants affect embryo
   failure. Floral fluctuating asymmetry thus may be related to an
   important component of developmental selection in outcrossing plants
   such as rosebay willowherb.},
