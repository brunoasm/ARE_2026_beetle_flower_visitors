   Univ Michigan, Dept Biol, Ann Arbor, MI 48109 USA.
   Purdue Univ, Dept Hort, W Lafayette, IN 47907 USA.},
DOI = {10.1093/oxfordjournals.pcp.a029623},
ISSN = {0032-0781},
Keywords = {benzenoid esters; Clarkia breweri; Clarkia concinna; evolution; floral
   scent; intron splicing},
Keywords-Plus = {S-LINALOOL SYNTHASE; FLORAL SCENT; BREWERI; EVOLUTION; PURIFICATION;
