Keywords = {bottlenecks; Galapagos Islands; inbreeding depression; small
   populations; Scalesia affinis},
Keywords-Plus = {BREEDING SYSTEM; OUTCROSSING RATE; POPULATIONS; CARYOPHYLLACEAE; RARE;
   CONSEQUENCES; ENVIRONMENTS; CONSERVATION; ONAGRACEAE; SUCCESS},
