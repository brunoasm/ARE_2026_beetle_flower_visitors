Title = {Phenology and yield of native fruits cloudberry/bakeapple (<i>Rubus
   chamaemorus</i> L.) and lingonberry/partridgeberry (<i>Vaccinium
   vitis</i>-<i>idaea</i> L.) grown in Southern Labrador, Canada},
Journal = {CANADIAN JOURNAL OF PLANT SCIENCE},
Year = {2016},
Volume = {96},
