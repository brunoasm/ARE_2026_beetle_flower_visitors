   Carleton Univ, Dept Biol, Ottawa, ON K1S 5B6, Canada.},
DOI = {10.1007/s10530-004-4062-4},
ISSN = {1387-3547},
Keywords = {alien plants; arthropods; Asclepiadaceae; feeding guilds; invasive
   plants; Vincetoxicum rossicum},
Keywords-Plus = {REPRODUCTIVE-BIOLOGY; HYPOTHESIS; INVADERS; RELEASE; NIGRUM; PLANTS;
