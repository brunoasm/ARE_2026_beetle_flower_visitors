DOI = {10.2307/2997216},
ISSN = {0040-9618},
Keywords = {Asclepias; Gonolobus; self-incompatibility; fly-pollination; pollination
   rates},
Keywords-Plus = {POLLEN-DONATION HYPOTHESIS; SELF-POLLINATION; FLORAL DISPLAY; FRUIT-SET;
   SYRIACA-L; EXALTATA; MILKWEED; CURASSAVICA; POPULATION; WEED},
