@article{ WOS:000186581700022,
Author = {Fischer, OA and Vícha, R},
Title = {Blowflies (Diptera, Calliphoridae) attracted by <i>Phallus impudicus</i>
   (Phallaceae) and <i>Stapelia grandiflora</i> (Asclepiadaceae)},
Journal = {BIOLOGIA},
Year = {2003},
Volume = {58},
Number = {5},
Pages = {995-998},
Month = {OCT},
Abstract = {Attraction of blowflies by the stinkhorn mushroom Phallus impudicus L.
   and the indoor succulent plant Stapelia grandiflora Mass. was studied.
   Imagoes of the blowflies Calliphora loewi, C. uralensis, C. vicina, C.
   vomitoria, Lucilia ampullacea, L. illustris and L. caesar were attracted
   by P. impudicus in one forest locality (Visky, Southern Moravia, Czech
   Republic). P. impudicus was visited by females and males of C. loewi, C.
   vicina, C. vomitoria, L. ampullacea and L. caesar, and females of C.
   uralensis and L. illustris. Spores of P. impudicus were found on body
   surfaces of blowflies. No oviposition was observed and no eggs of
   blowflies were found on P. impudicus. No flies were attracted by the
   net, which was scattered with fetid mucilaginous liquid of P. impudicus.
   C. vicina, L. caesar and L. cuprina were attracted by S. grandiflora
   placed on balconies in two South-Moravian urban localities, as monitored
   by rearing of imagoes from eggs. Although eggs were found on flowers,
   neither pollination nor larval development was observed. Both fetid
   plants are important for aggregation of imagoes of both sexes, which are
   dispersed in nature. S. grandiflora may attract synanthropic blowflies,
   such as C. vicina, to the vicinity of humans.},
Publisher = {VERSITA},
