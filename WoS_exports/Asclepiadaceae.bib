@article{ WOS:A1997WY95600010,
Author = {Kunze, H},
Title = {Corona and nectar system in Asclepiadinae (Asclepiadaceae)},
Journal = {FLORA},
Year = {1997},
Volume = {192},
Number = {2},
Pages = {175-183},
Month = {APR},
Abstract = {The structure of the staminal and interstaminal corona parts in the
   Asclepiadinae is analysed with respect to functional aspects of nectar
   conducting. It is shown that in all species analysed an interstaminal
   corona is present which is at least basally fused with the staminal
   corona lobes. Therefore the corona in this subtribe is basically annular
   {[}C(is)]. Many genera have a highly specialised nectar conducting
   system by means of which the nectar is transferred from the primary
   nectary beneath the guide rail to secondary nectar holders formed by the
   staminal corona (Gomphocarpus, Calotropis, Pentarrhinum, Pachycarpus,
   Aspidoglossum). This is similar to the well-known system in Asclepias.
   In Schizoglossum the nectar is conducted onto the corolla by the
   interstaminal corona. In some species the interstaminal corona just
   seems to function as the outward border of the primary nectary below the
   entrance of the guide rail (Parapodium crispum, Xysmalobium spp.,
   Pachycarpus dealbatus). These different nectar systems can be arranged
   in a morphocline according to the distance of the secondary nectar
   holders from the primary nectary and the increasing complexity of the
   nectar conducting system. The systematic relevance of the corona
   structure and the nectar system is discussed.},
Publisher = {GUSTAV FISCHER VERLAG},
Address = {VILLENGANG 2, D-07745 JENA, GERMANY},
