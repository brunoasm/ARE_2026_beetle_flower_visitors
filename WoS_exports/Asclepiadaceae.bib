   Wuhan Univ, Coll Life Sci, Wuhan 430072, Peoples R China.},
DOI = {10.1007/s00606-002-0223-z},
ISSN = {0378-2697},
Keywords = {Pedicularis; stigma; pollination adaptation; floral design; evolution},
