@article{ WOS:000169702900010,
Author = {Gafur, MA and Naznin, D},
Title = {Reproductive biology of <i>Tabernaemontana recurva</i> Roxb. and
   <i>Calotropis gigantea</i> (L.) R. Br. in Bangladesh},
Journal = {BANGLADESH JOURNAL OF BOTANY},
Year = {2001},
Volume = {30},
Number = {1},
Pages = {61-64},
Month = {JUN},
Abstract = {Reproductive biology of naturally grown Tabernaemontana recurva Roxb.
   and Calotropis gigantea (L,) R. Br. were studied for 61 days after
   flowering in Chittagong University Campus. Fruit formation was high in
   T. recurva but seed production was low. On the other hand, C. gigantea
   showed different phenomenon where fruit formation was low and seed
   production was high. Low seed productions in T. recurva probably
   indicate its rarity of occurrence. The main pollinators of T. recurva
   were species of Formis. Calliphora and Lucilig, and of C. gigantea were
   species of Formis, Danaus.. Euploea, Pyrrhocoris. Vespa and Xylocope. It
   was observed that Formis sp. as the most common visitor to the flowers
   of both species and mainly responsible for pollination.},
