@article{ WOS:A1981MG71500032,
Author = {CREPET, WL and DAGHLIAN, CP},
Title = {LOWER EOCENE AND PALEOCENE GENTIANACEAE - FLORAL AND PALYNOLOGICAL
   EVIDENCE},
Journal = {SCIENCE},
Year = {1981},
Volume = {214},
Number = {4516},
Pages = {75-77},
Abstract = {Lower Eocene flowers with Pistillipollenites macgregorii pollen
   represent the earliest megafossil evidence of the Gentianaceae. The
   Paleocene occurrence of P. macgregorii, the fossil''s modern floral
   structure, and suggested trends in the evolution of pollen in the
   Gentianaceae indicate a considerably earlier origin for the family.
   Floral morphology typical of bee-pollinated flowers provides the
   earliest, albeit indirect, fossil evidence of bees.},
