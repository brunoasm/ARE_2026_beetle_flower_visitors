Keywords = {GENTIANACEAE, GENTIANA; POLLINATION, HERKOGAMY, DICHOGAMY; FLORA OF
   CHATHAM ISLANDS, NEW-ZEALAND},
Keywords-Plus = {INTERFERENCE; ANGIOSPERMS; AVOIDANCE; STIGMAS; POLLEN},
