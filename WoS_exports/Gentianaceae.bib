@article{ WOS:A1980KU37400005,
Author = {INOUYE, DW and TAYLOR, OR},
Title = {VARIATION IN GENERATION TIME IN FRASERA-SPECIOSA (GENTIANACEAE), A
   LONG-LIVED PERENNIAL MONOCARP},
Journal = {OECOLOGIA},
Year = {1980},
Volume = {47},
Number = {2},
Pages = {171-174},
Abstract = {The perennial monocarp F. speciosa (Gentianaceae) flowers at a wide
   range of sizes and ages with consequent variation on generation time
   (T), net replacement rate (Ro) and intrinsic rate of increase (r).
   Values of r were calculated for hypothetical cohorts composed of
   individuals flowering at the same age. Maximum rates of r were achieved
   by plants which flower at the earliest possible age. Although older
   plants produced more flowers, this increase was not sufficient to
   compensate for the effect of increased T on r. Few plants in each
   population flower at the youngest possible age, and for the majority
   reproduction was delayed, generation times were longer and r lower than
   achieved by plants flowering at younger ages. Delayed reproduction may
   be favored by greater seed set, due to pollinator attraction to larger
   flower stalks, as well as broader seed dispersal which could increase
   the probability of seedling establishment. Delays greater than those
   observed may be selected against by decreasing probability of survival,
   a decrease in the rate of addition of flowers with increasing size, and
   slower transitions between leaf number classes in larger plants.
   Staggered reproduction by an individual''s offspring, whether
   environmentally or genetically determined, had the effect of insuring
   survival in an environment with high variability in pollinator
   effectiveness, germination and seedling establishment.},
