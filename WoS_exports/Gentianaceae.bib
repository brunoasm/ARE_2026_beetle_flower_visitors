@article{ WOS:A1990EC57500001,
Author = {DUDASH, MR},
Title = {RELATIVE FITNESS OF SELFED AND OUTCROSSED PROGENY IN A SELF-COMPATIBLE,
   PROTANDROUS SPECIES, SABATIA-ANGULARIS L (GENTIANACEAE) - A COMPARISON
   IN 3 ENVIRONMENTS},
