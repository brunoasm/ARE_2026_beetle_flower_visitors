ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {attractive structure; flower number; geographical variation; resource
   allocation hierarchy; self-fertilization; sex-allocation theory;
   trade-off},
Keywords-Plus = {EICHHORNIA-PANICULATA PONTEDERIACEAE; SEX-ALLOCATION; ATTRACTIVE
