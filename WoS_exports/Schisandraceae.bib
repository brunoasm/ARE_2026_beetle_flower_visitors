Keywords = {dichogamy; protandry; monophily; Trigona},
Keywords-Plus = {SCHISANDRACEAE; BIOLOGY},
Research-Areas = {Life Sciences \& Biomedicine - Other Topics},
Web-of-Science-Categories  = {Biology},
