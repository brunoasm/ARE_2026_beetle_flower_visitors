EISSN = {1872-8847},
Keywords = {Cycad pollination; Erotylidae; Plant thermogenesis; Plant-insect
   interactions},
Keywords-Plus = {INSECT POLLINATION; SEED DISPERSAL; COLEOPTERA; GYMNOSPERM; PATTERNS;
