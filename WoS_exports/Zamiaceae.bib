Number = {2},
Pages = {46-49},
Month = {FEB},
Abstract = {Insect pollination is a prominent type of plant-insect mutualism that
   can provide clues to the nature of diffuse coevolution.  A long-standing
   question in this field is to what extent the emergence of insect
   pollination caused rapid diversification in the interacting organisms. 
   Recent progress in systematics and paleontology is providing much of the
   information needed to address this issue.},
