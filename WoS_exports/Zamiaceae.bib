@article{ WOS:000413196200006,
Author = {Alekseev, Vitalii I. and Bukejs, Andris},
Title = {First fossil representatives of Pharaxonothinae Crowson (Coleoptera:
   Erotylidae): indirect evidence for cycads existence in Baltic amber
   forest},
Journal = {ZOOTAXA},
Year = {2017},
Volume = {4337},
Number = {3},
Pages = {413-422},
Month = {OCT 19},
Abstract = {A new species of Erotylidae, Cycadophila (s. str.) mumia sp. nov., the
   first fossil representative of the subfamily Pharaxonothinae, is
   described and illustrated from Eocene Baltic amber. A second closely
   related specimen is reported but not described as new due to poor
   preservation in amber. The occurrence of representatives of the Recent
   cycad-specialized genus in Baltic amber can indirectly indicate the
   presence of their host plants (Cycadales: Cycadophyta: Cycadopsida) in
   the Eocene amber forest.},
