@inproceedings{ WOS:000086521700025,
Author = {Vorster, P and Oberprieler, R},
Editor = {Chen, CJ},
Title = {Entomological evidence for and against taxonomical decisions in
   <i>Encephalartos sp</i>.},
Booktitle = {BIOLOGY AND CONSERVATION OF CYCADS},
Year = {1999},
Pages = {198-207},
Note = {4th International Conference on Cycad Biology, CYCAD SOC CHINA,
   PANZHIHUA, PEOPLES R CHINA, MAY 01-05, 1996},
Organization = {Cycad Soc China; IUCN CNPPA E Steering Comm; IUCN SSC Cycad Specialist
   Grp; Chinese Acad Sci, Inst Bot; Govt Panzhihua City},
Abstract = {Two instances of intimately associated and presumed pollinating weevils
   of the genus Porthetes (Coleoptera: Curculionidae), occurring in the
   cones of newly described species of Encephalartos and their presumed
   closest relatives, are reported. In the first of these cases, the
   entomological evidence fully supports the recognition of the new
   Encephalartos aplanatus Vorster as a species distinct from E. villosus
   Lemaire. In the second it is in partial conflict with the botanical
   viewpoint as the two presumed closely related but geographically
   disjunct species of Encephalartos, E. lebomboensis Verdoorn and E.
   senticosus Vorster, harbour the same species of Porthetes (as currently
   taxonomically recognizable). Some possible evolutionary explanations are
   offered for this scenario.},
