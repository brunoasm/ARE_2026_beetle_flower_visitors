Address = {233 SPRING STREET, NEW YORK, NY 10013 USA},
Type = {Article},
Language = {English},
Affiliation = {Roemer, R (Corresponding Author), Univ Utah, Dept Mech Engn, 50 S Cent Campus,2202 Merrill Engn Bldg, Salt Lake City, UT 84112 USA.
