@article{ WOS:A1986F875600005,
Author = {NORSTOG, KJ and STEVENSON, DW and NIKLAS, KJ},
Title = {THE ROLE OF BEETLES IN THE POLLINATION OF ZAMIA-FURFURACEA L FIL
   (ZAMIACEAE)},
Journal = {BIOTROPICA},
Year = {1986},
Volume = {18},
Number = {4},
Pages = {300-306},
Month = {DEC},
Abstract = {A snort weevil, Rhopalotoria mollis Sharp, is found to complete the
   reproductive phases of its life cycle and within male cones of the
   cycad, Zamia furfuracea. Larvae of this insect feed upon tissues of the
   male cone, pupate, and emerge as pollen-coated adults after boring
   through microsporangia and microsporophylls. Mature weevils visit
   pollen-receptive female cones but are nondestructive to ovules and
   seeds. Exclusion experiments show that weevils are capable of effecting
   the pollination of ovules of Z. furfuracea in the absence of airborne
   pollen.},
