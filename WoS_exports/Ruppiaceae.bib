
@article{ WOS:A1993KU18000001,
Author = {TALAVERA, S and GARCIAMURILLO, P and HERRERA, J},
Title = {CHROMOSOME-NUMBERS AND A NEW MODEL FOR KARYOTYPE EVOLUTION IN RUPPIA L
   (RUPPIACEAE)},
Journal = {AQUATIC BOTANY},
Year = {1993},
Volume = {45},
Number = {1},
Pages = {1-13},
Month = {MAR},
Abstract = {Populations of three species in the genus Ruppia that inhabit the
   western part of the Mediterranean region were studied caryologically.
   All three species present bimodal karyotypes. Ruppia drepanensis Tineo
   ex guss. (2n=20) has a karyotype asymmetry of the 2C type. Ruppia
   cirrhosa (Petagna) Grande and Ruppia maritima L. (both with 2n=40)
   present a 2B asymmetry. Observations of meiosis of microspore mother
   cells revealed that R. drepanensis forms ten bivalents at diakinesis and
   Metaphase I. The other two species exhibit 20 bivalents. The long arm of
   subtelocentric, large chromosomes in all three species shows no sign of
   chiasmata at meiosis.},
