@article{ WOS:000168889800006,
Author = {Tamari, F and Athanasiou, A and Shore, JS},
Title = {Pollen tube growth and inhibition in distylous and homostylous
   <i>Turnera</i> and <i>Piriqueta</i> (Turneraceae)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {2001},
Volume = {79},
Number = {5},
Pages = {578-591},
Month = {MAY},
Abstract = {We investigate sites of incompatibility for five Turnera L. species and
   for Piriqueta caroliniana (Walt.) Urban using aniline blue staining of
   pollen tubes and fluorescence microscopy. We show that sites of
   incompatibility occur in the stigma and upper regions of the style.
   There is an asymmetry between the morphs where, following selfing,
   pollen tubes tend to grow further into long-styled compared to
   short-styled plants, although the difference is not particularly marked.
   We demonstrate for the first time a qualitative difference in the
   appearance of pollen tubes. Upon self-pollination, pollen tubes in
   short-styled plants do not produce callose plugs, while all other
   pollinations result in callose plug formation. This could indicate that
   there is a difference in the mechanisms of incompatibility between the
   morphs. Exploiting crosses between two populations of Turnera scabra
   Millsp. that differ in flower size, we found no support for the
   hypothesis that incompatibility of long-styled plants is the result of
   insufficient nutrient reserves in pollen. Bud-pollinations provided
   limited support for the hypothesis that a short-specific style protein
   is involved in incompatibility. Crosses between distylous and
   homostylous species provided support for a recombinant origin for
   homostyly for four species, while deviations from this expectation were
   observed in four instances.},
Publisher = {NATL RESEARCH COUNCIL CANADA},
Address = {RESEARCH JOURNALS, MONTREAL RD, OTTAWA, ONTARIO K1A 0R6, CANADA},
Type = {Article},
Language = {English},
Affiliation = {Shore, JS (Corresponding Author), York Univ, Dept Biol, 4700 Keele St, Toronto, ON M3J 1P3, Canada.
   York Univ, Dept Biol, Toronto, ON M3J 1P3, Canada.},
