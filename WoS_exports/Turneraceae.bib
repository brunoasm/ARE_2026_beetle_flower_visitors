@article{ WOS:A1984SZ42800023,
Author = {SHORE, JS and BARRETT, SCH},
Title = {THE EFFECT OF POLLINATION INTENSITY AND INCOMPATIBLE POLLEN ON SEED SET
   IN TURNERA-ULMIFOLIA (TURNERACEAE)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1984},
Volume = {62},
Number = {6},
Pages = {1298-1303},
Abstract = {Controlled pollination experiments were performed on the
   self-incompatible distylous herb T. ulmifolia L. to investigate the
   effects of pollination intensity and large amounts of imcompatible
   pollen on seed set. In the 1st experiment, known numbers of compatible
   pollen grains ranging 1-100 were applied to stigmas of the floral
   morphs. In both morphs, increasing amounts of pollen generally resulted
   in increased levels of seed set, although considerable variance was
   observed at all pollination intensities. Approximately 2-7 pollen grains
   are required to produce a single seed and more than 95 grains are
   required to achieve maximum seed set in T. ulmifolia. Regression
   analysis of the seed set data failed to detect a difference in the
   response of the floral morphs to pollination intensity. In the 2nd
   experiment, know proportions of compatible and incompatible pollen were
   applied to stigmas at various time intervals. Most treatments involving
   mixtures of compatible and incompatible pollen had no significant effect
   on seed set when compared with the controls. Clogging was only observed
   in the long-styled morph when one anther of compatible pollen was
   applied to stigmas 1.5 and 3.0 h after pollination with 5 anthers of
   incompatible pollen. The clogging of stigmas by incompatible pollen
   seems unlikely to have played a major role in the evolution and
   maintenance of distyly in T. ulmifolia.},
Publisher = {CANADIAN SCIENCE PUBLISHING},
Address = {65 AURIGA DR, SUITE 203, OTTAWA, ON K2E 7W6, CANADA},
