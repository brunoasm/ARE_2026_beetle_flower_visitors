Type = {Proceedings Paper},
Language = {English},
Affiliation = {Havey, MJ (Corresponding Author), Univ Wisconsin, USDA ARS, Madison, WI 53706 USA.
   Univ Wisconsin, USDA ARS, Madison, WI 53706 USA.},
DOI = {10.17660/ActaHortic.2001.555.9},
