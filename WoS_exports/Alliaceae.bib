ISBN = {90-6605-904-4},
Keywords = {genetic linkage; cytoplasmic-genic male sterility; hybrid development},
Keywords-Plus = {OPEN-POLLINATED POPULATIONS; DNA POLYMORPHISM; CYTOPLASMS},
