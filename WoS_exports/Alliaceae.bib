@inproceedings{ WOS:000233358800018,
Author = {Tong, CF and Tang, CY and Cui, LW and Wang, GZ and Du, DJ},
Editor = {Guangshu, L},
Title = {Selection and utilization of the male-sterile line ``244A{''} in Welsh
   onion},
Booktitle = {Proceedings of the IVth International Symposium on Edible Alliaceae},
Series = {ACTA HORTICULTURAE},
Year = {2005},
Number = {688},
Pages = {151-157},
Note = {4th International Symposium on Edible Alliaceae, Beijing, PEOPLES R
   CHINA, APR 21-26, 2004},
Organization = {Int Soc Hort Sci; UN, Food \& Agr Org},
Abstract = {Welsh onion male-sterile plants were found in the seed propagation field
   of ``Donglingbai{''} Welsh onion. Six plants selected were pollinated in
   the same year. Three plants were harvested and their seeds were sown in
   three lines separately. In the second year, one plant selected from the
   lines with high male-sterile rate made a couple of hybridization with
   the original fertile plants. At the same time, the male parent was
   self-pollinated and desirable lines were selected cautiously from four
   generations. According to testing of male sterility and other
   characters, male-sterile plant No.025 was selected, followed by mixed
   pollination with the corresponding female parent. The male-sterile rate
   of the line was 100\% for three continuous generations for the next two
   years. This line is numbered as 244 in 1998, so it is briefly called
   244A, and the corresponding male parent is called 244B. The seed-setting
   ability of 244A is the same as that of the normal plants. The hybrid
   that was made using 244A as female parent showed a higher vigor, so 244A
   is worth to be used in breeding program.},
