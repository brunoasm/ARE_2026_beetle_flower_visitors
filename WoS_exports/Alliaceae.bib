   Univ Helsinki, Dept Systemat \& Ecol, FIN-00014 Helsinki, Finland.},
ISSN = {0003-3847},
Keywords = {Allium oleraceum; germination; pollination; seed; Vespidae; ``wasp
   blossom{''}},
