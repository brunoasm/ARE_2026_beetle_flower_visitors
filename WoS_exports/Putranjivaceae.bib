   Lawes, Michael/0000-0002-2381-6147},
Funding-Acknowledgement = {The National Research Foundation (South Africa)},
Funding-Text = {The authors thank R. Kaiser (Givaudan Natural Scents) for his expert
   analysis of the solvent scent samples and feedback on the manuscript. R.
   Wethered and S. Steenhuisen provided assistance in the laboratory. Mazda
   Wildlife Fund provided field vehicles. The National Research Foundation
