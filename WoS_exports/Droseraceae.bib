@article{ WOS:000254568200012,
Author = {Hagan, Daniel V. and Grogan, Jr., William L. and Murza, Gillian L. and
   Davis, Arthur R.},
Title = {Biting midges (Diptera: Ceratopogonidae) from the English sundew,
   <i>Drosera anglica</i> Hudson (Droseraceae), at two fens in
   Saskatchewan, Canada},
Journal = {PROCEEDINGS OF THE ENTOMOLOGICAL SOCIETY OF WASHINGTON},
Year = {2008},
Volume = {110},
Number = {2},
Pages = {397-401},
Month = {APR},
Abstract = {The plant-arthropod interactions of a native carnivorous plant, the
   English sundew, Drosera anglica Hudson, were studied in the Nisbet
   Provincial Forest of central Saskatchewan, Canada during July-August
   2000 and June-August 2001. The principal insect groups collected from
   sundew leaves were biting and predaceous midges (Diptera:
   Ceratopogonidae) and non-biting midges (Chironomidae), in nearly equal
   proportions. More than 1,600 individuals of each of these primitive
   flies were collected each year, with each family representing 30-35\% of
   total identifiable prey. Fifteen species of ceratopogonids were
   identified in seven genera, with the majority (75.7\%) being either
   Atrichopogon websteri (Coquillett) or Dasyhelea spp. The overall sex
   ratio of ceratopogonids was 15:1, females to males.},
