EISSN = {1365-2745},
Keywords = {Asclepias lanceolata; biodiversity; community structure; Everglades;
   plant-insect interactions; pollination; pollinator; reproductive
   success; species richness; tree islands},
Keywords-Plus = {FOREST FRAGMENTS; FLOWER-VISITORS; LANDSCAPE-SCALE; FORAGING RANGE;
