Number = {3},
Pages = {441-444},
Month = {JUL-SEP},
Abstract = {On the first tachinid fly (Diptera, Tachinidae) carrying Asclepiadoideae
   pollinaria in the Neotropical Region. This paper reports the first
   Neotropical Tachinidae species possibly associated to pollination of
   Asclepiadoideae: a female of Euacaulona sumichrasti Townsend, 1908
   (Diptera, Tachinidae, Phasiinae, Trichopodini) carrying pollinaria of
   Gonolobus parviflorus Decne., 1844 (Apocynaceae, Asclepiadoideae,
   Asclepiadeae: Gonolobinae) attached to its proboscis. The fly specimen
   was collected in Paraguay, Departamento Canindeyu. The pollinarium is
   illustrated and described herein. This represents the first anthophilous
   record to G. parviflorus and to the genus.},
