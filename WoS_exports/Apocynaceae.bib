   Univ Colorado, Dept Biol, Denver, CO 80217 USA.},
DOI = {10.2307/2446641},
ISSN = {0002-9122},
Keywords = {allozymes; Apocynaceae; Apocynum; hybridization; pollination; population
   genetics},
Keywords-Plus = {STARCH-GEL ELECTROPHORESIS; ASCLEPIADACEAE; POPULATIONS; EVOLUTION;
   BUFFERS},
