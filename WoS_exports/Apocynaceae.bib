Title = {The potential of plant biomechanics in functional biology and
   systematics},
Booktitle = {DEEP MORPHOLOGY: TOWARD A RENAISSANCE OF MORPHOLOGY IN PLANT SYSTEMATICS},
Series = {Regnum Vegetabile},
