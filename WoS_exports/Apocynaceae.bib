@article{ WOS:000280458500008,
Author = {Jonkers, H. A.},
Title = {<i>Desmidorchis impostor</i> spec. nov (Apocynaceae; Asclepiadoideae;
   Ceropegieae), a not-so-new, new stapeliad from northern Oman},
Journal = {BRADLEYA},
Year = {2010},
Volume = {28},
Pages = {67-78},
Abstract = {Desmidorchis impostor (Apocynaceae; Asclepiadoideae; Ceropegieae) is
   described as a new species, thirty-five years after it was first
   collected. It is endemic to Jabal Akhdar, the central and highest part
   of the Hajar mountain range of northern Oman. The new species is
   distinguished from the widespread D. arabica by having a compact
   sphaerical pseudo-umbel of smaller, campanulate, and always eciliate
   flowers. Both species have different flowering phenologies and their
   principal pollinators belong to separate fly families. D. impostor is
   one of the few known examples of microsapromyophily in stapeliads.},
