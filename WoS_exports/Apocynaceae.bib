@article{ WOS:000389004900003,
Author = {Bester, Stoffel P. and Nicholas, Ashley},
Title = {<i>Periglossum podoptyches</i> (Apocynaceae-Asclepiadoideae), a new
   species from KwaZulu-Natal province, South Africa},
