   phenology; Pine rocklands},
Keywords-Plus = {TROPICAL FORESTS; PINE ROCKLAND; APOCYNACEAE; SEASON; POLLINATION;
   INTENSITY; FREQUENCY; PHENOLOGY; ABUNDANCE; ECOSYSTEM},
