@article{ WOS:A1978EL61600015,
Author = {WALKER, DB},
Title = {POST-GENITAL CARPEL FUSION IN CATHARANTHUS-ROSEUS (APOCYNACEAE) .4.
   SIGNIFICANCE OF FUSION},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1978},
Volume = {65},
Number = {1},
Pages = {119-121},
Abstract = {The ontogenetic and phylogenetic significances of the postgenital carpel
   fusion in C. roseus were investigated experimentally. When 1 of the 2
   carpel primordia was surgically destroyed prior to carpel fusion, the
   remaining carpel nevertheless differentiated. The tissue development on
   the adaxial (normally fused) carpel face appeared aberrant. Possible
   reasons for this modified ontogeny are discussed. The suggestion that
   syncarpy is phylogenetically significant because any pollen tube can
   potentially reach any ovule was verified in C. roseus by monitoring
   pollen tube growth following spatially controlled pollinations. The
   suture formed by the postgenital fusion was no barrier to pollen tube
   growth, and the pollen tubes rapidly became distributed throughout the
   stigmatic tissue.},
