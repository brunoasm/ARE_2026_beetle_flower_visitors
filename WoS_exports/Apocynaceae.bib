DOI = {10.1016/j.baae.2007.06.013},
ISSN = {1439-1791},
EISSN = {1618-0089},
Keywords = {Asclepiadoideae; Ditassa; generalization; Jobinia; Orthosia; phenology;
   pollination systems; Scyphostelma; specialization},
