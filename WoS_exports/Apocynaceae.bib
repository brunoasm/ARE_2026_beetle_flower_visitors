@article{ WOS:000435486200003,
Author = {Fontes, Anderson Lopes and Valentin-Silva, Adriano and Demuner, Antonio
   Jacinto and Vieira, Milene Faria},
Title = {Functional Morphology and Floral Odor of <i>Ditassa burchellii</i>
   (Apocynaceae, Asclepiadoideae), a Micromyiophilous Species from
   Southeastern Brazil},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {2018},
Volume = {179},
Number = {6},
Pages = {450-460},
Month = {JUL-AUG},
Abstract = {Premise of research.Studying functional floral morphology in
   Asclepiadoideae requires anatomical and histochemical analyses due to
   the complex synorganization and high diversity of secretory tissues in
   their flowers. Pollinators of the subfamily are poorly known in some
   genera, yet floral volatiles presumably play an important role in their
   attraction. Thus, we addressed the following questions: (1) Are the
   floral morphology and pollination mechanism of Ditassa burchellii
   (Asclepiadoideae, Metastelmatinae) similar to those of other
   Asclepiadoideae species? (2) Due to its minute, odoriferous flowers, are
   the pollinators equally minute and attracted by specific floral
   volatiles? (3) Does most pollinarium removal occur during the flowering
   peak and, consequently, floral volatile emission peak?Methodology.We
   studied flower morphology by light and scanning electron microscopies,
   identified pollinators, determined floral volatile composition by
   headspace analysis, and quantified pollinarium removal before, during,
   and after the flowering peak.Pivotal results.Flowers have a single
   secretory tissue of mucilage and nectar, resulting from fusion between
   the staminal corona secretory tissue and the androecium secretory
   tissue. Small, saprophagous female flies (Pholeomyia sp. 1 and
   Odontosciara sp.) were the main pollinators. We identified 25 compounds
   in the unpleasant odor of the flowers. Most pollinarium removal occurred
   during and after the flowering peak.Conclusions.The flower morphology
   and pollination mechanism of D. burchellii are similar to those of other
   Asclepiadoideae, except for the single secretory tissue of mixed origin
   and mixed secretion, which we describe for the first time. The
   unpleasant odor, probably resulting from the combination of floral
   volatiles, and pollination by small flies altogether characterize
   micromyiophily, so far unreported to the Metastelmatinae. The main
   pollinators of D. burchellii are also reported here for the first time
   to Asclepiadoideae. The occurrence of most pollinarium removal during
   and after a period of high floral display reveals the important role
   floral volatiles play in attracting pollinators and maintaining their
   visits in the species.},
