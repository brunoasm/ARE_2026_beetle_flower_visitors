@article{ WOS:000248474400001,
Author = {Endress, Mary E. and Liede-Schumann, Sigrid and Meve, Ulrich},
Title = {Advances in Apocynaceae: The enlightenment, an introduction},
Journal = {ANNALS OF THE MISSOURI BOTANICAL GARDEN},
Year = {2007},
Volume = {94},
Number = {2},
Pages = {259-267},
Abstract = {This issue of the Annals of the Missouri Botanical Garden is devoted to
   advances in the Apocynaccae s.l. and is based oil the symposium,
   ``Recent progress in the Systematics of Apocynaceac,{''} held at the
   XVII International Botanical Congress in Vienna in 2005. The collection
   of papers presented here spans the phylogenctic and geographic breadth
   of the family and includes at least one study focused oil
   representatives from each of the five subfamilies: Rauvolfioideae,
   Apocynolideae, Periplocoideae, Secamonoideae, and Asclepiadoideae. The
   papers range front higher-level phylogenetic analyses to more narrowly
   defined case studies and include new results ill phylogenetics,
   taxonomy, biogeography, pollination biology, and a pharmacophagous
   plant-butterfly interaction involving pyrrolizidinc alkaloids, as well
   as a new hypothesis for the evolution of pollinia all loss of a compitum
   in some advanced taxa. An updated classification scheme of the
   Apocynaceac is presented, with one additional tribe recognized in
   Rauvolfioideae (the Aspidospermeae) all three in Apocynoideae (the
   Nerieae and odonladenieae its well as the Baisseeae, which are elevated
   in rank here). In Asclepiadoideae, seven subtribes are recognized within
   Asclepiadeae (the Asclepiadinae, Cynanchinae, Tylophorinae,
   Metastelmatinae, Orthosiinae, Oxypetalinae, and Gonolobinae) all four
   within Ceropegieae (the Aniso(ominae, Leptademinae, Heterostemminae ,
   and Stapelinae). Taken together, the papers here present the most
   Up-to-date overview of the family available at this time.},
