@article{ WOS:000294580700014,
Author = {de Moura, Thaysa Nogueira and Webber, Antonio Carlos and Melo Torres,
   Liliane Noemia},
Title = {Floral biology and a pollinator effectiveness test of the diurnal floral
   visitors of <i>Tabernaemontana undulata</i> Vahl. (Apocynaceae) in the
   understory of Amazon Rainforest, Brazil},
Journal = {ACTA BOTANICA BRASILICA},
Year = {2011},
Volume = {25},
Number = {2},
Pages = {380-386},
Month = {APR-JUN},
Abstract = {(Floral biology and a pollinator effectiveness test of the diurnal
   floral visitors of Tabernaemontana undulata Vahl. (Apocynaceae) in the
   understory of Amazon Rainforest, Brazil). In this paper we examined the
   floral biology, per-visit effectiveness, frequency of visits and
   relative abundance of the diurnal floral visitor taxa of T. undulata
   (Apocynaceae) at two populations located in the primary forest and in a
   disturbed area connected to the continuous forest. Its hermaphrodite
   flowers show a long and narrow floral tube and introrse anthers form a
   cone around the apex of the style head where the pollen is deposited.
   The stigmatic head has three functional regions, in a complex
   pollination mechanism favoring cross-pollination. In the pollinator
   censuses conducted in the primary forest population we registered
   Eulaema bombiformis. In the disturbed area Euglossa sp. was responsible
   for visits on T. undulata flowers. Eulaema bombiformis was not absent in
   the disturbed area, but preferred to forage on pollen and nectar-rich
   flowers of two neighboring flowering species. In the primary forest, T.
   undulata was the only flowering treelet at the end of the dry season.
   Significant differences were not observed regarding the frequency of
   visits and relative abundance among the diurnal flower visitors at both
   sites. In the per-visit effectiveness experiment among flower visitors,
   we observed one fruit produced after E. bombiformis' visits. Due to the
   complex breeding system of T. undulata in that it is characterized by
   very low fruit production even under natural conditions, an indirect
   measure of pollinator effectiveness is needed in at a future stage of
   this study in order to clarify the role of these bee species as
   pollinators of T. undulata.},
Publisher = {SOC BOTANICA BRASIL},
Address = {CAIXA POSTAL 3005, SAO PAULO SP, 01061-970, BRAZIL},
Type = {Article},
Language = {English},
Affiliation = {de Moura, TN (Corresponding Author), Univ Fed Amazonas, Inst Nat \& Cultura, Campus Alto Solimoes, Benjamin Constant, AM, Brazil.
   de Moura, Thaysa Nogueira, Univ Fed Amazonas, Inst Nat \& Cultura, Benjamin Constant, AM, Brazil.
   Webber, Antonio Carlos, Univ Fed Amazonas, Inst Ciencias Biol, Dept Biol, Manaus, AM, Brazil.
