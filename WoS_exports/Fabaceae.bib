@article{ WOS:000450549000017,
Author = {Udayakumar, A. and Shivalingaswamy, T. M.},
Title = {Nesting Biology, Seasonality and Host Range of Sweat Bee,
   <i>Hoplonomia</i> <i>westwoodi</i> (Gribodo) (Hymenoptera: Halictidae:
   Nomiinae)},
Journal = {SOCIOBIOLOGY},
Year = {2018},
Volume = {65},
Number = {3},
Pages = {491-496},
Month = {SEP},
Abstract = {Nesting biology and seasonal dynamics of Halictid bee, Hoplonomia
   westwoodi (Nomiinae: Halictidae) was studied at ICAR-National Bureau of
   Agricultural Insect Resources (NBAIR) Bengaluru, Yelahanka Campus
   (13.096792N, 77.565976E) India from July 2016 to May 2017. The bee built
   subterranean nests on a leveled soil surface with turrets and the main
   shaft running to a depth of 70.1 cm. In total, nineteen cells were
   observed in clusters at different depths. Different life stages of the
   bee were observed in the cells. The life cycle of the bee was completed
   in 41.80 days. The bees were found actively foraging on different flora
   belonging to the different families like Acanthaceae, Asteraceae,
   Convolvulaceae, Fabaceae, Lamiaceae, Malpighiaceae, Polygonaceae,
   Rubiaceae and Solanceae throughout the year with the peak population
   during the months of June to November. Marked preference and behavior of
   buzz pollination was observed on the flowers of Solanaceous crops like
   tomato and eggplant.},
