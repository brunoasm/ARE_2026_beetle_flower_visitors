Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Gustavus Adolphus Coll, Dept Biol, 800 W Coll Ave, St Peter, MN 56082 USA.
   Univ Calif Bodega, Marine Lab, Bodega Bay, CA 94923 USA.},
DOI = {10.2307/2656851},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {breeding system traits; cumulative fitness; inbreeding depression;
   isozymes; Lupinus; mean fitness; mixed mating system; outcrossing rate},
Keywords-Plus = {PLANT MATING SYSTEMS; SELF-FERTILIZATION; INSECT HERBIVORY; GENE FLOW;
   CROSS-FERTILIZATION; LETHAL MUTATIONS; BREEDING SYSTEM; EVOLUTION;
