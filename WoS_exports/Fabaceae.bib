   Elazab, Heba Elazab Mohamed, Ain Shams Univ, Dept Bot, Fac Sci, POB 11566, Cairo, Egypt.},
DOI = {10.1080/01916122.2015.1014524},
ISSN = {0191-6122},
EISSN = {1558-9188},
Keywords = {Acacia asak; dimorphism; harmomegathy; Mimosoideae; pollenkitt; polyad;
   sculpture},
Keywords-Plus = {LEGUMINOSAE},
