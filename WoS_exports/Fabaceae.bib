   Univ Nacl Cordoba, Lab Biol Floral, Inst Multidisciplinario Biol Vegetal, CONICET, Cordoba, Argentina.},
DOI = {10.1111/j.1095-8312.2006.00644.x},
ISSN = {0024-4066},
EISSN = {1095-8312},
Keywords = {fabaceae; long-tongued hawkmoth pollination; pollinator guild;
   pterotribic pollen deposition; Sphingidae},
