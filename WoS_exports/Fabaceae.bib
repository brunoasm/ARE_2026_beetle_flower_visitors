@article{ WOS:000750876100011,
Author = {Santos, T. S. and Martins, K. and Aguiar, V, A. and Baptista Filho, M.
   J. and Menucelli, J. R. and Faria, R. F. P. and Moura, R. D. and
   Machado, J. A. R. and Longui, E. L.},
Title = {Growth and Wood Quality Traits in a <i>Dipteryx alata</i> Vog.
   (Fabaceae) Progeny and Provenance Test},
Journal = {FOREST SCIENCE},
Year = {2021},
Volume = {67},
Number = {4},
Pages = {468-477},
Month = {AUG},
Abstract = {Dipteryx alata Vog. presents an excellent economic potential because of
   its multiple uses. However, it is currently threatened as a result of
   the degradation of the biome in which it occurs, the Brazilian Cerrado.
   Therefore, our goal was to provide subsidies for future breeding and ex
   situ conservation programs of D. alata. We evaluated genetic variation
   in growth, stem form, and wood quality traits in a progeny and
   provenance test planted in a random complete block design. The traits
   were measured in 37-year-old trees. Significant effect for provenance
   was obtained for all evaluated traits except bifurcation, but progeny
   effect was significant only for acoustic wave velocity (AWV). The
   estimates of individual narrow sense heritability were of low magnitude
   for all traits except AWV (0.24 +/- 0.09). Eleven groups were formed
   based on Mahalanobis genetic distance with 83.1\% of progenies allocated
   to one group. Dipteryx alata has genetic variability between progenies
   and provenances that can be explored to obtain genetic gain, especially
   for AWV. We also recommend the use of multi-trait selection index to
   obtain gains for both growth and wood quality traits. Controlled
   pollination between individuals from different progeny groups would
   increase variability in next generation breeding.
   Study Implications: Dipteryx alata is a tree species that presents
   multiple uses and is threatened as a result of the devastation of the
   Brazilian Cerrado. We evaluated genetic variation in growth, stem form,
   and wood quality traits in a progeny and provenance test planted 37
   years ago. We found genetic differences among progenies only for the
   wood quality trait, which can be explored to obtain genetic gains. The
   test is better suited for ex situ conservation, and the infusion of
   novel sources of germplasm is necessary for future generations of
   breeding.},
