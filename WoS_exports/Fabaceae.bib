EISSN = {1537-2197},
Keywords = {Bombus; defense-attraction; Fabaecae; floral reward; Lupinus; optimal
   defense theory; pollen chemistry; pollen foraging; pollination},
Keywords-Plus = {ALKALOID PROFILES; QUINOLIZIDINE ALKALOIDS; ARGENTEUS FABACEAE; FLORAL
