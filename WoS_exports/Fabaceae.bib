Keywords-Plus = {FLORAL NECTAR; REPRODUCTIVE-BIOLOGY; CHEMICAL-COMPOSITION; FLOWER
   STRUCTURE; PREFERENCES; BIRDS; POLLINATORS; SOLANACEAE; FABACEAE; FRUITS},
