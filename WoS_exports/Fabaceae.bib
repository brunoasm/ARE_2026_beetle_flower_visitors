@article{ WOS:000445858400001,
Author = {Siqueira, Estefane and Oliveira, Reisla and Doetterl, Stefan and
   Cordeiro, Guaraci Duran and Alves-dos-Santos, Isabel and Mota, Theo and
   Schlindwein, Clemens},
Title = {Pollination of <i>Machaerium opacum</i> (Fabaceae) by nocturnal and
