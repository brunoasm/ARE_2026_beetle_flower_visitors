   Kobayashi, S., Univ Ryukyus, Fac Sci, Nishihara, Okinawa, Japan.
   Kobayashi, S., Univ Ryukyus, Fac Sci, 1 Senbaru, Nishihara, Okinawa 9030213, Japan.},
DOI = {10.1111/plb.13557},
EarlyAccessDate = {JUL 2023},
ISSN = {1435-8603},
