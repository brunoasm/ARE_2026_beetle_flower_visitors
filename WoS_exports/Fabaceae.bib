Type = {Article},
Language = {English},
Affiliation = {Zych, M (Corresponding Author), Univ Warsaw, Bot Garden, Aleje Ujazdowskie 4, PL-00478 Warsaw, Poland.
   Jedrzejewska-Szmek, Krystyna; Zych, Marcin, Univ Warsaw, Bot Garden, PL-00478 Warsaw, Poland.},
