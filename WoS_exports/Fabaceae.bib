@article{ WOS:001321732100001,
Author = {da Silva, Amanda dos Santos Felix and Costa, Jociara Silva and de
   Aguiar, Willian Moura},
Title = {Floral preferences and nesting substrates used by Xylocopa bees (Apidae:
   Xylocopini) in Brazil},
Journal = {JOURNAL OF APICULTURAL RESEARCH},
Year = {2024},
Month = {2024 SEP 18},
Abstract = {The present study reviewed publications indexed to the Scopus platform,
   which evaluated the plants visited by Xylocopa bees and their nesting
   sites in Brazil. The stages of this survey included: searching for
   articles, selecting, analyzing information, and elaborating on results.
   It was observed that despite the wealth of bees of the genus in the
   country, the dominant species in studies are X. frontalis and X.
   grisescens. Our results indicate a preference of bees of the genus
   Xylocopa for native plants, such as the Fabaceae family (21.05\%),
   especially the genera Chamaecrista and Senna. Important crops have also
   been identified among the plants visited by carpenter bees (e.g.,
   Passiflora edulis f. flavicarpa, Phaseolus vulgaris, and Solanum
   lycopersicum). Most studies related to the group's nesting used trap
   nests made from bamboo internodes, even though native species have also
   been identified, such as Commiphora leptophloeos and Pera glabrata.
   Furthermore, there was a lack of overlap in the materials used to build
   the nests between the studies. The diversity of species used as a source
   of floral resources and nesting substrates demonstrates the needs of
   these bees in areas with great plant diversity. It was found that there
   are data gaps for certain regions of the country, mainly in the Pampa
   biome. The information collected here highlights the ecological and
   economic roles of Xylocopa bees in Brazil and summarizes key information
   to be considered in the adequate management of these bees' habitats to
   ensure the continuity of the pollination services provided by them.},
