@article{ WOS:A1979GM28600010,
Author = {ZOHARY, D and PLITMANN, U},
Title = {CHROMOSOME POLYMORPHISM, HYBRIDIZATION AND COLONIZATION IN THE
   VICIA-SATIVA GROUP (FABACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1979},
Volume = {131},
Number = {1-2},
Pages = {143-156},
Abstract = {V. sativa L. s.l. is presented as a variable complex consisting of 7
   subspecies {[}V. sativa ssp. sativa, V. sativa ssp. macrocarpa, V.
   sativa ssp. nigra var. nigra, V. sativa ssp. nigra var. segetalis, V.
   sativa ssp. cordata, V. sativa ssp. incisa, V. sativa ssp. amphicarpa
   and V. sativa ssp. pilosa], including wild types, weedy races and
   cultivated derivatives. The group is characterized by: decreasing
   aneuploid (dysploid) chromosome series (2n = 14, 12, 10); wide variation
   in karyotypes; pronounced weediness and colonization of disturbed
   habitats; cohabitation of several forms; intergradations between the
   main morphological types; predominance of self-pollination; lack of full
   sterility between the main chromosome types. Plants with different
   chromosome numbers or different karyotypes are loosely interconnected by
   occasional hybridization, particularly in disturbed habitats.
   Colonization apparently is associated with reticulate evolution and the
   recombination of previously separated gene pools. The wide karyotypic
   polymorphism characteristic for this complex is interpreted as a result
   of such relatively recent processes.},
