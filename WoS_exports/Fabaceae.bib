DOI = {10.1086/314211},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {contort aestivation; enantiomorphy; flower development; flower
   evolution; flower symmetry; Lamiales},
Keywords-Plus = {LEFT-RIGHT ASYMMETRY; FLORAL DEVELOPMENT; ANTIRRHINUM-MAJUS;
