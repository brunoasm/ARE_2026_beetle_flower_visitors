@article{ WOS:000239634900012,
Author = {Agostini, Kayna and Sazima, Marlies and Sazima, Ivan},
Title = {Bird pollination of explosive flowers while foraging for nectar and
   caterpillars},
Journal = {BIOTROPICA},
Year = {2006},
Volume = {38},
Number = {5},
Pages = {674-678},
Month = {SEP},
Abstract = {Mucuna (Fabaceae) has explosive flowers that open only if a pressure is
   applied on their wings and keel. The cacique Cacicus haemorrhous inserts
   its bill into a flower and spreading its mandibles apart it opens the
   flower to take nectar. This icterine bird also preys upon caterpillars
   of the butterfly Astraptes talus that pupates within the flowers.
   Foraging with use of bill movements to take nectar or insects within a
   flower is an adequate mechanism to open and pollinate explosive flowers.
   We suggest that a plausible behavioral scenario for the pollination
   relationship between icterines and Mucuna-like flowers might start with
   the birds' searching for insects within flowers.},
