@article{ WOS:000331608000215,
Author = {Yuan, C. Q. and Li, Y. F. and Wang, L. and Zhao, K. Q. and Hu, R. Y. and
   Sun, P. and Sun, Y. H. and Li, Y. and Gu, W. X. and Zhou, Z. Y.},
Title = {Evidence for inbreeding depression in the tree <i>Robinia
   pseudoacacia</i> L. (Fabaceae)},
Journal = {GENETICS AND MOLECULAR RESEARCH},
Year = {2013},
Volume = {12},
Number = {4},
Pages = {6249-6256},
Abstract = {The magnitude of inbreeding depression within populations is important
   for the evolution and maintenance of mixed mating systems. However, data
   are sparse on the magnitude of inbreeding depression in Robinia
   pseudoacacia. In this study, we compared differences in the mature seed
   set per fruit, seed mass, germination success, and seedling growth
   between self- and cross-pollination treatments and estimated the
   inbreeding depression at 3 stages: seed maturation, seedling emergence,
   and seedling growth at 10 and 20 weeks. We found that progenies
   resulting from cross-pollination treatments showed significantly higher
   fitness than progenies resulting from self-pollination, causing high
   levels of inbreeding depression. Inbreeding depression was not uniformly
   manifested, however, over the 3 stages. Inbreeding depression was the
   greatest between fertilization and seed maturation stage (delta =
   0.5419), and the seedling emergence (0.3654) stage was second. No
   significant differences in seedling growth were observed between selfed
   and crossed progenies. The cumulative inbreeding depression (delta)
   across all 3 stages averaged 0.7452. Inbreeding depression may promote
   outcrossing in R. pseudoacacia by acting as a post-pollination barrier
   to selfing. The large difference in the seed set between self- and
   cross-pollination that we detected indicated that inbreeding depression
   would probably be a reasonable explanation for the high abortion and low
   seed set in R. pseudoacacia.},
Publisher = {FUNPEC-EDITORA},
Address = {RUA FLORIANO PEIXOTO 2444, ALTO DA BOA VISTA, RIBEIRAO PRETO, SP 00000,
   BRAZIL},
Type = {Article},
Language = {English},
Affiliation = {Li, Y (Corresponding Author), Beijing Forestry Univ, Coll Biol Sci \& Biotechnol, Natl Engn Lab Tree Breeding, Minist Educ,Key Lab Genet \& Breeding Forest Trees, Beijing, Peoples R China.
   Yuan, C. Q.; Li, Y. F.; Zhao, K. Q.; Hu, R. Y.; Sun, P.; Sun, Y. H.; Li, Y., Beijing Forestry Univ, Coll Biol Sci \& Biotechnol, Natl Engn Lab Tree Breeding, Minist Educ,Key Lab Genet \& Breeding Forest Trees, Beijing, Peoples R China.
