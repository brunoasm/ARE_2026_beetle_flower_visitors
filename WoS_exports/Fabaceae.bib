   Piechowski, D., Univ Ulm, Inst Systemat Bot \& Ecol, D-89081 Ulm, Germany.
   Doetterl, S., Univ Bayreuth, Dept Plant Systemat, Bayreuth, Germany.
   Gottsberger, G., Univ Ulm, Bot Garden \& Herbarium, D-89081 Ulm, Germany.},
DOI = {10.1111/j.1438-8677.2009.00215.x},
ISSN = {1435-8603},
