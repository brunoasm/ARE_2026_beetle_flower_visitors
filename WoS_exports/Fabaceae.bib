@inproceedings{ WOS:000086908600008,
Author = {Gepts, P and Papa, R and González, A and Acosta, J and Salinas, AD},
Editor = {VanRaamsdonk, LWD and DenNijs, JCM},
Title = {Human effects on <i>Phaseolus vulgaris</i> adaptation during and after
   domestication},
Booktitle = {PLANT EVOLUTION IN MAN-MADE HABITATS},
Year = {1999},
Pages = {161-181},
Note = {7th International Symposium of the
   International-Organization-of-Plant-Biosystematists, AMSTERDAM,
   NETHERLANDS, AUG 10-15, 1998},
Organization = {Int Org Plant Biosyst},
Abstract = {The intraspecific genealogy and geographical origins of Phaseolus
   vulgaris L. are well understood. We use this knowledge to discuss the
   changes in adaptation brought about in this species during and after
   domestication. In a first stage, we describe the environment in which
   wild beans grow in Latin America. A common feature of all environments
   is the existence of a well-defined dry season, which coincides with
   maturity. Compared to their wild progenitors, some domesticated beans
   differ by at least three traits, photoperiod neutrality, heat tolerance,
   and tolerance to soil abiotic stresses. Andean cultivars display reduced
   levels of photosynthesis compared to the Mesoamerican gene pool. This
   reduction has been suggested as a possible cause for the lower yield
   potential of Andean cultivars. It is not clear, however, whether this
   reduction occurred prior to domestication or during domestication.
   Andean and Mesoamerican wild beans have apparently co-evolved with
   several their pathogens, such that Mesoamerican beans are more
   susceptible to Mesoamerican strains of the pathogen and vice-versa in
   the Andean gene pool. Molecular-marker based analyses of gene flow
   suggest that the overall distribution of genetic diversity has not been
   modified substantially by gene flow between wild and domesticated beans.
   Locally, however, gene flow may be more important depending on specific
   variables such as the presence of pollinators.},
Publisher = {UNIV AMSTERDAM, HUDGO DE VRIES LABORATORY},
Address = {POB 94062, NL-1090 GD AMSTERDAM, NETHERLANDS},
