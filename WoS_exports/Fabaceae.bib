   Sazima, I., Univ Estadual Campinas, Inst Biol, Museu Zool, BR-13083970 Campinas, SP, Brazil.},
DOI = {10.1007/s00606-009-0193-5},
ISSN = {0378-2697},
EISSN = {2199-6881},
Keywords = {Schizolobium parahyba; Floral features; Centris bees; Visiting
   behaviour; Stigmaphyllon ciliatum; Stigmaphyllon arenicola; Functional
   convergence},
