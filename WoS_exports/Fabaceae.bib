Language = {English},
Affiliation = {Koptur, S (Corresponding Author), Florida Int Univ, Dept Biol Sci, 11200 SW 8th St, Miami, FL 33199 USA.
   Koptur, S (Corresponding Author), Florida Int Univ, Int Ctr Trop Bot, 11200 SW 8th St, Miami, FL 33199 USA.
   Koptur, Suzanne; Khorsand, Roxaneh, Florida Int Univ, Dept Biol Sci, 11200 SW 8th St, Miami, FL 33199 USA.
   Koptur, Suzanne; Khorsand, Roxaneh, Florida Int Univ, Int Ctr Trop Bot, 11200 SW 8th St, Miami, FL 33199 USA.
   Khorsand, Roxaneh, Univ Northern Colorado, Sch Biol Sci, 501 20th St Campus Box 92, Greeley, CO 80639 USA.},
