@article{ WOS:A1988R827500014,
Author = {TEPPNER, H},
Title = {LATHYRUS-GRANDIFLORUS (FABACEAE-VICIEAE) - FLOWER STRUCTURE, FUNCTION
   AND XYLOCOPA-VIOLACEA},
Journal = {PHYTON-ANNALES REI BOTANICAE},
Year = {1988},
Volume = {28},
Number = {2},
Pages = {321-336},
Abstract = {The asymmetrical flowers of Lathyrus grandiflorus are Xylocopa blossoms
   with specialized adaptions. The two halves on both sides of the median
   plane of the flower are functionally different. Only on the right side
   the downwards movement of the wing-keel-complex is easily possible.
   Females of Xylocopa violacea are tilting to the right side while sucking
   the nectar. The style is reaching around the body of the bee and
   deposits the pollen which serves the pollination on her backside on the
   front edge of the abdomen and in the constriction. The pollen for
   storage is collected on the hind legs and in the crop. The development
   of this adaption of the flower is understandable from the conditions in
   some other species of Lathyrus sect. Lathyrus.},
