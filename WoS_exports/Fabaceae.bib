Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Xiao, ZS (Corresponding Author), Chinese Acad Sci, Inst Zool, State Key Lab Integrated Management Pest Insects, 1 Beichen West Rd, Beijing 100101, Peoples R China.
   Xiao, Zhishu, Chinese Acad Sci, Inst Zool, State Key Lab Integrated Management Pest Insects, 1 Beichen West Rd, Beijing 100101, Peoples R China.
   Xiao, Zhishu, Univ Chinese Acad Sci, Beijing, Peoples R China.},
