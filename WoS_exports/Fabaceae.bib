   Mannouris, Constantinos; Byers, Diane L., Illinois State Univ, Sch Biol Sci, Normal, IL 61790 USA.},
DOI = {10.1111/j.1095-8312.2012.01983.x},
ISSN = {0024-4066},
Keywords = {conservation genetics; genetic drift load; isolated populations;
   quantitative genetics; small populations},
