DOI = {10.1086/321919},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {Amborellaceae; ANITA grade; Austrobaileyaceae; basal angiosperms;
   Cabombaceae; Ceratophyllaceae; Chloranthaceae; floral biology; floral
   development; floral structure; Illiciaceae; Nymphaeaceae;
   Schisandraceae; Trimeniaceae},
