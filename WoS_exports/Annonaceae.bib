Type = {Article},
Language = {English},
Affiliation = {GOTTSBERGER, G (Corresponding Author), UNIV GIESSEN,INST BOT \& BOT GARTEN 1,SENCKENBERGSTR 17-25,W-6300 GIESSEN,GERMANY.},
