@article{ WOS:A1990DL23600009,
Author = {OKADA, H},
Title = {REPRODUCTIVE-BIOLOGY OF POLYALTHIA-LITTORALIS (ANNONACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1990},
Volume = {170},
Number = {3-4},
Pages = {237-245},
Abstract = {Flowering phenology of some amnonaceous trees and reproductive biology
   of Polyalthia littoralis (Annonaceae) were studied. The trees showed
   various types of flowering phenology within the family. Among them, P.
   littoralis hermaphroditic and protogynous flowers, and exhibited
   continuous flowering throughout the year. Bagged flowers set fruits and
   seeds comparable to the control. The observations of meiotic stages and
   the results of castrated tests indicated no possibility of apomictic 
   reproduction. The abscised anthers attached to torus by the extended
   spiral thickenings, and accomplished self-pollination. Outbreeding
   possibly occurs, but the following self-pollination guarantees seed set.},
