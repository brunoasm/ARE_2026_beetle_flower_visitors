@article{ WOS:001359986000001,
Author = {de Figueiroa, Leonara Evangelista and Beelen, Roger Nicolas and de
   Andrade, Anderson Bruno Anacleto and Diniz Junior, Irinaldo Basilio and
   Silva, Valdemir da Costa and de Araujo, Alice Maria Nascimento and
   Valente, Ellen Carine Neves and Trindade, Roseane Cristina Predes},
Title = {Toxicity of the microencapsulated extract of seeds of <i>Annona
   muricata</i> L. (Annonaceae) on Africanized honey bees},
Journal = {JOURNAL OF APICULTURAL RESEARCH},
Year = {2024},
Month = {2024 NOV 4},
Abstract = {Pesticide toxicity is one of the causes of pollinator decline worldwide.
   Here we evaluate the chronic (for seven days) and acute (for one day)
   toxicity of a microencapsulated formulation (MF) obtained from Annona
   muricata seeds on Apis mellifera in concentrations of 0.157 and 2.49 g.
   When bees were exposed daily to the formulation, a small increase in
   mortality occurred, and a significant difference was observed (p <
   0.001) between t survival curves. During the acute toxicity exposure,
   there was a low mortality in the first days after exposure. Based on the
   results obtained, we assume that the MF has low acute toxicity and
   chronic using LC50 on A. mellifera.},
Publisher = {TAYLOR \& FRANCIS LTD},
Address = {2-4 PARK SQUARE, MILTON PARK, ABINGDON OR14 4RN, OXON, ENGLAND},
Type = {Article; Early Access},
Language = {English},
