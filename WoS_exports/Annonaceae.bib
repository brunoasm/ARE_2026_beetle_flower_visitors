ISSN = {1055-7903},
EISSN = {1095-9513},
Keywords = {Annonaceae; Goniothalamus; Phylogeny; Magnoliid; Correlated character
   evolution; Morphological character evolution},
Keywords-Plus = {BAYESIAN-INFERENCE; LIKELIHOOD; DIVERSIFICATION; DISPERSAL; SEQUENCES;
   SIGNAL; PSEUDUVARIA; PATTERNS; TORTOISE; SYNOPSIS},
