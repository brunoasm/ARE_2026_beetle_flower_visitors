ISSN = {1058-5893},
Keywords = {floral development; gynoecium; Hernandia; Hernandiaceae;
   heterodichogamy; inflorescence modules; Lauraceae; Laurales; nectaries;
   synchronized dichogamy},
Keywords-Plus = {BASAL ANGIOSPERMS; BREEDING SYSTEM; POLLINATION; ANNONACEAE; DICHOGAMY;
