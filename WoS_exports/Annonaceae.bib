Language = {English},
Affiliation = {Blanche, R (Corresponding Author), CSIRO Entomol, Trop Forest Res Ctr, POB 780, Atherton, Qld 4883, Australia.
   CSIRO Entomol, Trop Forest Res Ctr, Atherton, Qld 4883, Australia.
   CSIRO Entomol, Canberra, ACT 2601, Australia.},
