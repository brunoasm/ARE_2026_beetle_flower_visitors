@article{ WOS:A1985ABH2800007,
Author = {ENDRESS, PK},
Title = {STAMEN ABSCISSION AND POLLEN PRESENTATION IN ANNONACEAE},
Journal = {FLORA},
Year = {1985},
Volume = {176},
Number = {1-2},
Pages = {95-98},
Abstract = {In certain Annonaeceae, in the male phase of the protogynous flowers,
   the abscising stamens remain attached to the torus by extended spiral
   thickenings of their vascular bundle. They provide a loosening of the
   compact androceium and allow better pollen presentation. Such isolated
   spiral thickenings were found in members of 3 tribes and both
   subfamilies. They apparently play a major role in the pollination
   biology of the family.},
