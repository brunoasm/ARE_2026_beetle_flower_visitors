@article{ WOS:000257959800017,
Author = {Tsukada, Morio and Tanaka, Daisuke and Higuchi, Hirokazu},
Title = {Thermal requirement for development of <i>Carpophilus marginellus</i>
   (Coleoptera: Nitidulidae), a potential pollinator of cherimoya and
   atemoya trees (Magnoliales: Annonaceae)},
Journal = {APPLIED ENTOMOLOGY AND ZOOLOGY},
Year = {2008},
Volume = {43},
Number = {2},
Pages = {281-285},
Month = {MAY},
Abstract = {Carpophilus marginellus is a candidate pollinator of the subtropical
   orchard trees cherimoya and atemoya. We investigated the developmental
   period and adult size of this species at constant temperatures of 18,
   20, 25, and 30 degrees C as basic information for mass rearing and
   release in greenhouses as a pollinator. The photoperiod was 16-h
   light/8-h dark at all temperatures. The developmental period was shorter
   and the adult size was smaller at higher temperatures. Mortality was
   lowest at 25 degrees C and highest at 30 degrees C. The thermal
   threshold (developmental zero) ranged from 11.9 (female larvae) to 15.6
   degrees C (female pupae) among developmental stages and sexes. The
   thermal constant (total effective temperature) of the period from egg to
   adult emergence was ca. 292 degree-days.},
