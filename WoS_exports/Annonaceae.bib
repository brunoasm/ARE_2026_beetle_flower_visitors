@article{ WOS:000936696000001,
Author = {Leal, Freddy and Paull, Robert E. E.},
Title = {The genus <i>Annona</i>: Botanical characteristics, horticultural
   requirements and uses},
Journal = {CROP SCIENCE},
Year = {2023},
Volume = {63},
Number = {3},
Pages = {1030-1049},
Month = {MAY},
Abstract = {An overview of the genus Annona in the Family Annonaceae is provided in
   this review. The mainly neotropical family of trees and lianas has
   numerous commercial fruits that are eaten fresh, processed, or used as
   popular medicines. The family has 109 recognized genera and from 2,300
   to 2,500 species. The taxonomy, morphology, and cytology of Annona spp.
   are discussed. The genus Annona has the most fruits of commercial
   importance, including the cherimoya (A. cherimola Mill.), soursop (A.
   muricata L.), sugar apple (A. squamosa L.), ilama (A. diversifolia
   Saff.), pond apple (A. glabra L.), biriba (A. mucosa Jacq. formerly
   Rollinia deliciosa Saff.), and hybrids such as the atemoya (A. squamosa
   x A. cherimola).},
