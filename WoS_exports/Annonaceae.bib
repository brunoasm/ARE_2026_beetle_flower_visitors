EISSN = {1347-605X},
Keywords = {beetle pollination; cherimoya; Nitidulidae; flower visitor assemblage;
   diversity},
Keywords-Plus = {SSP GLOBULUS MYRTACEAE; INTRODUCED HONEY-BEES; NITIDULID BEETLES;
   FRUIT-SET; TOMICUS-PINIPERDA; POLLINATION; COLEOPTERA; COL;
   SPECIALIZATION; RHIZOPHAGIDAE},
