@article{ WOS:000519925100001,
Author = {Johnson, David M. and Murray, Nancy A.},
Title = {A revision of <i>Xylopia</i> L. (Annonaceae): the species of Madagascar
   and the Mascarene islands},
Journal = {ADANSONIA},
Year = {2019},
Volume = {42},
Number = {1},
Pages = {1-88},
Abstract = {We recognize 30 species of the pantropical genus Xylopia L. from
   Madagascar and an additional three species from the Mascarene Islands.
   Of the six sections of the genus, three are represented in the region:
   sect. Xylopia, sect. Verdcourtia, and sect. Stenoxylopia. All species
   are endemic, and many are microendemics of conservation concern. The
   greatest species richness occurs in humid forests below 1000 m.
   Taxonomic review supports the hypothesis that the genus dispersed to
   Madagascar from continental Africa five times. Ten new species are
   described: Xylopia anomala D.M.Johnson \& N.A.Murray, sp. nov., X
   australis D.M.Johnson \& N.A.Murray, sp. nov., X carinata D.M.Johnson \&
   N.A.Murray, sp. nov., X. galokothamna D.M.Johnson \& N.A.Murray, sp.
   nov., X lokobensis D.M.Johnson \& N.A.Murray, sp. nov., X longirostra
   D.M.Johnson \& N.A.Murray, sp. nov., X. marejejyana D.M.Johnson \&
   N.A.Murray, sp. nov., X. ravelonarivoi D.M.Johnson \& N.A.Murray, sp.
   nov., X retusa D.M.Johnson \& N.A.Murray, sp. nov., and X sthrophylla
   D.M.Johnson \& N.A.Murray, sp. nov. An identification key, technical
   descriptions, illustrations, and distribution maps are provided.},
