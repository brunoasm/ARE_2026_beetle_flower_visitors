@article{ WOS:000076381900011,
Author = {Momose, K and Nagamitsu, T and Inoue, T},
Title = {Thrips cross-pollination of Popowia pisocarpa (Annonaceae) in a lowland
   dipterocarp forest in Sarawak},
Journal = {BIOTROPICA},
Year = {1998},
Volume = {30},
Number = {3},
Pages = {444-448},
Month = {SEP},
Abstract = {This paper reports thrips (Thysanoptera) cross-pollination in the
   primitive angiosperm, Popowia pisocarpa (Annonaceae), in lowland rain
   forest of Sarawak, Malaysia. Flowers of P. pisocarpa have a tiny
   pollination chamber (3-4 mm in depth) with the entrance almost dosed by
   the disk-shaped stigmatic herds, allowing only small insects to enter.
   Experiments showed that thrips were effective pollinators and flowers of
   P. pisocarpa were self-incompatible. Seed set was limited by pollen.
   Clumped adult trees had higher seed-set than mote distant individuals
   (>5 m from nearest flowering neighbor), indicating limited inter-tree
   movement by thrips.},
