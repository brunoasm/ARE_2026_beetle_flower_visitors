@article{ WOS:A1992JL21600002,
Author = {OLESEN, JM},
Title = {FLOWER MINING BY MOTH LARVAE VS POLLINATION BY BEETLES AND BEES IN THE
   CAULIFLOROUS SAPRANTHUS-PALANGA (ANNONACEAE) IN COSTA-RICA},
Journal = {FLORA},
Year = {1992},
Volume = {187},
Number = {1-2},
Pages = {9-15},
Month = {AUG},
Abstract = {Different species of beetles and bees were observed to visit and
   probably pollinate the tropical dry forest, cauliflorous tree Sapranthus
   palanga (Annonaceae) in Costa Rica. The flower had a carrion or
   dung-like smell. The reward to visiting beetles was a fan structure made
   up of nutritive tissue at the base of each inner petal. Most of the
   flowers, however, aborted due to different kinds of herbivory, e.g., a
   pyralid moth larva mined the fan and sometimes the stamen and ovary disc
   too. This activity was a major cause of flower abortion.},
