@article{ WOS:A1985AVC0200013,
Author = {NICHOLLS, MS},
Title = {THE EVOLUTIONARY BREAKDOWN OF DISTYLY IN LINUM-TENUIFOLIUM (LINACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1985},
Volume = {150},
Number = {3-4},
Pages = {291-301},
Abstract = {Distyly in Linum tenuifolium L. is associated with a high degree of
   self-incompatibility. Breakdown in this system has occurred without the
   morphological rearrangement expected as the result of cross-over within
   the distyly supergene. Pollen-flow in both distylous and monomorphic
   populations is leptokurtic. A high proportion of intra-flower
   pollination occurs. Pollen production per ovule is reduced in the
   self-compatible race. Mean seed-set is increased. Individuals of the
   self-compatible  race produce less vegetative growth and require a
   shorter time to reach reproductive maturity under cultivation. Increased
   fecundity appears to provide the selective advantage promoting the
   breakdown of self-incompatibility in this species. This is achieved
   through a massive shift of resources toward female reproductive function
   in plants of the monomorphic race. Subsequent colonization by this race
   has led to its increased distribution in C. and S. Europe.},
