@article{ WOS:000332067500009,
Author = {Yang, Mei-Lin and Yin, Lin-Ke and Yan, Cheng and Zhang, Ming-Li and
   Kong, Fan-Kui and Li, Shu-Juan},
Title = {THE CHARACTERISTICS VARIATION OF THE FLOWERS OF <i>CAPPARIS SPINOSA</i>
   L. DURING THE EXTENDED FLOWERING PROCESS AND THE INFLUENCE OF THE RATE
   OF SEED-SETTING},
Journal = {PAKISTAN JOURNAL OF BOTANY},
Year = {2014},
Volume = {46},
Number = {1},
Pages = {95-100},
Month = {FEB},
Abstract = {The reproductive characteristics of Capparis spinosa (Capparaceae) were
   examined at the Turpan Eremophytes Botanical Garden in Xinjiang, China.
   The flowering period was approximately five months long (from May to
   mid-October of 2011), during which time, two main and overlap flowering
   peaks emerged. Several significant differences between the two peaks
   were found: the number of flowers and duration of the flowering period
   for male flowers were identical in both peaks, but differed for perfect
   flowers(contain stamens and pistil); the filaments of both long and
   short stamens in male and perfect flowers in the first peak were longer
   than those in the second, whereas anther length showed the opposite
   trend; the frequency of fruit set and size in the first peak was
   respectively higher and larger than the second; and the seeds produced
   in the first peak were smaller and lighter than the second. These
   results provide that the continuously blooming C. spinosa and the
   variation in the proportion of male and perfect flowers have played a
   positive role in ensuring a continuous supply of pollen and controlling
   the investment of fruit.},
