@article{ WOS:A1987K931700005,
Author = {DAFNI, A and EISIKOWITCH, D and IVRI, Y},
Title = {NECTAR FLOW AND POLLINATORS EFFICIENCY IN 2 COOCCURRING SPECIES OF
   CAPPARIS (CAPPARACEAE) IN ISRAEL},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1987},
Volume = {157},
Number = {3-4},
Pages = {181-186},
Abstract = {Two closely related species of Capparis, C. ovata and C. spinosa, which
   are exposed to the same pollination environment were studied. The nectar
   volume and concentration of C. ovata are higher than in C. spinosa. Both
   species have similar pollination efficiency, but the relative
   contribution of each pollinator is different. C. ovata is pollinated
   mainly hy hawkmoths while the principal pollinators in C. spinosa are
   bees.},
