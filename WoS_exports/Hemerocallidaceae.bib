Address = {PO BOX 299, ST LOUIS, MO 63166-0299 USA},
Type = {Article},
Language = {English},
Affiliation = {Nitta, K (Corresponding Author), Kyushu Univ, Fac Sci, Dept Biol, Higashi Ku, 6-10-1 Hakozaki, Fukuoka 8128581, Japan.
   Nitta, Kozue; Yasumoto, Akiko A.; Yahara, Tetsukazu, Kyushu Univ, Fac Sci, Dept Biol, Higashi Ku, Fukuoka 8128581, Japan.},
DOI = {10.3732/ajb.0900001},
ISSN = {0002-9122},
Keywords = {circadian rhythms; daylily; flower opening time; flower closing time;
   Hemerocallis; F2 hybrids; Hemerocallidaceae; reproductive isolation;
