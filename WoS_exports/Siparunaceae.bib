ResearcherID-Numbers = {Renner, Susanne/J-8895-2014
   Garcez Lohmann, Lucia/C-9492-2013},
ORCID-Numbers = {Garcez Lohmann, Lucia/0000-0003-4960-0587},
Number-of-Cited-References = {61},
