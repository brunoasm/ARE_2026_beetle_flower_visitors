   Kosisky, Susan E.; Marks, Mariko S.; Nelson, Michael R., Walter Reed Army Med Ctr, Dept Allergy \& Immunol, Washington, DC 20307 USA.},
DOI = {10.1016/j.anai.2010.01.005},
ISSN = {1081-1206},
Keywords-Plus = {AMBROSIA-ARTEMISIIFOLIA L.; AIRBORNE POLLEN; ALLERGIC RHINITIS;
   NEW-JERSEY; CALIFORNIA; COUNTS; CITY; EPIDEMIOLOGY; ASTHMA; FUNGI},
