   Gandolfo, Maria A.; Crepet, William L.; Nixon, Kevin C., Cornell Univ, LH Bailey Hortorium, Sch Integrat Plant Sci, Plant Biol Sect, Ithaca, NY USA.},
DOI = {10.1139/cjb-2016-0061},
ISSN = {1916-2790},
EISSN = {1916-2804},
Keywords = {Cupressaceae; Athrotaxoideae; Athrotaxites; Cretaceous; Raritan
