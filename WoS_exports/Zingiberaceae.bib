Volume = {74},
Number = {2},
Pages = {153-157},
Month = {JUN},
Abstract = {Chromosme numbers in 22 germplasm collections and 28 open-pollinated
   seedling progenies of turmeric (Curcuma longa L.) were determined by
   counting the chromosomes of somatic metaphase plates. Among the
   germplasm collections analyzed 20 have 2n=63, the accepted chromosome
   number of turmeric, 1 collection was 2n=61 and another 1 was 2n=84. The
   seedling progenies showed various chromosome numbers ranging from 2n=63
   to 2n=86, of which 2n=84 was the most frequent. The role of
   abnormalities during triploid chromosomes segregation in generating
   chromosome number variation among open pollinated seedling progenies is
   discussed.},
