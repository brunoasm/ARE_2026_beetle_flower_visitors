   Smithsonian Inst, Natl Museum Amer Hist, Dept Systemat Biol Bot, Washington, DC 20560 USA.},
DOI = {10.1007/s006060200031},
ISSN = {0378-2697},
Keywords = {Alpinia kwangsiensis; anaflexistyly; cataflexistyly; flexistyly;
   pollination; stigma behaviour; tropics; Zingiberaceae},
Keywords-Plus = {INBREEDING DEPRESSION; SELF-FERTILIZATION; PLANTS; EVOLUTION;
