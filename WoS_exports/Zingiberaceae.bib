@article{ WOS:A1981MD82400010,
Author = {SCHEMSKE, DW},
Title = {FLORAL CONVERGENCE AND POLLINATOR SHARING IN 2 BEE-POLLINATED TROPICAL
   HERBS},
Journal = {ECOLOGY},
Year = {1981},
Volume = {62},
Number = {4},
Pages = {946-954},
Abstract = {The hypothesis that the understory herbs Costus allenii and C. laevis
   (Zingiberaceae) have converged in floral characteristics to use the same
   pollinator was investigated in central Panama. These species occupy the
   same habitats, flower synchronously, are identical in flower color,
   morphology and nectar secretion patterns, share the same pollinator (the
   bee Euglossa imperialis), are self-compatible, but not autogamous, and
   have strong barriers to hybridization. Both grow in low density along
   streamsides and produce a single flower per day for an extended period
   (up to 4 mo.). Flower density is depressed through extensive predation
   by the weevil Cholus cinctus, which damaged 31\% of all C. allenii and
   60\% of all C. laevis inflorescences. Direct observation of foraging
   bees indicated that individuals regularly visit both plant species. An
   experimental analysis of interspecific pollen transfer using powdered
   paint as a marker verified these results; 97\% of the flowers checked
   had received heterospecific visits. The high probability of
   interspecific pollination did not affect fruiting success. Apparently,
   low flower density, exaggerated by extreme floral predation, may have
   selected for floral similarity and pollinator sharing in these species.
   Floral convergence increases effective flower density and nectar
   supplies and probably increases the regularity and rate of pollinator
   visitation.},
