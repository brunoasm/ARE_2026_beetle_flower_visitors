@article{ WOS:A1989DL85000009,
Author = {STONE, GN and WILLMER, PG},
Title = {POLLINATION OF CARDAMOM IN PAPUA-NEW-GUINEA},
Journal = {JOURNAL OF APICULTURAL RESEARCH},
Year = {1989},
Volume = {28},
Number = {4},
Pages = {228-237},
Abstract = {This study assessed the role of two local wild bee populations (Apis
   mellifera mellifera L., Apidae, and the solitary Amegilla sapiens
   {[}Cockerell], Anthophoridae) in the pollination of cardamom (Elettaria
   cardamomum (L.) Maton, Zingiberaceae) at two sites in highland Papua New
   Guinea in September and October 1987. Study of the foraging behaviour of
   both species indicated that although less abundant than A. m. mellifera,
   A. sapiens was far more important as a pollineator than its  relatively
   low numbers would suggest. Measurement of flight activity over the day
   of both species revealed that application of pesticides to cardamom
   crops should be carried out as late as possible in the day to minimise
   damage to pollinator populations.},
