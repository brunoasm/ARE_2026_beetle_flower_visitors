@article{ WOS:000225811400017,
Author = {Deng, XB and Ren, PY and Gao, JY and Li, QJ},
Title = {The striped squirrel (<i>Tamiops swinhoei hainanus</i>) as a nectar
   robber of ginger (<i>Alpinia kwangsiensis</i>)},
