   Ley, Alexandra C., Univ Halle Wittenberg, Inst Biol, DE-06108 Halle, Saale, Germany.
   Harris, David J., Royal Bot Garden Edinburgh, Edinburgh EH3 5LR, Midlothian, Scotland.},
DOI = {10.5091/plecevo.2014.824},
ISSN = {2032-3913},
EISSN = {2032-3921},
Keywords = {Aframomum; Africa; character mapping; floral types; mechanical
   isolation; phylogeny; pollination; tropical understorey; Zingiberaceae},
Keywords-Plus = {COLOR PATTERNS; EVOLUTION; COEVOLUTION; RADIATION; SYSTEMS; PLANTS},
