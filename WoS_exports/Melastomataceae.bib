DOI = {10.1007/s12228-014-9337-1},
ISSN = {0007-196X},
EISSN = {1938-436X},
Keywords = {Floral evolution; floral generalist; Diptera; Lepidoptera; Miconia;
   Melastomataceae; Syrphidae; Tachinidae},
