@article{ WOS:A1996WV57900002,
Author = {Saraiva, LC and Cesar, O and Monteiro, R},
Title = {Breeding systems of shrubs and trees of a Brazilian savanna},
Journal = {ARQUIVOS DE BIOLOGIA E TECNOLOGIA},
Year = {1996},
Volume = {39},
Number = {4},
Pages = {751-763},
Abstract = {The reproductive biology of shrubs and trees of a preserved savanna
   (''cerrado'') area in the municipality of Corumbatai Sao Paulo State,
   Brazil was studied. The floral sexuality of 135 species were
   characterized, with 85.2 \% hermaphroditic, 9.4 \% dioecious, 4.5 \%
   monoecious, and one determine the breeding systems. Nine apomictic
   species were found, all belonging Melastomataceae. Among the twelve
   sexual reproducing species, seven (58.3 \%) proved to be
   self-compatible, and five (41.7 \%) self-incompatible. Anemophily was
   found in five species, although pollinations systems were not
   investigated in other species.},
