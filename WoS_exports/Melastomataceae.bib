@article{ WOS:000534079900002,
Author = {Michelangeli, Fabian A. and Santamaria-Aguilar, Daniel},
Title = {A new species of <i>Blakea</i> (Melastomataceae: Blakeeae) with
   pendulous flowers from Costa Rica},
Journal = {PHYTOTAXA},
Year = {2020},
