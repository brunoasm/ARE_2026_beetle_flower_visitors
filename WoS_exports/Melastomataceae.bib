   Hawkins, Susan M.; Robacker, Carol D., Univ Georgia, Dept Hort, Georgia Stn, 1109 Expt St, Griffin, GA 30223 USA.
   Ruter, John M., Univ Georgia, Dept Hort, 327 Hoke Smith Bldg,1225 Lumpkin St, Athens, GA 30602 USA.},
DOI = {10.21273/HORTSCI.51.4.325},
ISSN = {0018-5345},
EISSN = {2327-9834},
Keywords = {Melastomataceae; Dissotis rotundifolia; Dissotis princeps; Dissotis
   canescens; Tibouchina lepidota; Tibouchina fothergillae X pilosa;
