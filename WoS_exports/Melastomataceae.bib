@article{ WOS:000375361600003,
Author = {Hawkins, Susan M. and Ruter, John M. and Robacker, Carol D.},
Title = {Interspecific and Intergeneric Hybridization in <i>Dissotis</i> and
   <i>Tibouchina</i>},
Journal = {HORTSCIENCE},
Year = {2016},
Volume = {51},
Number = {4},
Pages = {325-329},
Month = {APR},
Abstract = {Four species of Dissotis and three species of Tibouchina, two genera of
   the Melastomataceae family, were crossed in an attempt to create
   interspecific and intergeneric hybrids. Intergeneric crosses set seed at
   a rate of 18.1\% and interspecific crosses had a 32.3\% rate of seed
   set. Germination was extremely poor, with only four crosses having
   germinated seed. Crosses produced 31 seedlings. Three of the seedlings
   were from intergeneric crosses between Dissotis canescens and Tibouchina
   lepidota. Interspecific crosses produced 25 seedlings from crosses
   between Dissotis princeps and Dissotis rotundifolia and three seedlings
   from crosses between D. canescens and D. princeps. The prognosis for
   conventional breeding for species in Dissotis and Tibouchina is poor due
   to low seed set, poor germination, and slow growth of progeny.},
Publisher = {AMER SOC HORTICULTURAL SCIENCE},
