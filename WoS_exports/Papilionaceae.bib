Address = {113 S WEST ST, STE 200, ALEXANDRIA, VA 22314-2851 USA},
Type = {Article},
Language = {English},
Affiliation = {Vaz, CG (Corresponding Author), Univ Quebec, Dept Sci Biol, CP 8888,Succ Ctr Ville, Montreal, PQ H3C 3P8, Canada.
   Univ Quebec, Dept Sci Biol, Montreal, PQ H3C 3P8, Canada.
   Fac Ciencias Agr Para, Dept Biol Vegetal \& Fitossanidade, BR-66077530 Belem, Para, Brazil.},
DOI = {10.21273/HORTSCI.33.7.1157},
ISSN = {0018-5345},
Keywords = {autogamy; Brazil; fruit set; Papilionaceae; pollen; pollination; Vigna
   unguiculata},
Research-Areas = {Agriculture},
Web-of-Science-Categories  = {Horticulture},
