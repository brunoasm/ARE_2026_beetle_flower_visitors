@article{ WOS:A1978HG14900005,
Author = {TEWARI, RB and NAIR, PKK},
Title = {WING MORPHOLOGY OF THE FLOWER IN CROTALARIA},
Journal = {PHYTOMORPHOLOGY},
Year = {1978},
Volume = {28},
Number = {3},
Pages = {283-290},
Abstract = {Zygomorphism in the flower of Papilionaceae is considered to be an
   important step in floral evolution in the direction of entomophilly.
   Except for the mention that there are colored stripes which act as honey
   guides, the occurrence of special structures on the wings has rarely
   been reported earlier. The present finding of the cavae in Crotalaria
   provides a new dimension to the knowledge of micromorphology of the
   flower in relation to pollination. The cavae also provide a working
   basis for the artificial delimitation of various species of Crotalaria.
   The present study conveys the need to make elaborate investigations of
   the micromorphology of the floral parts for a deeper and clearer
   understanding of the pollination mechanism, and the sociology of the
   insect and the plant. {[}Species studied were C. albida, C. bialate, C.
   calcina, C. humifusa, C. juncea, C. mysorensis, C. quinquefolia, C.
   tetragona and C. verrucosa.].},
