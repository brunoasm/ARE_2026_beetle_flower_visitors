@article{ WOS:A1978FX85800002,
Author = {TASEI, JN},
Title = {INSECTS POLLINATING LUCERNE (MEDICAGO-SATIVA L) IN FRANCE},
Journal = {APIDOLOGIE},
Year = {1978},
Volume = {9},
Number = {3},
Pages = {175-194},
Abstract = {A 9 yr survey in France on the abundance and activity of Apoidea,
   including honey bees is reported. Data on flight periods, wild bee
   spectrum variations and pollen loads are given. The honey bee (90\% of
   the apoids population) never collects pollen from lucerne flowers.
   Nectar collecting workers visit about 1\% of the flowers. There is no
   relation between honey bee density and seed yield. The highest number of
   wild bees recorded is 2500 females/ha and a 1000 kg/ha seed yield can be
   expected if such a bee visitation occurs. The main native pollinators
   are: Mellitturga clavicornis, Andrena labialis, A. ovatula, A. flavipes,
   Melitta leporina, Halictus marchali, Eucera clypeata, E. longicornis,
   Bombus terrestris and B. agrorum. A microscopic analysis of more than a
   thousand pollen loads demonstrates that Andrena ovatula, A. labialis,
   Melitta leporina, Melitturga clavicornis, Eucera longicornis and E.
   clypeata are attracted by Papilionaceae flowers (Trifolium pratense, T.
   repens, etc.), Halictus marchali and A. flavipes by Compositae and
   Bombus terrestris by various plant families.},
