   Neal, Jodi M., CSIRO, Div Plant Ind, St Lucia, Qld 4067, Australia.
   Neal, Jodi M.; Hardner, Craig M., Univ Queensland, Sch Land Crop \& Food Sci, St Lucia, Qld 4067, Australia.},
DOI = {10.1016/j.biocon.2010.06.029},
