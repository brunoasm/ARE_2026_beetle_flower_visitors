@inproceedings{ WOS:000170315100002,
Author = {Littlejohn, GM},
Editor = {VanHuylenbroeck, J and VanBockstaele, E and Debergh, P},
Title = {The challenges of breeding wild flower cultivars for use in commercial
   floriculture: African Proteaceae},
Booktitle = {PROCEEDINGS OF THE TWENTIETH INTERNATIONAL EUCARPIA SYMPOSIUM, SECTION
   ORNAMENTALS: STRATEGIES FOR NEW ORNAMENTALS},
Series = {Acta Horticulturae},
Year = {2001},
Number = {552},
Pages = {25-37},
Note = {20th International EUCARPIA Symposium - Section Ornamentals, MELLE,
   BELGIUM, JUL 03-06, 2001},
Organization = {EUCARPIA},
Abstract = {The three economically important genera of African Proteaceae provide
   the background to discussing the phases marked by the extent of control
   over the genetic material. Six phases in the domestication process are
   outlined: wild harvesting, basic domestication, clonal selection,
   interspecific hybridization, complete domestication and control of
   single genes. Each of these phases are discussed, briefly outlining the
