@article{ WOS:A1978FK84100001,
Author = {CARPENTER, FL},
Title = {HOOKS FOR MAMMAL POLLINATION},
Journal = {OECOLOGIA},
Year = {1978},
Volume = {35},
Number = {2},
Pages = {123-132},
Abstract = {Two species of Banksia {[}B. ericifolia and B. spinulosa] (family
   Proteaceae) studied in Australia were pollinated by small, non-flying
   mammals rather than by birds, as previously thought. Both species also
   possess several adaptations appropriate for mammal-rather than
   bird-pollination which are odor, troughs that channel excess nectar to
   the ground for attraction, open inflorescence structure for nectar
   accessibility, hooked wiry styles for effective pollen transfer,
   crepuscular and nocturnal nectar and pollen presentation and copious
   nectar. This apparently is the 1st documentation with quantified data of
   pollination by non-flying mammals, although many other probable examples
   exist. {[}Acanthorhynchus tenuirostris, Meliphaga leucotis, M. chrysops,
   M. lewinii, Phylidonyris niger, P. novaehollandiae, Anthochaera
   chrysoptera, A. carunculata, Zosterops lateralis, Antechinus sp.,
   Sminthopsis minima and Rattus fuscipes were also discussed.].},
