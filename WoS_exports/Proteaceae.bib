@article{ WOS:A1981LP01200014,
Author = {HOPPER, SD},
Title = {HONEYEATERS AND THEIR WINTER FOOD PLANTS ON GRANITE ROCKS IN THE CENTRAL
   WHEATBELT OF WESTERN AUSTRALIA},
Journal = {AUSTRALIAN WILDLIFE RESEARCH},
Year = {1981},
Volume = {8},
Number = {1},
Pages = {187-197},
Abstract = {In the winters of 1978 and 1979, 32 granite rocks in the central wheat
   belt were surveyed to document the distribution, abundance and food
   plants of honeyeaters. Eleven honeyeater species were encountered,
   including 5 that were widespread throughout the region, 4 that were
   confined to Boyagin Rock on the southwest boundary of the study area
   adjacent to the high-rainfall forest zone, and 2 that were restricted to
   rocks in the northeast section bordering the arid zone. Brown
   honeyeaters Lichmera indistincta were the most widespread and locally
   common; white-fronted honeyeaters Phylidonyris albifrons and New Holland
   honeyeaters P. novaehollandiae were also locally common. Red wattlebirds
   Anthochaera carunculata and spiny-cheeked honeyeaters A. rufogularis,
   the largest species seen, were very few on the rocks where they
   occurred. A number of the dominant shrubs and mallees in the vegetation
   fringing granite rocks, including species of Calothamnus, Eucalyptus
   (Myrtaceae), Grevillea and Hakea (Proteaceae), constituted the winter
   food plants of, and appeared to be pollinated by, the honeyeaters. The
   possible advantages of bird pollination to these plants are briefly
   considered. {[}Other species found were: Lichenostomus virescens, L.
   leucotis, Anthochaera chrysoptera, Melithreptus lunatus, Acanthorhynchus
   superciliosus, M. brevirostris.].},
