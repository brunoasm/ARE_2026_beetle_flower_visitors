@article{ WOS:A1989CF85700015,
Author = {WHELAN, RJ and GOLDINGAY, RL},
Title = {FACTORS AFFECTING FRUIT-SET IN TELOPEA-SPECIOSISSIMA (PROTEACEAE) - THE
   IMPORTANCE OF POLLEN LIMITATION},
Journal = {JOURNAL OF ECOLOGY},
Year = {1989},
Volume = {77},
Number = {4},
Pages = {1123-1134},
Month = {DEC},
Abstract = {This study examined whether or not receipt of out-cross pollen limited
   reproductive success in the Australian proteaceous shrub Telopea
   speciosissima. Exclusion of pollinators from inflorescences and
   self-pollination by hand (using whole-plant treatments) produced no
   fruit, indicating self-incompatibility. Experimental cross-pollination
   of all flowers on a sample of plants also left exposed to natural
   pollinators resulted in significantly greater fruit- and seed-set than
   in open-pollinated, control plants. Hand-pollinated plants produced
   fruits on 91\% of inflorescences compared to 52\% for control plants.
   Mean numbers of fruits plant-1 were 9.5 for controls and 22.3 for
   hand-pollinated plants, producing a mean of 133 seeds plant-1 for
   control plants and 352 for hand-pollinated plants. Fruit-set was
   extremely low even after hand-pollination (only 2.9\% of flowers
   produced fruits), so although ineffective pollination did limit
   fruit-set it is insufficient to explain the low fruit: flower ratio in
   this species. The number of fruits produced per plant, on unmanipulated
   plants, did not increase significantly with increasing numbers of
   inflorescences. There was a significant positive correlation for
   hand-pollinated plants, suggesting that plants with many inflorescences
   suffered greater pollination-limitation of fruit-set than those with
   few.},
