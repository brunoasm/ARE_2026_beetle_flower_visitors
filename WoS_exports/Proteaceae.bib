ISSN = {1058-5893},
Keywords-Plus = {REPRODUCTIVE SUCCESS; OFFSPRING QUALITY; BANKSIA-SPINULOSA; EMBRYO
   ABORTION; SEED ABORTION; GENETIC LOAD; PLANTS; SELF; POLLINATION;
   DEPRESSION},
