@article{ WOS:A1993MC29800006,
Author = {HEARD, TA},
Title = {POLLINATOR REQUIREMENTS AND FLOWERING PATTERNS OF MACADAMIA-INTEGRIFOLIA},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1993},
Volume = {41},
Number = {4-5},
Pages = {491-497},
Abstract = {A study of insect pollination of macadamia, Macadamia integrifolia
   Maiden \& Betche (Proteaceae) was undertaken in southern Queensland.
   Both initial nut set and final nut set increased with increasing insect
   visitation. Pollination was not limiting yield at this site, however, as
   racemes exposed to 6 h of bee visitation per day had similar final nut
   set to racemes constantly exposed (10 h of bee visitation). Honey bees
   and Trigona spp. bees visited the racemes in approximately equal numbers
   at the site. Approximately 50 bee visits were made per day to the
   racemes exposed for 6 h. Individual flowers remained attractive to
   insects for approximately 3 days. Hence approximately 150 visits per
   raceme are required to ensure adequate pollination. The flowers on a
   raceme opened over a period of approximately 7 days with peak opening at
   around day 2. Flowers opened during the day, peaking in the early
   afternoon.},
