@article{ WOS:000073983800005,
Author = {Smith-Ramirez, C and Armesto, JJ},
Title = {Avian nectarivory and pollination in Embothrium coccineum (Proteaceae)
   in temperate forests of southern Chile},
Journal = {REVISTA CHILENA DE HISTORIA NATURAL},
Year = {1998},
Volume = {71},
Number = {1},
Pages = {51-63},
Month = {MAR},
Abstract = {During the period of peak flowering of the Proteaceous tree Embothrium
   coccineum Forst. in the temperate forests of Chiloe Island, in southern
   Chile (42 degrees 30'S), nine bird species, eight Passerines, one
   Psittaciforme, consume nectar from its flowers. The major nectar-feeding
   bird visiting the flowers of E. coccineum (77\% of all the visits by
   birds in 242 periods of 30 minutes each, in November 1992 and 1993) was
   the Tyrannid Elaenia albiceps, which had been described earlier as
   insectivore and frugivore. The hummingbird, Sephanoides galeritus (12\%
   of the visits), and the Passerines Carduelis barbatus (5.6\%) and
   Phrygilus patagonicus (5\%) followed in importance. The remaining five
   bird species accounted for <1\% of the visits each. E. albiceps
   frequently establishes territories in flowering Embochrium trees,
   actively expelling other visiting birds. The flowers of E. coccineum
   secrete 16 mu l of nectar daily, with an average supply of 6.9 calories.
   Flowers can secrete nectar more than once in a day and have an average
   life span of four days. The energy supply of a flower during its life
   span is comparable to that of some fleshy fruits consumed by birds in
   the same area. We showed that both the hummingbird and E. albiceps carry
   pollen of E. coccineum in their bodies and hence these species are the
   pollinators of this tree. S. galeritus visits a larger number of flowers
   in each flight than E. albiceps. but the latter bird carries three times
   as many pollen grains and is a more specific visitor of the flowers of
   E. coccineum. The relative concentrations of sacarose and hexoses in the
   nectar of E. coccineum flowers are intermediate between the values
   described for the nectar of flowers pollinated primarily or exclusively
   by hummingbirds in the Neotropics (with predominance of sacarose) and
   those of flowers pollinated by other birds or insects (with predominance
   of hexoses).},
Publisher = {SOCIEDAD BIOLGIA CHILE},
Address = {CASILLA 16164, SANTIAGO 9, CHILE},
Type = {Article},
Language = {Spanish},
Affiliation = {Smith-Ramirez, C (Corresponding Author), Univ Chile, Fac Ciencias, Lab Ecol Terr, Casilla 653, Santiago, Chile.
   Univ Chile, Fac Ciencias, Lab Ecol Terr, Santiago, Chile.},
ISSN = {0716-078X},
Keywords = {hummingbirds; Elaenia albiceps; Embothrium coccineum; Embotriinae;
   nectarivory; nectar; bird pollination},
Keywords-Plus = {FLORAL NECTAR; PLANT; HUMMINGBIRDS; HONEYEATERS; PREFERENCES; ABUNDANCE;
   PATTERNS},
