ISSN = {0002-9122},
Keywords = {Alstroemeria aurea; Alstroemeriaceae; bumble bees; male and female
   functions; nectar secretion; plasticity; pollen removal and deposition;
   protandry},
Keywords-Plus = {FLORAL COLOR CHANGES; POLLINATOR VISITATION; INDIVIDUAL VARIATION;
