Keywords = {cattle; exotic species; grazing; herbivory; indirect effects; introduced
   ungulates; mutualism; path analysis; plant population density; plant
   reproduction; pollination; southern Andean temperate forest},
Keywords-Plus = {ECOLOGICAL IMPACTS; POPULATION-DENSITY; POLLEN PERFORMANCE; FLORAL
   CHARACTERS; HERBIVORES; FOREST; CONSEQUENCES; EVOLUTION; SUCCESS; FRUIT},
