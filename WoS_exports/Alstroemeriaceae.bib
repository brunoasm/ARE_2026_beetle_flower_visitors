ISSN = {0934-0882},
EISSN = {1432-2145},
Keywords = {resource allocation; pollination intensity; seed set; gametophytic
   competition},
Keywords-Plus = {POLLINATION INTENSITY; SEED SET; PROGENY PERFORMANCE;
