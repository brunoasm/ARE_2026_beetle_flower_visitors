Year = {1997},
Volume = {7},
Number = {2},
Pages = {210-212},
Month = {SUM},
Abstract = {A new species of Passiflora from the Brazilian Atlantic rainforest in
   the state of Sao Paulo is described and illustrated. Passiflora
   loefgrenii is placed in subgenus Passiflora `'series'' Lobatae. It is
   vegetatively similar to P. amethystina Mikan and P. eichleriana Masters,
   the three species occurring sympatrically. Passiflora loefgrenii differs
   from these species primarily by flower character. At the type locality
   Passiflora loefgrenii is pollinated by hermit hummingbirds and large
   bees.},
