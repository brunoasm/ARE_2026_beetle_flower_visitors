@inproceedings{ WOS:000313131400007,
Author = {Giovannini, A. and Dente, F. and De Benedetti, L. and Nicoletti, F. and
   Braglia, L. and Gavazzi, F. and Mercuri, A.},
Editor = {Orlikowska, T},
Title = {Interspecific Hybridization in Ornamental Passion Flowers},
Booktitle = {XXIV INTERNATIONAL EUCARPIA SYMPOSIUM SECTION ORNAMENTALS: ORNAMENTAL
   BREEDING WORLDWIDE},
