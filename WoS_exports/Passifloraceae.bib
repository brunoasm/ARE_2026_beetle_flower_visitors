Keywords = {Andes; Ensifera ensifera; Hummingbird; Nectar Robbers; Venezuela},
Keywords-Plus = {POLLINATOR BEHAVIOR; AVAILABILITY; HUMMINGBIRDS; REPRODUCTION;
   RESOURCES; EVOLUTION; MUTUALISM; FLOWERS; BIRDS; BEES},
