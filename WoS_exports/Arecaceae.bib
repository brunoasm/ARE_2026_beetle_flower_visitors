ISSN = {1055-7903},
EISSN = {1095-9513},
Keywords = {Androecium; Arecaceae; Arecoideae; Areceae; Phylogeny; Palms; Palmae;
   Ptychospermatinae; Stamen number; AGAMOUS; PRK; Low-copy nuclear DNA},
Keywords-Plus = {ARECOID PALMS ARECACEAE; PLASTID DNA; MICROSATELLITE MARKERS; NUCLEAR;
