@article{ WOS:001020234900001,
Author = {Kuhnhaeuser, Benedikt G. G. and Randi, Agusti and Petoe, Peter and Chai,
   Paul P. K. and Bellot, Sidonie and Baker, William J. J.},
Title = {Hiding in plain sight: The underground palm <i>Pinanga subterranea</i>},
Journal = {PLANTS PEOPLE PLANET},
Year = {2023},
Volume = {5},
Number = {6},
Pages = {815-820},
Month = {NOV},
Abstract = {The production of flowers and fruit below ground (geoflory and geocarpy,
   respectively) is a paradoxical reproductive strategy that seemingly
   hinders pollination and dispersal. Though rare, these phenomena occur in
   33 angiosperm families. Plants that flower and fruit entirely below
   ground are exceptionally unusual. Pinanga subterranea (Arecaceae), a
   species new to science from Borneo, is the first member of the palm
   family recorded to flower and fruit almost exclusively below ground.
   This raises many questions about its evolution, pollination and
   dispersal, which we discuss here. Strikingly, this remarkable species is
   widespread across western Borneo and valued by the local people for its
   edible fruits but has escaped the attention of scientists until now.},
