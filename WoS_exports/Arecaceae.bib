   Univ Aarhus, Inst Biol Sci, Dept Systemat Bot, DK-8240 Risskov, Denmark.
   Univ Gothenburg, Dept Chem Ecol, S-41319 Gothenburg, Sweden.},
DOI = {10.1007/BF00984371},
ISSN = {0378-2697},
Keywords = {Arecaceae, Phytelephantoideae, Aleocharinae, Baridinae, Derelomini,
   Mystrops, Xanthopygus; brood-site pollination; dioecy; evolution; floral
   scents; flower-breeding; pollination; thermogenesis},
