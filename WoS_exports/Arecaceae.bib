Address = {TIERGARTENSTRASSE 17, D-69121 HEIDELBERG, GERMANY},
Type = {Article},
Language = {English},
Affiliation = {Mora, MCP (Corresponding Author), Univ Reg Amazon Ikiam, Napo, Ecuador.
