@article{ WOS:000276570500011,
Author = {Rasco, Jr., Eufemio T.},
Title = {Biology of nipa palm (<i>Nypa fruticans</i> Wurmb., Arecaceae) and its
   potential for alcohol production},
Journal = {ASIA LIFE SCIENCES},
Year = {2010},
Volume = {19},
Number = {2},
Pages = {373-388},
Month = {JUL-DEC},
Abstract = {A survey was done in Vinzons, Camarines Norte, Philippines during April
   and May 2009 to study aspects of the biology of nipa, with emphasis on
   features that are relevant to its potential for alcohol production.
   Based on the count of leaf scars on the underground stem of plants with
   known planting date, it is estimated that nipa produces 1 leaf every 2
   months. Dichotomous branches are formed every 26-50 months depending on
   environmental conditions and sister plants branch synchronously. On the
   sites sampled, the proportion of plants with mature fruits was 25\%.
   According to the informants, it is possible to find plants in the
   reproductive stage any time of the year. However, there is a peak when a
   higher proportion of plants flower this falls in May and June. Most of
   the plants studied are monoecious and protogynous consistent with
   observations made elsewhere. However, 2 inflorescences do not have a
   pistil. This is not known to occur and it seems to be rare in Camarines
   Norte. Based on observation of 3 infructescences, the main stalk has 5
   lateral branches bearing the staminate flowers and ends in a pistillate
   head. The lateral branches starting from the bottom have a decreasing
   number of secondary branches: 5, 4, 3, 2, 1 (unbranched), respectively.
   The male flowers open sequentially from the top (nearest to the
   pistillate head) to the bottom. The bottom and more numerous) male
   flowers open much later than fruit set, indicating a cross-pollinating
   habit. Estimates of sap yield were much lower than the ones reported in
   literature. There is a need to verify these estimates based on actual
   measurements.},
Publisher = {ASIA LIFE SCIENCES},
Address = {C/O DR. WILLIAM SM. GRUEZO, CHAIRMAN, UNIVERSITY OF THE PHILIPPINES,
   D-206 BIOLOGICAL SCIENCES BUIL, LOS BANOS, COLLEGE, LAGUNA, 4031,
   PHILIPPINES},
Type = {Article},
Language = {English},
Affiliation = {Rasco, ET (Corresponding Author), Univ Philippines Mindanao, Dept Biol Sci \& Environm Studies, Coll Sci \& Math, Davao, Philippines.
   Rasco, Eufemio T., Jr., Univ Philippines Mindanao, Dept Biol Sci \& Environm Studies, Coll Sci \& Math, Davao, Philippines.
   Rasco, Eufemio T., Jr., NAST Philippines, Dept Sci \& Technol Complex, Taguig City, Metro Manila, Philippines.},
