DOI = {10.1007/BF00055101},
ISSN = {0960-3115},
Keywords = {ARECACEAE (PALMAE); CHAMAEDOREA; WENDLANDIELLA; POLLINATION BIOLOGY;
   ANEMOPHILY (WIND POLLINATION); INSECT-INDUCED WIND POLLINATION},
