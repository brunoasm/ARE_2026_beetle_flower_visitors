Address = {PO BOX 299, ST LOUIS, MO 63166-0299 USA},
Type = {Article},
Language = {English},
Affiliation = {Barfod, AS (Corresponding Author), Aarhus Univ, Dept Biosci, Ny Munkegade 114, DK-8000 Aarhus C, Denmark.
   Balhara, Manju; Balslev, Henrik; Barfod, Anders S., Aarhus Univ, Dept Biosci, DK-8000 Aarhus C, Denmark.
