@article{ WOS:000243697200004,
Author = {Inkrot, Daniela and Sattler, Dietmar and Geyer, Christian and Morawetz,
   Wilfried},
Title = {Flowering and fruiting phenology of <i>Normanbya normanbyi</i> (W. Hill)
   L. H. !Bailey (Arecaceae), a palm endemic to the lowland tropical
   rainforest of north-eastern Australia},
Journal = {AUSTRAL ECOLOGY},
Year = {2007},
Volume = {32},
Number = {1},
Pages = {21-28},
Month = {FEB},
Abstract = {Normanbya normanbyi (W. Hill) L. H. Bailey (Arecaceae) is a monoecious,
   arborescent palm with a very small distribution area within the Daintree
   rainforest in north-eastern Australia. Our 2-year study was focused on
   the reproductive phenology at the individual and population level. At
   the population level flowering peaked in the dry season, whereas
   fruiting was confined to the wet season. Each palm can bear up to three
   inflorescences/infructescences at the same time. Flowering of each
   inflorescence is separated from each other by a couple of weeks. A
   single inflorescence consists of about 1900 staminate and 800 pistillate
   flowers. The flowering of N. normanbyi is protandrous with a staminate
   phase lasting 40 days and a pistillate phase of approximately 2 weeks.
   Between both phases is a non-flowering phase of about 9 days. Fruit
   ripening takes 21 weeks, with an average of about 280 ripe fruit per
   tree. Comparison of three study plots revealed a moderate synchrony of
   flowering and fruiting initiation in this species of palm. The male
   phase of flowering shows a higher degree of synchrony than the female
   phase at the population level. Seasonal regularity of flowering and
   fruiting peaks appears to be predictable. The general flowering and
   fruiting phenology of N. normanbyi follows a subannual pattern with a
   strong tendency towards a continual pattern.},
Publisher = {BLACKWELL PUBLISHING},
Address = {9600 GARSINGTON RD, OXFORD OX4 2DQ, OXON, ENGLAND},
Type = {Article},
