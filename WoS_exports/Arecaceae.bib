Editor = {Saragih, HT and Ilmi, M and Nopitasari, S and Audinah, L and Widyasari, A and Sari, MA and Masri, M and Palilu, PT and Prabowo, BH and Soleha, S and Solikhah, A and Fitriana, N},
Title = {Pollen Collected by Stingless Bee <i>Tetragonula sapiens</i> Cockerell
   (Apidae: Meliponini) in Organic Farm Land},
Booktitle = {6TH INTERNATIONAL CONFERENCE ON BIOLOGICAL SCIENCE (ICBS 2019) -
   BIODIVERSITY AS A CORNERSTONE FOR EMBRACING FUTURE HUMANITY},
Series = {AIP Conference Proceedings},
Year = {2020},
Volume = {2260},
Note = {6th International Conference on Biological Science (ICBS) - Biodiversity
   as a Cornerstone for Embracing Future Humanity, Univ Gadjah Mada, Fac
   Biol, Yogyakarta, INDONESIA, OCT 10-11, 2019},
Organization = {Univ Tun Hussein Onn Malaysia},
Abstract = {This study aims to determine the types of plants that are preferred and
   used as food sources by stingless bee T. sapiens. Observations were made
   on the population of T. sapiens in the urban fanning area at Yogyakarta.
   Pollen collections carried out by stingless bee aim to sufficient the
   nutritional needs of the population in the nest, especially in the
   cohort of larvae. Pollen collected by T. sapiens from various shapes,
   sizes and types of flowers that are around the nest. Some types of
   pollen collected by T. sapiens include Croton glandulosus Linn.
   (Euphorbiaceae), Polygala paniculata Linn. (Polygalaceae), Ageratum sp.
   (Asteraceae), Solanum lycopersicum Linn. (Solanaceae); Maerua sp.
   (Capparaceae), Mangifera indica Linn. (Anacardiaceae), Oxalis
   barreliaeri Linn. (Oxalidaceae), Cucumis sativus Linn. (Cucurbitaceae);
   Cocos nucifera Linn. (Arecaceae), and there is one type of pollen whose
   type is unknown. The identified pollen data is temporal and can change
   according to the flowering period around the nest location. This
   information can be used to enrich knowledge in choosing the type of feed
   that can be planted to sufficient nutritional needs of T. sapiens
   population.},
