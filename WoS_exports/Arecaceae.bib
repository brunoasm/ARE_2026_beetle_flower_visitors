@article{ WOS:000289577100005,
Author = {Kirejtshuk, Alexander G. and Couturier, Guy},
Title = {Sap beetles of the tribe Mystropini (Coleoptera: Nitidulidae) associated
   with South American palm inflorescences},
Journal = {ANNALES DE LA SOCIETE ENTOMOLOGIQUE DE FRANCE},
Year = {2010},
