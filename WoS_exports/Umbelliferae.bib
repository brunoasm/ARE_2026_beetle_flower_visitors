Author-Email = {n.vislobokov@gmail.com},
Affiliations = {Lomonosov Moscow State University},
Funding-Acknowledgement = {Russian Scientific Fund {[}14-14-00250]},
Funding-Text = {The author is grateful to A. N. Kuznetsov, M. S. Nuraliev and D. D.
   Sokoloff for collected materials and photographs; to collective of
