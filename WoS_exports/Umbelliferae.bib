@article{ WOS:A1977EJ64500015,
Author = {CRUDEN, RW and HERMANNPARKER, SM},
Title = {TEMPORAL DIOECISM - ALTERNATIVE TO DIOECISM},
Journal = {EVOLUTION},
Year = {1977},
Volume = {31},
Number = {4},
Pages = {863-866},
Abstract = {A breeding system, called temporal dioecism, permits little geitonogamy
   regardless of the number of open flowers, even in self-compatible,
   protogynous species. Temporal dioecism is, in essence, a flowering
   sequence which is synchronized so there is little or no overlap between
   staminate and pistillate phases of an individual plant. Umbelliferae
   offer good examples of this system. Because temporal dioecism appears to
   do everything that dioecism does with respect to facilitating
   outcrossing, as well as maintaining fecundity, dioecism may have
   adaptive significance other than, or in addition to, that of enforcing
   outcrossing and/or maximizing pollinator effectiveness. If dioecism and
   temporal dioecism are equivalent in minimizing geitonogamy and
   maximizing outcrossing, there should be no selective advantage in
   shifting from temporal dioecism to dioecism. Yet in New Zealand and
   Australia there are numerous dioecious Umbelliferae as well as species
   that are, undoubtedly, temporally dioecious. If temporal dioecism is the
   primitive umbelliferous breeding system as data indicate, then dioecism
   is a derived condition and, in particular selective regimes, dioecious
   plants must enjoy a selective advantage compared to temporally dioecious
   plants.},
