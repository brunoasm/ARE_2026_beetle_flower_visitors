@article{ WOS:000389306500007,
Author = {Vislobokov, Nikolay A.},
Title = {<i>Aspidistra obtusata</i> sp nov (Asparagaceae) from Vietnam},
Journal = {NORDIC JOURNAL OF BOTANY},
