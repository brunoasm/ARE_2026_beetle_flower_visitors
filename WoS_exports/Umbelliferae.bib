@article{ WOS:A1995RA50200003,
Author = {SAKAI, S and SAKAI, A},
Title = {FLOWER SIZE-DEPENDENT VARIATION IN SEED SIZE - THEORY AND A TEST},
Journal = {AMERICAN NATURALIST},
Year = {1995},
Volume = {145},
Number = {6},
Pages = {918-934},
Month = {JUN},
Abstract = {We developed an optimal-allocation model for the variation in seed size
   among and within plants of the same species and tested the predictions
   using naturally growing plants of Lilium auratum. In the model, we
   considered size-number trade-offs among seeds and assumed that pollen
   capture is an increasing but diminishing function of allocation to
   pollen capture mechanisms. We predicted that seed size is positively
   correlated with allocation to pollen capture. This is because the
   increased cost of pollen capture makes it more advantageous to increase
   seed size to enhance the establishment probability of individual seeds
   than to increase seed number. Field tests were consistent with the
   predictions. First, hand pollination increased seed number per fruit,
   which indicated that pollen capture limited seed production, as is
   assumed in the model analyses. Both ovule size and mean seed weight per
   fruit were positively correlated with corolla dry weight. In addition,
   mean seed weight per fruit was negatively correlated with seed number
   per fruit. This effect, caused by resource competition between seeds
   coupled with pollen limitation, was also an important factor for seed
   size Variation among fruits in this species.},
