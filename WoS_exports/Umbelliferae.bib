@article{ WOS:A1978FK26900008,
Author = {BAUMANN, E},
Title = {FLOWER-VISITING SCUTTLE-FLIES (DIPTERA-PHORIDAE) - CRITICAL-REVIEW OF
   LITERATURE},
Journal = {FLORA},
Year = {1978},
Volume = {167},
Number = {3-4},
Pages = {301-314},
Abstract = {All available data from literature on phorid flies visiting flowers are
   reviewed, stating host plants, synonymy and distribution. From 1805
   (Fabricius) to 1977 (Disney), about 77 phorid fly spp. were recorded
   from 60 plants spp. Most observations came from Europe. As a food,
   source, plants with freely-exposed nectaries are generally preferred,
   especially Umbelliferae. Some necrophagous phorids are attracted by
   carrion-like scent substances, as in Amorphophallus. In the case of the
   neotropical bamusoid grass Pariana, at least 2 Pericyclocera spp. act as
   pollinators, probably even devouring pollen.},
