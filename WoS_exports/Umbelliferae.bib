@article{ WOS:A1978FX77900003,
Author = {BAUMANN, E},
Title = {FLOWER-VISITING PHORINAE (PHORIDAE DIPTERA) ON UMBELLIFERS (APIACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1978},
Volume = {130},
Number = {1-2},
Pages = {43-52},
Abstract = {About 1000 specimens of 28 spp. of Phorinae and their occurrence on 12
   spp. of Umbelliferae are reported. Collections were made in a variety of
   habitats ranging from the German North Sea coast up to altitudes of 2500
   m in the Western Alps. The morphology of the mouth-parts of the flies
   and their behavior on the umbels are discussed briefly. No specific
   adaptations exist between phorid flies and the visited umbels; their
   relationship is mutualistic. Climate and altitude have a greater
   influence on frequency and diversity of these visitors than the
   host-plants themselves. Visitors frequency and diversity increases with
   altitude.},
