Title = {OBSERVATION OF SPACE FILLING IN <i>Celosia cristata</i> FRACTAL},
Journal = {FRACTALS-COMPLEX GEOMETRY PATTERNS AND SCALING IN NATURE AND SOCIETY},
Year = {1994},
Volume = {2},
Number = {1},
Pages = {137-142},
Month = {MAR},
Abstract = {The fasciate flower aggregates (inflorescences) of Celosia cristata
   (Amaranthaceae) exhibit fractal behavior in the range from similar to 2
   to similar to 21 cm and have a surface fractal dimension similar to 3 in
   3-dimensional embedding Euclidean space. The inflorescence of this plant
   thus provides an outstanding example of the space-filling concept that
   originated from Peano in 1890. Such a structure of Celosia cristata may
   be advantageous in wind pollination.},
