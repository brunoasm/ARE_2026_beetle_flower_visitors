@article{ WOS:000444599500001,
Author = {Barrales-Lopez, Angelica and Guevara-Olvera, Lorenzo and Espitia-Rangel,
   Eduardo and Gonzalez-Chavira, Mario M. and Bernardino-Nicanor, Aurea and
   Gonzalez-Cruz, Leopoldo and Huanca-Mamani, Wilson and Acosta-Garcia,
   Gerardo},
Title = {Female gametogenesis and early seed development in <i>Amaranthus
   hypochondriacus</i> L.},
Journal = {BOTANICAL SCIENCES},
Year = {2018},
Volume = {96},
Number = {3},
Pages = {383-394},
Month = {JUL-SEP},
Abstract = {Background. Attention to amaranth grains has increased in recent years
   due to the nutritional value of their seed proteins, which have high
   levels of the amino acid lysine. However, there is no detailed study
   describing the stages of seed development in Amaranthus hypochondriacus.
   Question. How are the developmental patterns of the female gametophyte
   and young seed in Amaranthus hypochondriacus?
   Species studied. Amaranthus hypochondriacus L `Revancha'
   (Amaranthaceae).
   Study site and years of study. Plants were growth and collected from
   2014 to 2016, in a greenhouse at Institute Tecnologico de Celaya,
   Guanajuato, Mexico.
   Methods. Glomerules were collected before pollination and two weeks
   after anthesis. The ovules at different development stages were fixed
   and cleared and were analyzed by light microscopy. A clearing protocol
   was used to observe the developmental stages during female gametogenesis
   and embryogenesis.
   Results. We observed that the Amaranthus hypochondriacus ovule has a
   campylotropous form. The female gametophyte showed a Polygonum-type
   pattern of development. We were also able to identify all the stages
   from the megaspore mother cell to the cotyledon embryo stage. After
   meiosis, the micropylar megaspore differentiates into the functional
   megaspore. The embryo did not show symmetric divisions, although the
   final pattern is similar to that of in eudicotyledons. The suspensor
   showed additional longitudinal divisions, giving rise to a 2-rowed
   suspensor, while the endosperm showed a helobial development.
   Conclusions. These results will be used as baseline to identify
   morphological changes during seed development and to develop new
   strategies to improve seed quality or increase the yield.},
Publisher = {SOC BOTANICA MEXICO},
Address = {APARTADO POSTAL 70-385  DELEGACION COYOACAN, CIUDAD UNIV, MEXICO, D F
   00000, MEXICO},
Type = {Article},
Language = {English},
Affiliation = {Acosta-García, G (Corresponding Author), Inst Tecnol Celaya, Dept Bioquim, Guanajuato, Mexico.
   Barrales-Lopez, Angelica; Guevara-Olvera, Lorenzo; Bernardino-Nicanor, Aurea; Gonzalez-Cruz, Leopoldo; Acosta-Garcia, Gerardo, Inst Tecnol Celaya, Dept Bioquim, Guanajuato, Mexico.
   Espitia-Rangel, Eduardo, Inst Nacl Invest Forestales Agr \& Pecuarias, Campo Expt Valle Mexico, Texcoco, Estado De Mexic, Mexico.
   Gonzalez-Chavira, Mario M., Inst Nacl Invest Forestales Agr \& Pecuarias, Campo Expt Bajio, Guanajuato, Mexico.
