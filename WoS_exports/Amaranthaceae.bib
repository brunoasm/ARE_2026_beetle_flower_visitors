@article{ WOS:000520981900004,
Author = {Butcher, Chelsea L. and Rubin, Berish Y. and Anderson, Sylvia L. and
   Nandula, Vijay K. and Owen, Micheal D. K. and Gardner, Randolph G. and
   Lewis, J. D.},
Title = {Combining rare alleles and grouped pollen donors to assign paternity in
   pollen dispersal studies},
Journal = {APPLICATIONS IN PLANT SCIENCES},
Year = {2020},
Volume = {8},
Number = {3},
Month = {MAR},
Abstract = {Premise Pollen dispersal plays a critical role in gene flow of seed
   plants. Most often, pollen dispersal is measured using paternity
   assignment. However, this approach can be time-consuming because it
   typically entails genotyping all pollen donors, receptors, and offspring
   at several molecular markers.
   Methods We developed a faster, simpler protocol to track paternity,
   using pollen receptors and grouped pollen donors that possess rare
   alleles. We tested this approach using wind-pollinated Amaranthus
   tuberculatus and insect-pollinated Solanum lycopersicum. After screening
   potential markers for rare alleles, we grew both species in experimental
   arrays under field conditions.
   Results All tested A. tuberculatus seeds and 97\% of S. lycopersicum
   fruits could be assigned to the grouped pollen donors using each of two
   markers. From these results, we could infer paternity of untested
   offspring and assess pollen dispersal patterns in each array.
   Discussion By combining rare alleles and grouped pollen donors, we could
   assess pollen dispersal for both species and across all arrays after
   genotyping a small number of pollen donors and a representative subset
   of offspring. While directly applicable to A. tuberculatus and S.
   lycopersicum, this approach could be used in other species to assess
   pollen dispersal under field conditions.},
