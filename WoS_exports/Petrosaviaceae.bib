@article{ WOS:000729646600007,
Author = {Takahashi, Hiroshi and Yukawa, Tomohisa and Maki, Masayuki},
Title = {A New Species,<i> Petrosavia</i><i> amamiensis</i> (Petrosaviaceae),
   from Amami-Oshima Island, Kagoshima Prefecture, Japan},
Journal = {ACTA PHYTOTAXONOMICA ET GEOBOTANICA},
Year = {2021},
Volume = {72},
Number = {3},
Pages = {265-274},
Abstract = {Petrosavia amamiensis (Petrosaviaceae) is described as a new species
   from Amami-Oshima Island, Kagoshima Prefecture, Japan. The plants were
   previously identified as P. sakuraii. The flowers of P. amamiensis are
   autonomously self-pollinated at the beginning of anthesis, while those
   of P. sakuraii are self-pollinating at a later stage of anthesis.
   Petrosavia amamiensis has a shorter aerial stem, shorter internodes,
   more densely flowered inflorescence and smaller seeds than P. sakuraii.
   Moreover plastid and nuclear DNA differ greatly between P. amamiensis
   and P. sakuraii.},
Publisher = {JAPANESE SOC PLANT SYSTEMATICS, UNIV TOKYO, GRADUATE SCH},
