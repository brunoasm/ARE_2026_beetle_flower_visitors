@article{ WOS:A1983RS15200003,
Author = {BAWA, KS and BEACH, JH},
Title = {SELF-INCOMPATIBILITY SYSTEMS IN THE RUBIACEAE OF A TROPICAL LOWLAND WET
   FOREST},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1983},
Volume = {70},
Number = {9},
Pages = {1281-1288},
Abstract = {A program of experimental field pollinations was carried out on 14 spp.
   of woody Rubiaceae in a Costa Rican wet forest in order to test for the
   presence of self-incompatibility systems. Species of Cephaelis,
   Coussarea, Faramea, Hamelia, Posoqueria, Psychotria, Rudgea and
   Warszewiczia were investigated in the study. Ten of the species are
   distylous, and of these, 9 were self-incompatible. The site of the
   incompatibility barrier varied between and within species. Short style
   plants always had stigmatic inhibition of pollen tubes following self
   and intraform pollinations, but the site of the rejection response in
   long style plants was quite variable. In several species, pollen tubes,
   resulting from incompatible pollinations of the long style flowers,
   penetrated to the base of the style. Fruit set was followed in 2 of
   these species, and despite deep penetration of self and intraform pollen
   tubes in the long style morph, only interform pollinations resulted in
   fruit set. Four of  the species tested are florally monomorphic and each
   was self-incompatible on the basis of fruit set patterns. Pollen tubes
   in the styles of self-pollinated flowers of 2 of the monomorphic
   species, penetrated to the ovary, but no fruits resulted from
   self-pollinations. {[}The breeding systems of the following species were
   examined: Cephaelis elata Swartz, Coussarea sp. (voucher Beach 1424),
   Coussarea sp. (Beach 1467), Faramea sp. (Beach 1477), F. suerrensis
   Donn. Smith, Hamelia patens Jacq., H. xerocarpa Kuntze, Posoqueria
   grandiflora Standley, Psychotria acuminata Benth., P. chiapensis
   Standley, P. officinalis (Aubl.) Sandw., P. suerrensis Donn. Smith,
   Rudgea cornifolia (Humb. and Bonpl.) Standley, and Warszewiczia coccinea
   (Vahl) Klotzsch.].},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
