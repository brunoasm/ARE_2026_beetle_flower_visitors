@article{ WOS:000603582900015,
Author = {Borges, Rodrigo L. and Alves, Maria and Roque, Nadia},
Title = {<i>Tocoyena longilobata</i>, a replacement name for <i>Posoqueria
   speciosa</i> (Gardenieae, Rubiaceae)},
Journal = {PHYTOTAXA},
Year = {2020},
Volume = {477},
Number = {2},
Pages = {297-300},
Month = {DEC 24},
Abstract = {Aublet (1775) described Posoqueria Aublet (1775: 133, tab. 51) and
   differentiated it from Tocoyena Aublet (1775: 131, tab. 50) by the
   number of locules of the ovary (unilocular vs. bilocular, respectively)
   and seed shape (angulate vs. subspherical, respectively). However, in
   subsequent studies, L.C.M.Richard (1792) and Lamarck (1793) published
   under Tocoyena certain species that morphologically matched the generic
   concept of Posoqueria, causing an historical confusion concerning their
   generic delimitation. Achille Richard (1830), in his Memoire sur la
   famille des Rubiacees, synonymized Posoqueria under Tocoyena, a generic
   delimitation not widely adopted by subsequent authors. For example,
   Schumann (1889) in Flora Brasiliensis treated Posoqueria and Tocoyena as
   distinct genera.
   Generic delimitation of these genera remained problematic for a long
   time, with several species transferred back and forth between the two
   genera (e.g., Standley 1933, Steyermark 1967). More recently,
   phylogenetic studies using molecular data showed that Posoqueria and
   Tocoyena are indeed distantly related and placed in different tribes
   (Andreasen \& Bremer 2000, Persson 2000, Bremer \& Eriksson 2009, Mouly
   et al. 2014). Alternatively, taxonomic and morphological studies
   recognized the position of the lobed portion of the flower bud (erect in
   Tocoyena vs. oblique in many species of Posoqueria) and seed shape
   (discoid vs. obtusely angled) as taxonomically relevant characters for
   generic delimitation (Taylor \& Steyermark 2004; Macias \& Kinoshita
   2007). Furthermore, Posoqueria and Molopanthera Turczaninow (1848: 580),
   both currently placed in Posoquerieae, are characterized by their
   zygomorphic flowers and pollen grains dispersed through a catapult
   mechanism of the ventral stamen during pollination, which are considered
   exclusive characters to this tribe (Delprete 2009).
   A comprehensive taxonomic analysis of all Tocoyena protologues, and
   specimens from 21 herbaria (in-person study: ALCB, B, BM, CEPEC, GB,
   HUEFS, HURB, INPA, K, LE, M, P, R, RB, S, SPF, and UEC; online study: C,
   CORD, G, and HBG; acronyms according to Thiers 2020, onward) for the
   monograph of Tocoyena (Borges et al., in prep.), revealed the need for
   taxonomic and nomenclatural adjustments in the genus, which are
   presented below.},
Publisher = {MAGNOLIA PRESS},
Address = {250F Marua Road Mt Wellington, AUCKLAND, ST LUKES 1023, NEW ZEALAND},
