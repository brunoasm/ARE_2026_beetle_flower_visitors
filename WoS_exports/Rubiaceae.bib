@article{ WOS:000263674500002,
Author = {Chen, Minglin},
Title = {Comparative reproductive biology of <i>Primula merrilliana</i> Schltr.
   and <i>P</i>. <i>cicutariifolia</i> Pax},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2009},
Volume = {278},
Number = {1-2},
Pages = {23-32},
Month = {MAR},
Abstract = {The reproductive biology of Primula merrilliana Schltr. and P.
   cicutariifolia Pax that are sister taxa and the only two members of
   Primula sect. Ranunculoides were studied. The results showed that P.
   merrilliana is typically a distylous species not only in morphology but
   also in function; it has an incompatibility system that restricts the
   legitimate pollination to that between pin and thrum flower morphs, but
   self-fertilization may occur under certain conditions. P. cicutariifolia
   is self-compatible. The pin morph of P. merrilliana has longer stigma
   papillae and smaller pollen than the thrum morph. The results stated
   above support the view that P. filchnerae should be moved from sect.
   Pinnatae to sect. Auganthus.},
