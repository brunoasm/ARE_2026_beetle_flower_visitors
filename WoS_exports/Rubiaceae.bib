   Nascimento, S. S., UNESP, Fac Ciencias Agron, Rua Jose Barbosa de Barros 1780, BR-18610307 Botucatu, SP, Brazil.
   Longui, E. L.; Freitas, M. L. M., Inst Florestal Estado Sao Paulo, CP 1322, BR-01059970 Sao Paulo, SP, Brazil.},
DOI = {10.2478/sg-2018-0020},
