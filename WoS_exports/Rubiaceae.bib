@article{ WOS:A1986AXX1300009,
Author = {MCDADE, LA},
Title = {PROTANDRY, SYNCHRONIZED FLOWERING AND SEQUENTIAL PHENOTYPIC UNISEXUALITY
   IN NEOTROPICAL PENTAGONIA-MACROPHYLLA (RUBIACEAE)},
Journal = {OECOLOGIA},
Year = {1986},
Volume = {68},
Number = {2},
Pages = {218-223},
Abstract = {The neotropical shrub Pentagonia macrophylla Benth. (Rubiaceae) has
   protandrous two-day flowers. Synchronous development among flowers on a
   single individual results in sequential phenotypic unisexuality; the
   entire plant alternates gender from day to day. Pistillate flowers
   produce more nectar than staminate flowers at comparable hours, but this
   difference does not result in different patterns of visitation to male
   and female flowers by hummingbird pollinators. Rare periods of
   bisexuality  occur due to asynchronous floral development within or
   between inflorescences and are always followed by return to a
   synchronized pattern of alternation of gender. Reestablishement of
   synchrony usually involves a timeframe shift in the pattern of flowering
   (i.e., a plant produces staminate flowers on days when it previously
   would have been pistillate). It is suggested that timeframe shifts occur
   in response to inadequate pollination and serve to either desynchronize
   the plant from neighboring  conspecifics or to temporarily allow
   self-pollination.},
