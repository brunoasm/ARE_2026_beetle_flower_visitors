@article{ WOS:000849461400001,
Author = {Pinto, Alessandra Ribeiro and Moreira, Marina Muniz and Paglia, Isis and
   Rodriguez-Girones, Miguel A. and Freitas, Leandro},
Title = {Phenotypic integration of pollination traits in a distylous species with
   high intra-individual floral variation},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2022},
Volume = {308},
Number = {5},
Month = {OCT},
Abstract = {Plants are modular organisms, and flowers are their reproductive
   modules. Low intra-individual variation and high phenotypic integration
   are expected for floral traits, especially in distylous plants in which
   reciprocity between morphs enhances reproductive success. However, cases
   of high intra-individual floral variations and sets of traits more
   integrated within the flowers have been reported. We evaluated the
   morphometry of a distylous species, focusing on floral variation at
   different levels (between morphs, among individuals within the same
   morph, and within individuals) and on floral integration. We selected
   flowers from both long- and short-styled morphs within a population of
   Psychotria nuda (Rubiaceae). We measured floral parts to evaluate
   variability at the different levels, using a hierarchical model to
   partition the variation. We analyzed the integration of the whole flower
   and the two intra-floral modules: pollination-mechanics traits (PMT) and
   attraction traits (AT). We found high intra-individual variation, except
   for the stigma and anthers heights which distinguished the floral
   morphs. The intra-floral integration of PMT was higher than the
   integration of AT and of the whole flower, supporting the concept of
   functional structuring through intra-floral modularity related to
   pollination accuracy. Despite expecting low variation at intra-morph
   levels, we found high intra-individual floral variation in this species.
   We described a potential functional module within the flowers; hence,
   selection on PMT may be somewhat independent of selection on other
   floral traits. The intra-individual variation, added to the high degree
   of integration of PMT, could increase the chance of reciprocity between
   the two morphs in this distylous species.},
