   Garofalo, C. A., Univ Sao Paulo, Dept Biol, FFCLRP, BR-14040901 Sao Paulo, Brazil.},
DOI = {10.1093/aesa/sav153},
ISSN = {0013-8746},
EISSN = {1938-2901},
Keywords = {Atlantic forest; natural enemy; nesting biology; oil-collecting bee;
   pollen},
