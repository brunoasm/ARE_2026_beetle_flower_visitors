DOI = {10.2307/2445613},
ISSN = {0002-9122},
Keywords-Plus = {TEMPORAL DIOECISM; POLLEN; ANGIOSPERMS; DICHOGAMY; PLANTS; POLLINATION;
   COMMUNITY; RUBIACEAE; STIGMAS},
