@inproceedings{ WOS:A1996BH44Y00024,
Author = {Puff, C and Robbrecht, E and Buchner, R and DeBlock, P},
Editor = {Robbrecht, E and Puff, C and Smet, E},
Title = {A survey of secondary pollen presentation in the Rubiaceae},
Booktitle = {SECOND INTERNATIONAL RUBIACEAE CONFERENCE, PROCEEDINGS},
Series = {OPERA BOTANICA BELGICA},
Year = {1996},
Volume = {7},
Pages = {369-402},
Note = {2nd International Rubiaceae Conference, NATL BOTAN GARDEN BELGIUM,
   MEISE, BELGIUM, SEP 13-15, 1995},
Organization = {Dept Overseas Aid, Belgium; Natl Fund Sci Res, Belgium},
Abstract = {Following the most recent classification system of the Rubiaceae, up to
   date information on the occurrence of secondary pollen presentation
   (SPP) is given on a tribe to tribe basis, The paper includes a
   literature review, supplemented by original observations and
   investigations. Various previously published incorrect reports are
   corrected; hitherto unknown occurrences of SPP are added. General
   aspects of SPP in the Rubiaceae are described and discussed: position
   and shape of the pollen presenter in bud and in the open flower; pollen
   presenting area and receptive surfaces, surface adaptations of the
   pollen presenters favouring pollen deposition; SPP and the prevention of
   self-fertilization; SPP in taxa with unisexual flowers; SPP and
   pollination syndromes; taxonomic distribution of SPP.},
