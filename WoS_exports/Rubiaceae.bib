@article{ WOS:000473626000020,
Author = {Lehmann, L. J. and Maruyama, P. K. and Bergamo, P. Joaquim and
   Maglianesi, M. A. and Rahbek, C. and Dalsgaard, B.},
Title = {Relative effectiveness of insects <i>versus</i> hummingbirds as
   pollinators of Rubiaceae plants across elevation in Dominica, Caribbean},
Journal = {PLANT BIOLOGY},
Year = {2019},
Volume = {21},
Number = {4},
Pages = {738-744},
Month = {JUL},
Abstract = {Most angiosperms rely on animal pollination for reproduction, but the
   dependence on specific pollinator groups varies greatly between species
   and localities. Notably, such dependence may be influenced by both
   floral traits and environmental conditions. Despite its importance,
   their joint contribution has rarely been studied at the assemblage
   level. At two elevations on the Caribbean island of Dominica, we
   measured the floral traits and the relative contributions of insects
   versus hummingbirds as pollinators of plants in the Rubiaceae family.
   Pollinator importance was measured as visitation rate (VR) and single
   visit pollen deposition (SVD), which were combined to assess overall
   pollinator effectiveness (PE). In the wet and cool Dominican highland,
   we found that hummingbirds were relatively more frequent and effective
   pollinators than insects, whereas insects and hummingbirds were equally
   frequent and effective pollinators at the warmer and less rainy
   midelevation. Furthermore, floral traits correlated independently of
   environment with the relative importance of pollinators, hummingbirds
   being more important in plant species having flowers with long and wide
   corollas producing higher volumes of dilute nectar. Our findings show
   that both environmental conditions and floral traits influence whether
   insects or hummingbirds are the most important pollinators of plants in
   the Rubiaceae family, highlighting the complexity of plant-pollinator
   systems.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Lehmann, LJ (Corresponding Author), Univ Copenhagen, Nat Hist Museum Denmark, Ctr Macroecol Evolut \& Climate, Univ Pk 15, DK-2100 Copenhagen, Denmark.
   Lehmann, L. J.; Rahbek, C.; Dalsgaard, B., Univ Copenhagen, Nat Hist Museum Denmark, Ctr Macroecol Evolut \& Climate, Univ Pk 15, DK-2100 Copenhagen, Denmark.
   Lehmann, L. J., Univ Copenhagen, Dept Biol, Sect Ecol \& Evolut, Copenhagen, Denmark.
   Maruyama, P. K.; Bergamo, P. Joaquim, Univ Estadual Campinas, Inst Biol, Dept Biol Vegetal, Campinas, SP, Brazil.
