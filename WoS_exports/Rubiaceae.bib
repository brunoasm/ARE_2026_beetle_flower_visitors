ISSN = {1674-4918},
EISSN = {1759-6831},
Keywords = {Condamineeae; inter-specific competition; phenology; pollen-flower;
   pollination syndromes; Rubiaceae; self-incompatibility},
Keywords-Plus = {AFRICANIZED HONEY-BEE; REPRODUCTIVE-BIOLOGY; FLY POLLINATION; SEED
