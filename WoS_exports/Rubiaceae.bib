   Shimizu, Akira, Tokyo Metropolitan Univ, Dept Biol Sci, Hachioji, Tokyo, Japan.
   Sugawara, Takashi, Tokyo Metropolitan Univ, Grad Sch Sci, Makino Herbarium, Hachioji, Tokyo, Japan.},
DOI = {10.1111/1442-1984.12013},
ISSN = {0913-557X},
