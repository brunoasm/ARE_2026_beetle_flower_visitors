@article{ WOS:000417093400024,
Author = {Galindo Da Costa, Ana Carolina and Machado, Isabel Cristina},
Title = {Pin-monomorphism in <i>Palicourea crocea</i> (SW.) Roem. \& Schult.
   (Rubiaceae): reproductive traits and role of floral visitors},
Journal = {BRAZILIAN JOURNAL OF BOTANY},
Year = {2017},
Volume = {40},
Number = {4},
Pages = {1063-1070},
Month = {DEC},
Abstract = {Although heterostyly frequently occurs in Rubiaceae, there are cases of
   distylous species with populations that have variations in their
   reproductive systems. For example, in the typically distylous genus
   Palicourea, P. crocea showed a pin-monomorphism. Considering this, the
   questions addressed in the present study were: (1) Are there other
   pin-monomorphic Palicourea crocea populations? (2) How important are
   flower visitors to the pollination of this species? (3) What is the
   compatibility system in P. crocea? In addition, we tested the hypothesis
   that P. crocea is self-compatible and autogamous that can be a result of
   a variation in the distylous pattern. To answer the questions, we
   verified the position of anthers and stigmas in flowers of other
   populations of Palicourea crocea using voucher specimens. Furthermore,
   we made focal observations to analyze the role of flower visitors and we
   made field experiments to verify the compatibility system in P. crocea.
   Among seven flower visitors species observed-four bees, one wasp, one
   butterfly and one hummingbird-the latter was considered the main
   pollinator due to its high frequency of visits at all times analyzed.
   However, the small size of the population in the study area, the
   territorial behavior of hummingbirds, and the activity of nectar robbers
   may contribute to a low pollen flow. In this situation, traits as
   self-compatibility and autogamy observed in Palicourea crocea are
   beneficial, since they maintain species fertility. This could represent
   a new evolutionary path for the reproduction of this population,
   different from that of P. crocea populations that display distinct
   floral morphs.},
