DOI = {10.2307/2388996},
ISSN = {0006-3606},
Keywords = {FLORAL ECOLOGY; PLANT REPRODUCTIVE BIOLOGY; COMPETITION; NECTAR
   MEASUREMENT; PARASITISM; PHORESY; ENERGETICS; LA SELVA; COSTA RICA},
