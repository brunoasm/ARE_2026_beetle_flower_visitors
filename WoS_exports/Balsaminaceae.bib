EISSN = {1537-2197},
Keywords = {Apis mellifera; Balsaminaceae; Bombus impatiens; humble bees; honey
   bees; pollinator effectiveness; Vermont},
Keywords-Plus = {BEE APIS-MELLIFERA; POLLINATION EFFECTIVENESS; FLORAL VISITORS;
