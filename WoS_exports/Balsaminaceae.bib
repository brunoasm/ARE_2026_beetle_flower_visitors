Affiliations = {University of Ottawa; University of British Columbia},
Funding-Acknowledgement = {Natural Sciences and Engineering Research Council of Canada},
Funding-Text = {We thank R. El Hage and J. Reilly for assistance in the field, N. Stowe
   from the city of Ottawa for providing the GIS data, and J. Kerr for
   advice on the landscape analyses. We are grateful to J. Forrest, H.
