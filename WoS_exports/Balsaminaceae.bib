Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Young, HJ (Corresponding Author), Middlebury Coll, Dept Biol, Middlebury, VT 05753 USA.
