Year = {2019},
Number = {124},
Pages = {139-147},
Month = {JUN 21},
Abstract = {Impatiens jenjittikuliae Ruchis. \& Suksathan, a new species from a
   limestone area in Thasongyang District, Tak Province, Northern Thailand,
   is described and illustrated. This endemic new species is distinguished
   from the most similar, L lacei Hook.f. through having pilose lateral
   sepals vs glabrous, and by the absence of long hairs along the lamina
   margin. Its pollen and seed morphology, stem anatomy, and pollination
   ecology are also observed. Furthermore, its conservation status as
   Critically Endangered is also assessed.},
