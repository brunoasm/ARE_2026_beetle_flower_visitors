Keywords = {Aspundlia uncinata Harling; cantharophily; geitonogamy; infructescence
   abortion; plant/pollinator mutualism; pollinator efficiency; pollinator
   reproduction; reproductive system},
Keywords-Plus = {FLORAL BIOLOGY; POLLINATION; GENUS; CONSEQUENCES; STAMINODEUS;
