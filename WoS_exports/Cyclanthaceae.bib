Language = {English},
Affiliation = {Rudall, PJ (Corresponding Author), Royal Bot Gardens, Richmond TW9 3NJ, Surrey, England.
   Graca Sajo, M.; Lombardi, Julio A., Univ Estadual Paulista UNESP, Inst Biociencias, BR-13506900 Rio Claro, SP, Brazil.
   Forzza, Rafaela C., Inst Pesquisas Jardim Bot Rio de Janeiro, BR-22470180 Rio De Janeiro, RJ, Brazil.
   Rudall, Paula J., Royal Bot Gardens, Richmond TW9 3NJ, Surrey, England.},
DOI = {10.1086/676817},
