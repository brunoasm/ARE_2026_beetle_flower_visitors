@article{ WOS:A1994MQ91800006,
Author = {ERIKSSON, R},
Title = {THE REMARKABLE WEEVIL POLLINATION OF THE NEOTROPICAL CARLUDOVICOIDEAE
   (CYCLANTHACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1994},
Volume = {189},
Number = {1-2},
Pages = {75-81},
Abstract = {Further evidence for a specialized plant-pollinator relationship in the
   weevil pollinated Carludovicoideae (Cyclanthaceae) is presented, with
   emphasis on the previously uninvestigated genus Sphaeradenia. Weevils
   use the carludovicoid inflorescence for feeding, shelter, mating, and
   oviposition, the last-mentioned activity in the usually caducous
   staminate flowers. While visiting the inflorescence, they effect
   pollination. Adaptations, advantages, and consequences for this
   sophisticated system, both of the plants and pollinators, are discussed.},
