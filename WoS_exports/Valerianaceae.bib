@article{ WOS:A1983RH72300006,
Author = {CAREY, K},
Title = {BREEDING SYSTEM, GENETIC-VARIABILITY, AND RESPONSE TO SELECTION IN
   PLECTRITIS (VALERIANACEAE)},
Journal = {EVOLUTION},
Year = {1983},
Volume = {37},
Number = {5},
Pages = {947-956},
Abstract = {P. congesta (approximately 75\% outcrossed in nature) and P.
   brachystemon (less than 2\% outcrossed in nature) are 2 very closely
   related species which occur sympatrically in a number of locations. Six
   generations of plants of both species were grown under controlled
   conditions, and separate populations selected for short and tall stature
   at anthesis, and for early and late anthesis. Two sets of P. congesta
   populations were maintained, one outcrossed (approximately 65\%) and one
   selfed  (outcrossed approximately 15\%); the P. brachystemon populations
   were naturally self-pollinating. Selection intensity in the experiment
   was approximately 10\%: 20 of the 200 plants in any population were
   selected to provide 10 fruits each to form the next generation, on the
   basis of height or flowering time in the treatment populations, and at
   random in the control populations. The P. congesta populations responded
   to bidirectional selection for height at anthesis, indicating that
   genetic variability for this character was present in the species. There
   were no significant differences between the outcrossed and selfed lines
   over the course of the experiment. Two estimates of narrow sense
   heritability quantified the genetic variance. There was a decline in the
   phenotypic variance for height at anthesis in the P. congesta lines
   selected for this character. The P. brachystemon populations did not
   respond to selection for height, and appear to have no genetic variance
   detectable  for this character. Both species had significant genetic
   variance for flowering time, as both responded to divergent selection
   for this character. According to the heritability estimates, P. congesta
   is more variable than P. brachystemon. There was a decline in the
   phenotypic variance for flowering time in the selected lines in all 3
   groups. Increase in dispersion in fruit phenotype frequencies was not
   significantly different from that expected to result from random drift.
   A relatively  large increase in aberrant characters in the P. congesta
   lines compared to P. brachystemon lines is probably indicative of
   inbreeding depression in the normally outcrossed P. congesta. The
   maintainance of relatively high levels of genetic variance for flowering
   time in P. brachystemon, in the face of strong inbreeding pressure which
   must be present, is certainly adaptive and may arise through occasional
   outcrossing and multiniche selection among the resultant segregating
   lines. Despite their breeding system differences, the 2 Plectritis
   species are able to maintain variability by similar processes (genetic)
   in some characters, as in flowering time, and by different processes
   (genetic in P. congesta, phenotypic in P. brachystemon) in other
   characters, as in height at anthesis.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
