Type = {Article},
Language = {English},
Affiliation = {DIAZLIFANTE, Z (Corresponding Author), UNIV SEVILLA,DEPT BIOL VEGETAL \& ECOL,APARTADO 1095,E-41080 SEVILLE,SPAIN.},
ISSN = {0253-1453},
Keywords = {ASPHODELUS; ASPHODELACEAE; BREEDING SYSTEMS; SELF-INCOMPATIBILITY;
   POLLEN; NECTAR; HYBRIDIZATION},
