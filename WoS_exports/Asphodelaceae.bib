@article{ WOS:000315571900016,
Author = {Duffy, Karl J. and Patrick, Kirsten L. and Johnson, Steven D.},
Title = {EMASCULATION INCREASES SEED SET IN THE BIRD-POLLINATED HERMAPHRODITE
   <i>KNIPHOFIA LINEARIFOLIA</i> (XANTHORRHOEACEAE): EVIDENCE FOR SEXUAL
   CONFLICT?},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2013},
Volume = {100},
Number = {3},
Pages = {622-627},
Month = {MAR},
Abstract = {Premise of the study: Hermaphroditism in plants can lead to gender
   conflicts, such as pollen discounting-the loss of siring opportunities
   following self-pollination, and ovule discounting-the loss of seed
   production opportunities when self-pollen tubes disable ovules through
   early inbreeding depression or late-acting self-incompatibility. If
   ovules are discounted by self-pollination, it can be predicted that
   emasculation (removal of self-pollen) should increase seed production,
   as long as pollinators are not deterred by emasculation.
   Methods: Using the hermaphroditic Kniphofia linearifolia, which belongs
   to a lineage known to possess late-acting self-incompatibility, we
   performed hand-pollinations with either self-or cross-pollen and
   recorded pollen tube growth and seed production. We paired
   experimentally emasculated plants with non-emasculated controls and
   quantified pollinator visitation rates, fruit, and seed set in both
   groups.
   Key Results: Ovules penetrated by tubes from self-pollen uniformly
   failed to develop into seeds, as expected from ovarian
   self-incompatibility (or strong early inbreeding depression).
   Experimental emasculation had no effect on the rate of visitation by
   birds, the primary pollinators of this species, but led to increased
   rejection by bees, which are secondary pollinators. Despite reducing
   visitation by some pollinators, emasculation led to increased seed
   production and reduced rates of seed abortion.
   Conclusions: These results show that female performance in
   hermaphroditic flowers can be enhanced when flowers are emasculated,
   even if the overall number of pollinator visits is decreased. The most
   likely explanation for this effect of emasculation is that it reduces
   ovule discounting arising from pollinator-mediated self-pollination.},
Publisher = {BOTANICAL SOC AMER INC},
Address = {PO BOX 299, ST LOUIS, MO 63166-0299 USA},
Type = {Article},
Language = {English},
Affiliation = {Duffy, KJ (Corresponding Author), Univ KwaZulu Natal, Sch Life Sci, Private Bag X01, ZA-3209 Pietermaritzburg, South Africa.
   Duffy, Karl J.; Patrick, Kirsten L.; Johnson, Steven D., Univ KwaZulu Natal, Sch Life Sci, ZA-3209 Pietermaritzburg, South Africa.},
DOI = {10.3732/ajb.1200531},
ISSN = {0002-9122},
Keywords = {Apis mellifera scutellata; floral emasculation; hermaphroditism;
   Kniphofia linearifolia; pollen tubes; sunbird},
Keywords-Plus = {ACTING SELF-INCOMPATIBILITY; IPOMOPSIS-AGGREGATA POLEMONIACEAE;
