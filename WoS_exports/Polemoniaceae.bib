   UTAH STATE UNIV,DEPT BIOL,LOGAN,UT 84322.
   UNIV CALIF IRVINE,DEPT ECOL \& EVOLUTIONARY BIOL,IRVINE,CA 92717.
   ROCKY MT BIOL LABS,CRESTED BUTTE,CO.},
DOI = {10.1093/oxfordjournals.jhered.a111608},
