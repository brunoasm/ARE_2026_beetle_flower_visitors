@article{ WOS:A1992JG18700010,
Author = {BRODY, AK},
Title = {OVIPOSITION CHOICES BY A PREDISPERSAL SEED PREDATOR (HYLEMYA SP) .2. A
   POSITIVE ASSOCIATION BETWEEN FEMALE CHOICE AND FRUIT-SET},
Journal = {OECOLOGIA},
Year = {1992},
Volume = {91},
Number = {1},
Pages = {63-67},
Month = {AUG},
Abstract = {Pre-dispersal seed predators must choose proper hosts and flowers on
   those hosts that have a high probability of setting seed. In this study,
   I documented that flowers of Ipomopsis aggregata (Polemoniaceae) chosen
   by a pre-dispersal seed predator (Anthomyiidae: Hylemya sp.) had a
   higher probability of seed set than flowers the fly did not choose. I
   experimentally tested the hypothesis that Hylemya uses a
   post-fertilization cue in making oviposition choices. I found no
   evidence for this hypothesis.},
