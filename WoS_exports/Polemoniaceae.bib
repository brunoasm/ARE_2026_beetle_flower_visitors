@article{ WOS:A1980KH16900011,
Author = {ZIMMERMAN, M},
Title = {REPRODUCTION IN POLEMONIUM - PRE-DISPERSAL SEED PREDATION},
Journal = {ECOLOGY},
Year = {1980},
Volume = {61},
Number = {3},
Pages = {502-506},
Abstract = {The anthomyiid seed predator, Hylemya sp., of P. foliosissimum Gray
   (Polemoniaceae) preferentially attacks those plants which receive high
   numbers of pollinator visits {[}from Bombus bifarius and B. flavifrons].
   Seed mortality is high in ovaries which set many seeds (i.e., mortality
   is density-dependent) during the portion of the flowering season when
   pollinators are limiting resources and plants compete for pollinator
   service. The actions of both the seed predator and the pollinators of P.
   foliosissimum are responsible, in part, for the observed flowering
   phenology of this species.},
