   Irwin, Rebecca E., Dartmouth Coll, Sch Biol Sci, Hanover, NH 03755 USA.
   McCutcheon, Meghan L., Hampshire Coll, Sch Nat Resources, Amherst, MA 01002 USA.},
DOI = {10.1007/s00442-007-0879-8},
