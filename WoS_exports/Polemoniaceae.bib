@article{ WOS:A1979HR86700007,
Author = {ANDERSON, WR},
Title = {FLORAL CONSERVATISM IN NEOTROPICAL MALPIGHIACEAE},
Journal = {BIOTROPICA},
Year = {1979},
Volume = {11},
Number = {3},
Pages = {219-223},
Abstract = {Over 950 spp. of Malpighiaceae grow in a variety of neotropical habitats
   and show great diversity in habit, fruit, pollen and chromosome number.
   Their flowers tend to be very similar in general architecture,
   especially in those aspects concerned with the attraction, orientation
   and reward of pollinators. The flowers are visited only by Hymenoptera,
   principally female anthophorid bees and trigonid bees. The anthophorids
   collect oil from the calyx glands, mix it with pollen and use the
   mixture as food for larvae. The trigonids collect pollen. The usual
   character syndrome of the flower seems related to and maintained by
   pollination by oil bees; it is probably ancestral in the family.
   Pollination by pollen-collecting bees is probably secondary in many
   genera and shifts to primary importance in groups that lose the calyx
   glands. Other families such as Polemoniaceae, which have evolved very
   diverse flowers, reward pollinators with a sugary nectar that attracts a
   variety of secondary pollinators. This faunal diversity provides a
   bridge between one character syndrome in the flowers and another. The
   specialized rewards and resulting lack of diversity in pollinators in
   neotropical Malpighiaceae explain why the flowers have remained so
   conservative in spite of the evolution of great diversity in other
   aspects of the phenotype. Calyx glands seem to have been lost in most
   paleotropical lines in the absence of oil bees, but field observations
   on the pollination of those plants are practically nonexistent.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
