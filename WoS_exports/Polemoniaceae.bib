@article{ WOS:000415995200010,
Author = {Campbell, Diane R. and Brody, Alison K. and Price, Mary V. and Waser,
   Nickolas M. and Aldridge, George},
Title = {Is Plant Fitness Proportional to Seed Set? An Experiment and a Spatial
   Model},
Journal = {AMERICAN NATURALIST},
Year = {2017},
Volume = {190},
Number = {6},
Pages = {818-827},
Month = {DEC},
Abstract = {Individual differences in fecundity often serve as proxies for
   differences in overall fitness, especially when it is difficult to track
   the fate of an individual's offspring to reproductive maturity. Using
   fecundity may be biased, however, if density-dependent interactions
   between siblings affect survival and reproduction of offspring from
   high- and low-fecundity parents differently. To test for such
   density-dependent effects in plants, we sowed seeds of the wildflower
   Ipomopsis aggregata (scarlet gilia) to mimic partially overlapping seed
   shadows of pairs of plants, one of which produced twice as many seeds.
   We tested for differences in offspring success using a genetic marker to
   track offspring to flowering multiple years later. Without density
   dependence, the high-fecundity parent should produce twice as many
   surviving offspring. We also developed a model that considered the
   geometry of seed shadows and assumed limited survivors so that the
   number of juvenile recruits is proportional to the area. Rather than a
   ratio of 2:1 offspring success from high- versus low-fecundity parents,
   our model predicted a ratio of 1.42:1, which would translate into weaker
   selection. Empirical ratios of juvenile offspring and of flowers
   produced conformed well to the model's prediction. Extending the model
   shows how spatial relationships of parents and seed dispersal patterns
   modify inferences about relative fitness based solely on fecundity.},
Publisher = {UNIV CHICAGO PRESS},
Address = {1427 E 60TH ST, CHICAGO, IL 60637-2954 USA},
Type = {Article},
Language = {English},
Affiliation = {Campbell, DR (Corresponding Author), Univ Calif Irvine, Dept Ecol \& Evolutionary Biol, Irvine, CA 92697 USA.
   Campbell, DR (Corresponding Author), Rocky Mt Biol Labs, Crested Butte, CO 81224 USA.
   Campbell, Diane R., Univ Calif Irvine, Dept Ecol \& Evolutionary Biol, Irvine, CA 92697 USA.
   Campbell, Diane R.; Brody, Alison K.; Price, Mary V.; Waser, Nickolas M.; Aldridge, George, Rocky Mt Biol Labs, Crested Butte, CO 81224 USA.
   Brody, Alison K., Univ Vermont, Dept Biol, Burlington, VT 05405 USA.
   Price, Mary V.; Waser, Nickolas M., Univ Arizona, Sch Nat Resources \& Environm, Tucson, AZ 85719 USA.},
DOI = {10.1086/694116},
ISSN = {0003-0147},
EISSN = {1537-5323},
Keywords = {density dependence; fitness; Ipomopsis aggregata; seed set; seed shadow;
