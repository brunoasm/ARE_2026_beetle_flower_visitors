Affiliation = {Becklin, KM (Corresponding Author), Univ Missouri, Div Biol Sci, 105 Tucker Hall, Columbia, MO 65211 USA.
   Univ Puget Sound, Dept Biol, Tacoma, WA 98416 USA.},
DOI = {10.1139/B06-099},
ISSN = {0008-4026},
