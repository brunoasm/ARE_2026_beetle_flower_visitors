DOI = {10.2307/2410882},
ISSN = {0014-3820},
EISSN = {1558-5646},
Keywords = {evolutionary response to selection; floral traits; genetic correlation;
   heritability; Ipomopsis aggregata; nectar production;
   pollinator-mediated selection},
Keywords-Plus = {IPOMOPSIS-AGGREGATA POLEMONIACEAE; LIFE-HISTORY TRAITS; ALPINE SKY
   PILOT; QUANTITATIVE GENETICS; NECTAR PRODUCTION; DELPHINIUM-NELSONII;
   NATURAL-SELECTION; POLLEN DISPERSAL; MIMULUS-GUTTATUS; SEED PRODUCTION},
