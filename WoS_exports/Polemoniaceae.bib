Keywords = {MECHANICAL ISOLATION; HUMMINGBIRD POLLINATION; HAWKMOTH POLLINATION;
   INTROGRESSION; IPOMOPSIS-AQUILEGIA DIPLACUS},
Keywords-Plus = {COLORADO; INTERGRADATION; POLEMONIACEAE; POLLINATION},
