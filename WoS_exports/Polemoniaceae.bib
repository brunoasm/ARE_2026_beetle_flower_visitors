Type = {Article},
Language = {English},
Affiliation = {Irwin, RE (Corresponding Author), Univ Georgia, Inst Ecol, Athens, GA 30602 USA.
   Univ Georgia, Inst Ecol, Athens, GA 30602 USA.
   Rocky Mt Biol Labs, Crested Butte, CO 81224 USA.
   Colorado NW Community Coll, Dept Nat Sci, Meeker, CO 81641 USA.},
