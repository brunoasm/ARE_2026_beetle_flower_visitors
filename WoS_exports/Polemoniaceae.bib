@article{ WOS:A1949XW56900007,
Author = {GRANT, V},
Title = {POLLINATION SYSTEMS AS ISOLATING MECHANISMS IN ANGIOSPERMS},
Journal = {EVOLUTION},
Year = {1949},
Volume = {3},
Number = {1},
Pages = {82-97},
Abstract = {Angiosperms that are pollinated exclusively by certain types of animals
   (non-promiscuous angiosperms) possess barriers to interspecific
   pollination (floral isolating mechanisms) which arise from the
   structural contrivances of the flowers (mechanical isolation), the
   flower constancy of the pollinators (ethological isolation), or both. A
   survey of the taxonomic keys for 416 genera of angiosperms, representing
   all of the principal modes of pollination, shows that non-promiscuous
   plants are differentiated into species on floral characters to a much
   greater extent than angiosperms pollinated promiscuously by
   miscellaneous insects. 40\% of the taxonomic characters in bee and
   long-tongued fly plants pertain to the floral parts exclusive of calyx,
   and the corresponding figure in bird plants is 37\%, as compared with
   15\% of floral characters in promiscuous, entomophilous angiosperms, and
   4\% in wind-pollinated angiosperms. The great taxonomic importance of
   floral characters in non-promiscous angiosperms is regarded as a
   consequence of the operation of floral isolating mechanisms.
   Observations and expts. with Gilia capitata (Polemoniaceae) provide an
   example of ethological isolation under artificial conditions. Two
   different forms of this sp., one with linear corolla lobes and
   sweet-scented nectar, the other with oval corolla lobes and
   creosote-scented nectar, were grown intermixed in a garden where they
   were pollinated by honeybees. The bees were observed in general to
   remain with either one group or the other, and not to Gross-pollinate
   them; in the progeny of the garden plants a low proportion (0-21.7\%) of
   F1 hybrids between the 2 groups of gilias was encountered. The principal
   evolutionary role of ethological isolation in bee plants is the
   augmentation of the efficiency of allopatric speciation; it is also
   hypothetically capable of bringing about sympatric speciation. Bee
   plants, in so far as they possess a method of isolation not available to
   promiscuous plants, are able to undergo more rapid evolution than the
   less specialized groups of angiosperms. There are. in the flora of
   southern California, an avg. number of 5.94 spp. per genus in bee
   plants, as opposed to 3.38 spp. per genus in promiscuous, entomophilous
   angiosperms.},
