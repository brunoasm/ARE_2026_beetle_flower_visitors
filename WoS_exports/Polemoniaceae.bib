@article{ WOS:A1980KH16900010,
Author = {ZIMMERMAN, M},
Title = {REPRODUCTION IN POLEMONIUM - COMPETITION FOR POLLINATORS},
Journal = {ECOLOGY},
Year = {1980},
Volume = {61},
Number = {3},
Pages = {497-501},
Abstract = {The flowering season of P. foliosissimum Gray (Polemoniaceae) can be
   divided into 2 distinct periods. In the 1st, the bee {[}Bombus bifarius
   and B. flavifrons]: flower ratio is relatively high and large numbers of
   seeds per ovary are set. No correlation exists between the pollinator
   visitation rate to flowers and seed-set. In the 2nd period the
   bee:flower ratio and seed-set are lower and a very strong correlation
   exists between pollinator service and seed-set. Pollinators are limiting
   resources during this portion of the season and those individual plants
   which can best attract pollinators have a strong selective advantage at
   this time. Intraspecific exploitation competition for pollinator service
   might be occurring during this portion of the flowering season.},
