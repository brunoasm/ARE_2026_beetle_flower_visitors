Keywords-Plus = {TENUITUBA POLEMONIACEAE; NATURAL-POPULATIONS; HYBRIDIZATION;
   POLLINATION; STATISTICS; MIGRATION; SELECTION; EXCHANGE; TAXONOMY; PLANT},
Research-Areas = {Genetics \& Heredity},
