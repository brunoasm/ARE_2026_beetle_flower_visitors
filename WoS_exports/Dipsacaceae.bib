   Uppsala Univ, Dept Plant Ecol, Evolutionary Biol Ctr, SE-75236 Uppsala, Sweden.
   Lund Univ, Dept Anim Ecol, SE-22362 Lund, Sweden.},
DOI = {10.1016/j.biocon.2006.08.030},
ISSN = {0006-3207},
EISSN = {1873-2917},
Keywords = {extinction; minimal resource; oligolecty; pollen limitation;
   specialisation; threshold},
