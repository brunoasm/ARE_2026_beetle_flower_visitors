}

@inproceedings{ WOS:A1997BJ01A00016,
Author = {Kwak, MM and Velterop, O},
Editor = {Sommeijer, MJ and Francke, PJ},
Title = {Flower visitation by generalists and specialists: Analysis of pollinator
   quality},
Booktitle = {PROCEEDINGS OF THE SECTION EXPERIMENTAL AND APPLIED ENTOMOLOGY OF THE
   NETHERLANDS ENTOMOLOGICAL SOCIETY (N.E.V.), VOL 8, 1997},
Year = {1997},
Pages = {85-89},
Note = {8th Meeting of Experimental and Applied Entomologists in the
   Netherlands, UTRECHT, NETHERLANDS, DEC   13, 1996},
Organization = {Netherlands Entomol Soc, Exptl Appl Entomol Sect},
Abstract = {Flowers of Scabiosa columbaria (Dipsacaceae) are visited by a large
   number of insect species, generalists and one specialist. Per population
   one insect species or group was dominant. Syrphids, bumblebee males and
   the day-active night moth Autographa gamma were the most numerous
   visitors in Dutch populations. In French populations a number of
   butterfly species, honeybees and the specialist bee Dasypoda argentata
   were the most frequent visitors. The purity of the pollen loads on
   insect bodies was studied. Bumblebees, both workers and males, and
   syrphid flies carried a body load containing pollen of several plant
   species. The percentage of S. columbaria pollen was not larger than 22
   percent. Butterflies carried a very small number of pollen grains. The
   specialist D. argentata and honeybees carried only S. columbaria pollen,
   the first species in very large numbers. Stigmas in populations visited
   by D. argentata and honeybees contained a very pure load of nearly only
   Scabiosa pollen. Stigmas in populations visited by bumblebees, syrphid
   flies and butterflies had up to 30\% Scabiosa pollen; a large variation
   of pollen from different plant species was found.},
Publisher = {NEDERLANDSE ENTOMOLOGISCHE VERNIGING ( N E V )},
Address = {PLANTAGE MIDDENLAAN 64, 1018 DH AMSTERDAM, NETHERLANDS},
