Affiliation = {Kwak, MM (Corresponding Author), UNIV GRONINGEN,DEPT PLANT BIOL,LAB PLANT ECOL,POB 14,NL-9750 AA HAREN,NETHERLANDS.},
ISBN = {90-71912-16-7},
Keywords = {purity pollen load; syrphids; bumblebees; honeybee; Dasypoda argentata;
   butterflies, Scabiosa columbaria},
