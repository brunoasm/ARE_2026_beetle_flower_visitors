Address = {233 SPRING STREET, NEW YORK, NY 10013 USA},
Type = {Article},
Language = {English},
Affiliation = {Larsson, M (Corresponding Author), Uppsala Univ, Evolutionary Biol Ctr, Dept Plant Ecol, Villavagen 14, S-75236 Uppsala, Sweden.
   Uppsala Univ, Evolutionary Biol Ctr, Dept Plant Ecol, S-75236 Uppsala, Sweden.},
DOI = {10.1007/s00442-005-0217-y},
ISSN = {0029-8549},
