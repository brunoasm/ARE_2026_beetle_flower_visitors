   Franzen, Markus, Lund Univ, Dept Anim Ecol, SE-22362 Lund, Sweden.
   Larsson, Magnus, Uppsala Univ, Evolutionary Biol Ctr, Dept Plant Ecol, SE-75236 Uppsala, Sweden.},
DOI = {10.1111/j.1756-1051.2009.00348.x},
ISSN = {0107-055X},
EISSN = {1756-1051},
Keywords-Plus = {VISCARIA-VULGARIS; BUMBLEBEE VISITATION; MELAMPYRUM-PRATENSE; PATCH
