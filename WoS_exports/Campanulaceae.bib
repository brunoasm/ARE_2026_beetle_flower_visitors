Address = {SACHSENPLATZ 4-6, PO BOX 89, A-1201 WIEN, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {Chinese Acad Sci, NW Inst Plateau Biol, Lab Qinghai Tibetan Plateau Biol Evolut \& Adaptat, Xining 180001, Peoples R China.
   Chinese Acad Sci, NW Inst Plateau Biol, Lab Qinghai Tibetan Plateau Biol Evolut \& Adaptat, Xining 180001, Peoples R China.
