   Ollerton, Jeff; Cranmer, Louise; Sullivan, Steve, Univ Northampton, Sch Appl Sci, Landscape \& Biodivers Res Grp, Northampton NN2 7AL, England.},
DOI = {10.1007/s00114-008-0467-8},
