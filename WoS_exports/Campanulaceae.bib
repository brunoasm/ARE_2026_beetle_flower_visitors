Pages = {105-117},
Abstract = {Two species of Siphocampylus (Campanulaceae: Lobelioideae) from the
   Central Andes of Peru and Bolivia are described, illustrated, and
   discussed with reference to related species. One species, Siphocampylus
   antonellii, is endemic to high elevation grasslands of Calca, Peru,
