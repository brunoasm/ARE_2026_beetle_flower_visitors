@article{ WOS:000454309000006,
Author = {Gardere, Mathieu L.},
Title = {Snails in the flowers of <i>Campanula jacobaea</i> C.Sm. ex Webb
   (Campanulaceae) from the island of Sao Nicolau, Cabo Verde archipelago},
Journal = {ADANSONIA},
Year = {2018},
Volume = {40},
Number = {2},
Pages = {183-186},
Month = {DEC},
Abstract = {On the eastern flank of the island of Sao Nicolau in the Cape Verde
   archipelago, a species of snail Leptods bollei (Albers, 1854)
   (Pulmonata, Hygromiidae) was observed on several occasions in the
   flowers of Campanula jacobaca C.Sm. ex Webb (Campanulaceae), feeding on
   anthers and sheltering in the bottom of the corolla. Much more than just
   a predator, the snail is an occasional but active transporter of pollen
   on its shell, favouring cross-pollination and considered here a rare
   example of malacophily.},
