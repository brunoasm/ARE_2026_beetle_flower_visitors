Keywords = {Campanulaceae; female-phase duration; floral display; floral longevity;
   Lobelia siphilitica; male-phase duration; phenotypic gender; phenotypic
   plasticity; pollination; pollinator declines},
Keywords-Plus = {PHENOTYPIC PLASTICITY; PISTILLATE PHASES; NATURAL-SELECTION; FLOWERING
