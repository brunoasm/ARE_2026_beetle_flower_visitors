   Yamada, T.; Maki, M., Tohoku Univ, Div Ecol \& Evolutionary Biol, Grad Sch Life Sci, Aoba Ku, Sendai, Miyagi 9808578, Japan.
   Kashiwagi, T.; Sawamura, M., Kochi Univ, Dept Bioresources Sci, Fac Agr, Nanko Ku, Kochi 7838502, Japan.},
DOI = {10.1007/s00606-010-0317-y},
