Affiliation = {Uys, E (Corresponding Author), Univ Witwatersrand, Sch Anim Plant \& Environm Sci, Private Bag 3, ZA-2050 Johannesburg, South Africa.
   Uys, E.; Cron, G. V., Univ Witwatersrand, Sch Anim Plant \& Environm Sci, ZA-2050 Johannesburg, South Africa.},
DOI = {10.1016/j.sajb.2013.01.011},
ISSN = {0254-6299},
EISSN = {1727-9321},
