Language = {English},
Affiliation = {Muchhala, N (Corresponding Author), Univ Miami, Dept Biol, 1301 Mem Dr, Miami, FL 33143 USA.
   Univ Miami, Dept Biol, Miami, FL 33143 USA.},
DOI = {10.3732/ajb.93.8.1081},
ISSN = {0002-9122},
Keywords = {chiropterophily; cloud forests; Ecuador; floral morphology;
   generalization vs. specialization; Lobelioideae; ornithophily;
   pollination syndromes},
Keywords-Plus = {FLORAL SPECIALIZATION; FLOWERING PLANTS; TRADE-OFFS; EVOLUTION; SYSTEMS;
   LOBELIOIDEAE; VISITATION; HUMMINGBIRDS; MUTUALISM; COMMUNITY},
