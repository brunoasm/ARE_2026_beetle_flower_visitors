@article{ WOS:000335400300001,
Author = {Liu, Jian-Quan and Duan, Yuan-Wen and Hao, Gang and Ge, Xue-Jun and Sun,
   Hang},
Title = {Evolutionary history and underlying adaptation of alpine plants on the
   Qinghai-Tibet Plateau},
Journal = {JOURNAL OF SYSTEMATICS AND EVOLUTION},
Year = {2014},
Volume = {52},
Number = {3, SI},
Pages = {241-249},
Month = {MAY},
Abstract = {As the highest and largest plateau in the world, the Qinghai-Tibet
   Plateau, with its numerous endemic species, is one of the important
   alpine biodiversity hotspots. Only recently have the evolutionary
   histories and underlying adaptations of these alpine plants become
   clear, through research mostly based on testable experiments and
   analyses. In this issue, we collected a total of 13 papers related to
   such aims. In addition, we selected a few published papers to highlight
   the major findings in the recent past. We also outlined the outlook and
   direction of future research.},
