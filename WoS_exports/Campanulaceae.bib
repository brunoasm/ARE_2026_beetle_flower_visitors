DOI = {10.1086/501051},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {cryptic self-incompatibility; pollen competition; outcrossing
   mechanisms; geitonogamy; pollen tube growth},
Keywords-Plus = {POLLEN-TUBE GROWTH; DECODON VERTICILLATUS LYTHRACEAE;
