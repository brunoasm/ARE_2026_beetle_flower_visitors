   Penn State Univ, State Coll, PA 16802 USA.},
DOI = {10.1086/320787},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {pollen competition; partial self-incompatibility; mixed mating system;
   Campanula rapunculoides; self-incompatibility},
