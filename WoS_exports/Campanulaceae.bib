@article{ WOS:000238284800008,
Author = {Hansen, Vivi-Iren and Totland, Orjan},
Title = {Pollinator visitation, pollen limitation, and selection on flower size
   through female function in contrasting habitats within a population of
   <i>Campanula persicifolia</i>},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {2006},
Volume = {84},
Number = {3},
Pages = {412-420},
Month = {MAR},
Abstract = {We looked at whether flower visitation rates, pollen limitation on seed
   production, and phenotypic selection on flower size through female
   function varied across a sharp gradient in light intensity (open meadow
   vs. forest) within a population of the perennial plant Campanula
   persicifolia L.a(Campanulaceae). Flower visitation rates of putative
   pollinators were similar in both habitats. Seed number per fruit was
   strongly pollen limited, with no difference in the magnitude of pollen
   limitation between the two habitats. This strong pollen limitation set
   the basis for significant phenotypic selection, through female function,
   on a trait that probably is important for pollinator attraction: flower
   size. This was revealed by path analysis and structural equation
   modelling. The lack of difference in pollen limitation on seed
   production in the two habitats may be explained by the similarity in
   flower visitation rates in the two habitats. Moreover, the similarity in
   pollen limitation in the two habitats probably resulted in a similar
   magnitude and direction of selection on flower size through female
   function. Our results suggest that pollen limitation and selection
   through female function may vary little across space within a popualtion
   despite large variation in the environmental conditions experienced by
   plants.},
Publisher = {CANADIAN SCIENCE PUBLISHING},
Address = {65 AURIGA DR, SUITE 203, OTTAWA, ON K2E 7W6, CANADA},
Type = {Article},
Language = {English},
Affiliation = {Totland, O (Corresponding Author), Norwegian Univ Life Sci, Dept Ecol \& Nat Resource Management, POB 5003, N-1432 As, Norway.
   Norwegian Univ Life Sci, Dept Ecol \& Nat Resource Management, N-1432 As, Norway.},
DOI = {10.1139/B06-012},
ISSN = {0008-4026},
Keywords = {Campanula; flower size; flower visitation rate; pollen limitation;
   phenotypic selection},
Keywords-Plus = {PHENOTYPIC SELECTION; FLORAL TRAITS; PLANT REPRODUCTION; FOREST PLANTS;
   PATH-ANALYSIS; SKY PILOT; POLEMONIUM; HETEROGENEITY; EVOLUTIONARY;
