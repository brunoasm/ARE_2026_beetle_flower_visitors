   Royal Bot Gardens, Jodrell Lab, Mol Systemat Sect, Richmond TW9 3DS, Surrey, England.
   Royal Bot Garden, Edinburgh EH3 5LR, Midlothian, Scotland.},
DOI = {10.2307/25065582},
ISSN = {0040-0262},
EISSN = {1996-8175},
Keywords = {Canacomyrica; dioecy; Fagales; Myricaceae; New Caledonia; rbcL
   sequences; staminodes},
