@article{ WOS:000379565000008,
Author = {Eileen, Dworaczek and Regine, Classen-Bockhoff},
Title = {`False resupination' in the flower-pairs of <i>Thalia</i> (Marantaceae)},
Journal = {FLORA},
Year = {2016},
Volume = {221},
Number = {SI},
Pages = {65-74},
Abstract = {Resupination, i.e., the turn by 180 degrees, arranges zygomorphic
   flowers in a suitable position for pollination. It is well-known from
   orchids, but also occurs in further angiosperm families. Within the
   genus Thalia L. (Marantaceae), T. dealbata has erect and T. geniculata
   pendulous inflorescences. Nevertheless, in both species the zygomorphic
   flower-pairs show the right position for pollination. Thus, resupination
   is expected in Marantaceae. To reconstruct spatial arrangement, flower
   development was investigated from meristem formation to anthesis. Early
   morphogenetic stages were analysed under the scanning electron
   microscope, late stages were documented by time-lapse records. Gravity
   experiments were added to test for plastic or genetically fixed
   flower-pair position. Flowers in both Thalia species develop almost
   identically. They originate from a common primordium and show the
   unusual floral organ sequence already described for the family. In T.
   dealbata, the flower-pair gets its final position by bending 90 degrees
   backwards, while in T. geniculata a lateral rotation of 90 degrees takes
   place shortly before anthesis. In both species, position is genetically
   fixed. Results clearly indicate that the flower-pairs in Thalia do not
   show resupination according to the given definition. Instead of the
   expected 180 degrees turn in one species, flower-pairs in both species
   each dislocate for 90 degrees. (C) 2015 Elsevier GmbH. All rights
   reserved.},
Publisher = {ELSEVIER GMBH},
Address = {HACKERBRUCKE 6, 80335 MUNICH, GERMANY},
Type = {Article},
Language = {English},
Affiliation = {Eileen, D (Corresponding Author), Johannes Gutenberg Univ Mainz, Inst Spezielle Bot, Anselm Franz von Bentzelweg 9a, D-55099 Mainz, Germany.
   Eileen, Dworaczek; Regine, Classen-Bockhoff, Johannes Gutenberg Univ Mainz, Inst Spezielle Bot, Anselm Franz von Bentzelweg 9a, D-55099 Mainz, Germany.},
DOI = {10.1016/j.flora.2015.08.007},
ISSN = {0367-2530},
EISSN = {1618-0585},
Keywords = {Ontogeny; Zygomorphic flowers; Flower movements; Spatial orientation;
   Floral unit meristem; Gravity experiments},
Keywords-Plus = {PHYLOGENETIC-RELATIONSHIPS; POLLINATION; GENUS; ZINGIBERACEAE;
   BIGNONIACEAE; EVOLUTION; TAXA},
Research-Areas = {Plant Sciences; Environmental Sciences \& Ecology},
