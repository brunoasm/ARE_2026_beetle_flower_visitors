Address = {SACHSENPLATZ 4-6, PO BOX 89, A-1201 WIEN, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {Glinos, E (Corresponding Author), CONICET Univ Nacl Cordoba, Lab Biol Floral, Inst Multidisciplinario Biol Vegetal, Casilla Correo 495, RA-5000 Cordoba, Argentina.
   Glinos, Evangelina; Cocucci, A. A., CONICET Univ Nacl Cordoba, Lab Biol Floral, Inst Multidisciplinario Biol Vegetal, RA-5000 Cordoba, Argentina.},
DOI = {10.1007/s00606-010-0379-x},
ISSN = {0378-2697},
Keywords = {Canna indica; Style anatomy; Pollination biology; Hummingbirds;
   Stigmatic secretions; Viscidium},
Keywords-Plus = {SECONDARY POLLEN PRESENTATION; ORCHIDANTHA LOWIACEAE; COSTA-RICA; 5
