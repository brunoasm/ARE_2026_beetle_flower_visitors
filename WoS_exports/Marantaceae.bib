Address = {SACHSENPLATZ 4-6, PO BOX 89, A-1201 WIEN, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {Pischtschan, E (Corresponding Author), Johannes Gutenberg Univ Mainz, Inst Spezielle Bot, D-55099 Mainz, Germany.
   Pischtschan, Elke; Claen-Bockhoff, Regine, Johannes Gutenberg Univ Mainz, Inst Spezielle Bot, D-55099 Mainz, Germany.},
DOI = {10.1007/s00606-010-0282-5},
ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {Cell-wall perforations; Histology; Maceration; Style construction},
Keywords-Plus = {POLLINATION; PLANT; POLLEN; RELEASE; FLOWER},
