@article{ WOS:A1984TL75500001,
Author = {KUNZE, H},
Title = {COMPARATIVE STUDIES OF THE FLOWER IN CANNACEAE AND MARANTACEAE},
Journal = {FLORA},
Year = {1984},
Volume = {175},
Number = {5},
Pages = {301-318},
Abstract = {The flowers in both faimilies are similar in structure as well as in
   their ontogenesis. Both show strong tendencies of reduction in the outer
   staminal ring which consists of only 2 to 0 staminodes. The median
   staminode of this ring is always aborted. In both families the flowers
   assume the shape of lip flowers by way of gaining a secondary
   symmetrical habitus. The symmetry is always oriented on the main axis,
   independent of the degree of ramification. Morphologically the 6 members
   of the perianth are considered as transformed bracts. The staminodes are
   distinctly different from them in their pattern of veins and are
   interpreted as antherial wings homologous to those in the Zingiberaceae.
   The staminodes of Canna are functionally semaphylls, whereas in the
   Marantaceous flower the staminodes of the inner ring are highly
   specialized organs. They show strong traits of synorganization in their
   functions. So 1/2 of the Staminodium cucullatum envelops the style in
   order to keep the  anther in the correct position for discharge the
   pollen, the 2nd half forms the trigger with its basal plate. Movement of
   the plate against the style triggers the explosive rolling up of the
   style. Most probably the style is not under tension as long as there is
   no irritation coming from the basal plate. The movement of the trigger
   causes differences in turgor in the style, and this finally leads to
   pollination. The functions of the Staminodium callosum comprise guiding
   of the insect, forming of secondary nectar receptacles and keeping the
   stamen in correct position for depositing the pollen. The deposition of
   the pollen on the style and its presentation might be considered as
   analogous in both families, since in Canna it is accomplished in a
   different way and on a different side of the style. This convergence
   nevertheless points to a disposition common to both families, the
   premature ripening of the theca and the close ontogenetic connections
   between style and stamen. This connection  is also characteristics in
   Zingiberaceae, where the style is commonly enclosed and supported by the
   anther. So the comparison between the flowers of both families,
   Cannaceae and Marantaceae shows aside from the fundamental conformity a
   far higher specialization and synorganization in the Marantaceae. Both
   families also have basic characters in common with the Zingiberacea,
   which seem to be the least specialized family of the 3.},
Publisher = {ELSEVIER GMBH},
Address = {HACKERBRUCKE 6, 80335 MUNICH, GERMANY},
Type = {Article},
