ISSN = {0305-7364},
Keywords = {Africa; floral diversity; functional pollinator groups; Gabon;
   Marantaceae; nectar; plant-animal interaction; pollination syndromes},
Keywords-Plus = {THALIA-GENICULATA MARANTACEAE; DIPTEROCARP FOREST; FLOWER; BEES;
