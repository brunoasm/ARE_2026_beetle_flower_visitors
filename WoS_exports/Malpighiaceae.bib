   Aguiar, Antonio J. C., Univ Brasilia, Dept Zool, BR-70910900 Brasilia, DF, Brazil.
   Melo, Gabriel A. R., Univ Fed Parana, Dept Zool, Lab Biol Comparada Hymenoptera, BR-80060000 Curitiba, PR, Brazil.},
DOI = {10.1111/j.1096-3642.2010.00678.x},
