@article{ WOS:000342807700003,
Author = {De Lyra Neves, Cynthia Maria and Lopes De Carvalho, Carlos Alfredo and
   Machado, Cerilene Santiago and Lima Aguiar, Candida Maria and Das Merces
   Sousa, Fernanda Silva},
Title = {Pollen consumed by the solitary bee <i>Tetrapedia diversipes</i>
   (Apidae: Tetrapediini) in a tropical agroecosystem},
Journal = {GRANA},
Year = {2014},
Volume = {53},
Number = {4},
Pages = {302-308},
Month = {OCT 2},
Abstract = {Pollen analysis of the larval food supply is an important tool for
   identifying the plants that provide the floral resources used by bees.
   The present study documents the pollen sources consumed by larvae of the
   solitary bee Tetrapedia diversipes in a tropical agroecosystem. A total
   of 60 pollen types were recorded with three families being the most
   important. Euphorbiaceae (60.5\%), Malpighiaceae (16.8\%) and Asteraceae
   (12.2\%) pollen had the greatest representation in the samples examined.
   The pollen of Dalechampia dioscoreifolia predominated in the diet of the
   larvae of T. diversipes (RF = 56.35\%) and indicates the importance of
   this plant in maintaining populations of this solitary bee.},
