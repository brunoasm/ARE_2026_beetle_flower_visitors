Year = {1979},
Volume = {27},
Number = {2},
Pages = {203-205},
Abstract = {The very substantial set of West Indian cherries (M. punicifolia) in
   Jamaican orchards is apparently due to the numerous visits by the
   anthophorid bee (C. dirrhoda). This relationship is typical of the need
   of members of the Malpighiaceae to be visited by their specialist
   pollinators. In Hawaii {[}USA], where the fruit was introduced from the
   Caribbean region, the yields were poor and they did not increase when
   colonies of honey bees were placed in the orchards.},
