@article{ WOS:000167775600004,
Author = {van Doorn, WG},
Title = {Categories of petal senescence and abscission: A re-evaluation},
Journal = {ANNALS OF BOTANY},
Year = {2001},
Volume = {87},
Number = {4},
Pages = {447-456},
Month = {APR},
Abstract = {In a previous paper (Woltering and van Doom, 1988, Journal of
   Experimental Botany 39: 1605-1616) we identified three types of flower
   life cessation: by petal wilting or withering, which was either
   ethylene-sensitive or insensitive. and by abscission of turgid petals,
   which was ethylene-sensitive. These categories tended to be consistent
   within families. Here we re-examine these relationships by testing a
   further 200 species, and a number of other families. As previously,
   flowering shoots: were exposed to 3 ppm cthylene for 24 h at 20
   degreesC, in darkness, Most monocotyledonous species tested showed
   ethylene-insensitive petal wilting, although ethylene sensitive wilting
   occurred in the Alismataceae and Commelinaceae. Petals of the
   dicotyledonous species tested were generally sensitive to ethylene,
   except for a Few groups showing wilting (Crassulaceae, Gentianaceae and
   Fumariaceae, and one subfamily in both the Ericaceae and Saxifragaceae).
   Petal abscission was generally ethylene-sensitive, but ethylene
   insensitivity was found in some Tulipa cultivars and thrice Saxifraga
   species. In most tulip cultivars tested, the petals wilted and then
   fell. It is concluded that (a) the response to cthylene is often
   consistent within either families or subfamilies; and (b) a fourth
   category, ethylene insensitive petal abscission. exists both in
   monocotyledons and dicotyledons. (C) 2001 Annals of Botany Company.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Univ Wageningen \& Res Ctr, Agrotechnol Res Inst, POB 17, NL-6700 AA Wageningen, Netherlands.
   Univ Wageningen \& Res Ctr, Agrotechnol Res Inst, NL-6700 AA Wageningen, Netherlands.},
DOI = {10.1006/anbo.2000.1357},
ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {ethylene sensitivity; flower longevity; petal abscission; petal wilting;
