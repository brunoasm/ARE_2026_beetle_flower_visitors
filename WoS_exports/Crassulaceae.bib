Address = {ONE NEW YORK PLAZA, SUITE 4600, NEW YORK, NY, UNITED STATES},
Type = {Article},
Language = {English},
Affiliation = {UNIV GRANADA, FAC CIENCIAS, DIPARTIMENTO BIOL ANIM \& ECOL, E-18001 GRANADA, SPAIN.},
DOI = {10.1007/BF00317631},
ISSN = {0029-8549},
EISSN = {1432-1939},
Keywords = {ANT POLLINATION; EXCLUSION EXPERIMENTS; PROFORMICA-LONGISETA;
   HORMATHOPHYLLA-SPINOSA; HIGH-MOUNTAIN ECOLOGY},
Keywords-Plus = {DIAMORPHA-SMALLII CRASSULACEAE; POLEMONIUM-VISCOSUM;
   LEPORELLA-FIMBRIATA; POLLEN; FLOWERS; TRAITS},
Research-Areas = {Environmental Sciences \& Ecology},
