@article{ WOS:000284289800012,
Author = {de Sa-Haiad, B. and Torres, C. A. and de Abreu, V. H. R. and Goncalves,
   M. R. and Mendonca, C. B. F. and de Santiago-Fernandes, L. D. R. and
   Bove, C. P. and Goncalves-Esteves, V.},
Title = {Floral structure and palynology of <i>Podostemum weddellianum</i>
   (Podostemaceae: Malpighiales)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {2010},
Volume = {290},
Number = {1-4},
Pages = {141-149},
Month = {DEC},
Abstract = {The family Podostemaceae is exceptional among angiosperms because of its
   uncommon biology and morphology, the absence of double fertilisation and
   endosperm, and the obscure distinction between root, stem, and leaf. The
   highly modified morphology produced by reductions and specialisations is
   reflected in the multiple positions that the Podostemaceae has occupied
   in different classification systems. In the family, structural studies
   are mainly related to the vegetative body. In the genus Podostemum,
   structural data are related to the development and embryology of
   Podostemum ceratophyllum Michx., which, with P. weddellianum, has
   pre-anthesis cleistogamy. P. weddellianum is analysed for the first time
   with regard to floral structure and palynology. The presence of silica
   in the spathella, the apical septum in the ovary, dyads and
   pseudomonads, unimodal embryo sac and chasmogamous flowers with the
   possibility of self-pollination contribute to the characterisation of
   the Podostemoideae and the search for relationships among Podostemaceae
   and the clusioids.},
