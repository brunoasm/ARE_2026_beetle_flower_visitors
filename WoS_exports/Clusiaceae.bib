@article{ WOS:000187724600001,
Author = {Dick, CW and Abdul-Salim, K and Bermingham, E},
Title = {Molecular systematic analysis reveals cryptic tertiary diversification
   of a widespread tropical rain forest tree},
Journal = {AMERICAN NATURALIST},
Year = {2003},
Volume = {162},
Number = {6},
Pages = {691-703},
Month = {DEC},
Abstract = {The broad geographic range of many Neotropical rain forest tree species
   implies excellent dispersal abilities or range establishment that
   preceded the formation of current dispersal barriers. In order to
   initiate historical analyses of such widespread Neotropical trees, we
   sequenced the nuclear ribosomal spacer (ITS) region of Symphonia
   globulifera L.f. (Clusiaceae) from populations spanning the Neotropics
   and western Africa. This rain forest tree has left unmistakable Miocene
   fossils in Mesoamerica (15.5-18.2 Ma) and in South America (similar to15
   Ma). Although marine dispersal of S. globulifera is considered
   improbable, our study establishes three marine dispersal events leading
   to the colonization of Mesoamerica, the Amazon basin, and the West
   Indies, thus supporting the paleontological data. Our phylogeographic
   analysis revealed the spatial extent of the three Neotropical S.
   globulifera clades, which represent trans-Andes (Mesoamerica + west
   Ecuador), cis-Andes (Amazonia + Guiana), and the West Indies. Strong
   phylogeographic structure found among trans-Andean populations of S.
   globulifera stands in contrast to an absence of ITS nucleotide variation
   across the Amazon basin and indicates profound regional differences in
   the demographic history of this rain forest tree. Drawing from these
   results, we provide a historical biogeographic hypothesis to account for
   differences in the patterns of beta diversity within Mesoamerican and
   Amazonian forests.},
Publisher = {UNIV CHICAGO PRESS},
Address = {1427 E 60TH ST, CHICAGO, IL 60637-2954 USA},
Type = {Article},
Language = {English},
Affiliation = {Smithsonian Trop Res Inst, Unit 0948, APO, AA 34002 USA.
   Smithsonian Trop Res Inst, Unit 0948, APO, AA 34002 USA.
   Harvard Univ Herbaria, Cambridge, MA 02138 USA.},
DOI = {10.1086/379795},
ISSN = {0003-0147},
EISSN = {1537-5323},
Keywords = {internal transcribed spacer (ITS); phylogeography; molecular clock;
   fossils; long-distance dispersal; tropical trees},
Keywords-Plus = {MAHOGANY SWIETENIA-MACROPHYLLA; SYMPHONIA-GLOBULIFERA CLUSIACEAE;
   INTERNAL TRANSCRIBED SPACER; NUCLEAR RIBOSOMAL DNA; MESOAMERICAN
