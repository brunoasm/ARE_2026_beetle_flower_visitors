Pages = {131-134},
Month = {AUG},
Abstract = {The chemical composition of the oil on the anthers of Symphonia
   globulifera L. f., in which the pollen grains are completely immersed,
   was investigated. An unsaturated fatty acid methyl ester (methyl
   nervonate), very rare in plants, was found to be the only component of
