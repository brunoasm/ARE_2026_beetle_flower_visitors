@article{ WOS:000324623200004,
Author = {Furness, Carol A.},
Title = {EVOLUTION OF POLLEN AND TAPETAL CHARACTERS IN OCHNACEAE (MALPIGHIALES)},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {2013},
Volume = {174},
Number = {8},
Pages = {1134-1152},
Month = {OCT 1},
Abstract = {Ochnaceae are members of the recently recircumscribed and extremely
   diverse rosid order Malpighiales. They consist of three lineages,
   Ochnoideae, Quiinoideae, and Medusagyne oppositifolia (jellyfish tree),
   a critically endangered endemic from the Seychelles. However,
   relationships among these lineages are unclear, as are relationships
   between Ochnaceae and other Malpighiales. In this article, pollen and
   tapetum characters are evaluated in relation to recent hypotheses of
   relationships within Ochnaceae and between Ochnaceae and their putative
   relatives, with a focus on the remarkable pollen apertures with
   cone-like exine protrusions in Medusagyne. The comparative morphology
   and structure of pollen and tapetum are examined using TEM in selected
   Chrysobalanaceae (Chrysobalanus), Euphroniaceae (Euphronia), and
   Ochnaceae (Cespedesia, Medusagyne, Ochna, and Touroulia). Pollen and
   tapetum characters in Ochnaceae and selected outgroups are optimized
   onto a recent molecular phylogeny. The optimizations indicate that
   pollen morphological and structural characters are potentially
   informative in elucidating hypotheses of relationship within Ochnaceae.
   Very small pollen (mu m) is a synapomorphy for Ochnaceae, including
   Medusagyne, and is possibly related to buzz pollination in many taxa.
   Striate pollen could indicate a relationship between Medusagyne and
   Ochnoideae. Apertures with compound pores and large atria, apomorphic
   for Medusagyne, suggest a closer relationship with Ochnaceae with
   costate apertures and may have a protective function. The optimizations
   also indicate that clusioids and a clade of five families
   (Balanopaceae-Trigoniaceae-Dichapetalaceae-Euphroniaceae-Chrysobalanacea
   e) are more closely related to each other than to Ochnaceae. Ochnaceae
   pollen has probably become specialized in various ways, in response to
   environmental conditions and pollinators.},
Publisher = {UNIV CHICAGO PRESS},
Address = {1427 E 60TH ST, CHICAGO, IL 60637-2954 USA},
Type = {Article},
Language = {English},
Affiliation = {Furness, CA (Corresponding Author), Royal Bot Gardens, Jodrell Lab, Micromorphol Sect, Richmond TW9 3DS, Surrey, England.
   Royal Bot Gardens, Jodrell Lab, Micromorphol Sect, Richmond TW9 3DS, Surrey, England.},
