@article{ WOS:000290221600006,
Author = {Vlasakova, Blanka and Gustafsson, Mats H. G.},
Title = {<i>Clusia blattophila</i> sp nov (Clusiaceae) from an inselberg in
   French Guiana},
Journal = {NORDIC JOURNAL OF BOTANY},
Year = {2011},
Volume = {29},
Number = {2},
Pages = {178-181},
Abstract = {Clusia blattophila (Clusiaceae) is described as a new species. It is
   distinguished from related species in C. sect. Oedematopus by e.g. the
   relatively large and reflexed petals and from other Clusia spp. by
   having fewer (6-16) stamens and only four petals. Unique traits are the
   almost sessile inflorescence and the presence of a secretory pit at the
   floral apex in staminate flowers. The species grows epilithically and is
   known only from the Nouragues inselberg, a massive granite outcrop in
   eastern French Guiana. The name refers to its cockroach pollinators.},
