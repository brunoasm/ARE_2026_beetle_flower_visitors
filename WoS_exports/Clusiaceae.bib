   Wallace, Helen M., Univ Sunshine Coast, Fac Sci Hlth \& Educ, Maroochydore, Qld, Australia.
   Schmitt, Thomas, Univ Freiburg, Fac Biol, Dept Evolutionary Biol \& Anim Ecol, Freiburg, Germany.},
DOI = {10.1111/j.1442-9993.2010.02184.x},
ISSN = {1442-9985},
EISSN = {1442-9993},
Keywords = {Corymbia torelliana; cuticular profile; melittochory; resin; stingless
   bee},
