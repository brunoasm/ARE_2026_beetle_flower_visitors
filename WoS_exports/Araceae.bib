@article{ WOS:A1984TT95800008,
Author = {MEEUSE, BJD and SCHNEIDER, EL and HESS, CM and KIRKWOOD, K and PATT, JM},
Title = {ACTIVATION AND POSSIBLE ROLE OF THE FOOD-BODIES OF SAUROMATUM (ARACEAE)},
Journal = {ACTA BOTANICA NEERLANDICA},
Year = {1984},
Volume = {33},
Number = {4},
Pages = {483-496},
Abstract = {In the inflorescence of the voodoo lily (S. guttatum Schot), the
   spectacular thermogenic respiration which manifests itself in the
   so-called appendix on the 1st day of flowering (D-day) is coupled with
   unfolding of the spathe and is synchronized with a mild respiratory
   climacteric and fragrance production in the yellow, club-shaped organs
   on the central floral axis just above the pistillate (female) flowers.
   The agent (or mixture of agents) responsible for triggering these 3
   coordinated events originates in the primordia (buds) of the staminate
   (male) flowers, from which it begins to emigrate about 1 day before
   D-day. The club-shaped organs, their structure, the fragrance they
   produce, the chemical nature and mobilization of reserve material and
   the nature of the respiratory process are described. The results, based
   on literature, allow speculation as to their biological function, which
   may well be the stimulation of mating in visiting beetles, i.e.,
   extension of the span of time these potential pollinators spend in the
   inflorescences. The possibility that in addition the club-shaped organs
   serve as food for the beetles cannot be excluded.},
