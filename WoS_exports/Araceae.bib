@article{ WOS:A1980KE74200007,
Author = {CROAT, TB},
Title = {FLOWERING BEHAVIOR OF THE NEOTROPICAL GENUS ANTHURIUM (ARACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1980},
Volume = {67},
Number = {6},
Pages = {888-904},
Abstract = {The genus Anthurium (Araceae) is one of the most taxonomically complex
   genera in the neotropics. Studies of living material show modes of
   behavior which probably influence pollination biology and evolution.
   Separation of the sexes is accomplished by marked protogyny. Differences
   exist in the rate of development of flowers, the presence, source and
   amount of stigmatic nectar, and the method of pollen presentation. The
   genus exhibits an unusual pattern of staminal emergence. In all species
   studied the lateral pair of stamens are 1st to emerge, usually 1 at a
   time followed by the anterior and then the posterior stamens of the
   alternate pair. There are differences in the degree of exsertion, the
   disposition with respect to the stigma, and the degree of retraction and
   changes in pollen color. Some species have stamens which are retracted
   completely after opening; others have stamens which scarcely emerge but
   force the pollen out in long ribbons. Important differences also exist
   in flower aromas with both fly and bee pollination syndromes exhibited.
   All of these aspects of flowering behavior are natural phenomena,
   believed to be important in pollination biology.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
