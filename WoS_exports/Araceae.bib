@article{ WOS:000188786700004,
Author = {Angioy, AM and Stensmyr, MC and Urru, I and Puliafito, M and Collu, I
   and Hansson, BS},
Title = {Function of the heater: the dead horse arum revisited},
Journal = {PROCEEDINGS OF THE ROYAL SOCIETY B-BIOLOGICAL SCIENCES},
Year = {2004},
Volume = {271},
Number = {3},
Pages = {S13-S15},
Month = {FEB 7},
Abstract = {The dead horse arum, Helicodiceros muscivorus, is a conspicuous, foul
   smelling and thermogenic plant of the Araceae family. This Mediterranean
   arum lily copies several aspects of a carcass in order to attract
   carrion blowflies, which are subsequently exploited as unrewarded
   pollinators. We have previously shown that this plant exhibits a highly
   accurate olfactory carrion mimicry, which serves to attract the
   blowflies. In this study, we have investigated the role of thermogeny in
   the arum. We show that the thermogeny has a direct effect on the
   pollinators, altering their behaviour. By manipulating heat and odour
   release of the plant, we can show that the heat, produced along the
   appendix, is important to lure the flies to this structure, which is
   vital as the flies from the appendix are more prone to enter the trap
   chamber that houses the female and male florets. This study provides
   rare evidence for a direct functional role of thermogeny.},
Publisher = {ROYAL SOC},
Address = {6-9 CARLTON HOUSE TERRACE, LONDON SW1Y 5AG, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Hansson, BS (Corresponding Author), Swedish Univ Agr Sci, Dept Crop Sci, POB 44, SE-23053 Alnarp, Sweden.
   Swedish Univ Agr Sci, Dept Crop Sci, SE-23053 Alnarp, Sweden.
   Univ Cagliari, Dept Expt Biol, I-09042 Monserrato, Italy.},
DOI = {10.1098/rsbl.2003.0111},
ISSN = {0962-8452},
Keywords = {thermogeny; Araceae; mimicry; Diptera},
Keywords-Plus = {ARACEAE; PHILODENDRON},
Research-Areas = {Life Sciences \& Biomedicine - Other Topics; Environmental Sciences \&
