@article{ WOS:A1976CR23400004,
Author = {WILLIAMS, NH and DRESSLER, RL},
Title = {EUGLOSSINE POLLINATION OF SPATHIPHYLLUM (ARACEAE)},
Journal = {SELBYANA},
Year = {1976},
Volume = {1},
Number = {4},
Pages = {349-356},
Abstract = {Of 26 spp. of euglossine bees which visit Spathiphyllum, only 3 visit
   more than 1 sp. All those sharing pollinators are allopatric or are in
   different sections of the genus. Floral fragrances may serve as the
   isolating mechanism between closely related species of Spathiphyllum,
   and pollination by male euglossine bees may account for speciation
   trends in neotropical species of Spathiphyllum. Primitive and advanced
   characters in Spathiphylleae are discussed. {[}The species of
