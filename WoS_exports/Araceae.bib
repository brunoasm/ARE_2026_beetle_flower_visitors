@article{ WOS:000084827000009,
Author = {Gibernau, M and Barabé, D and Cerdan, P and Dejean, A},
Title = {Beetle pollination of <i>Philodendron solimoesense</i> (Araceae) in
   French Guiana},
Journal = {INTERNATIONAL JOURNAL OF PLANT SCIENCES},
Year = {1999},
Volume = {160},
Number = {6},
Pages = {1135-1143},
Month = {NOV},
Abstract = {The pollination of Philodendron solimoesense (subgenus Meconostigma) was
   studied in four populations of French Guiana. Flowering is asynchronous
   within each population during July and the flowering cycle is a 2-d
   process. Numerous insects visit Philodendron inflorescences, but the
   main pollinator seems to be Cyclocephala colasi (Scarabaeidae,
   Dynastinae). The pollination process displays aspects typical of beetle
   pollination: the production of heat and of a strong odor, the presence
   of a food reward (stigmatic secretion and sterile male flowers), and the
   presence of a copula don chamber. Flower heat production is important
   (ca. 11 degrees C above the ambient air) and may help to volatilize the
   fragrance. Attraction and choice-test experiments showed that C. colasi
   is not likely to depend on chemical information (such as pheromone) to
   localize conspecifics but may rely instead on stimuli produced by the
   inflorescences in order to meet mating partners.},
