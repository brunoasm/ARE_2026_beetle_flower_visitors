Title = {`UPLB White' and `Eternity': Two New Varieties of Anthurium for Cut
   Flowers},
Journal = {PHILIPPINE AGRICULTURAL SCIENTIST},
Year = {2009},
Volume = {92},
Number = {4},
Pages = {441-445},
Month = {DEC},
Abstract = {Anthurium `UPLB White' is a selection from among the germplasm
   collection of anthuriums at the University of the Philippines Los Banos
   (UPLB). The spathe is basically white with occasional pink blushes at
   maturity, slightly ridged with medium texture, large to extra large in
   size, broad heart in shape and with open lobes. The spadix is reddish
   pink and reclining.
   Anthurium `Eternity' is a selection from among the progenies of the open
   pollinated A. `Blushing Innocence. The spathe is light pink, slightly
   ridged with medium texture, medium to large in size, broad heart in
   shape with closed lobes. The reclining spadix is reddish brown.
   The two selections were micropropagated and were registered with the
   National Seed Industry Council (NSIC), Department of Agriculture. The
   registry number of `UPLB White' is NSIC 2008 Or 63 while that of
   `Eternity' is NSIC 2008 Or 64.},
