@article{ WOS:A1997XP66700018,
Author = {Willson, MF and Hennon, PE},
Title = {The natural history of western skunk cabbage (Lysichiton americanum) in
   southeast Alaska},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1997},
Volume = {75},
Number = {6},
Pages = {1022-1025},
Month = {JUN},
Abstract = {Western skunk cabbage is protogynous, with great seasonal variation in
   floral sex ratios. It is pollinated chiefly by a small staphylinid
   beetle (Pelecomalius testaceum), which was found most abundantly on
   male-phase inflorescences in southeast Alaska. Yellow spathes attracted
   more beetles than green ones, especially on male inflorescences. The
   gelatinous coat around the seed impeded local dispersal, slowed
   germination slightly, had no detectable effect on seed predation, and
   had a possible deterrent effect on a pathogenic fungus.},
