Volume = {12},
Month = {JUL 24},
Abstract = {We compared Araceae abundance among mature forests, secondary forests,
   and plantations (8-14 years) in central Panama. Araceae colonization was
   virtually nonexistent in secondary forests and plantations. Low
   humidity, relatively short forest stature, and time could drive this
   absence. These results highlight the conservation value of forests
   containing intact populations of Araceae.},
