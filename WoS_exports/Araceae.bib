@article{ WOS:000766076000001,
Author = {Etl, Florian and Francke, Wittko and Schoenenberger, Jurg and Doetterl,
   Stefan},
Title = {Chemical Attraction of Gall Midge Pollinators (Cecidomyiidae:
   Cecidomyiinae) to <i>Anthurium acutangulum</i> (Araceae)},
Journal = {JOURNAL OF CHEMICAL ECOLOGY},
Year = {2022},
Volume = {48},
Number = {3, SI},
Pages = {263-269},
Month = {MAR},
Abstract = {Flowering plants often use chemical signals to attract their
   pollinators, and compounds that elicit attraction are known for several
   groups of pollinators. For other pollinators such as gall midges,
   however, compounds responsible for their attraction to flowers are
   largely unknown. Here, we describe the pollination biology of Anthurium
   acutangulum, a Neotropical aroid species found to be attractive to gall
   midges. We collected and analyzed its floral scent by dynamic headspace
   collections and gas chromatography coupled to mass spectrometry, and
   identified compounds responsible for pollinator attraction. The
   inflorescences were almost exclusively visited by gall midges (females;
   Cecidomyiidae: Cecidomyiinae) and released a strong scent reminiscent of
   freshly cut cucumber, mainly (5S,7S)-trans-conophthorin,
   (E2,Z6)-2,6-nonadienal, and cis-conophthorin. Behavioral assays with the
   two most abundant compounds identified (E2,Z6)-2,6-nonadienal as being
   highly attractive to the female gall midge pollinators, whereas
   (5S,7S)-trans-conophthorin was not attractive. Overall, we introduce a
   new specialized gall midge pollination system and identify the chemical
   mediating communication between the pollinators and their host plants.},
Publisher = {SPRINGER},
Address = {VAN GODEWIJCKSTRAAT 30, 3311 GZ DORDRECHT, NETHERLANDS},
Type = {Article},
Language = {English},
Affiliation = {Etl, F (Corresponding Author), Univ Vienna, Dept Bot \& Biodivers Res, Vienna, Austria.
   Dötterl, S (Corresponding Author), Paris Lodron Univ Salzburg, Dept Environm \& Biodivers, Salzburg, Austria.
   Etl, Florian; Schoenenberger, Jurg, Univ Vienna, Dept Bot \& Biodivers Res, Vienna, Austria.
   Francke, Wittko, Univ Hamburg, Inst Organ Chem, Hamburg, Germany.
   Doetterl, Stefan, Paris Lodron Univ Salzburg, Dept Environm \& Biodivers, Salzburg, Austria.},
DOI = {10.1007/s10886-022-01349-3},
EarlyAccessDate = {MAR 2022},
ISSN = {0098-0331},
EISSN = {1573-1561},
Keywords = {Chemical communication; Cucumber aldehyde; Flower scent; Gall midge
   Pollination; Spiroacetals},
Keywords-Plus = {THEOBROMA-CACAO L; DIPTERA; FLOWER; EVOLUTION; ECOLOGY},
Research-Areas = {Biochemistry \& Molecular Biology; Environmental Sciences \& Ecology},
Web-of-Science-Categories  = {Biochemistry \& Molecular Biology; Ecology},
Author-Email = {florian.etl@univie.ac.at},
Affiliations = {University of Vienna; University of Hamburg; Salzburg University},
ResearcherID-Numbers = {ETL, FLORIAN/AAE-8703-2020
   Schonenberger, Jurg/D-3413-2014},
ORCID-Numbers = {Dotterl, Stefan/0000-0001-5228-1332
   Schonenberger, Jurg/0000-0001-6791-2731},
