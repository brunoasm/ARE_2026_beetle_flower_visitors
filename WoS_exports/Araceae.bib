ISSN = {0024-4066},
EISSN = {1095-8312},
Keywords = {breeding system; Dionconotus; inflorescence odour; Lasioglossum},
Keywords-Plus = {DECEPTIVE POLLINATION; BEETLE POLLINATION; SCENT COMPOSITION; FLOWERS;
   BIOLOGY; CONSEQUENCES; COLEOPTERA; BEHAVIOR; ORCHIDS},
