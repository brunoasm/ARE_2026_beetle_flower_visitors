Address = {SACHSENPLATZ 4-6, PO BOX 89, A-1201 WIEN, AUSTRIA},
Type = {Article},
Language = {English},
Affiliation = {Wong, SY (Corresponding Author), Univ Malaysia Sarawak, Fac Resource Sci \& Technol, Dept Plant Sci \& Environm Ecol, Kota Samarahan 94300, Malaysia.
   Low, Shook Ling; Wong, Sin Yeng, Univ Malaysia Sarawak, Fac Resource Sci \& Technol, Dept Plant Sci \& Environm Ecol, Kota Samarahan 94300, Malaysia.
