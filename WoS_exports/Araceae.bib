   Gottsberger, Gerhard; Silberbauer-Gottsberger, Ilse, Univ Ulm, Bot Garden, D-89081 Ulm, Germany.
   Gottsberger, Gerhard; Silberbauer-Gottsberger, Ilse, Univ Ulm, Herbarium, D-89081 Ulm, Germany.
   Doetterl, Stefan, Univ Bayreuth, Dept Plant Systemat, D-95440 Bayreuth, Germany.},
DOI = {10.1007/s00606-013-0763-4},
