   Bournemouth Univ, Sch Conservat Sci, Poole BH12 5BB, Dorset, England.},
DOI = {10.2307/3558352},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Araceae; Arum italicum; between-plant distance; floral display;
   flowering dynamics; flowering synchrony; inflorescence number;
   pollination context},
Keywords-Plus = {REPRODUCTIVE SUCCESS; BEETLE POLLINATION; POLLEN LIMITATION;
   HEAT-PRODUCTION; FLORAL DISPLAY; SELECTION; SET; POPULATION; SIZE;
