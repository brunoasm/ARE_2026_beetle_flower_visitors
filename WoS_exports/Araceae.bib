Language = {English},
Affiliation = {Univ Miami, Dept Biol, POB 249118, Coral Gables, FL 33124 USA.
   Fdn EcoAndina, Wildlife Conservat Soc Colombia Program, Cali, Colombia.
   Univ Valle, Dept Biol, Cali, Colombia.},
DOI = {10.1111/j.1744-7429.2005.00049.x},
ISSN = {0006-3606},
EISSN = {1744-7429},
Keywords = {Andes; Araceae; Colombia; Cyclocephala; Dinastinae; Macrostola
   costulata; Nitidulidae; pollination; seed predation; Xanthosoma},
