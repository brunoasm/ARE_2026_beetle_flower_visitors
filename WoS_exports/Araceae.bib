@article{ WOS:000247094000008,
Author = {Chouteau, Mathieu and Barabe, Denis and Gibernau, Marc},
Title = {Thermogenesis in <i>Syngonium</i> (Araceae)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {2007},
Volume = {85},
Number = {2},
Pages = {184-190},
Month = {FEB},
Abstract = {Floral cycles and spadix temperatures were recorded for two species of
   Syngonium: Syngonium schottianum Wendl. ex Schott (section Cordatum) and
   Syngonium angustatum Schott (section Syngonium). Both species exhibited
   a 3-day flowering cycle, beginning with stigma receptivity and opening
   of the spathe the first day, the female phase continues over the second
   day, and the male phase continues over the third day. These species
   displayed two distinct patterns of heat production during flowering. In
   S. schottianum, the spadix warmed up twice during the beginning of the
   second and third nights, but in S. angustatum, the spadix warmed up
   twice the second day, once the second night, and once the third day.
   These different thermogenic cycles are discussed in regard to other
   genera that are phylogenetically close or sharing similar flowering and
   thermogenic cycles.},
