Month = {OCT},
Abstract = {Homalomena lambirensis S. Y. Wong \& P. C. Boyce is described and
   illustrated as a new species of the Homalomena Hanneae complex
   {[}Cyrtocladon clade] from Lambir Hills National Park, northeast
