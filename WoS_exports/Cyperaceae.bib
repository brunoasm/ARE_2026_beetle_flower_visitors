   Nguyen Thi Kim Thanh, Vietnam Natl Univ, VNU Univ Sci, Fac Biol, Dept Bot, Hanoi, Vietnam.
   Vu Anh Tai, Vietnam Acad Sci \& Technol, Inst Geog, Hanoi, Vietnam.},
DOI = {10.1600/036364417X695998},
