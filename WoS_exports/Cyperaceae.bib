@article{ WOS:000300170300007,
Author = {Kaur, N. and Datson, P. M. and Murray, B. G.},
Title = {Hybridization amongst New Zealand <i>Schoenus</i> (Cyperaceae)?},
Journal = {NEW ZEALAND JOURNAL OF BOTANY},
Year = {2011},
Volume = {49},
Number = {4},
Pages = {503-507},
Abstract = {Artificial pollinations were made between five New Zealand species of
   Schoenus (Cyperaceae) to determine whether they could form interspecific
   hybrids. No hybrids were produced and the site of the interspecific
   incompatibility was investigated using fluorescence microscopy. The site
   of pollen inhibition varied in the different cross combinations. No
   relationship was observed between pollen size and subsequent pollen
   germination and tube growth in the style. The results do not support the
   claim that S. concinnus and S. nitens form hybrids in nature.},
