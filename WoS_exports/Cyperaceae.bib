@article{ WOS:000265832000008,
Author = {King, Matthew G. and Roalson, Eric H.},
Title = {Isolation and characterization of 11 microsatellite loci from <i>Carex
   macrocephala</i> (Cyperaceae)},
Journal = {CONSERVATION GENETICS},
Year = {2009},
Volume = {10},
Number = {3},
Pages = {531-533},
Month = {JUN},
Abstract = {Carex macrocephala (Cyperaceae) is a species of great conservation
   concern along the northwest coast of North America. Using a
   biotinylated-streptavidin bead protocol, we successfully isolated and
   characterized 11 microsatellite loci from a C. macrocephala genomic
   library. Although these loci are polymorphic, the scored populations
   exhibit a significant deficiency in heterozygosity. Carex macrocephala
   is a self-pollinating rhizomatously spreading sedge, consequently this
   may contribute to the observed patterns.},
