@article{ WOS:A1955WN37600007,
Author = {LEPPIK, EE},
Title = {DICHROMENA-CILIATA, A NOTEWORTHY ENTOMOPHILOUS PLANT AMONG CYPERACEAE},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1955},
Volume = {42},
Number = {5},
Pages = {455-458},
Abstract = {A number of insects have been recorded which act regularly as carriers
   of pollen of Dichromena ciliata. This is a rare case of insect
   pollination among Cyperaceae. White bases of the upper leaves function
   as petals, imitating a white corolla of an ordinary flower. Stingless
   wild bees, bumblebees, and honey bees were regular visitors, but no
   moths, butterflies or flies were recorded on Dichromena ciliata. Some
   observable evolu-tionary tendencies of this peculiar Dichromena
   ``flower{''} are discussed.},
