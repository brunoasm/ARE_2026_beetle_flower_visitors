Language = {English},
Affiliation = {Möller, M (Corresponding Author), Royal Bot Garden Edinburgh, 20A Inverleith Row, Edinburgh EH3 5LR, Midlothian, Scotland.
   Royal Bot Garden Edinburgh, Edinburgh EH3 5LR, Midlothian, Scotland.
   Scottish Crop Res Inst, Dundee DD2 5DA, Scotland.
   Nat Hist Museum, Dept Bot, London SW7 5BD, England.},
DOI = {10.1006/anbo.2000.1167},
ISSN = {0305-7364},
Keywords = {Acmopyle pancheri; gymnosperms; NMR imaging; nuclear magnetic resonance
   imaging; Phyllocladaceae; Phyllocladus hypophyllus; Podocarpaceae;
   pollination drop; pollination mechanism},
