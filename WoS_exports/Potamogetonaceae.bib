   HARVARD UNIV FOREST,PETERSHAM,MA 01366.},
DOI = {10.1007/BF00940398},
ISSN = {0378-2697},
Keywords = {MARINE ANGIOSPERMS; ZOSTERACEAE; PHYLLOSPADIX-SCOULERI; ABIOTIC
   POLLINATION; DIOECISM; HYDROPHILOUS POLLINATION; SUBMARINE POLLINATION;
   SURFACE POLLINATION; SEAGRASSES},
