Pages = {67-70},
Month = {JAN},
Abstract = {Restriction fragment length polymorphisms in the internal transcribed
   spacer region of ribosomal DNA and in the chloroplast genome combine to
   confirm the existence of Potamogeton x bottnicus (P. pectinatus x P.
   vaginatus) in Britain. One of the parents, P. vaginatus, is not
   currently a member of the British nora, but did occur here in the past
   (the latest fossil fruits date from 30 000 BP) and the hybrid may
