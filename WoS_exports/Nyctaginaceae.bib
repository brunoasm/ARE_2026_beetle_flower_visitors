@article{ WOS:000259334900014,
Author = {Douglas, Norman A.},
Title = {<i>Tripterocalyx carneus</i> (Nyctaginaceae) is self-compatible},
Journal = {SOUTHWESTERN NATURALIST},
Year = {2008},
Volume = {53},
Number = {3},
Pages = {403-406},
Month = {SEP},
Abstract = {Recent phylogenetic work has demonstrated that the ability of species of
   the angiosperm family Nyctaginaceae to self-fertilize is evolutionarily
   labile. However, the potential for further investigation of the
   evolution of mating systems in the family is limited, because there is
   no information on reproductive biology for several genera. I performed
   an experiment on a natural population of Tripterocalyx campus to
   determine whether this species is self-compatible. Individual flowers
   were emasculated, bagged to exclude pollinators, or both. Flowers that
   were bagged but not emasculated set viable fruit in the majority of
   cases, which demonstrates that this species is self-compatible.},
