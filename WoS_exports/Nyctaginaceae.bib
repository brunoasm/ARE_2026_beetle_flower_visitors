@article{ WOS:A1964AZ44800001,
Author = {BAKER, HG},
Title = {VARIATION IN STYLE LENGTH IN RELATION TO OUTBREEDING IN MIRABILIS (
   NYCTAGINACEAE )},
Journal = {EVOLUTION},
Year = {1964},
Volume = {18},
Number = {3},
Pages = {507+},
Abstract = {The significance of heterostyly as a pollination system promoting
   cross-fertilization is discussed and reasons for the rarity of tristyly
   compared with distyly are suggested. Investigations of the apparent
   tristyly in species of the section Quamoclidion of Mirabilis are
   reported. Style length variation is shown to be continuous, there is no
   complementary relation between style and stamen lengths and no linkage
   between style length and the incompatibility system. It is concluded
   that variability in style length is probably not playing a significant
   role in the promotion of outbreeding in these species; neither is it a
   stage in the development of a heterostylous breeding system.},
