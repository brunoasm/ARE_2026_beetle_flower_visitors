ISSN = {0120-548X},
EISSN = {1900-1649},
Keywords = {andromonoecy; entomophily; incomplete protogyny; self-incompatibility;
   social bees},
Keywords-Plus = {SOUTHEASTERN BRAZIL; NEW-ZEALAND; PATTERNS; POLLEN; GENUS; ANDROMONOECY;
   PHYLOGENY; DIVERSITY; MYRTACEAE},
