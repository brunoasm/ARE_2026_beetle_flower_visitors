   Univ Toronto, Dept Bot, Toronto, ON M5S 3B2, Canada.
   Tulane Univ, Cell \& Mol Biol Dept, New Orleans, LA 70118 USA.
   CSIRO, Waite Labs, Glen Osmond, SA 5064, Australia.},
DOI = {10.1093/aob/mch113},
ISSN = {0305-7364},
EISSN = {1095-8290},
Keywords = {Illicium floridanum; self-incompatibility; self-sterility; complete
   dichogamy; early-acting inbreeding depression; Illiciaceae;
   Austrobaileyales},
Keywords-Plus = {INBREEDING DEPRESSION; FLORAL BIOLOGY; POSTPOLLINATION EVENTS;
