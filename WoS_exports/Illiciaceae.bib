@article{ WOS:000269538500003,
Author = {Carlquist, Sherwin},
Title = {Xylem heterochrony: an unappreciated key to angiosperm origin and
   diversifications},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
