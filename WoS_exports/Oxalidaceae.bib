@article{ WOS:A1981MS21400001,
Author = {WELLER, SG},
Title = {POLLINATION BIOLOGY OF HETEROMORPHIC POPULATIONS OF OXALIS-ALPINA (ROSE)
   KNUTH (OXALIDACEAE) IN SOUTHEASTERN ARIZONA},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1981},
Volume = {83},
Number = {3},
Pages = {189-198},
Abstract = {In southeastern Arizona, heterostylous (often trimorphic) populations of
   O. alpina (Rose) Knuth are visited most commonly by females of the
   solitary bee Heterosarus bakeri Cockerell. Bees collect pollen from
   flowers and are probably the major pollinators of O. alpina in this
   region. Analysis of pollen loads from the corbiculae of H. bakeri
   suggests that individual bees may specialize temporally on different
   floral forms. The apparent preferential collection of pollen probably
   results from spatial segregation of morphs and the localized foraging
   behavior of bees rather than preference on the part of individual bees
   for particular stylar forms. As a group, bees visit floral morphs of O.
   alpina indiscriminately, even though individual bees may have a
   preponderance of pollen from 1 morph type. Despite spatial segregation
   leading to pollinator flights between members of the same
   incompatibility group, capsule and seed production in populations of O.
   alpina is high for all forms. Loss of the mid form in some populations
   cannot be attributed to pollinator preferences for individual style
   morphs.},
Publisher = {OXFORD UNIV PRESS},
