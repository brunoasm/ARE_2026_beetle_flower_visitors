   Univ Munich, Dept Biol, D-80638 Munich, Germany.},
DOI = {10.1093/aob/mcl121},
ISSN = {0305-7364},
Keywords = {introduced species; Oxalis; male sterility; pollen viability; chromosome
   counts; vegetative reproduction.},
Keywords-Plus = {BREEDING SYSTEM; OXALIDACEAE; TUBEROSA; CHROMOSOME},
Research-Areas = {Plant Sciences},
