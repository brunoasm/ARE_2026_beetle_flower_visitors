Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Demarco, D (Corresponding Author), Univ Sao Paulo, Dept Bot, Inst Biociencias, BR-05508090 Sao Paulo, SP, Brazil.
   Hirao, Yasmin V.; Monteiro, Mariana M.; Demarco, Diego, Univ Sao Paulo, Dept Bot, Inst Biociencias, BR-05508090 Sao Paulo, SP, Brazil.},
DOI = {10.1093/botlinnean/boy076},
ISSN = {0024-4074},
EISSN = {1095-8339},
Keywords = {asynchronous development; false septum; floral ontogeny; gynoecium;
   morphological evolution; staminode},
