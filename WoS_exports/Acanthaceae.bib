@article{ WOS:A1983RQ00300007,
Author = {MCDADE, LA},
Title = {POLLINATION INTENSITY AND SEED SET IN TRICHANTHERA-GIGANTEA
   (ACANTHACEAE)},
Journal = {BIOTROPICA},
Year = {1983},
Volume = {15},
Number = {2},
Pages = {122-124},
Abstract = {Counts of pollen grains on the stigmas of individual flowers of T.
   gigantea in Central Panama were related to seed set. At least 8 grains
   were necessary for fruit set in this species and mean seed set per fruit
   was less than 1 (of a maximum of 8). Less than 50\% of the flowers (108
   of 277) received 8 or more pollen grains and, of these, only 51 set
   fruit. Pollination probably limits seed production by this species at
   this site.},
