@article{ WOS:000281623200017,
Author = {Tripp, Erin A.},
Title = {Taxonomic Revision of <i>Ruellia</i> Section <i>Chiropterophila</i>
   (Acanthaceae): a Lineage of Rare and Endemic Species from Mexico},
Journal = {SYSTEMATIC BOTANY},
Year = {2010},
Volume = {35},
Number = {3},
Pages = {629-661},
Month = {JUL-SEP},
Abstract = {Ruellia section Chiropterophila as here recognized contains 11 species
   endemic to areas in and around the transnational Volcanic Belt of Mexico
   the Sierra Madre del Sur, the Balsas Depression, and the Altiplano Most
   of these species are rare, and nearly half are known only from one of
   two collections Of the remaining six two are restricted to single states
   One species described as new to science, Ruellia taslobasensis, is
   distinguished from a close relative by its smaller corollas, calyces,
   and fruits Ruellia chilpancingania is placed into synonymy with R
   sororia Ruellia section Urceolata is synonymized with sect
   Cluropterophila Two species previously treated in sect Chiropterophila,
   Nudist pet talons (as R palmeri) and R carmenacunliae, are excluded from
   the section Phylogenetic analyses using three chloroplast markers
   (trnG-trnR, (trnG-trnS, psbA-trnH) and one nuclear marker (ITS + 5 8S)
   were conducted to test the monophyly of sect Chiropterophila and to
   reconstruct relationships among species Sequences were successfully
   generated for all species in sect Chiropterophila, some are known only
   from old herbarium material One of these, collected in 1894, is among
   the oldest known plant herbarium specimens lobe successfully sequenced
   Analyses reveal that section Chiropterophila is monophyletic but not
   well supported, an alternative hypothesis of nonmonophyly of the section
   could not be rejected Species descriptions, botanical illustrations, and
   a dichotomous key to distinguish the 11 taxa in Ruellia sect
   Cliropteroplula are provided},
