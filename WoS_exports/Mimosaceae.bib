@article{ WOS:000259950800001,
Author = {Bumrungsri, Sara and Harbit, Andrew and Benzie, Charles and Carmouche,
   Kristine and Sridith, Kitichate and Racey, Paul},
Title = {The pollination ecology of two species of <i>Parkia</i> (Mimosaceae) in
   southern Thailand},
Journal = {JOURNAL OF TROPICAL ECOLOGY},
Year = {2008},
Volume = {24},
Number = {5},
Pages = {467-475},
Month = {SEP},
Abstract = {Although the floral traits of Parkia conform to the bat-pollination
   syndrome, many visitors other than bats have been observed at their
   flowers. Some chiropterophilous plants are also pollinated by other
   animals; the syndrome is therefore best regarded as a hypothesis for
   which field observations and pollination experiments are required. The
   present study aimed. for the first time, to determine the breeding
   system of the economically important canopy trees. Parkia speciosa and
   P. timoriana, and to identify their pollinators. Pollination experiments
   carried out in Trang and Songkhla Provinces. in 28 trees of P. speciosa
   and four P. timoriana indicated that they are self incompatible. Open
   pollination resulted in the highest fruit set (average 60-67\% of
   inflorescences per tree) although this was not significantly different
   from hand-crossed pollination (48-60\%). Insect pollination resulted in
   fruit set in only 12\% of P. speciosa inflorescences. Fruit bats, mainly
   Eonycteris spelaea, visit flowering plants continuously from dusk till
   after midnight. Nocturnal and diurnal insects (moths and stingless bees
   respectively) visit capitula, mostly at the nectar zone. Nectarivorous
   bats are the most effective pollinator for P. speciosa and P. timoriana.
   The fact that populations of E. spelaea appear to be declining
   throughout their distribution is therefore a matter of increasing
   concern.},
Publisher = {CAMBRIDGE UNIV PRESS},
Address = {32 AVENUE OF THE AMERICAS, NEW YORK, NY 10013-2473 USA},
Type = {Article},
Language = {English},
Affiliation = {Bumrungsri, S (Corresponding Author), Prince Songkla Univ, Dept Biol, Hat Yai 90112, Songkhla, Thailand.
   Bumrungsri, Sara; Sridith, Kitichate, Prince Songkla Univ, Dept Biol, Hat Yai 90112, Songkhla, Thailand.
   Harbit, Andrew; Benzie, Charles; Carmouche, Kristine; Racey, Paul, Univ Aberdeen, Sch Biol Sci, Aberdeen, Scotland.},
DOI = {10.1017/S0266467408005191},
ISSN = {0266-4674},
EISSN = {1469-7831},
Keywords = {chiropterophily; Eonycteris spelaea; insect pollination; pollination
   syndrome self-incompatibility},
Keywords-Plus = {REPRODUCTIVE-BIOLOGY; RAIN-FOREST; BATS; LEGUMINOSAE; EVOLUTION;
   SYSTEMS; FRUIT},
Research-Areas = {Environmental Sciences \& Ecology},
Web-of-Science-Categories  = {Ecology},
Author-Email = {sara\_psu@hotmail.com},
Affiliations = {Prince of Songkla University; University of Aberdeen},
Funding-Acknowledgement = {Thailand Research Fund; Carnegie Trust for the Universities of Scotland;
   British Council},
Funding-Text = {The authors thank D. Pongmanawuti. S. Wongchana, B. Wongchana and staff
   of The Trang Horticulture Station, and S. Thong-Aree and staff of
   Bala-Hala Wildlife Research Station for permitting us to carry out field
