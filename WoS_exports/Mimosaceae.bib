   3168, AUSTRALIA},
Type = {Article; Proceedings Paper},
Language = {English},
Affiliation = {Coates, DJ (Corresponding Author), Dept Environm \& Conservat, Locked Bag 104,Bentley Delivery Ctr, Bentley, WA 6983, Australia.
