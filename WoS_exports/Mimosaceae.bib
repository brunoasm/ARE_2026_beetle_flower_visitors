Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article; Proceedings Paper},
Language = {English},
Affiliation = {UNIV COLL N WALES, SCH AGR \& FOREST SCI, BANGOR LL57 2UW, GWYNEDD, WALES.},
