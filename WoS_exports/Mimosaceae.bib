@article{ WOS:A1957XE15100007,
Author = {BAKER, HG and HARRIS, BJ},
Title = {THE POLLINATION OF PARKIA BY BATS AND ITS ATTENDANT EVOLUTIONARY
   PROBLEMS},
Journal = {EVOLUTION},
Year = {1957},
Volume = {11},
Number = {4},
Pages = {449+},
Abstract = {An historical survey (51 Dats as pollinators is followed by an account
   of the pollination of Parkia clappertoniana Keay (Mimosaceae) in Ghana.
   At dusk, the bat Epomophorus gambianus seeks nectar from both staminate
   and pistillate inflorescences. Later, another bat, Nanonycteris
   veldkampii takes over. All stages of visitations are illustrated
   photographically. Both bats appear to be important pollen-vectors. The
   geographical range of potentially bat-pollinated species of Parkia is
   considered in relation to that of nectar-lapping bats. Bat-pollination
   of Parkia is also known from the East Indies and is likely in Amazonia.
   Megachiroptera are restricted to the Old World tropics and
   nectar-lappers apparently have only evolved recently from insectivorous
   Microchiroptera in the New World. Nevertheless, Parkia may have
   originated in the New World tropics and appears to have a longer history
   than that known for bats. Its pre-Eocene pollinators remain a mystery.},
