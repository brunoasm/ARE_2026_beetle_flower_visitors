@article{ WOS:A1989CE15000009,
Author = {MORRISON, DA and MYERSCOUGH, PJ},
Title = {TEMPORAL REGULATION OF MATERNAL INVESTMENT IN POPULATIONS OF THE
   PERENNIAL LEGUME ACACIA-SUAVEOLENS},
Journal = {ECOLOGY},
Year = {1989},
Volume = {70},
Number = {6},
Pages = {1629-1638},
Month = {DEC},
Abstract = {Temporal regulation of maternal investment was studied in eight
   noncultivated populations of the shrub Acacia suaveolens (Mimosaceae)
   over 3 yr. The eight populations were each even-aged, covering a range
   of plant ages up to 17 yr. The plants produce seed in their 2nd yr, and
   live for up to 20 yr. The number of inflorescence buds, number of
   flowers within buds, proportion of hermaphrodite flowers, proportion of
   ovaries forming fruits, number of immature fruits developed and aborted
   or eaten,  and number of fruits matured were recorded each year on 15
   plants in each population. Evidence for limitation of the potential
   extent of maternal investment was found at a number of these
   developmental stages. The most pronounced was the number of
   inflorescences produced per plant, which was inversely related to plant
   age. However, only 44\% of the flowers produced ovaries, only 25\% of
   these ovaries produced fruits, and 60\% of these fruits absorbed shortly
   after formation, thus indicating a rapid canalization of maternal
   expenditure into fewer units as the amount of required investment
   increases. Clear evidence of adjustment of maternal investment was found
   at only two developmental stages. The first was the number of
   inflorescences produced per plant, which was related to rainfall during
   the initiation of inflorescence buds. The second was the development of
   fertilized ovaries during the initial stage of fruit growth. Control of
   maternal investment through the early development of the fruits was
   confirmed by experimental pollination in the field, in which
   fertilization of ovaries was both increased and decreased in relation to
   that of open-pollinated controls. The number of fruits matured was
   independent of the level of fertilization of the ovaries, and was
   controlled by levels of abortion during the initial development of young
   fruits.},
