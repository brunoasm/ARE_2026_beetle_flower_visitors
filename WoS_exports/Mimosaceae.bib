   Rodger, James G.; Johnson, Steven D., Univ KwaZulu Natal, Sch Life Sci, Ctr Invas Biol, ZA-3209 Pietermaritzburg, South Africa.},
DOI = {10.1016/j.sajb.2013.08.002},
ISSN = {0254-6299},
