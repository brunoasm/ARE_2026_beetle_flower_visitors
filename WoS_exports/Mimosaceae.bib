Type = {Article},
Language = {English},
Affiliation = {de Freitas, ADD (Corresponding Author), Univ Fed Fluminense, Inst Geociencias, Niteroi, RJ, Brazil.
   Barth, Monika, Inst Oswaldo Cruz, Rio De Janeiro, Brazil.
   de Freitas, Alex da Silva, Univ Fed Fluminense, Inst Geociencias, Niteroi, RJ, Brazil.},
