@article{ WOS:000229461700002,
Author = {Gross, CL},
Title = {A comparison of the sexual systems in the trees from the Australian
   tropics with other tropical biomes - More monoecy but why?},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2005},
Volume = {92},
Number = {6},
Pages = {907-919},
Month = {JUN},
Abstract = {Rainforests in tropical Australia occupy a very small, discontinuous
   area (< 1\% of the continent), yet they are floristically diverse (c.
   2800 vascular species) with high endemicity. There is a distinctive
   Gondwanan and autochthonous element, and some of the world's ancestral
   links to the basal angiosperms are uniquely found here. The rainforests
   can be evergreen or deciduous, but there is a distinct dry season with
   intermittent drought years. With these characters, the evolutionary
   pressures on species may be very different to that experienced
   elsewhere. Sexual systems of 1113 tree species (83 families) from
   northern Australia were compared with published accounts from the paleo-
   and neotropics. Hermaphroditic systems dominated all tree floras, and
   within all floras but Australia dioecy was the most common unisexual
   system. In tropical Australia, however, significantly more monoecy than
   dioecy occurred at landscape and community levels. Incorporating
   phylogeny revealed that sex and fruit types are significantly clustered.
   The Euphorbiaceae and Sapindaceae contributed c. 50\% of the monoecious
   taxa. Inefficient pollinators (e.g., beetles) may have favored the
   maintenance of monoecy at the expense of dioecy in the Australian
   tropics although < 1\% of the flora has been studied for pollinators and
   none of the monoecious tree species.},
Publisher = {BOTANICAL SOC AMER INC},
Address = {PO BOX 299, ST LOUIS, MO 63166-0299 USA},
Type = {Article},
Language = {English},
Affiliation = {Gross, CL (Corresponding Author), Univ New England, Armidale, NSW 2351, Australia.
   Univ New England, Armidale, NSW 2351, Australia.},
DOI = {10.3732/ajb.92.6.907},
ISSN = {0002-9122},
Keywords = {Australian rainforest; meta-analysis; monoecy; phylogenetic
   conservatism; pollinator efficiency; supertree},
Keywords-Plus = {RAIN-FOREST TREES; MYRISTICA-INSIPIDA MYRISTICACEAE; MELASTOMA-AFFINE
   MELASTOMATACEAE; BREEDING SYSTEMS; FLOWERING PLANTS; FLORAL BIOLOGY;
   REPRODUCTIVE-BIOLOGY; PIONEER SHRUB; SEED PLANTS; DIOECY},
