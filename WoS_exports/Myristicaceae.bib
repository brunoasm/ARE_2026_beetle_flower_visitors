Affiliation = {ILLINOIS STATE UNIV, DEPT BIOL SCI, NORMAL, IL 61761 USA.
   COLORADO OUTDOOR EDUC CTR, PIKES PEAK RES STN, FLORISSANT, CO 80816 USA.},
DOI = {10.2307/2388359},
ISSN = {0006-3606},
EISSN = {1744-7429},
