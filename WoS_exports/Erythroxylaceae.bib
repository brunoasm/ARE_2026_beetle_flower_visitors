@article{ WOS:A1991FM09400001,
Author = {BERRY, PE and TOBE, H and GOMEZ, JA},
Title = {AGAMOSPERMY AND THE LOSS OF DISTYLY IN ERYTHROXYLUM-UNDULATUM
   (ERYTHROXYLACEAE) FROM NORTHERN VENEZUELA},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1991},
Volume = {78},
Number = {5},
Pages = {595-600},
Month = {MAY},
Abstract = {Erythroxylum undulatum is a gametophytic apomict that produces about
   15\% seed set independently of pollination.  Embryo sac formation is
   aposporous, and the plants are largely pollen-sterile, which may be a
   result of polyploidy and hybrid origin.  It appears to be derived from a
   distylous ancestor, as all other known species of Erythroxylum are
   distylous or secondarily dioecious, and all examined individuals of E.
   undulatum correspond to the normal long-styled morph.  This is the first
   clearly documented case of agamospermy derived from distyly.},
