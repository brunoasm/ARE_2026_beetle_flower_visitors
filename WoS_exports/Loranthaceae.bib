@article{ WOS:000423310000003,
Author = {Gonzalez, Favio and Pabon-Mora, Natalia},
Title = {Inflorescence and floral traits of the Colombian species of
   <i>Tristerix</i> (<i>Loranthaceae</i>) related to hummingbird
   pollination},
Journal = {ANALES DEL JARDIN BOTANICO DE MADRID},
Year = {2017},
Volume = {74},
Number = {2},
Abstract = {Floral diversification in Loranthaceae reaches its highest peak in the
   Andes. The flowers of the exclusively Andean genus Tristerix exhibit
   tubular and Vividly coloured flowers pollinated by hummingbirds. We
   studied inflorescence and flower motphoanatomy of the two Colombian
   species, T longebracteolus and the highly endangered T secundus. Both
   species have terminal racemes with up to 26 ebracteolate flowers, of
   which the proximal one opens and sets fmits first. The slightly
   irregular calyx initiation is followed by the simultaneous initiation of
   petals and the successive initiation of stamens. Anthesis is fenestrate,
   explosive, and triggered by the tension of the style against the abaxial
   petals, a mode so far not reported in Loranthaceae. Anthetic petals
   spread symmetrically in I. longebracteatus and asymmetrically in I.
   secundu,Y. Nectar is produced by a supraovarial disk and by the petal
   mesophyll. Floral lifespan lasts up to 20 days. The hummingbirds
   Eriocnemis vestito and Plerophones cyanopterus are the likely
   pollinators of 1. secundus. Morphological traits are inconclusive to
   support one of the two competing sister group relationships that involve
   Tristerix, as the lack of cataphylls in renewal shoots links Liguria and
   Tristerix, whereas the terminal inflorescences support its relationship
   with Desmario and Tupeia.},
