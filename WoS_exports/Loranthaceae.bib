@article{ WOS:A1984SE26700005,
Author = {BERNHARDT, P},
Title = {MISTLETOES ON MISTLETOES - THE FLORAL ECOLOGY OF AMYEMA-MIRACULOSUM AND
   ITS HOST, AMYEMA-MIQUELII (LORANTHACEAE)},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1984},
Volume = {32},
Number = {1},
Pages = {73-86},
Abstract = {In Victoria {[}Australia] self-incompatible A. miraculosum may exist as
   a locally obligate parasite on partially self-compatible A. miquelii.
   For the 1st time, the pollination ecology of a mistletoe on a mistletoe
   is analyzed. Both species were generalist ornithophiles with overlapping
   flowering seasons from Jan.-March. Consequently, the hyperparasite was
   in competition with its congeneric host for pollen vectors belonging to
   the local nectar bird guild (Meliphagidae and Zosteropidae). A. miquelii
   produced flowers that were longer-lived, and had a higher nectar
   content, than those of A. miraculosum. From mid Feb.-March, A. miquelii
   plants offered more inflorescences, with open flowers, than A.
   miraculosum. There was an average of twice as many flowers on an A.
   miquelii inflorescence as on an A. miraculosum inflorescence. More than
   70\% of avian foraging bouts observed were to A. miquelii only. Eight
   bird species foraged for nectar on A. miquelii while only 5 were
   recorded on A. miraculosum. While 22\% of all foraging bouts were
   interspecific, no examples of interspecific hybridization were found.
   This corresponds with previous observation of the reciprocal failure of
   interspecific crosses in vitro.},
