@article{ WOS:A1982NM06000006,
Author = {BERNHARDT, P},
Title = {INTERSPECIFIC INCOMPATIBILITY AMONGST VICTORIAN SPECIES OF AMYEMA
   (LORANTHACEAE)},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1982},
Volume = {30},
Number = {2},
Pages = {175-184},
Abstract = {Each of the 6 Amyema spp. collected in Victoria had a natural
   distribution and floral phenology that overlapped with at least 1 of its
   Victorian congenerics. All of the Amyema spp. were pollinated by the
   same family of birds (Meliphagidae, honeyeaters) and often by the same
   species. All intraspecific cross-pollinations in vitro consistently
   produced an average of > 5 pollen tubes per style which grew more than
   0.125 the length of the style within 24 h. Seventeen of 30 interspecific
   pollinations in vitro failed to produce pollen tubes in the style over
   the same time. Only 8 of the 30 interspecific crosses attempted produced
   results competitive with respective intraspecific crosses. The success
   of the interspecific cross may depend on the breeding system of the
   species receiving pollen from another. Self-incompatible A. pendulum
   (Sieb. ex Spreng.) Van Tieghem and A. miraculosum (Miq.) Van Tieghem
   repeatedly failed to accept the pollen of all the other species.
   Self-compatible A. preisii (Miq.) Van Tieghem and A. quandang (Lindl.)
   Van Tieghem showed good to excellent interspecific pollen tube
   penetration of stylar tissue. Partially self-compatible A. linophyllum
   (Fenzl) Van Tieghem and A. miquelii (Lehm. ex Miq.) Van Tieghem showed
   results intermediate between self-compatible and self-incompatible taxa.
   Geographic and floral phenological barriers contribute partially to
   interspecific isolation as intercompatible species may have regionally
   different flowering seasons and distributions. F1 hybrids recorded in
   southern Australia show extremely low rates of pollen viability and seed
   production. There is no current evidence that introgression occurs.},
Publisher = {CSIRO PUBLISHING},
Address = {UNIPARK, BLDG 1, LEVEL 1, 195 WELLINGTON RD, LOCKED BAG 10, CLAYTON, VIC
   3168, AUSTRALIA},
