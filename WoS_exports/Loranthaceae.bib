   Weston, Kerry A.; Chapman, Hazel M.; Kelly, Dave, Univ Canterbury, Sch Biol Sci, Christchurch 1, New Zealand.
   Moltchanova, Elena V., Univ Canterbury, Dept Math \& Stat, Christchurch 1, New Zealand.},
DOI = {10.1017/S026646741100068X},
