@article{ WOS:000259215900006,
Author = {Polatto, Leandro P. and Alves, Jr., Valter V.},
Title = {The use of floral resources by visitors on <i>Sparattosperma
   leucanthum</i> (Vell.) K. Schum. (Bignoniaceae)},
