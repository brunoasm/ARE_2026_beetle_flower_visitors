Number = {3},
Pages = {273-276},
Abstract = {The pattern of floral anthocyanins exhibits little variation in the
   family Bignoniaceae. Floral pigments of the genus Paulownia are
   consistent with an assignment to the Bignoniaceae. No evidence of a
   pigment syndrome associated with bat pollination could be detected. The
   3-desoxyanthocyanidin, carajurin, appears to be unique to the genus
   Arrabidaea.},
