Language = {English},
Affiliation = {vanDoorn, WG (Corresponding Author), DLO, ATO, AGROTECHNOL RES INST, POB 17, NL-6700 AA WAGENINGEN, NETHERLANDS.},
DOI = {10.1093/jexbot/48.314.1615},
