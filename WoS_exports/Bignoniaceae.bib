Keywords = {breeding system; late-acting self-incompatibility; hummingbird
   pollination; nectar secretion; Zeyheria; Bignoniaceae},
Keywords-Plus = {ACTING SELF-INCOMPATIBILITY; HUMMINGBIRD POLLINATION; POSTPOLLINATION
