@article{ WOS:000271544700005,
Author = {Carbonari, Vladson and Polatto, Leandro Pereira and Aives-Junior, Valter
   Vieira},
Title = {Evaluation of the Impact on <i>Pyrostegia venusta</i> (Bignoniaceae)
   Flowers Due to Nectar Robbery by <i>Apis mellifera</i> (Hymenoptera,
   Apidae)},
Journal = {SOCIOBIOLOGY},
Year = {2009},
Volume = {54},
Number = {2},
Pages = {373-382},
Abstract = {Research indicates that nectar theft or robbery has a potentially
   negative impact on plants through the action of several mechanisms,
   including harm to reproductive tissues, decrease in the attractiveness
   of robbed flowers to effective pollinators and resource expense to
   restore the removed nectar. In this study, it was observed that Apis
   mellifera intensely robbed the nectar of Pyrostegia venusta floral buds
   and flowers. The study results showed strong indications that robbery
   increased the occurrence of floral abortion and consequently reduced the
   reproductive effectiveness of the plant, also influencing the
   competition for the offered floral resource. Therefore, the introduction
   of apiaries in vegetation remainders needs to be evaluated.},
