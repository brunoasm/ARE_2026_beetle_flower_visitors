Language = {English},
Affiliation = {Singh, S (Corresponding Author), Punjab Agr Univ, Dept Floriculture \& Landscaping, Ludhiana 141004, Punjab, India.
   Rana, Nepu; Singh, Simrat; Dhatt, K. K., Punjab Agr Univ, Dept Floriculture \& Landscaping, Ludhiana 141004, Punjab, India.
