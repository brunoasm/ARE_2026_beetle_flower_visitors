@article{ WOS:A1978FW25300003,
Author = {GOULD, E},
Title = {FORAGING BEHAVIOR OF MALAYSIAN NECTAR-FEEDING BATS},
Journal = {BIOTROPICA},
Year = {1978},
Volume = {10},
Number = {3},
Pages = {184-193},
Abstract = {Feeding strategies of Malaysian nectarivorous bats {[}Macroglossus
   minimus, M. sobrinus and Eonycteris spelaea] include trap-line foraging
   and territorial defense of resources. A high initial-visit rate with a
   subsequent leveling off of activity by bat pollinators is related to
   nectar parceling mechanisms of Oroxylum indicum (Bignoniaceae) flowers.
   Differing temporal patterns of visitation to Durio zibethinus, Parkia
   and Musa acuminata reflect different flowering strategies. Patterns of
   visitation to flowers may provide a useful comparative measure of bat
   pollination energetics in the New and Old World tropics.},
