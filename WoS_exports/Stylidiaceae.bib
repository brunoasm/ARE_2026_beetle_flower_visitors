Address = {PO BOX 25178, CHRISTCHURCH, NEW ZEALAND},
Type = {Review},
Language = {English},
Affiliation = {Buxton, MN (Corresponding Author), Univ Otago, Dept Bot, POB 56, Dunedin, New Zealand.
   Buxton, MN (Corresponding Author), New Zealand Inst Plant \& Food Res Ltd, Ruakura Res Ctr, Hamilton 3240, New Zealand.
   Buxton, Max N.; Lord, Janice M., Univ Otago, Dept Bot, POB 56, Dunedin, New Zealand.
   Anderson, Barbara J., Landcare Res, Private Bag 1930, Dunedin, New Zealand.
   Buxton, Max N., New Zealand Inst Plant \& Food Res Ltd, Ruakura Res Ctr, Hamilton 3240, New Zealand.},
DOI = {10.20417/nzjecol.42.11},
