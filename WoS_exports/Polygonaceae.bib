@article{ WOS:A1979HW62100003,
Author = {HESSE, M},
Title = {DEVELOPMENT AND ULTRASTRUCTURE OF POLLENKITT AND EXINE IN CLOSELY
   RELATED ENTOMOPHILOUS AND ANEMOPHILOUS ANGIOSPERMS - POLYGONACEAE},
Journal = {FLORA},
Year = {1979},
Volume = {168},
Number = {6},
Pages = {558-577},
Abstract = {Polygonum bistorta, Fagopyrum esculentum (both entomophilous), Rheum
   rhabarbarum and Rumex scutatus (both anemophilous) (Polygonaceae) were
   studied in relation to pollenkitt (amount, structure, distribution on
   the exine) and to the exine itself (sculpturing, intrasexinous caves,
   bacula, tectum). In P. bistorta, the large quantity of the homogeneous,
   electron-dense pollenkitt is deposited in the rather small intrasexinous
   caves, but also as homogeneous droplets at the nearly closed
   smooth-surfaced tectum. F. esculentum produces a heterogeneous, less
   electron-dense and a rather small quantity of pollenkitt is deposited
   mostly in the caves of the reticulate exine, but also at the tectum.
   Compared to F. esculentum, Rheum rhabarbarum produces a large but very
   heterogeneous quantity of pollenkitt. The pollenkitt is deposited very
   heterogenously at the pollen grains. Moreover, the pollenkitt is
   deposited mostly in the intrasexinous caves, and only some
   electron-lucent droplets adhere at the tectum. The small quantity of the
   very heterogeneous pollenkitt of Rumex scutatus can be observed as
   predominantly electron-dense mass in the tall intrasexinous caves, while
   only small fibrous quantities of pollenkitt adhere at the rather rough
   tectum surface. These findings indicate that the changes from entomo- to
   anemophily in the pollination mode of angiosperms are accompanied by
   step-wise changes of the correlated character syndromes. These character
   syndromes do not affect only the flowers, but also the pollen grains in
   relation to the fine structure of the exine and pollenkitt.},
Publisher = {ELSEVIER GMBH},
Address = {HACKERBRUCKE 6, 80335 MUNICH, GERMANY},
Type = {Article},
Language = {German},
Affiliation = {VIENNA UNIV, INST BOT \& BOT GARTEN, A-1030 VIENNA, AUSTRIA.},
ISSN = {0367-2530},
EISSN = {1618-0585},
Research-Areas = {Plant Sciences; Environmental Sciences \& Ecology},
Web-of-Science-Categories  = {Plant Sciences; Ecology},
