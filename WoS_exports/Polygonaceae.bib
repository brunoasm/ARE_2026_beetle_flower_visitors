DOI = {10.1007/BF02515647},
ISSN = {0034-5466},
Keywords = {POLYGONUM-THUNBERGII; POLYGONACEAE; AMPHICARPIC PLANT; CHASMOGAMOUS AND
   CLEISTOGAMOUS FLOWERS; POLLINATION ECOLOGY; FRUIT SET; RESOURCE
   LIMITATION; POLLINATOR LIMITATION},
Keywords-Plus = {PLANTS; EVOLUTION; ECOLOGY},
