Author = {Enache, Monica and Danaila-Guidea, Silvana Mihaela and Basa, Adrian
   Gheorghe and Jurcoane, Stefana},
Title = {PRELIMINARY ANALYSIS OF 8 BEE POLLEN SAMPLES COLLECTED AT THE MOARA
