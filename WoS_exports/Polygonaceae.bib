
@article{ WOS:A1991FN24600008,
Author = {HONG, SP},
Title = {THE DIMORPHIC HETEROSTYLY IN ACONOGONON-CAMPANULATUM (POLYGONACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1991},
Volume = {176},
Number = {1-2},
Pages = {125-131},
Abstract = {Heterostyly is clearly confirmed in Aconogonon campanulatum.  This
   distylous species is dimorphic for tepals, styles, stigma surface,
   stamens, pollen grain size, and pollen sexine ornamentation.  The floral
   shape is campanulate and thrum flowers are slightly larger than pin
   flowers.  Small solitary bees were observed as flower visitors and
   probably effected pollination.  The possible evolution of dioecy via
   heterostyly within the genus Aconogonon is discussed.},
