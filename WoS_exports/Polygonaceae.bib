@article{ WOS:000200486700005,
Author = {Wodehouse, RP},
Title = {Pollen grains in the identification and classification of plants VI.
   Polygonaceae},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1931},
Volume = {18},
Number = {9},
Pages = {749-U9},
Month = {NOV},
Abstract = {The primitive form of grain in the family is the simple ellipsoidal or
   spheroidal 3-furrowed type exhibited in Chorizanthe pungens, in which
   the furrows are long and broad, opening and closing freely in
   accommodation to changes in volume. An inherent tendency among the
   grains of the family is towards an increase in the number of furrows,
   the pollen of most species exhibiting, besides the 3-furrowed form, some
   grains with 4, 6 and higher numbers of furrows. From the simple basic
   3-furrowed form 2 divergent evolutionary lines are recognized: one,
   among the wind pollinated members, leading to thin-walled forms such as
   those of Rumex in which furrows are represented only by linear
   depressions, without function in accommodating changes in volume; and
   one, among insect-pollinated members, in which the exine is greatly
   thickened and alveolate. This structure appears to have demobilized the
   furrows. Their consequent loss of function in accommodating changes in
   volume is compensated for by an increase in their number, which is about
   30 in such grains us those of Persicaria. Figures are given of the grams
   of Rumex acetosella, Chorizanthe pungens, Erio-gonum gracile, Polygonum
   californicum, P. chinense and Persicaria muehlenbergii, and a key to the
   pollen-gram forms of 27 spp.},
