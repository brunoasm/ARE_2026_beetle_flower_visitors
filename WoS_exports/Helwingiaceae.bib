ISSN = {0918-9440},
EISSN = {1618-0860},
Keywords = {Aquifoliales; Embryology; Floral anatomy; Flower; Helwingia;
   Helwingiaceae},
Keywords-Plus = {SAXIFRAGACEAE SENSU-LATO; PHYLOGENETIC-RELATIONSHIPS; CARDIOPTERIS;
   POLLINATION; POLLEN; GENES},
Research-Areas = {Plant Sciences},
Web-of-Science-Categories  = {Plant Sciences},
Author-Email = {tobe@sys.bot.kyoto-u.ac.jp},
Affiliations = {Kyoto University},
