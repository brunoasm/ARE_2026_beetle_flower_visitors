ISSN = {0167-6857},
Keywords = {YELLOW-POPLAR; CHINESE TULIPTREE; MICROPROPAGATION; RFLP},
Keywords-Plus = {MAGNOLIACEAE; TULIPIFERA; DIVERGENCE; EMBRYOS},
