Keywords = {basal angiosperms; floral biology; floral structure; flower evolution;
   pollination biology},
Keywords-Plus = {AMBORELLA-TRICHOPODA AMBORELLACEAE; REPRODUCTIVE-BIOLOGY; POLLINATION
