@article{ WOS:A1981LZ49500006,
Author = {VOGEL, S},
Title = {THE GLUE-PRODUCING ANTHER HAIRS OF CYCLANTHERA-PEDATA (CUCURBITACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1981},
Volume = {137},
Number = {4},
Pages = {291-316},
Abstract = {The highly specialized, 2-celled hairs fringing the anthers of C. pedata
   (L.) Schrad and its relatives aid in pollination by producing a glue
   which sticks the coarse pollen grains onto insect visitors. The adhesive
   is extruded from the big basal cell which bursts at the slightest touch
   to the small top cell. Turgor and swelling pressure of the sticky
   material are probably responsible for plasmoptysis and ejaculation. Cell
   contraction is due to tension of cuticular clips and to elasticity of
   the pectinic wall. A preformed apical dehiscence line disrupts when the
   top cell is bent aside. The anther hairs of a flower develop
   synchronously. From light and electron microscopic observations, the
   adhesive appears not to be a product of internal secretion. It
   originates from the endopolyploid giant nucleus of the basal cell, which
   degenerates by liquefying and swelling. The numerous peculiar
   elaioplasts do not contribute to the hair''s function. The anther hairs
   are homologous to and possibly evolved from the explosion hairs
   occurring on the green parts of many Cucurbitaceae.},
