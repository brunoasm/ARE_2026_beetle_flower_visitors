Type = {Article},
Language = {English},
Affiliation = {Dept Appl Biol, POB 27, FIN-00014 Helsinki, Finland.
   Univ Jyvaskyla, Dept Biol \& Environm Sci, FIN-40351 Jyvaskyla, Finland.},
DOI = {10.1139/B04-069},
ISSN = {0008-4026},
Keywords = {Betula pendula; female choice; nonrandom abortion; pollen competition;
   sexual selection},
