   Rodrigues, Sergio R., Univ Estadual Mato Grosso do Sul, Cassilandia, MS, Brazil.
   Leal, Walter S., Univ Calif Davis, Dept Mol \& Cellular Biol, Davis, CA 95616 USA.},
DOI = {10.1371/journal.pone.0235028},
