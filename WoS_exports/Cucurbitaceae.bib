@article{ WOS:000265900900004,
Author = {Theis, Nina and Kesler, Karen and Adler, Lynn S.},
Title = {LEAF HERBIVORY INCREASES FLORAL FRAGRANCE IN MALE BUT NOT FEMALE
   <i>CUCURBITA PEPO</i> SUBSP <i>TEXANA</i> (CUCURBITACEAE) FLOWERS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2009},
Volume = {96},
Number = {5},
Pages = {897-903},
Month = {MAY},
Abstract = {Mutualisms are key interactions that affect population dynamics and
   structure communities, but the extent to which mutualists can attract
   potential partners may depend on community context. Many studies have
   shown that leaf herbivory reduces pollinator visitation and have focused
   on reduced floral visual display and rewards as potential mechanisms.
   However, olfactory display plays a critical role in mediating
   interactions between plants, herbivores, and pollinators. We simulated
   leaf damage in Cucurbita pepo subsp. texana and measured fragrance
   emission and other floral characters of both male and female flowers.
   Contrary to our expectations, damage increased fragrance production, but
   only in male flowers. Female flowers, which were bigger and produced
   more fragrance than males, were unaffected by leaf damage. The greatest
   increase in floral fragrance compounds was in the terpenoids, which we
   hypothesize could be byproducts of defensively induced cucurbitacins, or
   they may function defensively themseleves. In summary, this study is the
   first to demonstrate changes in floral fragrance due to leaf damage.
   Such changes in floral fragrance following herbivory may be a critical
   and overlooked mechanism mediating interactions between plants,
   herbivores, and pollinators.},
