@article{ WOS:A1983RD22900010,
Author = {HANDEL, SN},
Title = {CONTRASTING GENE FLOW PATTERNS AND GENETIC SUBDIVISION IN ADJACENT
   POPULATIONS OF CUCUMIS-SATIVUS (CUCURBITACEAE)},
Journal = {EVOLUTION},
Year = {1983},
Volume = {37},
Number = {4},
Pages = {760-771},
Abstract = {A test of the similarity of gene migration patterns between 2 adjacent
   field populations of C. sativus was conducted by interplanting a block
   of plants with the dominant bitter gene in the center of each of 2 large
   plots of plants with the recessive allele for this marker. After natural
   pollination, mature fruits were mapped and collected from both fields,
   and the seedling progeny scored from the presence of the bitter gene.
   The pattern of gene flow in both plots was restricted, with most of the
   bitter pollen deposited within 2-3 m from the central bitter block. A
   small percentage of the fruits at ends of the field, however, bore some
   seedlings with the bitter gene. This leptokurtic pattern is consistent
   with several other studies on the distribution of pollen by
   bee-pollinated plants. In one field, pollen migration was symmetrical
   around the block of dominant plants, but in the other field, there was a
   significant asymmetric movement of the gene towards one side of the
   plot. The close location of a honeybee hive from the 2nd field may have
   influenced this result. Adjacent plant populations, even in homogeneous
   environments, can have different pollen flow dynamics. There can be a
   directional migration of alleles in a plant population without the
   influence of a selection pressure acting on one part of the population.
   Gene frequencies in natural plant populations may experience similar
   shifts due, for example, to the interaction of the plant and the
   pollinator source. These changes and the subsequent patchy or
   heterogeneous distribution of genes create a new and different genotypic
   arrangement upon which selection may act.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
