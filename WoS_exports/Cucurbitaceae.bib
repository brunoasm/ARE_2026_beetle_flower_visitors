@article{ WOS:A1997XW43800006,
Author = {Johannsson, MH and Stephenson, AG},
Title = {Effects of pollination intensity on the vigor of the sporophytic and
   gametophytic generation of Cucurbita texana},
Journal = {SEXUAL PLANT REPRODUCTION},
Year = {1997},
Volume = {10},
Number = {4},
Pages = {236-240},
Month = {AUG},
Abstract = {We examined the effects of pollen competition (pollen load size) on
   sporophytic vigor and gametophytic performance in Cucurbita texana, a
   wild gourd, while controlling fur alternative interpretations of the
   data. Under field conditions we compared the vigor of progeny produced
   from large and small pollen loads and examined the in vitro performance
   of the pollen produced by the progeny. We found chat the progeny from
   large pollen loads germinated faster and had a greater reproductive
   output (male flowers and fruits) than progeny produced from small pollen
   loads. In addition, we found that the pollen produced on plants derived
   from large pollen loads grew faster in vitro than the pollen produced on
   plants derived from small pollen Toads. These findings indicate that
   pollen competition affects the performance of the resulting sporophytic
   generation and the microgametophytes they produce.},
