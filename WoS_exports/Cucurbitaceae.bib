ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {animal-pollination; breeding systems; duration stigma receptivity;
   pollen grain number; pollen grain size; pollen packaging units;
   pollenovule ratios; secondary pollen presentation; sexual systems;
   stigma area and depth; wind-pollination},
