@article{ WOS:000363352500006,
Author = {Mitchell, Thomas C. and Doetterl, Stefan and Schaefer, Hanno},
Title = {Hawk-moth pollination and elaborate petals in Cucurbitaceae: The case of
   the Caribbean endemic <i>Linnaeosicyos amara</i>},
Journal = {FLORA},
Year = {2015},
Volume = {216},
Pages = {50-56},
Abstract = {Linnaeosicyos amara is a little known cucurbit endemic to the Caribbean
   island of Hispaniola. The species possesses conspicuously fringed petals
   which are known in just four other cucurbit genera and hypothesised to
   play a role in pollinator attraction. A population of flowering L amara
   plants was observed for a total of 78 h, which revealed that Sphingid
   moths are the primary pollinators. Floral scent was dominated by the
   terpenoid (E)-beta-ocimene. The elaborate petal fringes almost doubled
   the apparent diameter of L. amara flowers and the maximal extension of
   petal fringes was found to coincide with the peak visitation period of
   hawk-moths, with withering starting soon after. We conclude that petal
   fringes likely play a role in the visual attraction of hawk-moths by
   exploiting their preference for large flowers with deeply-divided petal
   margins, whilst limiting energy costs to the plant. (C) 2015 Elsevier
   GmbH. All rights reserved.},
Publisher = {ELSEVIER GMBH},
Address = {HACKERBRUCKE 6, 80335 MUNICH, GERMANY},
Type = {Article},
Language = {English},
Affiliation = {Mitchell, TC (Corresponding Author), Tech Univ Munich, Plant Biodivers, Freising Weihenstephan, Germany.
   Mitchell, Thomas C.; Schaefer, Hanno, Tech Univ Munich, Plant Biodivers, Freising Weihenstephan, Germany.
   Doetterl, Stefan, Salzburg Univ, Dept Ecol \& Evolut, Plant Ecol, A-5020 Salzburg, Austria.},
DOI = {10.1016/j.flora.2015.08.004},
ISSN = {0367-2530},
EISSN = {1618-0585},
Keywords = {Floral scent; Flora of Hispaniola; Fringed petals; Nectar; Sphingidae},
