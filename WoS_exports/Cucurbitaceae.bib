@article{ WOS:000182107800015,
Author = {Li, Y and Yu, JQ and Ye, QJ and Zhu, ZJ and Guo, ZJ},
Title = {Expression of CycD3 is transiently increased by pollination and
   <i>N</i>-(2-chloro-4-pyridyl)-<i>N</i>′-phenylurea in ovaries of
   <i>Lagenaria leucantha</i>},
Journal = {JOURNAL OF EXPERIMENTAL BOTANY},
Year = {2003},
Volume = {54},
Number = {385},
Pages = {1245-1251},
Month = {APR},
Abstract = {Lagenaria leucantha is an important vegetable crop and a potential model
   for the study of fruit development. To study the function of D cyclins
   in fruit development, full-length cDNA clones for two D cyclin genes
   were isolated from young ovaries of Lagenaria leucantha. They were
   classified as D3 cyclins by sequence similarities and phylogenetic
   analysis, and nominated LlCycD3;1 and LlCycD3,2, respectively. The
   deduced amino acid sequence of both LlCycD3 genes contained a
   retinoblastoma-binding motif and a PEST-destruction motif. Unpollinated
   ovaries failed to develop and eventually aborted.
   N-(2-chloro-4-pyridyl)-N-phenylurea (CPPU) induced parthenocarpic fruit
   significantly larger than pollinated ones. In unpollinated ovaries, the
   expression of both LlCycD3 genes was abundant at anthesis and then
   suddenly decreased, concomitant with the cessation of cell division.
   Pollination/fertilization induced an activation of the cell cycle
   accompanied by a large increase in the transcript levels of LlCycD3;1
   and LlCycD3;2 in young fruits. Treating ovaries with CPPU also
   reactivated cell division and transcription of CycD3 genes and the
   effect was more rapid and pronounced than after
   pollination/fertilization.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Zhejiang Univ, Dept Hort, Huajiachi Campus Kaixuan Rd 268, Hangzhou 310029, Peoples R China.
   Zhejiang Univ, Dept Hort, Hangzhou 310029, Peoples R China.
   Zhejiang Univ, Inst Biotechnol, Hangzhou 310029, Peoples R China.},
DOI = {10.1093/jxb/erg124},
ISSN = {0022-0957},
EISSN = {1460-2431},
Keywords = {cucurbitaceae; CycD3; cytokinin; fruit development; pollination},
Keywords-Plus = {D-TYPE CYCLINS; CELL-CYCLE; FRUIT-DEVELOPMENT; PLANT; GROWTH;
   ACTIVATION; DIVISION; GENES; ENLARGEMENT; REGULATORS},
