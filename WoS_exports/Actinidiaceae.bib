Affiliation = {Jung, C (Corresponding Author), Andong Natl Univ, Dept Plant Med, Andong 760749, GB, South Korea.
   Ghosh, Sampat, Andong Natl Univ, Agr Sci Tech Res Inst, Andong 760749, GB, South Korea.
