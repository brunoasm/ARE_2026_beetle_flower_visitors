EISSN = {1537-2197},
Keywords = {Chenopodiaceae; pollination, delayed; sex expression; sex ratio;
   spinach; stigma length; stigmatic growth, indeterminate},
Keywords-Plus = {POLLEN-TUBE GROWTH; ZEA-MAYS-L; TEMPORAL DIOECISM; PLANTS; COMPETITION;
   SELECTION; MANIPULATION},
