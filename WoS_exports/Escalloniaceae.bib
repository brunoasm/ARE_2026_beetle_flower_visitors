
@article{ WOS:A1994PN14000011,
Author = {WEBB, CJ},
Title = {POLLINATION, SELF-INCOMPATIBILITY, AND FRUIT PRODUCTION IN COROKIA
   COTONEASTER (ESCALLONIACEAE)},
Journal = {NEW ZEALAND JOURNAL OF BOTANY},
Year = {1994},
Volume = {32},
Number = {3},
Pages = {385-392},
Abstract = {Corokia cotoneaster (Escalloniaceae) is an evergreen, divaricating shrub
   endemic to New Zealand. Although it has small, simple, open flowers and
   is neither dichogamous nor markedly herkogamous, the pollination system
   exhibits some specialised features. C. cotoneaster is visited by a wide
   range of insects, but a single species of native bee appears to be the
   effective pollinator. In addition, C. cotoneaster is self-incompatible,
   an unusual condition in the New Zealand flora. It is suggested that the
   divaricating habit may impose particular constraints on the reproductive
   biology of this and other species.},
