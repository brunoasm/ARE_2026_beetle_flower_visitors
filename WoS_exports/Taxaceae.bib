@article{ WOS:000179937900006,
Author = {Laaidi, M and Thibaudon, M},
Title = {Circadian periodicity of the pollination of some allergenic taxa},
Journal = {ACTA BOTANICA GALLICA},
Year = {2002},
Volume = {149},
Number = {4},
Pages = {445-456},
Abstract = {The aim of this study was to determine the circadian periodicity of the
   pollination of four allergenic groups of plants, Poaceae, Urticaceae,
   Cupressaceae-Taxaceae and birch. The bi-hourly data came from volumetric
   traps set up in ten French cities. The results showed that Cupressaceae
   rather pollinate in the morning and until the beginning of the
   afternoon. The birch has no defined rhythm, but presents brief off-peaks
   during the night. The Urticaceae have an earlier pollination peak in the
   South. Lastly, the Poaceae, except in Paris and Lyons, preferably
   pollinate in the afternoon and in the evening, with a minor peak in the
   morning. The determination of the diurnal periodicity of the pollination
   can bring new knowledge on the rhythmic activities of plants and also
   makes up a prevention tool for allergic people.},
Publisher = {SOC BOTANIQUE FRANCE},
Address = {FACULTE DE PHARMACIE, BP 83, F-59006 LILLE-CEDEX, FRANCE},
Type = {Article},
Language = {French},
Affiliation = {Ctr Univ Epidemiol Populat, Fac Med, BP 87900, F-21079 Dijon, France.
   Ctr Univ Epidemiol Populat, Fac Med, F-21079 Dijon, France.
