Author = {Osie, Mulatu and Shibru, Simon and Dalle, Gemedo and Nemomissa, Sileshi},
Title = {Habitat fragmentation effects on vascular epiphytes diversity in Kafa
   biosphere reserve and nearby coffee agroecosystem, southwestern Ethiopia},
Journal = {TROPICAL ECOLOGY},
Year = {2022},
Volume = {63},
Number = {4},
