   Univ Hong Kong, Dept Ecol \& Biodivers, Hong Kong, Hong Kong, Peoples R China.},
DOI = {10.1006/bojl.1999.0305},
ISSN = {0024-4074},
Keywords = {autogamy; breeding system; electrophoresis; floral morphology; isozymes;
