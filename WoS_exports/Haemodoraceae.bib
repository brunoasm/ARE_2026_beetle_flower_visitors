@article{ WOS:000178098100009,
Author = {Jesson, LK and Barrett, SCH},
Title = {Enantiostyly in <i>Wachendorfia</i> (Haemodoraceae):: The influence of
   reproductive systems on the maintenance of the polymorphism},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2002},
Volume = {89},
Number = {2},
Pages = {253-262},
Month = {FEB},
Abstract = {Enantiostyly is a form of directional asymmetry in plants in which the
   style is deflected away from the main axis of the flower, either to the
   left or right side. In Wochendorfia (Haemodoraceae), a small genus of
   insect-pollinated geophytes restricted to the Cape Province of South
   Africa, populations are usually polymorphic for asymmetry. Here we
   investigate dimorphic enantiostyly in the four species of Wachendofia to
   determine whether variation in their reproductive systems influences the
   maintenance of this genetic polymorphism. Experimental field
   pollinations of W. paniculata and W thyrstflora indicated higher
   fertility for cross- than for self-pollinations, whereas in W.
   brachyandra, these types of pollination produced similar levels of
   fertility. Outcrossing rates were highest in W paniculata (t =
   0.78-0.98), with W brachyandra (t = 0.39-0.79) and W. thyrstflora (t = 0
   76) exhibiting mixed mating systems. Outcrossing rates in two
   populations of W. parviflora varied from mixed mating (t = 0.61) to
   predominant selfing (t = 0.07) Population style-morph ratios ranged from
   1:1 in outcrossing W. paniculata to monomorphism in selfing W.
   parviflora and clonal W thyrstflora. In W brachyandra, a species with
   delayed selfing, morph ratios were usually biased. The maintenance of
   enantiostyly in Wachendorfia appears to be strongly influenced by levels
   of disassortative mating and the balance between sexual and clonal
   recruitment.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Univ Toronto, Dept Bot, 25 Willcocks St, Toronto, ON M5S 3B2, Canada.
   Univ Toronto, Dept Bot, Toronto, ON M5S 3B2, Canada.},
DOI = {10.3732/ajb.89.2.253},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {delayed selfing; enantiostyly; experimental pollinations; floral design;
   Haemodoraceae; outcrossing rates; spatial analysis; style-morph ratios;
   Wachendorfia},
Keywords-Plus = {DIRECTIONAL ASYMMETRY; SELF-FERTILIZATION; POLLEN LIMITATION; CLONAL
   GROWTH; EVOLUTION; SELECTION; POPULATIONS; PATTERNS; RATIOS; PLANTS},
