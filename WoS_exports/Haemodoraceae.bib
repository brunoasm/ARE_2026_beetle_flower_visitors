@article{ WOS:A1978ET36700015,
Author = {ORNDUFF, R and DULBERGER, R},
Title = {FLORAL ENANTIOMORPHY AND REPRODUCTIVE-SYSTEM OF WACHENDORFIA-PANICULATA
   (HAEMODORACEAE)},
Journal = {NEW PHYTOLOGIST},
Year = {1978},
Volume = {80},
Number = {2},
Pages = {427-434},
Abstract = {Flowers of the South African genus Wachendorfia (Haemodoraceae) are
   dimorphic. Some individuals in a population produce flowers in which the
   style and one stamen are deflected to the right and the other 2 stamens
   are deflected to the left; other individuals produce flowers with the
   reverse arrangement of style and stamens. Artificial pollinations of W.
   paniculata indicate that it has a weakly developed self-incompatibility
   system; intermorph crosses produced more seeds than self-pollinations or
   intramorph pollinations. Features of the flora morphology of W.
   paniculata suggest that it is pollinated by a large-bodied insect,
   possibly Xylocopa. The dimorphism in the position of anthers and stigmas
   probably increases the level of intermorph pollination. The low sugar
   concentration of the nectar, low pollen production per flower, and few
   flowers per plant also probably result in pollinators visiting more than
   1 plant during their foraging activities, thus reinforcing the floral
   dimorphism and increasing the opportunities for intermorph pollination.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {UNIV CALIF BERKELEY, DEPT BOT, BERKELEY, CA 94720 USA.
