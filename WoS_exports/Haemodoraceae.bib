@article{ WOS:A1978FK64100007,
Author = {HOPPER, SD and BURBIDGE, AH},
Title = {ASSORTATIVE POLLINATION BY RED WATTLEBIRDS IN A HYBRID POPULATION OF
   ANIGOZANTHOS LABILL (HAEMODORACEAE)},
Journal = {AUSTRALIAN JOURNAL OF BOTANY},
Year = {1978},
Volume = {26},
Number = {3},
Pages = {335-350},
Abstract = {The specificity and spatial pattern of foraging movements of red
   wattlebirds (Anthochaera carunculata Shaw) were studied in a hybrid
   population of A. manglesii D. Don and A. humilis Lindl. in the shire
   cemetery at Gingin {[}West Australia]. Differences in phenology, nectar
   production, stem height and floral dimensions between F1 hybrids and the
   2 parental Anigozanthos species were also documented to assess their
   influence on foraging behavior and interspecific pollen flow. The red
   wattlebirds showed a 97\% fidelity for A. humilis at its seasonal peak
   in Aug. 1976 and, a month later, equally strong fidelity (97\%) for A.
   manglesii at its seasonal peak. Interspecific foraging movements
   constituted only 1.2\% of the total of 925 observed during these 2 study
   periods. The spatial distribution of flowering individuals and plant
   stature appeared to be principal factors determining assortative
   pollination, presumably because of their influence on the energetics of
   foraging. The observed nearest-neighbor foraging pattern apparently
   results in spatial restrictions on pollen flow and may be responsible
   for the confinement of hybrids to ecotonal zones where the parental
   species grow intermixed. Gene exchange between species is also
   restricted by differences in pollen deposition/retrieval sites arising
   from the divergent floral structures of A. humilis and A. manglesii.
   Honeyeaters have generated strong selective pressures influencing the
   stature, floral structure and phenology of these kangaroo paws.},
