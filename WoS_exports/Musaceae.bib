@article{ WOS:A1976BM73300001,
Author = {NUR, N},
Title = {STUDIES ON POLLINATION IN MUSACEAE},
Journal = {ANNALS OF BOTANY},
Year = {1976},
Volume = {40},
Number = {166},
Pages = {167-177},
Abstract = {Observations and experiments on several species of Musaceae
   {[}Macroglossus-acuminata, M. balbisiana, M. halabanensis, M. ornata, M.
   textilis, M. coccinea, Ensete glaucum and E. ventricosum] in West Java
   and central Sumatra showed that the species with pendent inflorescences
   are pollinated by macroglossine bats, principally by the long-tongued
   fruit bats, Macroglossus minimus and Eonycteris spelaea. Among the
   species with an erect inflorescence Musa velutina proves to be self
   pollinating, while M. salaccensis has sunbirds (Nectariniidae) and tree
   shrews (Tupaia) as pollinators. A discussion on pollination in this
   family is presented in this paper.},
