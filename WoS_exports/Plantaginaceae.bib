   Chi, Katherine; Molano-Flores, Brenda, Univ Illinois, Dept Plant Biol, Urbana, IL 61801 USA.
   Chi, Katherine; Molano-Flores, Brenda, Illinois Nat Hist Survey, Champaign, IL 61820 USA.},
DOI = {10.3732/ajb.1300457},
