   Soper, J.; Beggs, J. R., Univ Auckland, Sch Biol Sci, Auckland 1, New Zealand.},
DOI = {10.1080/0028825X.2013.793202},
ISSN = {0028-825X},
Keywords = {alien invasive species; distribution; pollination; pollen load;
