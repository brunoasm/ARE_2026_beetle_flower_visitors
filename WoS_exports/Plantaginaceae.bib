EISSN = {1537-2197},
Keywords = {conservation; demography; fitness; floral display; habitat
   fragmentation; population biology; reproductive ecology},
Keywords-Plus = {POLLINATOR VISITATION; PLANT-DENSITY; REPRODUCTIVE SUCCESS;
