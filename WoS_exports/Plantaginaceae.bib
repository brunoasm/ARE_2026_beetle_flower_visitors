   Meudt, H. M., Museum New Zealand Te Papa Tongarewa, Wellington, New Zealand.
   Meudt, H. M., Victoria Univ Wellington, Sch Biol Sci, Wellington, New Zealand.},
DOI = {10.1080/0028825X.2012.671179},
ISSN = {0028-825X},
EISSN = {1175-8643},
Keywords = {morphological analyses; native species; new species; New Zealand;
   Plantago; Plantaginaceae; polyploidy; species delimitation; Tasmania;
