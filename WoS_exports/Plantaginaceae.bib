Address = {1160 BATTERY STREET, STE 100, SAN FRANCISCO, CA 94111 USA},
Type = {Article},
Language = {English},
Affiliation = {Prancl, J (Corresponding Author), Acad Sci Czech Republ, Inst Bot, CS-25243 Pruhonice, Czech Republic.
   Prancl, Jan; Kaplan, Zdenek; Travnicek, Pavel; Jarolimova, Vlasta, Acad Sci Czech Republ, Inst Bot, CS-25243 Pruhonice, Czech Republic.
