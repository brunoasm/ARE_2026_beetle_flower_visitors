@article{ WOS:001063740100001,
Author = {Guo, Li and Huang, Ziya and Chen, Xingyu and Yang, Min and Yang,
   Miaomiao and Liu, Ziwei and Han, Xuejie and Ma, Xiangjie and Wang,
   Xiaoli and Gao, Qiguo},
Title = {SD-RLK28 positively regulates pollen hydration on stigmas as a PCP-Bβ
   receptor in <i>Arabidopsis thaliana</i>},
Journal = {JOURNAL OF INTEGRATIVE PLANT BIOLOGY},
Year = {2023},
Volume = {65},
Number = {10},
Pages = {2395-2406},
Month = {OCT},
Abstract = {Pollen hydration on dry stigmas is strictly regulated by pollen-stigma
   interactions in Brassicaceae. Although several related molecular events
   have been described, the molecular mechanism underlying pollen hydration
   remains elusive. Multiple B-class pollen coat proteins (PCP-Bs) are
   involved in pollen hydration. Here, by analyzing the interactions of two
   PCP-Bs with three Arabidopsis thaliana stigmas strongly expressing
   S-domain receptor kinase (SD-RLK), we determined that SD-RLK28 directly
   interacts with PCP-B beta. We investigated pollen hydration, pollen
   germination, pollen tube growth, and stigma receptivity in the sd-rlk28
   and pcp-b beta mutants. PCP-B beta acts in the pollen to regulate pollen
   hydration on stigmas. Loss of SD-RLK28 had no effect on pollen
   viability, and sd-rlk28 plants had normal life cycles without obvious
   defects. However, pollen hydration on sd-rlk28 stigmas was impaired and
   pollen tube growth in sd- rlk28 pistils was delayed. The defect in
   pollen hydration on sd-rlk28 stigmas was independent of changes in
   reactive oxygen species levels in stigmas. These results indicate that
   SD-RLK28 functions in the stigma as a PCP-B beta receptor to positively
   regulate pollen hydration on dry stigmas.},
