@article{ WOS:000401494600005,
Author = {Lysenkov, S. N. and Galinskaya, T. V.},
Title = {COMPARISON OF THE POLLEN CONTENT ON THE BODY AND IN THE GUT OF
   HOVERFLIES (DIPTERA, SYRPHIDAE)},
Journal = {ZOOLOGICHESKY ZHURNAL},
Year = {2017},
Volume = {96},
Number = {2},
Pages = {184-191},
Month = {FEB},
Abstract = {We analyzed the pollen content in the gut and on the body of hoverflies
   (Diptera: Syrphidae), mostly from three genera (Eristalis, Syrphus s. 1.
   and Sphaerophoria) that visited flowers of two jointly flowering species
   of Apiaceae with indistinguishable pollen (Anthriscus sylvestris and
   Aegopodium podagraria) and of Bunias orientalis (Brassicaceae). Pollen
   compositions depended on the plant whence the flies were collected
   rather than on insect genus. However, individual preferences of the
   study flies to food plant species were confirmed. The pollen
   compositions in the gut and on the body correlated weakly. Two possible
   reasons for such a weak correlation were discussed: individual
   differences in fly feeding habits and differences in the time of pollen
   maintenance in the gut and on the body.},
