@article{ WOS:000178098100006,
Author = {Weinig, C},
Title = {Phytochrome photoreceptors mediate plasticity to light quality in
   flowers of the Brassicaceae},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {2002},
Volume = {89},
Number = {2},
Pages = {230-235},
Month = {FEB},
Abstract = {The family of phytochrome photoreceptors mediates stein-elongation
   responses to ambient ratios of red far-red light (R FR) Although
   phytochrome genes are expressed in flowers in addition to vegetative
   parts, nothing is known about floral plasticity to R FR or the
   pleiotropic effects of phytochrome genes on flowers Here, the following
   floral morphologic were compared (1) wild-type Arabidoposis thaliana and
   Brassica rapa plants experiencing high R . FR characteristic of sunlight
   vs low R FR typical of foliar shade and (2) wild-type and
   phytochrome-deficient A thaliana plants Wild-type A thaliana exposed to
   low R FR had diminished petal and pistil lengths but longer filaments
   for a given petal size than plants experiencing high R . FR. Brassica
   rapa plants had qualitatively similar responses. In comparison to
   wild-type I thaliana, Mutants lacking phytochrome A had smaller flowers
   (smaller petals, pistils, and filaments), whereas phytochrome
   B-deficient mutants exhibited longer filament lengths. These results
   provide the first evidence that R . FR and phytochromes affect floral
   phenotypes in addition to vegetative ones Although the ecological
   relevance remains to be established, the observed plasticity of flowers
   to R FR may be relevant to individual fitness in some species because
   stigma and filament positions can affect pollen removal and levels of
   self-pollination.},
