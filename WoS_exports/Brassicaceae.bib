@article{ WOS:000165478800006,
Author = {Heizmann, P and Luu, DT and Dumas, C},
Title = {The clues to species specificity of pollination among Brassicaceae},
Journal = {SEXUAL PLANT REPRODUCTION},
Year = {2000},
Volume = {13},
Number = {3},
Pages = {157-161},
Month = {NOV},
Abstract = {The Brassica S product of the pollen-signalling S-gene (SP11 for
   Specificity Pollen, or SCR for S locus Cysteine Rich) has recently been
   identified as a member of the family of PCPs (Pollen Coat Proteins), a
   group of small basic proteins. In female plants SRK (S Receptor kinase)
   has been demonstrated, among several stigma-expressed S genes, to
   exclusively control self-pollen rejection. Genes and gene products that
   an highly related to the sporophytic SI system appear to take part in
   the control of several stages of pollen-stigma interactions in the
   Brassicaceae. These genes ensure, in particular, the species specificity
   of late pollen adhesion. Pollen capture itself is not species specific,
   since it depends essentially on lipophilic affinities between pollen
   coatings and waxy pellicles on the stigma. These interactions and their
   control are reviewed here.},
