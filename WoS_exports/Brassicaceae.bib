Language = {English},
Affiliation = {Goring, DR (Corresponding Author), Univ Toronto, Dept Cell \& Syst Biol, Toronto, ON M5S 3B2, Canada.
   Samuel, Marcus A.; Chong, Yolanda T.; Haasen, Katrina E.; Aldea-Brydges, May Grace; Stone, Sophia L.; Goring, Daphne R., Univ Toronto, Dept Cell \& Syst Biol, Toronto, ON M5S 3B2, Canada.
   Goring, Daphne R., Univ Toronto, Ctr Anal Genome Evolut \& Funct, Toronto, ON M5S 3B2, Canada.},
DOI = {10.1105/tpc.109.069740},
ISSN = {1040-4651},
EISSN = {1532-298X},
Keywords-Plus = {LOCUS RECEPTOR KINASE; S-LOCUS; PLASMA-MEMBRANE; GOLGI-APPARATUS;
   PROTEIN; PLANTS; EXOCYTOSIS; CELLS; POLLINATION; EXPRESSION},
