@article{ WOS:000269403800006,
Author = {Bicknell, R. A. and Heenan, P. B. and Dawson, M. I. and Fletcher, P. J.
   and Christie, M. C.},
Title = {Matromorphy in <i>Pachycladon exile</i> (Brassicaceae) revealed by
   interspecific hybridisation},
Journal = {NEW ZEALAND JOURNAL OF BOTANY},
Year = {2009},
Volume = {47},
Number = {2},
Pages = {139-148},
Month = {JUN},
Abstract = {Pachycladon is a genus from New Zealand and Tasmania with 10 alpine
   species. During a study of Pachycladon exile, maternal-like seedlings
   were frequently observed following interspecific crosses with other
   members of this genus. Crosses were conducted between P. exile and P.
   cheesemanii, P. novae-zelandiae, Arabidopsis thaliana, and Brassica rapa
   to explore the breeding system of this species and to determine the
   genetic origin of these matromorphic plants. Pachycladon exile was found
   to be a sexual, self-compatible species. However, under conditions of
   wide hybridisation, occasional matromorphic seedlings did arise. A
   single copy of the green fluorescence protein (GFP) gene was
   successfully inserted into P. exile and P. cheesemanii by Agrobacterium
   tumefaciens, and these plants were used to follow allelic inheritance in
   this highly homozygous system. It was noted that matromorphic seedlings
   were homozygous for the marker, despite its inheritance from a single
   parent that was hemizygous for GFP. This suggests that these seedlings
   resulted from aberrant development after the reductional division of
   meiosis. We propose that these data indicate that the matromorphic
   progeny of P. exile result from the action of a post-zygotic mechanism
   involving uniparental chromosome elimination and endoreduplication.},
