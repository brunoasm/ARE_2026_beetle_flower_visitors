ISSN = {0378-2697},
Keywords = {BRASSICACEAE, DRABA; POLYPLOIDY, FIXED HETEROZYGOSITY, REPRODUCTIVE
   BIOLOGY, PROTOGYNY, DELAYED SELFING, SEED SET, INBREEDING, MIXED MATING;
   ARCTIC-ALPINE PLANTS},
