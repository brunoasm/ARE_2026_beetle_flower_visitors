   Bogusch, Petr; Blahova, Eliska; Horak, Jakub, Univ Hradec Kralove, Fac Sci, Dept Biol, Rokitanskeho 62, Hradec Kralove 50003, Czech Republic.},
DOI = {10.1007/s11829-020-09789-y},
EarlyAccessDate = {OCT 2020},
ISSN = {1872-8855},
EISSN = {1872-8847},
Keywords = {Bees; Monolectic; Oligolectic; Polylectic; Flower; Red list; Habitat},
Keywords-Plus = {HOST-RANGE EVOLUTION; HONEYBEE DECLINE; HYMENOPTERA; POLLINATOR;
   MEGACHILIDAE; PHYLOGENY; PESTICIDE; PATTERNS; IMPACTS; BRITAIN},
