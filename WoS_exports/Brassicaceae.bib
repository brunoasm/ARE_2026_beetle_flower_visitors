@article{ WOS:A1976BR33000003,
Author = {HURKA, H and KRAUSS, R and REINER, T and WOHRMANN, K},
Title = {FLOWERING BEHAVIOR OF CAPSELLA-BURSA-PASTORIS (BRASSICACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1976},
Volume = {125},
Number = {2},
Pages = {87-95},
Abstract = {C. bursa-pastoris (L.) Med. is a partially self-pollinating, autogamous
   plant. The selfing-rate depends on ecological factors. High atmospheric
   humidity at temperatures over 15.degree. C and low light intensity, i.e.
   cloudy and rainy weather, lead to almost exclusive self-pollination,
   while dry and sunny weather favors outcrossing. At low temperatures
   (about 4-10.degree. C) anthesis is prolongated up to 5-fold, but
   allogamy is reduced. Day-length distinctly influences the beginning of
   flowering. C. bursa-pastoris is not a day-neutral plant (as was supposed
   up to now) but behaves as a quantitative long-day plant.},
