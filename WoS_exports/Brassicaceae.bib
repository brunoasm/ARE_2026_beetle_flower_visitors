   Louisiana State Univ, Ctr Agr, Dept Plant Pathol \& Crop Physiol, Agr Expt Stn, Baton Rouge, LA 70803 USA.
   Marine Biol Lab, Biocurrents Res Ctr, Woods Hole, MA 02543 USA.},
DOI = {10.1139/b99-098},
