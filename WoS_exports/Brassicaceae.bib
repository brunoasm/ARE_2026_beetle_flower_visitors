Year = {1997},
Pages = {141-144},
Note = {1997 Congress of the Sociedad-Espanola-de-Malherbologia, VALENCIA,
   SPAIN, NOV 24-26, 1997},
Organization = {Soc Espanola Malhebologia},
Abstract = {This work evaluates the reproductive strategy of Erucastrum
   nasturtiifolium (Poiret) O. W. Schulz (Brassicaceae) in barley (Hordeum
   vulgare L.)-fallow systems. Some demographic, morphologic, and
   reproductive parameters have been compared in a nan-herbicides
   experiment. Breeding sq stem studies has also been carried out by hand
   pollination. Barley competition decreases survival and fertility off.
   nasturtiifolium and causes a drastic reduction in morphologic
   characters. Moreover fecundity is affected by the absence of pollinators
   inside the barley crop.},
