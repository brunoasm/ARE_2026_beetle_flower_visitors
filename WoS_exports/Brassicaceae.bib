Funding-Acknowledgement = {Deutsche Forschungsgemeinschaft {[}TH 417/4-1, -2, NE 314/7-1]},
Funding-Text = {We gratefully acknowledge E. Stolle and F. Burger (Institute of Zoology,
   Halle) for taxonomic determination of Syrphidae and bees plus wasps,
