
@article{ WOS:000172582800009,
Author = {Otero-Arnaiz, A and Oyama, K},
Title = {Reproductive phenology, seed-set and pollination in <i>Chamaedorea
   alternans</i>, an understorey dioecious palm in a rain forest in Mexico},
Journal = {JOURNAL OF TROPICAL ECOLOGY},
Year = {2001},
Volume = {17},
Number = {5},
Pages = {745-754},
Month = {SEP},
Abstract = {The pollination ecology and reproductive phenology of a dioecious palm,
   Chamaedorea alternans were studied at Los Tuxtlas Biological Station in
   Veracruz state., Mexico during the 1995-96 flowering season. The sexes
   flower synchronously from October to January. Field observations
   investigated reproductive phenology, flower visitors and inflorescence
   and fruit production. Males produce more flowers and inflorescences than
   females. Seed-set was 13\%, indicating low reproductive efficiency.
   Individual plants showed a great variation in number of inflorescences
   produced. Five female and eight male plants (out of 25 and 37 plants,
   respectively) produced 45\% of all inflorescences in the population
   studied. These five females also produced c. 75\% of all fruits. Seed
   production did not show significant differences between insect-excluded
   and open-pollinated inflorescences, in experiments to test the
   efficiency of wind pollination. Flowers of this species are
   wind-pollinated but a great activity of undetermined species of thrips
   (Thysanoptera) was observed in male inflorescences.},
Publisher = {CAMBRIDGE UNIV PRESS},
Address = {32 AVENUE OF THE AMERICAS, NEW YORK, NY 10013-2473 USA},
Type = {Article},
Language = {English},
Affiliation = {Univ Nacl Autonoma Mexico, Inst Ecol, Apartado Postal 70-275, Mexico City 04510, DF, Mexico.
   Univ Nacl Autonoma Mexico, Inst Ecol, Mexico City 04510, DF, Mexico.},
DOI = {10.1017/S0266467401001559},
ISSN = {0266-4674},
EISSN = {1469-7831},
Keywords = {arecaceae (Palmae); Chamaedorea; dioecy; phenology; pollination biology;
   seed-set; wind pollination},
Keywords-Plus = {FRUIT-SET; ACROCOMIA-ACULEATA; POLLEN LIMITATION; WIND-POLLINATION;
   PATTERNS; DENSITY; POPULATION; BIOLOGY; GROWTH; RATIOS},
Research-Areas = {Environmental Sciences \& Ecology},
Web-of-Science-Categories  = {Ecology},
Affiliations = {Universidad Nacional Autonoma de Mexico},
