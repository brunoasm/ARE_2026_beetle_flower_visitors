@article{ WOS:000180539800014,
Author = {Borchsenius, F},
Title = {Staggered flowering in four sympatric varieties of <i>Geonoma
   cuneata</i> (Palmae)},
Journal = {BIOTROPICA},
Year = {2002},
Volume = {34},
Number = {4},
Pages = {603-606},
Month = {DEC},
Abstract = {Phenology, flowering biology, and pollination were studied for one year
   in four sympatric varieties of the polymorphic palm Geonoma cuneata in
   Ecuador. Flowering seasons of the three most common varieties were
   significantly staggered resulting in minimal temporal overlap. No marked
   differences were found with respect to flowering biology or pollination.
   The implication of these findings for explaining the complicated
   morphological variation pattern found in G. cuneata and similar species
   complexes is discussed.},
