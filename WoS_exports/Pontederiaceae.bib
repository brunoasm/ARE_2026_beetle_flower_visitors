ISSN = {0002-9122},
Keywords-Plus = {SPRENG SOLMS PONTEDERIACEAE; MATING SYSTEM; ADAPTIVE SIGNIFICANCE;
   FILAMENT ELONGATION; SELF-FERTILIZATION; FLORAL VARIATION; EVOLUTION;
