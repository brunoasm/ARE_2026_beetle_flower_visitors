ISSN = {1010-061X},
Keywords = {FLORAL INSTABILITY; POSITION EFFECTS; STRESS CONDITIONS; LOGISTIC
   REGRESSION; EICHHORNIA-PANICULATA; SELFING FLOWERS; HETEROSTYLY},
