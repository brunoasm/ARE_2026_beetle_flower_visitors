   Vrije Univ Brussels, BE-1050 Brussels, Belgium.},
DOI = {10.1016/j.actao.2006.06.005},
ISSN = {1146-609X},
Keywords = {distyly; floral morph; habitat fragmentation; pin reproductive
   advantage; pollination failure; population size; Primula veris; seed
   abortion},
Keywords-Plus = {EICHHORNIA-PANICULATA PONTEDERIACEAE; DECODON-VERTICILLATUS LYTHRACEAE;
   TRISTYLOUS-LYTHRUM-SALICARIA; SEED-SET; POLLINATOR LIMITATION; SMALL
   POPULATIONS; AGRICULTURAL LANDSCAPE; INBREEDING DEPRESSION; GENETIC
   CONSEQUENCES; POLLEN LIMITATION},
