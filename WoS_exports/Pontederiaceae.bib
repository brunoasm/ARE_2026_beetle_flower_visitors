Title = {THE FUNCTION AND ADAPTIVE SIGNIFICANCE OF TRISTYLY IN PONTEDERIA-CORDATA
   L (PONTEDERIACEAE)},
Journal = {BIOLOGICAL JOURNAL OF THE LINNEAN SOCIETY},
