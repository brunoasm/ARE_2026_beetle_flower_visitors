@article{ WOS:000760879400002,
Author = {Pitcairn, Michael J. and Pratt, Paul D. and Villegas, Baldo and Popescu,
   Viola and Borkent, Chris and Reddy, Angelica M.},
Title = {Biological control of water hyacinth, <i>Pontederia crassipes</i> (C.
   Mart.) Solms (Pontederiaceae), in California: release and
   re-distribution of biological control agents 1987-2006},
Journal = {PAN-PACIFIC ENTOMOLOGIST},
Year = {2021},
Volume = {97},
Number = {2},
Pages = {55-66},
Month = {APR},
Abstract = {Water hyacinth, Pontederia crassipes (C. Mart.) Solms (Pontederiaceae),
   is a serious aquatic weed in lakes, ponds, and waterways in California
   and around the world. Three insects, the weevils Neochetina eichhorniae
   Warner, 1970, Neochetina bruchi llustache, 1926 (Coleoptera:
   Brachyceridae), and a leaf moth Niphograpta albiguttalis (Warren, 1889)
   (Lepidoptera: Crambidae) were released at four sites in 1982-1987 for
   the biological control of water hyacinth in the Sacramento-San Joaquin
   River Delta. Here we report on statewide efforts to distribute the
   biological control agents outside the Delta and subsequent surveys to
   determine insect establishment. From 1987-2006, the three insects were
   redistributed to seven locations in five counties (Fresno, Los Angeles,
   Merced, Sacramento, and Santa Cruz) in California. Surveys in 2018-2020
   found both Neochetina weevils at two locations in Merced County and one
   location in Sacramento County. No weevils were found at release
   locations in the upper San Joaquin River and associated waterways in
   western Fresno County or at the release location in Santa Cruz County.
   Plants at the release locations in Los Angeles County and eastern Fresno
   County had been eradicated and not sampled in this survey. These
   recoveries expand the known locations of Neochetina weevils in central
   California. The hyacinth moth, N. alhiguttalis, was not recovered.},
