   Univ Toronto, Dept Bot, Toronto, ON M5S 3B2, Canada.},
DOI = {10.2307/2656706},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Amaryllidaceae; late-acting self-incompatibility; Narcissus; ovule
