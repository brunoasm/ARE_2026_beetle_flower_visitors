@article{ WOS:A1978FZ57000002,
Author = {BARRETT, SCH},
Title = {FLORAL BIOLOGY OF EICHHORNIA-AZUREA (SWARTZ) KUNTH (PONTEDERIACEAE)},
Journal = {AQUATIC BOTANY},
Year = {1978},
Volume = {5},
Number = {3},
Pages = {217-228},
Abstract = {Since only the long- and short-styled forms of E. azurea (Swartz) Kunth
   were observed by botanists, the species was considered distylous.
   Populations containing these forms and the missing mid-styled form are
   reported from the Lower Amazon {[}South America] demonstrating that E.
   azurea is tristylous. Strong pollen trimorphism and moderate
   self-incompatibility accompany floral heteromorphism. The
   incompatibility behavior of pollen from the 2 anther levels of a flower
   differ markedly. Self-pollination of a long-styled form resulted in
   94.3\% capsule set with pollen from mid level anthers, whereas only
   12.2\% of flowers pollinated with pollen from short level anthers
   produced capsules. A semi-homostylous race of E. azurea from Costa Rica
   is self-compatible, autogamous and possesses dimorphic pollen. E. azurea
   is similar to E. crassipes (Mart.) Solms-Laubach in its dispersal both
   by floating vegetative parts and by seeds. Its breeding system more
   closely resembles that of tristylous Pontederia species {[}P. cordata
   and P. rotundifolia] than E. crassipes.},
