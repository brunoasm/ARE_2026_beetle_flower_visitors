Language = {English},
Affiliation = {Weller, SG (Corresponding Author), Univ Calif Irvine, Dept Ecol \& Evolutionary Biol, Irvine, CA 92697 USA.
   Univ Calif Irvine, Dept Ecol \& Evolutionary Biol, Irvine, CA 92697 USA.},
ISSN = {0024-4074},
EISSN = {1095-8339},
Keywords = {distyly; heteromorphic self-incompatibility; heterostyly; homomorphic
   multi-allelic self-incompatibility; inbreeding depression; reciprocal
   herkogamy; tristyly},
