@article{ WOS:A19656915400002,
Author = {JAMES, SH},
Title = {COMPLEX HYBRIDITY IN ISOTOMA PETRAEA .I. OCCURRENCE OF INTERCHANGE
   HETEROZYGOSITY AUTOGAMY AND A BALANCED LETHAL SYSTEM},
Journal = {HEREDITY},
Year = {1965},
Volume = {20},
Number = {3},
Pages = {341+},
Abstract = {In Isotoma petraea the typical Lobeliaceae pollination mechanism has
   been modified so that in many south-western populations at least,
   autogamy is achieved. Isotoma species are pre-adapted for the
   maintenance of interchange heterozygosity by virtue of their general
   cyto-logical features. Interchange heterozygosity occurs widely
   throughout I. petraea, I. axillaris and I. anaethifolia. There is a
   basic karyotype (chromosome end sequence) common to petraea, axillaris
   and anaethifolia and it is transcontinental in distribution. There is no
   evidence to indicate that this karyotype has been replaced by new
   sequences to any significant extent. Complex hybridity has evolved in
   the extreme south-western population through a process of sequential
   fixation of interchanges in the heterozygous condition. The complex
   hybrids are true breeding being stabilised by a balanced lethal
   mechanism operating through zygotic elimination of the structural
   homozy-gotes. It seems clear that the complex hybrid genetic system has
   evolved under conditions of, and as a response to, a high degree of
   inbreeding in the natural populations.},
Publisher = {SPRINGERNATURE},
Address = {CAMPUS, 4 CRINAN ST, LONDON, N1 9XW, ENGLAND},
