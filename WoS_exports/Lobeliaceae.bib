   Grinnell Coll, Dept Biol, Grinnell, IA 50112 USA.
   Grinnell Coll, Dept Math, Grinnell, IA 50112 USA.
   Grinnell Coll, Dept Biol, Grinnell, IA 50112 USA.},
DOI = {10.3732/ajb.90.9.1333},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {Lobelia cardinalis; Lobelia siphilitica; Lobeliaceae; natural selection;
   phenotypic selection; pollination; spatial variation; temporal variation},
