DOI = {10.1016/j.foodchem.2009.11.037},
ISSN = {0308-8146},
EISSN = {1873-7072},
Keywords = {Citrus paradisi; Rutaceae; Volatiles; Essential oil; Pollination; SPME;
   Multivariate statistical analysis},
