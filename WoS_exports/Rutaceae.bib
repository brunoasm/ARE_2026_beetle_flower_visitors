   Tang, Jing-Yu; Ren, Ming-Xun, Chinese Acad Sci, Wuhan Bot Garden, Key Lab Aquat Bot \& Watershed Ecol, Wuhan 430074, Peoples R China.},
DOI = {10.1016/j.actao.2011.05.013},
ISSN = {1146-609X},
