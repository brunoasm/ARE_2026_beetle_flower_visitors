   Stobdan, Tsering},
Title = {Identification and validation of sex-linked SCAR markers in dioecious
   <i>Hippophae rhamnoides</i> L. (Elaeagnaceae)},
Journal = {BIOTECHNOLOGY LETTERS},
Year = {2012},
Volume = {34},
Number = {5},
Pages = {973-978},
Month = {MAY},
Abstract = {The actinorhizal plant seabuckthorn ( L., Elaeagnaceae) is a wind
   pollinated dioecious crop. To distinguish male genotypes from female
   genotypes early in the vegetative growth phase, we have developed robust
   PCR-based marker(s). DNA bulk samples from 20 male and 20 female plants
   each were screened with 60 RAPD primers. Two primers, OPA-04 and OPT-06
   consistently amplified female-specific (FS) polymorphic fragments of
   1,164 and 868 bp, respectively, that were absent in the male samples.
   DNA sequence of the two markers did not exhibit significant similarity
   to previously characterized sequences. A sequence-characterized
   amplified region marker (JQ284019) and (JQ284020) designed for the two
   fragments, continued to amplify the FS allele in 120 female plants but
   not in 100 male plants tested in the current study. Thus, and are FS
   markers that can determine the sex of seabuckthorn plants in an early
   stage and expedite cultivations for industrial applications.},
