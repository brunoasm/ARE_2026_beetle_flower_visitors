DOI = {10.1663/0006-8101(2002)068{[}0055:DAAEIN]2.0.CO;2},
ISSN = {0006-8101},
EISSN = {1874-9372},
Keywords-Plus = {PHYLOGENETIC-RELATIONSHIPS; SOUTH-AMERICA; POLLINATION; HUMMINGBIRD;
   MONOGRAPH; PLANTS; BIRDS; COEVOLUTION; SUBFAMILIES; MYCORRHIZAE},
