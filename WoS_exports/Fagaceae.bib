DOI = {10.1016/j.foreco.2008.06.049},
ISSN = {0378-1127},
Keywords = {Acorn production; Cork oak; Holm oak; Hybridization; Phenology of
   flowering; Quercus ilex subsp rotundifolia; Q. rotundifolia; Quercus
   suber},
