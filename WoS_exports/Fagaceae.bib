@article{ WOS:A1989AD15800007,
Author = {CREPET, WL and NIXON, KC},
Title = {EARLIEST MEGAFOSSIL EVIDENCE OF FAGACEAE - PHYLOGENETIC AND
   BIOGEOGRAPHIC IMPLICATIONS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1989},
Volume = {76},
Number = {6},
Pages = {842-855},
Month = {JUN},
Abstract = {Fossil evidence of Fagaceae from the Paleocene/Eocene boundary of
   western Tennessee is described and discussed. These fossils include a
   newly discovered pistillate inflorescence and dispersed fruits of
   subfamily Castaneoideae as well as a taxon that resembles modern
   trigo-nobalanoids (pistillate inflorescences and dispersed mature
   fruits). Fossil staminate catkins with fagaceous pollen, which we
   suggest may be conspecific with the trigonobalanoid infructescences, are
   also found at the locality.  Two distinct types of fagaceous leaves are
   present at the locality. The reproductive structures are the oldest
   megafossils unequivocally assignable to Fagaceae and represent the
   oldest remains of subfamily Fagoideae and the oldest megafossil remains
   of Castaneoideae. In addition, the fossils provide insights into the
   chronology of diversification, biogeography, and phylogeny of Fagaceae.
   The trigonobalanoid remains may also provide insights into the timing
   and circumstances of the evolution of  wind pollination in Fagaceae.},
