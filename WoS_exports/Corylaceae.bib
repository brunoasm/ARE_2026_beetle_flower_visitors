
@article{ WOS:000072457100006,
Author = {Frenguelli, G and Ferranti, F and Tedeschini, E and Andreutti, R},
Title = {Volume changes in the pollen grain of Corylus avellana L. (Corylaceae)
   during development},
Journal = {GRANA},
Year = {1997},
Volume = {36},
Number = {5},
Pages = {289-292},
Abstract = {Pollen development in 8-year-old hazel plants (Corylus avellana L.) from
   Central Italy was monitored in order to investigate the chilling
   completion date of the catkins. Meiotic division occurred in September
   and pollen development continued until mid-October when the first
   haploid mitosis divisions were observed. The catkins elongated gradually
   during the summer until mid-October when their growth slowed. In
   mid-December the catkins resumed rapid growth and released pollen. From
   the end of October the pollen grain volume decreased by 12\% on average,
   reaching its minimum value on 6th November. From this time onwards
   volume increased again to reach its maximum value al the beginning of
   December, just before pollination. In mid-October the daily mean
   temperature dropped below 12.4 degrees C and remained at this low level
   during the succeeding period; a relatively high mean temperature, above
   4.5 degrees C, was recorded in the second week of December. The
   beginning of dormancy could be correlated with the slowing down of
   catkin growth and the decrease in the volume of the pollen grains after
   the first haploid mitosis. When the chilling requirement is fulfilled,
   at about 640 chill units, the pollen grain volume reaches its maximum
   value.},
