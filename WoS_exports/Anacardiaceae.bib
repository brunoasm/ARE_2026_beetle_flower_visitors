@article{ WOS:000086386900003,
Author = {Chung, MG and Chung, JM and Epperson, BK},
Title = {Spatial genetic structure of allozyme polymorphisms within populations
   of <i>Rhus trichocarpa</i> (Anacardiaceae)},
Journal = {SILVAE GENETICA},
Year = {1999},
Volume = {48},
Number = {5},
Pages = {223-227},
Abstract = {Rhus trichocarpa MIQ. (Anacardiaceae) is a dioecious, insect-pollinated
   tree. It has a wide distribution in East Asia, from Japan, China and
   Korea, north to Sakhalin. In these regions, R. trichocarpa is a pioneer
   tree that, once established, creates conditions favorable for subsequent
   successional tree species, by providing attractive perching for various
   bird species, which then drop seed of the later successional species.
   Later species form pine-oak forests which overgrow R. trichocarpa. We
   used allozyme loci and spatial autocorrelation statistics to examine the
   spatial distribution of allozyme polymorphisms of individuals in two
   Korean populations. Populations of the species maintain moderate levels
   of allozyme variation (mean H-e = 0.173, G(ST) = 0.064). It was found
   that genetic patch width was at least 25 m, and this was created by
   limits to seed or pollen dispersal.},
