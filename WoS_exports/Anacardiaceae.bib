@article{ WOS:A1986F914400004,
Author = {MONCUR, MW and WAIT, AJ},
Title = {FLORAL ONTOGENY OF THE CASHEW, ANACARDIUM-OCCIDENTALE L (ANACARDIACEAE)},
Journal = {SCIENTIA HORTICULTURAE},
Year = {1986},
Volume = {30},
Number = {3},
Pages = {203-211},
Month = {DEC},
Abstract = {Scanning electron micrographs of the cashew are presented, showing the
   development of the male and hermaphrodite inflorescences. An unusual
   feature is the three different lengths of stamens and their role in
   pollination. Although cashew flowers have many features common to
   flowers pollinated by insects, few were observed except for ants. Nectar
   was not detected in many flowers and concentrations varied between
   selections. These results are discussed in the light of conflicting
   views of whether  anemophily or entomophily is the basic mode of
   pollination.},
