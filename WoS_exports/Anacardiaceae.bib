@article{ WOS:000272194300008,
Author = {Matsuyama, Shuhei and Osawa, Naoya and Sakimoto, Michinori},
Title = {Generalist pollinators in the dioecious shrub <i>Rhus trichocarpa</i>
   Miq. (Anacardiaceae) and their role in reproductive success},
Journal = {PLANT SPECIES BIOLOGY},
Year = {2009},
Volume = {24},
Number = {3},
Pages = {215-224},
Month = {DEC},
Abstract = {We examined the floral display size and potential pollinators of female
   and male Rhus trichocarpa in northern Kyoto, Japan, in June 2005. The
   entomophilous pollination system comprised 431 insects and one spider
   belonging to 124 species. Most pollinators were non-social bees and
   occasional Diptera and Coleoptera, whereas eusocial bees were not
   dominant in the pollination system. Male-biased frequencies were
   observed in the eusocial bees and in some of the non-social bees,
   probably because they are sensitive to the larger male floral rewards. A
   pollinator introduction experiment confirmed that male-biased, unbiased
   and infrequent non-social bees can pollinate R. trichocarpa, indicating
   that non-social bees can contribute to fruit set. The results suggest
   that there are likely to be two different functional groups of
   generalist pollinators: (i) the majority of the pollinators may
   contribute to reproductive success through unbiased and occasional
   visits; and (ii) a minority group of eusocial bees may contribute to
   reproductive success through male-biased visits.},
