@article{ WOS:000269119900021,
Author = {de Brito Melo Trovao, Dilma Maria and de Souza, Bruno Cruz and Dantas de
   Carvalho, Ellen Cristina and Barbosa Oliveira, Pedro Thiago and Rocha
   Ferreira, Lucianna Marques},
Title = {VEGETABLE SPECIES OF THE CAATINGA ASSOCIATED THE COMMUNITIES OF BEES
   (Hymenoptera: Apoidea: Apiformis)},
Journal = {REVISTA CAATINGA},
Year = {2009},
Volume = {22},
Number = {3},
Pages = {136-143},
Abstract = {This work was carried out in an area covered by the caatinga
   (savanna-like) vegetation in order to study insect-plant interactions,
   with emphasis on the pollination agents of the Apoideae superfamily. The
   study site is situated in the municipality of Caturite, Paraiba,
   Northeast Brazil (7 degrees 25' 12 `' S; 36 degrees 1' 37 `' W). Plant
   species visited by bees were identified, as well as the Hymenopterans
   considered as their visitors. Sixteen Angiospermae species from nine
   families were identified as being associated to bees in the woody and
   herbaceous strata. The most visited plant families were Fabaceae (50\%)
   and Anacardiaceae (12.5\%). Anandenanthera macrocarpa (Benth) and Senna
   spectabillis had the greatest numbers of visitors (85\% and 57\%
   respectively). Among the pollinating bees, the one which visited more
   plant species was Trigona spinipes (Fabricius). It was found visiting
   81.25\% of the plant species under study.},
Publisher = {UNIV FED RURAL SEMI-ARIDO-UFERSA},
Address = {PRO-REITORIA PESQUISA POS-GRADUACAO, BR 110 - KM 47 S-N, MOSSORO,
   59625-900, BRAZIL},
Type = {Article},
