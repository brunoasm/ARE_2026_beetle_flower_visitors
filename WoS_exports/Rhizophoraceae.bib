Address = {OHIO STATE UNIV-DEPT BOTANY 1735 NEIL AVE, COLUMBUS, OH 43210 USA},
Type = {Article},
Language = {English},
Affiliation = {Sun, M (Corresponding Author), Univ Hong Kong, Dept Bot \& Zool, Pokfulam Rd, Hong Kong, Hong Kong.
   Univ Hong Kong, Dept Bot \& Zool, Hong Kong, Hong Kong.
   Griffith Univ, Sch Appl Sci, Gold Coast, Qld 9726, Australia.},
