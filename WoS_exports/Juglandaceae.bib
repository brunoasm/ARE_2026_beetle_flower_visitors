Language = {English},
Affiliation = {Cao, GX (Corresponding Author), Sichuan Agr Univ, Dept Forestry, Chengdu 611130, Peoples R China.
   Cao, Guo-Xing; Li, Rui-Ting; Li, Lin; Zeng, Hong; Wang, Jing-Yan, Sichuan Agr Univ, Dept Forestry, Chengdu 611130, Peoples R China.},
