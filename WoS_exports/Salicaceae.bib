Keywords = {SALICACEAE; SALIX; POLLINATION; ENTOMOPHILY; ANEMOPHILY; FLORAL SCENT;
   DIOECY; CHEMICAL ANALYSIS; GC-MS; 1,4-DIMETHOXY BENZENE},
