@article{ WOS:A1992JX23500004,
Author = {TOLLSTEN, L and KNUDSEN, JT},
Title = {FLORAL SCENT IN DIOECIOUS SALIX (SALICACEAE) - A CUE DETERMINING THE
   POLLINATION SYSTEM},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1992},
Volume = {182},
Number = {3-4},
Pages = {229-237},
Abstract = {Floral scents of male and female inflorescences of three dioecious Salix
   species were collected by head-space adsorption, and analysed by GC-MS.
   In Salix caprea and S. cinerea 1,4-dimethoxy benzene was the main
   compound, and male and female scents showed a high degree of
   resemblance. No dominant compound was found in S. repens and male-female
   scent similarity was low. Floral scent in Salix is likely a strong
   orientation cue, guiding pollinators between male and female plants
   ensuring pollen transfer and pollination. We suggest that a high degree
   of male-female floral scent resemblance is coupled to a high degree of
   insect pollination. Floral scent does not promote reproductive isolation
   between S. caprea and S. cinerea.},
