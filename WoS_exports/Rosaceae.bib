   Pymatuning Lab Ecol, Linesville, PA 16424 USA.},
DOI = {10.1086/338395},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {gametophyte; relative growth rate; Fragaria virginiana; pollen
   competition; progeny vigor; resource environment; sporophyte; strawberry},
Keywords-Plus = {LOAD SIZE; EVOLUTION; PERFORMANCE; POLLINATION; DIVERSITY; QUANTITY;
   FITNESS; DIOECY; DONORS},
