@article{ WOS:A1986D266100020,
Author = {ALLEN, GA},
Title = {FLOWERING PATTERN AND FRUIT PRODUCTION IN THE DIOECIOUS SHRUB
   OEMLERIA-CERASIFORMIS (ROSACEAE)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1986},
Volume = {64},
Number = {6},
Pages = {1216-1220},
Month = {JUN},
Abstract = {Male plants of Oemleria cerasiformis have a larger flower display and a
   longer flowering period than females, and tend to show greater
   phenological variability. Male inflorescences generally begin to flower
   sooner than females, but reach their peak and finish flowering later.
   Their longer blooming period is mainly the result of less synchronous
   flower opening in males. In both sexes flowering tends to be completed
   more rapidly in later inflorescences. Fruit set in females is positively
   correlated with time of flowering (r = 0.313) and inflorescence size (r
   = 0.421). Hand-pollination of female flowers increased fruit set in most
   inflorescences, indicating that reproductive success in female O.
   cerasiformis may be pollen limited.},
