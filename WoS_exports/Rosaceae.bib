@article{ WOS:001172751300001,
Author = {Morimoto, Takuya and Narazaki, Ryuya and Okabe, Hiroaki and Zhang, Lumin
   and Nishimura, Kazusa and Itai, Akihiro},
Title = {Introduction of a diverse genetic background of <i>Pyrus</i> into
   <i>Malus</i> through intergeneric hybridization},
Journal = {MOLECULAR GENETICS AND GENOMICS},
Year = {2024},
Volume = {299},
Number = {1},
Month = {DEC},
Abstract = {Wide hybridizations across species and genera have been employed to
   enhance agriculturally important traits in crops. Within the tribe
   Maleae of the Rosaceae family, different genera and species exhibit
   several traits useful for increasing diversity and gene pool through
   hybridization. This study aimed to develop and characterize intergeneric
   hybrid individuals between Malus and Pyrus. Through seed germination,
   shoot multiplication, and rooting in vitro, acclimatized seedlings
   showing vegetative growth on their own roots were obtained from crosses
   of Malus x domestica pollinated by Pyrus communis, P. bretschneideri,
   and the Pyrus interspecific hybrid (P. communis x P. pyrifolia).
   Comparative analysis of leaf morphology, flow cytometry, and molecular
   genotyping confirmed the hybrid status of the individuals. Genome-wide
   genotyping revealed that all the hybrid individuals inherited genomic
   fragments symmetrically from the Malus and Pyrus parents. To the best of
   our knowledge, this is the first report on the development of
   intergeneric hybrid seedlings between Malus x domestica and P.
   bretschneideri. Furthermore, the Pyrus interspecific hybrid individual
   served as a bridge plant for introducing the genetic background of P.
   pyrifolia into Malus x domestica. The results of this study provided a
   crucial foundation for breeding through intergeneric hybridization
   between Malus and Pyrus, facilitating the incorporation of valuable
   traits from diverse gene pools.},
