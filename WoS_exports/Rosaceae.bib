@article{ WOS:A1985C203400002,
Author = {NYBOM, H},
Title = {ACTIVE SELF-POLLINATION IN BLACKBERRIES (RUBUS SUBGEN RUBUS, ROSACEAE)},
Journal = {NORDIC JOURNAL OF BOTANY},
Year = {1985},
Volume = {5},
Number = {6},
Pages = {521-525},
Abstract = {Most blackberry species are apomictic but pseudogamous, i.e. embryo
   development is dependent on prior pollination. Two different types of
   stamen arrangement were noted in senescing flowers of 18 Swedish species
   {[}R. nessensis, R. scissus, R. plicatus, R. sulcatus, R. nitidus, R.
   affinis, R. sprengelii, R. axillaris, R. pyramidalis, R. insularis, R.
   polyanthemus, R. lindebergii, R. thyrsanthus, R. vestitus, R. taeniarum,
   R. radula, R. harthmannii, and R. bellardii] and 2 common cultivars. The
   stamens of `'cross-pollinating'' species seldom touch the stigmas while
   the those while those of `'self-pollinating'' species instead arch over
   the pistils and dry up in this position. All species set seed wall after
   artificial self-pollination an are thus self-compatible. Isolation
   experiments were carried out during 3 years. When inflorescences were
   bagged, seed set was drastically lowered in `'cross-pollinators'' but
   remained almost unaltered in `'self-pollinators''. The different
   responses to isolation are probably due to the inherent stamen behavior.},
