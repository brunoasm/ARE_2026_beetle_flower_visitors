ISSN = {0018-5345},
EISSN = {2327-9834},
Keywords = {Bateson-Dobzhansky-Muller model; hybrid lethality; Rosaceae; tissue
   culture},
Keywords-Plus = {HYBRID NECROSIS; SELF-INCOMPATIBILITY; ANTHOCYANINS; MITSCHURINII;
