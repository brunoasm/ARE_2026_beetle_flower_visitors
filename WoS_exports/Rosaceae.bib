@article{ WOS:000255131000011,
Author = {Karst, Amanda L. and Antos, Joseph A. and Allen, Geraldine A.},
Title = {Sex ratio, flowering and fruit set in dioecious <i>Rubus chamaemorus</i>
   (Rosaceae) in Labrador},
Journal = {BOTANY-BOTANIQUE},
Year = {2008},
Volume = {86},
Number = {2},
Pages = {204-212},
Month = {FEB},
Note = {Symposium on Ethnobotany held at the 42nd Annual Meeting of the
   Canadian-Botanical-Association, Montreal, CANADA, JUN, 2006},
Organization = {Canadian Botan Soc},
Abstract = {Rubus chamaemorus L. is a dioecious clonal herb with highly variable
   fruit production. Our overall objective was to determine how fruit
   production (and the reproductive stages leading to fruit) for R.
   chamaemorus varied with habitat and population (especially sex ratio)
   characteristics at scales from 1 m(2) quadrats to whole populations in
   southeastern Labrador, Canada. During the climatically favourable year
   studied, reproductive variables were only weakly correlated with habitat
   characteristics. Strongly biased sex ratios were found at scales of 1-10
   m. Male-dominated quadrats exhibited a significantly higher proportion
   of flowering ramets than did female-dominated quadrats. Female-biased
   sex ratios of flowering ramets and large distances between male and
   female flowers were correlated with decreased seed set. We found no
   differences in microhabitats of males and females. Although the biased
   local sex ratios could limit sexual reproduction, the high fruit set we
   measured clearly indicates that populations are able to produce abundant
   fruit during favourable years in this unpredictable environment.},
