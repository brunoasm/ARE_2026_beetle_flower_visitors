@article{ WOS:A1993MH15400010,
Author = {GUITIAN, J},
Title = {WHY PRUNUS-MAHALEB (ROSACEAE) PRODUCES MORE FLOWERS THAN FRUITS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1993},
Volume = {80},
Number = {11},
Pages = {1305-1309},
Month = {NOV},
Abstract = {Various mutually compatible hypotheses have been proposed to explain the
   low levels of fruit set observed in many hermaphrodite plants. I carried
   out trials to determine which of these hypotheses best explains the low
   fruit set occurring in Prunus mahaleb L. (Rosaceae).The results of
   insect exclusion, supplementary pollination, and flower removal
   experiments indicate that the ovary reserve hypothesis and the selective
   abortion hypothesis seem to be the most likely explanations for the
   production of excess flowers in P. mahaleb.},
