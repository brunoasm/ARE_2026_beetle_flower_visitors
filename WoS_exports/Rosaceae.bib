   McLaughlin, Rachel; Keller, Joseph; Wagner, Elizabeth; Biddinger, David; Grozinger, Christina; Hoover, Kelli, Penn State Univ, Dept Entomol, University Pk, PA 16802 USA.},
DOI = {10.1093/ee/nvab141},
