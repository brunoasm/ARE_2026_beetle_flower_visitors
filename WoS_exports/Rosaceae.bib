Title = {Molecular characterization of interspecific hybrids of scented roses
   using RAPD markers},
Booktitle = {PROCEEDINGS OF THE IVTH INTERNATIONAL SYMPOSIUM ON ROSE RESEARCH AND
   CULTIVATION},
Series = {Acta Horticulturae},
Year = {2007},
Number = {751},
