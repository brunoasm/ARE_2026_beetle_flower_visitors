@article{ WOS:A1996VJ70800013,
Author = {Sperens, U},
Title = {Is fruit and seed production in Sorbus aucuparia L (Rosaceae)
   pollen-limited?},
Journal = {ECOSCIENCE},
Year = {1996},
Volume = {3},
Number = {3},
Pages = {325-329},
Abstract = {Pollen-limitation to fruit and seed production in a population of Sorbus
   aucuparia L. was tested in a hand-pollination experiment in northern
   Sweden. Forty-two trees in one population were used as either
   experimental (n = 21) or control trees (n = 21). On each experimental
   tree inflorescences were used for: i) hand-pollination, ii) open
   pollination, close (5-20 cm) to the hand-pollinated inflorescences, and
   iii) open pollination, distant (60-120 cm) to the hand-pollinated
   inflorescences. A positive effect of additional cross-pollen on
   fruit-flower ratio and seed production in hand-pollinated inflorescences
   was found. However. the control inflorescence closest to the
   hand-pollinated inflorescence showed lower fruit-flower ratio and number
   of seeds per fruit than both the more distant control inflorescence and
   the hand-pollinated inflorescence. This observation suggests that
   resources were shifted from the close control inflorescence to the
   hand-pollinated inflorescence. When experimental and control trees were
   compared, no difference in the number of seeds per flower was found.
   These results suggest that resources, rather than pollen, limits fruit
   and seed production in S. aucuparia. However, control trees, but not
   experimental trees, showed a significant positive correlation of
   fruit-flower ratio and number of seeds per flower with floral display.
   This relation indicates that trees with a small floral display under
   natural conditions may be pollen-limited, perhaps because of low
   pollinator attraction.},
Publisher = {TAYLOR \& FRANCIS INC},
Address = {530 WALNUT STREET, STE 850, PHILADELPHIA, PA 19106 USA},
Type = {Article},
Language = {English},
Affiliation = {UMEA UNIV, DEPT ECOL BOT, S-90187 UMEA, SWEDEN.},
