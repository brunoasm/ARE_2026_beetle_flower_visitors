@article{ WOS:A1980KK24200002,
Author = {SAID, C},
Title = {SOME ASPECTS OF FLORAL ECOLOGY IN ROSACEAE .2. A MORPHOLOGICAL AND
   HISTOLOGICAL COMPARATIVE-STUDY IN ALCHEMILLA-VULGARIS L AND
   SIBBALDIA-PROCUMBENS L},
Journal = {BULLETIN DE LA SOCIETE BOTANIQUE DE FRANCE-LETTRES BOTANIQUES},
Year = {1980},
Volume = {127},
Number = {3},
Pages = {227-236},
Abstract = {The relationships between organs related to pollination (floral nectary,
   stigma and pollen grains) and the nature of pollination in 2 Rosaceae
   (A. vulgaris L. and S. procumbens L.) are described. The flowers of both
   species show functional nectaries, reduced surface stigmas, wet at
   maturity and sticky pollen grains with ornamented wall. All these
   characteristics agree with the entomogamous nature of the pollination.
   The development of stigmas and pollen grains was examined:
   self-pollination is possible in S. procumbens but difficult in A.
   vulgaris which is characterized by protandrous flowers.},
