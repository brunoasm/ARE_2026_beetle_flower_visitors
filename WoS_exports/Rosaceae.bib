   Wang, Qi-Rui, Henan Acad Forest, Zhengzhou City 450008, Henan, Peoples R China.
   Cao, Yu-Fen, Chinese Acad Agr Sci, Res Inst Pomol, Xingcheng City 125100, Liaoning, Peoples R China.},
DOI = {10.1080/01140670709510208},
ISSN = {0114-0671},
Keywords = {Chinese pears; self-incompatibility; S-genotype; S-RNases; PCR; 3' RACE;
   pollination tests},
