@inproceedings{ WOS:000221598900020,
Author = {Mezzetti, B and Costantini, E and Chionchetti, F and Landi, L and
   Pandolfini, T and Spena, A},
Editor = {Simpson, DW},
Title = {Genetic transformation in strawberry and raspberry for improving plant
   productivity and fruit quality},
Booktitle = {PROCEEDINGS OF THE EURO BERRY SYMPOSIUM - COST 836 FINAL WORSKHOP},
Series = {ACTA HORTICULTURAE},
Year = {2004},
Number = {649},
Pages = {107-110},
Note = {Euro Berry Symposium, Ancona, ITALY, OCT, 2003},
Organization = {Meiosis; Dow AgroSci BV; Bayer CropSci; Coviro; New Fruits;
   Fragoladriatica; Confcooperat Marche; Provincia Di Ancona; CIV; APA Sant
   Orsola; APOFRUIT; APO Scaligera},
Abstract = {DefH9-iaaM-transgenic plants belonging to the three species showed
   achenes development in the absence of fertilisation (parthenocarpy).
   Furthermore, parthenocarpic achenes were able to induce and sustain the
   growth of the receptacle. Under standard cultivation conditions, i.e.
   allowing pollination/ fertilization, the DefH9-iaaM gene increases fruit
   productivity in three perennial species (i.e. wild strawberry,
   cultivated strawberry, raspberry) belonging to the Rosaceae. The
   increased fruit production is caused by an increase of the following
   parameters: fruit weight, fruit number per inflorescence, number of
   inflorescences per plant. The increase in fruit production does not
   curtail fruit total sugar content, a parameter related to fruit quality.
   Different rolC clones of `Calypso', an ever-bearing cultivated
   strawberry, were studied for their agronomic behaviour and tolerance to
   Phytophthora cactorum. Field observation on plant phenotype, fruit
   production, fruit size and quality, as well as tolerance to P. cactorum,
   allowed the identification of 2 `Calypso' rolC lines with improved
   agronomic performances of particular interest for strawberry production.},
