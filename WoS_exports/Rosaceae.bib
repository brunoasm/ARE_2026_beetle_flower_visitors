@article{ WOS:000253031200002,
Author = {Zhang, Lin and Tan, Xiao-Feng and Wuyun, Ta-Na and Qiu, Jian and Yuan,
   De-Yi and Wang, Qi-Rui and Cao, Yu-Fen and Zhang, Dang-Quan},
Title = {Identification of new <i>S</i>-RNase alleles and <i>S</i>-genotype in
   two pear species (<i>Pyrus pyrifolia</i> and <i>P-bretschneideri</i>)
   grown in China by genomic PCR and pollination tests},
Journal = {NEW ZEALAND JOURNAL OF CROP AND HORTICULTURAL SCIENCE},
Year = {2007},
Volume = {35},
Number = {4},
Pages = {403-413},
Month = {DEC},
Abstract = {Most of the economically important Chinese pears display S-RNase-based
   gametophytic self-incompatibility (GSI). By genomic PCR and sequence
   analysis, five new S-RNase alleles (S-5a and S-11 to S-14) in three
   Chinese sand pear (Pyrus pyrifolia) cultivars and six (S-a to S-f) in
   five Chinese white pear (P bretschneideri) cultivars were identified.
   Comparison of nucleotide sequences of S-RNase alleles from the two
   different Chinese pear species revealed that S-a, S-b, and S-d of P.
   bretschneideri was identical to S-8, S-14, and S-12 of P. pyrifolia,
   respectively. We obtained the full-length cDNA sequence of S-12 and
   determined S-12 was expressed only in the style of pear. The functions
   of the new S-RNase alleles were confirmed by the controlled pollination
   tests. As the results, the eight cultivars of the two Chinese pear
   species were genotyped as: `Maogong' (S11S12), `Cangxixueli' (S5aS13),
   `Guiguan' (S2S14), `Jinfeng' ((SSb)-S-a), `Matihuang' ((SSc)-S-b),
   `Jinhuasihao' ((SSe)-S-d), `Youli' ((SSc)-S-b), and `Jitui' ((SSf)-S-c).
   Elucidation of S-genotype would contribute to higher and stable yields
   in the orchards and a more efficient breeding programme of pears.},
Publisher = {RSNZ PUBLISHING},
Address = {PO BOX  598, WELLINGTON, 00000, NEW ZEALAND},
Type = {Article},
Language = {English},
Affiliation = {Tan, XF (Corresponding Author), Cent S Univ Forestry \& Technol, Key Lab Nonwood Forest Prod Forest Minist, 498 S Shaoshan Rd, Changsha 410004, Hunan, Peoples R China.
