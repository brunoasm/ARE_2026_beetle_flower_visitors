@article{ WOS:A1984SR97400034,
Author = {OLSON, AR},
Title = {STRUCTURAL ASPECTS OF POLLINATION IN AMELANCHIER-ALNIFOLIA (MALOIDEAE)},
Journal = {CANADIAN JOURNAL OF BOTANY-REVUE CANADIENNE DE BOTANIQUE},
Year = {1984},
Volume = {62},
Number = {4},
Pages = {858-864},
Abstract = {The blossom structure of A. alnifolia conforms to the typical pattern of
   the Maloideae (Rosaceae). The bowl-shaped perianth of the open flower
   and the staminal whorls around the stigmas facilitate pollination by
   foraging insects. Each of the 5 stigmas is characterized by large
   vacuolate papillae. Stigmatic secretions begin during petal elongation
   resulting in a sticky lipidic exudate on the papillate surface at full
   bloom. The tricolpate pollen adhering to the wet stigmas produce pollen
   tubes that penetrate the stigmas in between adjacent papillae and grow
   through the intercellular spaces of the transmitting tissue toward the
   ovarian locules. Although the blossom structure encourages entomophily,
   anther proximity to the stigmas just prior to anthesis in conjunction
   with the preanthesis shedding of pollen suggests a developmental
   mechanism that promotes a limited amount of autogamy.},
