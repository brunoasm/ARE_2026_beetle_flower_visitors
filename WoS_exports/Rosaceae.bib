@article{ WOS:000184977700002,
Author = {Nyléhn, J and Hamre, E and Nordal, I},
Title = {Facultative apomixis and hybridization in arctic <i>Potentilla</i>
   section <i>Niveae</i> (Rosaceae) from Svalbard},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {2003},
Volume = {142},
Number = {4},
Pages = {373-381},
Month = {AUG},
Abstract = {The degree of sexual seed set and the ability to cross were investigated
   in three taxa of Potentilla section Niveae (P. chamissonis, R insularis
   and R nivea) from the Svalbard Archipelago. Emasculated and bagged
   flowers had little or no seed set, while 71\% of the emasculated, bagged
   and pollinated flowers had some. The taxa are interpreted as
   pseudogamous apomicts. Parental plants and offspring were subjected to
   isozyme analysis. Most of the offspring were clones of the mother plant,
   but 1.7\% had bands from the pollen donor. The sexual offspring were all
   produced by mother plants of R insularis, which is interpreted as a
   facultative apomict. Surprisingly, crosses between different taxa gave
   higher seed to ovule ratios and numbers of sexually produced offspring
   than crosses within taxa. Some of the sexually produced hybrid offspring
   had the same kind of hairs on the petioles as their mother taxon,
   showing that hybrids may not be intermediate in hair characters, which
   are considered important in the delimitation of these taxa. The results
   of the present study indicate very close relationships among the
