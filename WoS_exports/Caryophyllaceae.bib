DOI = {10.1007/BF00982316},
ISSN = {0378-2697},
Keywords = {CARYOPHYLLACEAE, DIANTHUS GLACIALIS; POLLINATION, NECTAR, SCENT,
   AUTOGAMY, SEED SET, SEED OVULE RATIO},
Keywords-Plus = {REPRODUCTIVE SUCCESS; ORGANIC-SUBSTANCES; FLORAL NECTAR; CHROMATOGRAPHY;
