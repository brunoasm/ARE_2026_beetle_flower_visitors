   Kula, Abigail A. R.; Dudash, Michele R.; Fenster, Charles B., Mt Lake Biol Stn, Pembroke, VA 24136 USA.},
DOI = {10.3732/ajb.1200636},
ISSN = {0002-9122},
EISSN = {1537-2197},
Keywords = {floral traits; fruit predation; Hadena; nursery pollinator; pollinating
   seed predator; pollination; Silene},
Keywords-Plus = {MILL GARCKE CARYOPHYLLACEAE; REPRODUCTIVE SUCCESS; LARVAL SURVIVAL;
