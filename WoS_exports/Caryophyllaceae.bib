DOI = {10.1086/605872},
ISSN = {1058-5893},
EISSN = {1537-5315},
Keywords = {artificial selection; flower number; petal size; plasticity; sexual
   dimorphism},
Keywords-Plus = {SEXUAL-DIMORPHISM; FLOWER SIZE; TRADE-OFFS; WATER-USE; TRAITS; ALBA;
