@article{ WOS:A1985AKG5000011,
Author = {SVENSSON, L},
Title = {AN ESTIMATE OF POLLEN CARRYOVER BY ANTS IN A NATURAL-POPULATION OF
   SCLERANTHUS-PERENNIS L (CARYOPHYLLACEAE)},
Journal = {OECOLOGIA},
Year = {1985},
Volume = {66},
Number = {3},
Pages = {373-377},
Abstract = {Pollen carryover by ants was estimated in a natural population of S.
   perennis L. (Caryophyllaceae) using fluorescent dye as a pollen analog.
   A highly significant exponential decrease in deposition of dye grains in
   a sequence of flowers visited by the main flower visitor, Formica
   Serviformica rufibarbis F., was observed with most grains being
   deposited in the 1st few flowers visited. At most 12 flowers were
   visited in a sequence. The mean between-flower transfer distance was
   estimated to be 6.2 cm, within-plant movements were excluded the mean
   was 22.5 cm. The distribution of transport distances differed from what
   was observed for honey-bees which occasionally foraged on dense stands
   of S. perennis. Calculations made on the deposition of dye grains
   transferred by ants showed that 7\% of the dye grains deposited in the
   1st flower visited after the dye source may reach a flower situated
   .apprx. 30 cm from the dye source.},
