Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Kula, AAR (Corresponding Author), Univ Maryland, Dept Biol, College Pk, MD 20742 USA.
   Kula, Abigail A. R.; Dudash, Michele R.; Fenster, Charles B., Univ Maryland, Dept Biol, College Pk, MD 20742 USA.
   Kula, Abigail A. R.; Castillo, Dean M.; Dudash, Michele R.; Fenster, Charles B., Mt Lake Biol Stn, Pembroke, VA 24136 USA.
   Castillo, Dean M., Indiana Univ, Dept Biol, Bloomington, IN 47405 USA.},
