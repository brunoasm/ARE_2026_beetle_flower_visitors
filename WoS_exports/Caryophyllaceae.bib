@article{ WOS:A1979HS62000004,
Author = {BATRA, SWT},
Title = {INSECTS ASSOCIATED WITH WEEDS IN THE NORTHEASTERN UNITED-STATES .3.
   CHICKWEED, STELLARIA-MEDIA, AND STITCHWORT, STELLARIA-GRAMINEA
   (CARYOPHYLLACEAE)},
Journal = {JOURNAL OF THE NEW YORK ENTOMOLOGICAL SOCIETY},
Year = {1979},
Volume = {87},
Number = {3},
Pages = {223-235},
Abstract = {Phytophagous and pollinating insects (156 spp.) and 3 phytophagous mites
   are associated with the introduced Eurasian chickweeds, S. media L.
   (Cyrillo) and S. graminea L. in the northeastern USA. Among these are 16
   crop pests, including 3 known vectors of crop viruses that also infect
   S. media. Pollinators are primarily Apoidea, Syrphidae and Formicidae.
   The collection of Tmetothrips subapterus (Haliday) on S. graminea
   represents the 1st Western Hemisphere record. S. media ranks among the
   10 most important weeds in the United States. A biological control
   program is possible, although it may be difficult due to the habit and
   habitat of this winter annual.},
