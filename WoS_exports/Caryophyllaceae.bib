DOI = {10.1007/s10592-019-01226-9},
ISSN = {1566-0621},
EISSN = {1572-9737},
Keywords = {Caryophyllaceae; Conservation genetics; Genetic structure; Geocarpon;
   Glades; Mating systems; Microsatellites; Saline slicks;
   Self-fertilization},
Keywords-Plus = {INBREEDING DEPRESSION; DIVERSITY; EVOLUTION; CONSERVATION; INFERENCE;
