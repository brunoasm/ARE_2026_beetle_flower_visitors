@article{ WOS:A1984TJ95300010,
Author = {WYATT, R},
Title = {THE EVOLUTION OF SELF-POLLINATION IN GRANITE OUTCROP SPECIES OF ARENARIA
   (CARYOPHYLLACEAE) .1. MORPHOLOGICAL CORRELATES},
Journal = {EVOLUTION},
Year = {1984},
Volume = {38},
Number = {4},
Pages = {804-816},
Abstract = {Taxonomists have recognized 2 very closely related spp. of Arenaria
   endemic to granite outcrops in the southeastern USA: the widespread,
   outcrossing A. uniflora and the rare, selfing A. alabamensis. A survey
   of 9 populations showed a wide range of variation in degree of
   protandry, which correlated closely with levels of spontaneous fruit-set
   in the absence of insect pollinators. Highly distinctive differences
   among populations for 11 floral characters were maintained under uniform
   growing conditions in a greenhouse. The characters also varied little
   between years. Strongly protandrous populations had larger petals,
   stamens and styles than homogamous ones, a trend consistent with
   previous observations that selfers often show reduction or loss of
   features associated with the attraction of pollinators. Analysis of 7
   vegetative characters showed clinal geographical patterns, unrelated to
   variation in the breeding system. Self-pollinating morphs probably have
   evolved independently at least twice at the margins of the range of A.
   uniflora.},
