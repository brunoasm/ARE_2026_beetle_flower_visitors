@article{ WOS:A1994NX60400008,
Author = {FLEMING, TH and MAURICE, S and BUCHMANN, SL and TUTTLE, MD},
Title = {REPRODUCTIVE-BIOLOGY AND RELATIVE MALE AND FEMALE FITNESS IN A
   TRIOECIOUS CACTUS, PACHYCEREUS-PRINGLEI (CACTACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1994},
