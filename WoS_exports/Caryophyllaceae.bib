ISSN = {0014-3820},
EISSN = {1558-5646},
Keywords = {Arenaria uniflora; autogamy; male fitness; pollen discounting;
   self-fertilization},
Keywords-Plus = {INBREEDING DEPRESSION; MATING SYSTEM; FERTILIZATION; POLLINATION;
