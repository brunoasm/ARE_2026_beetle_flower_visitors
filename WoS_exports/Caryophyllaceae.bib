@article{ WOS:A1982NU68400004,
Author = {LEVESQUE, CM and BURGER, JF},
Title = {INSECTS (DIPTERA, HYMENOPTERA) ASSOCIATED WITH MINUARTIA-GROENLANDICA
   (CARYOPHYLLACEAE) ON MOUNT WASHINGTON, NEW-HAMPSHIRE, USA, AND THEIR
   POSSIBLE ROLE AS POLLINATORS},
Journal = {ARCTIC AND ALPINE RESEARCH},
Year = {1982},
Volume = {14},
Number = {2},
Pages = {117-124},
Abstract = {M. groenlandica, an abundant alpine plant inhabiting exposed rocky
   slopes on Mount Washington, is attractive to at least 15 nectarivorous
   and pollinivorous insect species {[}Sylvicola marginatus (Say), Hilara
   sp., Carposcalis obscurus (Say), Eristalis tenax (L.), Scathophaga
   nigrolimbata Cresson, Delia platura (Meigen), Nupedia aestiva (Meigen),
   Paregle audacula (Harris) (= radicum, of authors) Spilogona caroli
   (Malloch), Thricops hirtulus (Zetterstedt), T. septentrionalis (Stein),
   T. spiniger (Stein), Phaonia protuberans Malloch, P. rugia (Walker), and
   Bombus terricola terricola], all, except bumblebees, in the order
   Diptera. The most common dipterous visitors are Muscidae, Anthomyiidae
   and noneristaline Syrphidae not specialized for carrying pollen and
   therefore having smaller pollen loads on the body than eristaline
   Syrphidae, and bumblebees possessing specialized pollen retaining
   bristles. These unspecialized flies may compensate for relatively
   inefficient pollen transfer by their numerical superiority and by
   remaining active on cold, cloudy, windy days when specialized
   pollinators are not active. Abundance and variety of insect visitors to
   the plant and their ability to function in the rigorous alpine
   environment unique to Mount Washington ensures cross-pollinaton. The
   plant''s ubiquity ensures abundant pollen and nectar resources for
   insects during peak flowering, allowing them to exist in otherwise
   marginal or inhospitable habitats such as exposed rocky slopes.},
