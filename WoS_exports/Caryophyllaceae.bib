@article{ WOS:A1993LC83600009,
Author = {CARROLL, SB and MULCAHY, DL},
Title = {PROGENY SEX-RATIOS IN DIOECIOUS SILENE-LATIFOLIA (CARYOPHYLLACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1993},
Volume = {80},
Number = {5},
Pages = {551-556},
Month = {MAY},
Abstract = {Most sex ratios reported for Silene latifolia are female biased. As a
   result of experiments performed by Correns in the early 1900s, pollen
   tube competition has generally been accepted as the primary cause of
   these skewed ratios. We did four sets of hand pollinations in which we
   varied the size of pollen loads and placement of pollen along the
   filamentous stigma. The effect of pollen load size on progeny sex ratios
   was not statistically significant. Of 32 maternal families, 17 contained
   more females than males (one ratio deviated statistically from 1:1), and
   13 contained more males than females. Paternal families exhibited a
   greater range of sex ratios, including three with a significant female
   bias and one with a significant male bias. Within experiments. neither
   thy maternal parent nor where pollen was placed had a statistically
   significant effect on progeny sex ratios; the paternal effect was
   significant in one experiment. We suggest that sex ratios in Silene
   latifolia are not necessarily affected by the level of pollen
   competition. Other factors, including variation among males and
   sex-linked mortality, may help explain the skewed sex ratios that
   characterize populations of this species. Further, Correns' observations
   of excess females may have resulted from his use of interspecific
   hybrids.},
Publisher = {BOTANICAL SOC AMER INC},
Address = {OHIO STATE UNIV-DEPT BOTANY 1735 NEIL AVE, COLUMBUS, OH 43210},
Type = {Article},
Language = {English},
Affiliation = {UNIV MASSACHUSETTS,DEPT BIOL,AMHERST,MA 01003.},
