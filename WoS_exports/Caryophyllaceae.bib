DOI = {10.1006/bijl.1996.0119},
ISSN = {0024-4066},
EISSN = {1095-8312},
Keywords = {facilitated inbreeding; floral biology; genetic diversity; island
   biology; Mediterranean Basin; mixed mating-system; pollen to ovule
   ratio; reproductive assurance},
Keywords-Plus = {SELF-FERTILIZATION; EICHHORNIA-PANICULATA; PLANTS; EVOLUTION;
