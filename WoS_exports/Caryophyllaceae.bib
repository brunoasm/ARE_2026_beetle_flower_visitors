Funding-Acknowledgement = {U.S. Fish \& Wildlife Service (USFWS); Division of Forestry and Wildlife
   (DOFAW); National Science Foundation {[}DEB 9815878]},
Funding-Text = {We thank the U.S. Fish \& Wildlife Service (USFWS) for financial
