Address = {ONE NEW YORK PLAZA, SUITE 4600, NEW YORK, NY, UNITED STATES},
Type = {Article},
Language = {English},
Affiliation = {Reynolds, RJ (Corresponding Author), Univ Alabama Birmingham, Dept Med, Div Clin Immunol \& Rheumatol, Birmingham, AL 35294 USA.
   Reynolds, Richard J.; Kula, Abigail A. R.; Fenster, Charles B.; Dudash, Michele R., Mt Lake Biol Stn, Pembroke, VA 24136 USA.
   Reynolds, Richard J.; Kula, Abigail A. R.; Fenster, Charles B.; Dudash, Michele R., Univ Maryland, Dept Biol, College Pk, MD 20742 USA.},
