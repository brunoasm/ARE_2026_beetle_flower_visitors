@article{ WOS:A1991FY20800009,
Author = {CARROLL, SB and MULCAHY, DL},
Title = {THE RELATIONSHIP BETWEEN POLLEN GRAIN-SIZE AND PROGENY GENDER IN
   DIOECIOUS SILENE-LATIFOLIA (CARYOPHYLLACEAE)},
Journal = {SEXUAL PLANT REPRODUCTION},
Year = {1991},
Volume = {4},
Number = {3},
Pages = {203-207},
Month = {JUL},
Abstract = {Experiments and observations conducted during the past 90 years have
   provided conflicting evidence concerning the existence of a size
   difference between pollen grains containing an X chromosome
   (female-determining) and those containing a Y chromosome
   (male-determining) in dioecious Silene latifolia.  Were such a size
   difference to exist, this might explain, at least in part, the
   observation that X-bearing pollen tubes reach the ovary more quickly, on
   average, than Y-bearing pollen tubes.  We tested for such a size
   difference by separating pollen collected from single anthers into three
   size classes:  small, large, and random.  Fruit set (number of
   pollinated flowers that set fruit) and seed set (number of seeds per
   capsule) did not differ for these three pollination treatments.  Progeny
   sex ratios resulting from these three pollen size classes also did not
   differ significantly.  Thus, pollen grain size is not affected by which
   of the two sex chromosomes is present.  Our experiment is the first
   direct test of this relationship.  Based on our results, size
   differences should not be invoked to explain competitive differences in
   male- and female-determining microgametophytes.},
Publisher = {SPRINGER VERLAG},
