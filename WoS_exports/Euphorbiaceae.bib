@article{ WOS:000225242500015,
Author = {Wurdack, KJ and Hoffmann, P and Samuel, R and De Bruijn, A and Van der
   Bank, M and Chase, MW},
Title = {Molecular phylogenetic analysis of Phyllanthaceae (Phyllanthoideae Pro
