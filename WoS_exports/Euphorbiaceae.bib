DOI = {10.1007/s00606-016-1287-5},
ISSN = {0378-2697},
EISSN = {1615-6110},
Keywords = {Barbacenia flava; Campos Rupestres; Endophytic bacteria; Meliponina;
   Ultrastructure; Vellozia intermedia},
