Editor = {Saragih, HT and Ilmi, M and Nopitasari, S and Audinah, L and Widyasari, A and Sari, MA and Masri, M and Palilu, PT and Prabowo, BH and Soleha, S and Solikhah, A and Fitriana, N},
Title = {Pollen Collected by Stingless Bee <i>Tetragonula sapiens</i> Cockerell
   (Apidae: Meliponini) in Organic Farm Land},
Booktitle = {6TH INTERNATIONAL CONFERENCE ON BIOLOGICAL SCIENCE (ICBS 2019) -
   BIODIVERSITY AS A CORNERSTONE FOR EMBRACING FUTURE HUMANITY},
