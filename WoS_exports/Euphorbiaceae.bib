@incollection{ WOS:000281465700003,
Author = {Li Kun and Luo Chang-wei and Liu Fang-yan and Sun Yong-yu and Tang
   Guo-yong and Wang Xiao-qing},
Editor = {Ponterio, C and Ferra, C},
Title = {PROPAGATION CHARACTERISTICS OF <i>JATROPHA CURCAS</i> UNDER DIFFERENT
   CLIMATE CONDITIONS IN YUNNAN, CHINA},
Booktitle = {JATROPHA CURCAS AS A PREMIER BIOFUEL: COST, GROWING AND MANAGEMENT},
Series = {Energy Science Engineering and Technology},
Year = {2010},
Pages = {65-83},
Abstract = {Yunnan Province, located at Southwest of China, is abundant in wild
   Jatropha curcas resources, and is to become the greatest Jatropha
   planting forest province in China in the following 10 years. According
   to different climate conditions at wide distribution area of Jatropha,
   its flowering and fruiting nature changes. To the best of our knowledge,
   there are few papers reporting Jatropha propagating characteristic under
   different climate conditions. This paper made related Jatropha
   investigations between 2006 and 2007, including flowering biology, fruit
   setting biology, pollination, seeds biology under various conditions in
   Yunnan. The results are reported as follows.
   Main Jatropha distribution areas in Yunnan are the hot-dry or warm-dry
   river valleys, including Jinsha River, Honghe River, Lantsang River and
   Nujiang River Valley. Jatropha mainly stand in three tree types as
   forest trees, the four-side scattered trees, and the scattered ones. For
   plants quantity, the four-side scattered trees have the trump card with
   the amount more than 10.13x10(6), while the scattered ones have the
   least with the figure of 2.69x10(6), falling in between are forest ones
   with 6.93x10(6).
   Flora display of Jatropha changes with different water conditions of
   soil. Planted in humid fields, its male flowers often blossom firstly,
   following by quick opening of female ones. Many male floweres are still
   left un-open after all the female ones have blossomed totally. In a few
   inflorescences, female flowers may open firstly. However, if planted in
   drought areas, many female flowers would blossom after all male flowers
   have opened.
   Most of Jatropha plants have two crops of fruit setting, while the first
   crop of fruit is the most important commercially. Individual fruits
   output increase with declined planting density, and increasing soil
   fertilizer content and better water regimes.
   Pollination vector of Jatropha is insect pollinator. Flower visitors are
   mainly bees, flies, beetles, ants, butterflies, and bugs. Flower visitor
   species and visitor number are relating to the species and abundance of
   flowering plants near Jatropha population.
   Biological characteristics of Jatropha seeds collected from 12 different
   sample plots are measured. Its hundred grain weight (HGW) ranges from
   45.08 g to 69.89 g, hundred kernel weight (HKW) is 25.68-45.97 g, and
   kernel rate (KR) is 56.97\%-65.78\%. Seed oil content (SOC) is
   33.18\%-40.14\%, and kernel oil content (SOC) is 53.01\%-64.25\%. Seed
   biological characteristics are different from one producing area to
   another. Correlation analysis between the biological characteristics and
   accumulated temperature shows that there is a positive correlation
   between KOC, HGW, HKW and local accumulated temperature below 7000
   degrees C. While above 7000 degrees C, the correlations is negative.
   There are no evident correlations between HGW, HKW, and accumulated
   temperatures.},
