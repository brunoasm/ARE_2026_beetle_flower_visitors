@article{ WOS:A1997XJ87000010,
Author = {Pacini, E and Franchi, GG and Lisci, M and Nepi, M},
Title = {Pollen viability related to type of pollination in six angiosperm
   species},
Journal = {ANNALS OF BOTANY},
Year = {1997},
Volume = {80},
Number = {1},
Pages = {83-87},
Month = {JUL},
Abstract = {Pollen viability was tested at various times during anther opening in
   three anemophilous (Chamaerops humilis, Festuca arundinacea, Mercurialis
   annua) and three entomophilous (Acanthus mollis, Cucurbita pepo,
   Spartium junceum) species. In certain species of both pollination types
   (Cucurbita pepo, Festuca arundinacea, Mercurialis annua), all pollen
   grains were dead 72 h after anthesis, and in others (Spartium junceum,
   Acanthus mollis, Chamaerops humilis) viability lasted longer. The
   results are discussed in terms of the reproductive ecophysiology of the
