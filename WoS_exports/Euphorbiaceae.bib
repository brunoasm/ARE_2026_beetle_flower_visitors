@article{ WOS:A1976BR15400004,
Author = {EHRENFELD, J},
Title = {REPRODUCTIVE-BIOLOGY OF 3 SPECIES OF EUPHORBIA SUBGENUS CHAMAESYCE
   (EUPHORBIACEAE)},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1976},
Volume = {63},
Number = {4},
Pages = {406-413},
Abstract = {The breeding system, pollen tube development and floral biology of 3
   spp. of Euphorbia subgenus Chamaesyce from SE Arizona {[}USA] were
   examined in field and greenhouse studies. E. albomarginata was entirely
   dependent on insect vectors for pollination and seed production, E.
   capitellata required insect visitors for maximum seed set, but was
   capable of limited self-pollination and E. hyssopifolia was
   self-pollinating and entirely independent of insect vectors. All 3 spp.
   were self-compatible. The differences in reliance on insect vectors,
   diversity of insects and probable amount of outcrossing were related to
   differences in cyathial size and arrangement. The reproductive biology
   of the 3 spp. was similar to that described for other weedy plant taxa.},
