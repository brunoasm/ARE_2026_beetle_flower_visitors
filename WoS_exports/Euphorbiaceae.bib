@article{ WOS:000818703500001,
Author = {De-Farias, Luis F. and Silva, Simone A. and Aona, Lidyanne Y. S. and De
   Oliveira, Favizia F.},
Title = {Floral biology and reproductive system of physic nut (<i>Jatropha
   curcas</i> L., Euphorbiaceae in `Reconcavo da Bahia', Brazil},
Journal = {ANAIS DA ACADEMIA BRASILEIRA DE CIENCIAS},
Year = {2022},
Volume = {94},
Number = {3},
Abstract = {Understanding the floral and reproductive biology of botanical species
   is crucial for the development of strategies in plant breeding systems.
   latropha curcas L. is a promising species for the manufacture of
   biofuels, being previously studied mainly in genetic improvement to
   develop characteristics suitable to biofuels. In order to contribute
   with data for hybridization and breeding programs, this paper studies
   the floral biology and reproductive system in two experimental
   populations of different ages of latropha curcas in Cruz das Almas/BA.
   Both of them were examined about their anthesis, durability, number of
   flowers, stigma receptivity, P:O ratio, and reproduction tests. As
   observed, latropha curcas is a monoecious species and its flowering
   occurs between September and April. Inflorescences are composed of
   unisexual flowers with daytime anthesis (male: 05-06h; female: 07-08h),
   where the staminates last 10h and pistillates 60h. The physic nut is
   self-compatible, forming fruits by self-fecundation and
   cross-pollination, although the greatest number of fruits/seeds is
   generated by natural pollination. Experiment 02, presented a larger
   number of flowers, probably due to the plant's age and physiology.
   Performing artificial pollination between 08:00h and 09:30h is
   recommended for larger production since the stigma is receptive and the
   flowers have a large amount of pollen available.},
