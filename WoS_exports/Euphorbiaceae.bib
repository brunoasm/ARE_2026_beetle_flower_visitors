Keywords = {competition; facilitation; mating system; mimicry; pollination;
   pseudoflowers; rust fungi; spermatia},
Keywords-Plus = {BUMBLE BEES; COMPETITION; NECTAR; COMMUNITY; BEHAVIOR; MIMICRY; FLOWERS},
