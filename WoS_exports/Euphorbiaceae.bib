Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Yamasaki, E (Corresponding Author), Kyoto Univ, Ctr Ecol Res, Otsu, Shiga 5202113, Japan.
   Yamasaki, Eri; Kawakita, Atsushi, Kyoto Univ, Ctr Ecol Res, Otsu, Shiga 5202113, Japan.
   Sakai, Shoko, Res Inst Humanity \& Nat, Kita Ku, Kyoto 6038047, Japan.},
