   Grad Univ, Chinese Acad Sci, Beijing 100049, Peoples R China.},
DOI = {10.1360/aps06097},
ISSN = {0529-1526},
Keywords = {Antidesma montanum; dioecy; fly pollination; Diptera; Euphorbiaceae},
Keywords-Plus = {EVOLUTION; MUTUALISM; ECOLOGY; SYSTEMS; FOREST},
