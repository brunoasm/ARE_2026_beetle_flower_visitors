Keywords = {Androdioecy; allopolyploid; hexaploid; microsatellites; selfing rate;
   outcrossing rate; mixed mating system; wind-pollination; Mercurialis;
   Euphorbiaceae},
Keywords-Plus = {SEX-RATIO EVOLUTION; DEPENDENT SELF-FERTILIZATION; SPECIES RANGE
