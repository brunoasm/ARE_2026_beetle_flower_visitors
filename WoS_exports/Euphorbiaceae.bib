@article{ WOS:000228185000015,
Author = {Goulart, MF and Ribeiro, SP and Lovato, MB},
Title = {Genetic, morphological and spatial characterization of two populations
   of <i>Mabea fistulifera</i> Mart. (Euphorbiaceae), in different
   successional stages},
Journal = {BRAZILIAN ARCHIVES OF BIOLOGY AND TECHNOLOGY},
Year = {2005},
Volume = {48},
Number = {2},
Pages = {275-284},
Abstract = {Two populations of Mabea fistulifera (Euphorbiacea) located at Rio Doce
   State Park (Minas Gerais, Brazil) in places characterized as in
   different successional stages, were investigated through genetic and
   ecological traits. Twenty randomly chosen individuals from each
   population had its genetic data assessed by 43 RAPD markers and were
   also evaluated through five morphologic traits and its spatial
   distribution. Both Shannon's index and AMOVA reveled that most of the
   genetic variation was found between individuals within populations and
   about 9\% of variation was located between populations. Moreover,
   populations differed genetically, but presented similar values of
   genetic diversity. Morphologic data showed differences between
   populations. Significant correlations among matrix of genetic geographic
   and morphologic distances were obtained considering both populations and
   spatially closer individuals were more similar genetically,
   characterizing genetic substructured populations.},
