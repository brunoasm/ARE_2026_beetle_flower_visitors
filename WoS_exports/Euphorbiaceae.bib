@article{ WOS:000352799000010,
Author = {Yao, Gang and Zhang, Dian-Xiang},
Title = {Reinstatement of three names in <i>Glochidion</i> (Phyllanthaceae) based
   on morphological and palynological evidence},
Journal = {NORDIC JOURNAL OF BOTANY},
Year = {2015},
Volume = {33},
Number = {2},
Pages = {197-203},
Month = {APR},
Abstract = {Based on morphological and palynological comparisons, three names, viz.,
   Glochidion mishmiense Hook. f., G. pseudo-obscurum Pamp., and G.
   rubidulum Chin are reinstated. The three names have previously been
   reduced to synonymy of G. zeylanicum var. tomentosum (Dalzell) Trimen,
   G. puberum (L.) Hutch., and G. thomsonii (Muell. Arg.) Hook. f.,
   respectively. Floral morphological characters of G. mishmiense are
   described here for the first time. In addition, G. mishmiense and G.
   pseudo-obscurum are lectotypified, and G. mishmiense is newly recorded
   in China, while the record of G. thomsonii in China is rejected.},
