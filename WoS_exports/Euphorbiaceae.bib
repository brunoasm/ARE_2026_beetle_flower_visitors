Journal = {BIOTROPICA},
Year = {1994},
Volume = {26},
Number = {2},
Pages = {172-179},
Month = {JUN},
Abstract = {Anemophily may be frequent in neotropical dioecious trees, of diverse
   taxonomic affinity, as shown here for 19 species in 13 families at one
   locality, on the basis of floral morphology and pollen presentation.
   Flower-visiting bees often are not pollinators but commensal or
   parasitic. The perceived scarcity of anemophily in tropical trees is
   brought into question by a reconsideration of the evidence regarding
   pollen type, nectar, weather, insect visitors, and tree density.},
