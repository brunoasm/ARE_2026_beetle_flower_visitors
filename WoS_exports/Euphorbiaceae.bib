@article{ WOS:000262542100015,
Author = {Pemberton, Robert W. and Liu, Hong},
Title = {Naturalization of <i>Dalechampia scandens</i> in southern Florida},
Journal = {CARIBBEAN JOURNAL OF SCIENCE},
Year = {2008},
Volume = {44},
Number = {3},
Pages = {417-419},
Abstract = {Dalechampia scandens, a native to the American tropics, was recently
   found naturalized in two Broward County parks in southern Florida. This
   is the first spontaneous occurrence of the plant in the continental
   United States. One of the populations may be an escape from a butterfly
   attraction where the plant was introduced and grown to rear cracker
   (Hamadryas) butterflies. Dalechampia scandens is pollinated by Euglossa
   viridissima, a recently naturalized orchid bee in Florida, known to
   pollinate this species in Mexico.},
