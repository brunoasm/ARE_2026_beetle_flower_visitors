@article{ WOS:A1996VT87400009,
Author = {Lisci, M and Cardinali, G and Pacini, E},
Title = {Pollen dispersal and role of pollenkitt in Mercurialis annua L
   (Euphorbiaceae)},
Journal = {FLORA},
Year = {1996},
Volume = {191},
Number = {4},
Pages = {385-391},
Month = {OCT},
Abstract = {Pollen dispersal of Mercurialis annua L. was studied in the field and
   experimentally. The number of pollen grains that landed on the stigma
   was found to have a mode that varied in relation to wind speed and
   direction. At distances beyond that of the peak, this number decreased
   with increasing distance of pollen dispersal. Under field conditions,
   the pollen was sparse and isolated on the stigma. In the laboratory, the
   pollen on the silicone-coated slides adhered both in clumps and as
   isolated grains. Their number showed a mode which varied in distance in
   relation to wind speed. At higher speeds, the peak was further from the
   plants. The number of grains per clump was larger at shorter distances.
   The wind speed of 0.2 m/s was not sufficient to blow all the pollen
   grains from the anther. At speeds of 0.5 and 1 m/s the anthers were
   always completely empty. These results show that Mercurialis annua
   pollen can be transported in the atmosphere as single grains or in
   clumps of different numbers held together by pollenkitt.},
