   Univ Alaska, Inst Arctic Biol, Fairbanks, AK 99775 USA.
   Univ Alaska Anchorage, Alaska Nat Heritage Program, Environm \& Nat Resources Inst, Anchorage, AK 99501 USA.},
DOI = {10.1046/j.1420-9101.2003.00556.x},
