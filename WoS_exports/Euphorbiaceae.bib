   Svensson, Glenn P., Lund Univ, Dept Ecol, SE-22362 Lund, Sweden.
   Okamoto, Tomoko; Kawakita, Atsushi; Goto, Ryutaro; Kato, Makoto, Kyoto Univ, Grad Sch Human \& Environm Studies, Sakyo Ku, Kyoto 6068501, Japan.},
DOI = {10.1111/j.1469-8137.2010.03227.x},
