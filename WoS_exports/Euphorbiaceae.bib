@article{ WOS:A1997YG21000002,
Author = {Vanzela, ALL and Ruas, PM and MarinMorales, MA},
Title = {Karyotype studies of some species of Dalechampia Plum. (Euphorbiaceae)},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {1997},
Volume = {125},
Number = {1},
Pages = {25-33},
Month = {SEP},
Abstract = {Karyotype studies in eight species of Dalechampia, including 10 natural
   populations, revealed chromosome numbers (2n = 36, 46, 138 and 198)
   differing from two numbers cited in the literature (2n = 44 and 72). The
   basic number a = 6, as in the genus Acalypha, may he considered
   ancestral in Dalechampia. Analyis of chromosome number, haploid
   chromosome length and karotype symmetry suggests that the major
   chromosome mechanism acting in karotype evolution of Dalechampia is
   polyploidy, hut differences in chromosome morphology may be caused be
   chromosome rearrangements.},
