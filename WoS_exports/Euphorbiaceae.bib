   Univ Miami, Dept Biol, Miami, FL 33143 USA.},
DOI = {10.1111/j.1744-7429.2007.00381.x},
ISSN = {0006-3606},
Keywords = {Campanulaceae; floral morphology; hummingbird; Neotropics; pollination;
