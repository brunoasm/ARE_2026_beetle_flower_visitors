EISSN = {1537-5323},
Keywords-Plus = {LEAF SESQUITERPENES; BROWSING MAMMALS; EUGLOSSINE BEES; SNOWSHOE HARES;
   BALSAM POPLAR; WOODY-PLANTS; EUPHORBIACEAE; HERBIVORY; HYMENAEA; ANT},
Research-Areas = {Environmental Sciences \& Ecology; Evolutionary Biology},
