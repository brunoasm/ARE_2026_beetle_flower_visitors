@article{ WOS:000677447000001,
Author = {Kavane, Aarti and Bishoyi, Ashok Kumar and Geetha, K. A.},
Title = {Assessment of facultative apomixis in Commiphora wightii (Burseraceae):
   A detailed study by controlled pollination followed by histology and
   flow cytometry},
Journal = {FLORA},
Year = {2021},
Volume = {281},
Month = {AUG},
Abstract = {Commiphora wightii (Arnott) Bhandari is an important medicinal plant and
   is enlisted as Critically Endangered (CR) category in Red Data Book of
   IUCN. Mostly, the plant is an apomict and existence of obligate
   apomictic and obligate sexual plants was also reported. However, there
   is no conclusive study carried out so far for the identification of
   facultative apomictic plants and its degree of distribution. Therefore,
   a thorough investigation has been carried out to understand the
   facultative nature of the plants using controlled pollination experiment
   followed by histological and flow cytometry analyses. The results of the
   study confirmed both type of reproduction i.e., sexual as well as
   apomictic exists among accessions of C. wightii. Under the
   non-availability of pollen grains, apomictic embryos were visualized
   after 3-5 days after anthesis (DAA) which were developed from the
   nucellar tissues at chalazal as well as micropylar end. However; under
   the availability of pollen grains, the sexual embryo development was
   observed along with apomictic embryos at the micropylar end and were
   visible after 10-15 DAA. Moreover, apomictic embryo development does not
   prevent the sexual embryo development process and hence polyembryony
   state has been achieved by the plant. Maximum four apomictic embryos
   along with a sexual embryo were documented per ovule by this
   investigation. The controlled pollination study also revealed that
   pollination increased the fruit set percentage and fruit filling over
   non-pollinated or open-pollinated plants. The flow-cytometric analysis
   provided evidence of endosperm formation through triple fusion (in
   zygotic embryo development) as well as autonomous (in apomictic embryo
   development) in C. wightii, which proved the facultative apomictic
   nature of the plant. The facultative apomictic plant with polyembryonic
   properties can be used as best suitable material for the identifications
   and mapping of responsible genes for the said traits and for the
   fixation of heterosis.},
Publisher = {ELSEVIER GMBH},
