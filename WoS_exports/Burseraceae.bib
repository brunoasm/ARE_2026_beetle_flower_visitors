@article{ WOS:000296312100007,
Author = {Lippi, Marta Mariotti and Giuliani, Claudia and Gonnelli, Tiziana and
   Bini, Laura Maleci},
Title = {Floral color changes in <i>Boswellia sacra</i> Flueck. (Burseraceae): A
   dialogue between plant and pollinator},
Journal = {FLORA},
Year = {2011},
Volume = {206},
Number = {9},
Pages = {821-826},
Abstract = {The present study provides new information about the reproductive
   biology of Boswellia sacra (Burseraceae), focusing on the nectary and
   its attractiveness for pollinators. The nectary disc changes its color
   from yellow to orange and red during the flower development. The colors
   are related to the main period of the stigmatic receptivity, to the
   dehiscence of anthers with pollen presentation and the nectar secretion.
   Pollinators preferentially visit the flowers in the ``yellow{''} phase
   and neglect the ``red phase{''}. This suggests a sophisticated dialogue
   between the plant and its pollinators. The color change from yellow to
   red occurs in a very short time (less than 24 h) and it is due to the
   accumulation of anthocyanins. Despite this dialogue between plant and
   pollinators, the number of fruits is often scanty. (C) 2011 Elsevier
   GmbH. All rights reserved.},
