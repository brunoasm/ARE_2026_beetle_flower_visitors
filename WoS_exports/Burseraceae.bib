   Forero-Montana, Jimena; Zimmerman, Jess K., Univ Puerto Rico, Inst Trop Ecosyst Studies, San Juan, PR 00931 USA.},
ISSN = {0008-6452},
Keywords = {Burseraceae; Cecropiaceae; dioecy; Luquillo Experimental Forest;
   phenology; pollen limitation; sexual selection},
Keywords-Plus = {FLORAL DISPLAY; EVOLUTION; POLLINATION; PATTERNS; FEMALE},
