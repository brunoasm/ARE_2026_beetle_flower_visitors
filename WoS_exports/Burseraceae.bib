@article{ WOS:000378651100016,
Author = {Niebler, Johannes and Eslamieh, Jason and Buettner, Andrea},
Title = {Frankincense Revisited, Part II: Volatiles in Rare <i>Boswellia</i>
   Species and Hybrids},
Journal = {CHEMISTRY \& BIODIVERSITY},
Year = {2016},
Volume = {13},
Number = {5},
Pages = {630-643},
Month = {MAY},
Abstract = {In this second part of the investigation of volatiles and semivolatiles
   in Boswellia gum resins, an additional five less common species were
   analyzed by (SPME-) GC/MS, namely B. ameero, B. elongata, B. neglecta,
   B. popoviana, and B. rivae. Moreover, the results of hybridization
   experiments are reported in combination with the volatile composition of
   their gum resins. Our study shows that B. sacra benefits from an
   intraspecific cross-pollination, as the resulting hybrid B. sacra var.
