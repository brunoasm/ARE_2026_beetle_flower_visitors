@article{ WOS:000081327200002,
Author = {Van Creij, MGM and Kerckhoffs, DMFJ and Van Tuyl, JM},
Title = {The effect of ovule age on ovary-slice culture and ovule culture in
   intraspecific and interspecific crosses with <i>Tulipa gesneriana</i> L.},
Journal = {EUPHYTICA},
Year = {1999},
Volume = {108},
Number = {1},
Pages = {21-28},
Abstract = {The efficiency of two embryo rescue techniques, direct ovule culture and
   ovary-slice culture followed by ovule culture, is studied in crosses
   with Tulipa gesneriana as maternal genotype. The germination percentages
   increased, in most cases, significantly with increasing ages of te
   ovary-slices and ovules at the start of the cultures. The low number of
   embryos recovered at early culture dates is caused by a higher rate of
   embryo abortion and by retarded embryo development. The germination
   percentages for ovary-slice culture followed by ovule culture was mostly
   comparable to direct ovule culture. Unique hybrids have been obtained
   from the crosses T. gesneriana x T. agenensis and T. gesneriana x T.
   praestans.},
