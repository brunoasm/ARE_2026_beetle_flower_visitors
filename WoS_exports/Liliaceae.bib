Type = {Proceedings Paper},
Language = {English},
Affiliation = {Jules, ES (Corresponding Author), Univ Michigan, Dept Biol, Ann Arbor, MI 48109 USA.
   Univ Michigan, Dept Biol, Ann Arbor, MI 48109 USA.},
ISBN = {0-9656852-0-9},
Keywords = {edge effects; extinction; habitat fragmentation; Siskiyou Mountains;
   Trillium ovatum; Liliaceae},
Keywords-Plus = {HABITAT FRAGMENTATION; EDGE; CONSERVATION; HISTORY; POLLINATION;
   DEMOGRAPHY; POPULATION; DISPERSAL},
Research-Areas = {Plant Sciences; Environmental Sciences \& Ecology; Mycology},
