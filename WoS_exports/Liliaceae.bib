@inproceedings{ WOS:000078270700028,
Author = {Jules, ES},
Editor = {Kaye, TN and Liston, A and Love, RM and Luoma, DL and Meinke, RJ and Wilson, MV},
Title = {Consequences of forest fragmentation for the understory plant,
   <i>Trillium ovatum</i> (Liliaceae)},
Booktitle = {CONSERVATION AND MANAGEMENT OF NATIVE PLANTS AND FUNGI},
Year = {1997},
Pages = {201-206},
Note = {Oregon Conference on the Conservation and Management of Native Vascular
   Plants, Bryophytes, and Fungi, OREGON STATE UNIV, CORVALLIS, OR, NOV
   15-17, 1995},
Organization = {Native Plant Soc Oregon; Oregon Dept Agr; Oregon State Univ, Dept Bot \&
   Plant Pathol; USDI Bur Land Management, Oregon State Off},
Abstract = {The destruction and fragmentation of habitat is thought to be the
   greatest threat to terrestrial biodiversity. Theory predicts that
   populations in fragmented ecosystems are more likely to become extinct
   due to effects associated with both smaller sizes of remnant habitat and
   increased amounts of ``edge{''} habitat. I studied the effects of forest
   fragmentation in the Siskiyou Mountains of southwestern Oregon on a
   perennial herb, Trillium ovarum (western trillium), for which the ages
   of individual plants can be estimated. Surveys of tree plantations in
   areas that had been clearcut indicate that approximately 2.4 percent of
   the individuals survive clearcutting, and in general these plants have
   not produced offspring since the date of harvest. Studies of T. ovatum
   populations in remnant habitat fragments demonstrate that edge effects
   can be severe, and that populations within 60 meters of an edge have had
   little recruitment of new individuals since the formation of the edge.
   Fragmentation isolates T, ovatum in remnant forests, and these forests
   provide much less suitable habitat than their actual area. These results
   are probably applicable only to regions where the summer climate is dry
   and hot and conditions between fragments are too extreme for T. ovatum
   establishment.},
Publisher = {NATIVE PLANT SOCIETY OREGON},
