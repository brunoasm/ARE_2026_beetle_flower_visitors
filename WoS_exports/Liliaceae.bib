@article{ WOS:A1984SY53700007,
Author = {TAKAHASHI, H},
Title = {THE FLORAL BIOLOGY OF TRICYRTIS-LATIFOLIA MAXIM (LILIACEAE)},
Journal = {BOTANICAL MAGAZINE-TOKYO},
Year = {1984},
Volume = {97},
Number = {1046},
Pages = {207-217},
Abstract = {The flora biology of T. latifolia was investigated at 4 sites: Nigorigo,
   Kurumijima and Hikagedaira-san, Gifu Prefecture, and Joge, Miyagi
   Prefecture {[}Japan]. The flowers open fully by 3:00 h, and anthesis
   begins at about 8:00 h. Most pollen is taken away by bumblebees by 10:00
   h. The distal parts of the trifid style-branches (each branch is further
   bifid) and the immature stigmata are above the anthers in the 1st-day
   flowers. The distal parts of the style-branches with their extension 
   curve downward and are positioned under the anthers on the morning of
   the 2nd day and the stigmata are fully matured. The flowers wilt by the
   3rd day. The primary pollinators of T. latifolia were Bombus diversus
   and B. honshuensis in 3 sites; only the former was a primary pollinator
   at the Joge site. Bees forage the 1st and 2nd day flowers, and their
   backs contact the anthers and stigmata of the 2nd day flowers while the
   bees are sucking nectar. T. latifolia is fairly self-compatible. The
   avoidance of autogamy and the possibility of geitonogamy are discussed.},
Publisher = {BOTANICAL SOC JAPAN},
Address = {TOSHIN BUILDING HONGO 2-27-2 BUNKYO-KU, TOKYO, 113, JAPAN},
