@article{ WOS:000436630100006,
Author = {Afroz, Sumona and Rahman, M. Oliur and Hassan, Md. Abul},
Title = {TAXONOMY AND REPRODUCTIVE BIOLOGY OF THE GENUS <i>ZEPHYRANTHES </i>HERB.
   (LILIACEAE) IN BANGLADESH},
Journal = {BANGLADESH JOURNAL OF PLANT TAXONOMY},
Year = {2018},
Volume = {25},
Number = {1},
Pages = {57-69},
Month = {JUN},
Abstract = {The genus Zephyranthes Herb. is revised along with its pollination
   mechanism, seed germination and vegetative propagation. Detailed
   taxonomy of four Zephyranthes species occurring in Bangladesh, namely,
   Z. atamasco (L.) Herb., Z. candida (Lindl.) Herb., Z. carinata Herb. and
   Z. tubispatha (L'Her.) Herb. ex Traub. was studied with their updated
   nomenclature, important synonyms, phenology, specimens examined,
   habitat, distribution, economic value and mode of propagation. A
   dichotomous bracketed key is provided for easy identification of the
