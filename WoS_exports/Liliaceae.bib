@article{ WOS:A19679161000013,
Author = {FUKUDA, I},
Title = {FORMATION OF SUBGROUPS BY DEVELOPMENT OF INBREEDING SYSTEMS IN A
   TRILLIUM POLULATION},
Journal = {EVOLUTION},
Year = {1967},
Volume = {21},
Number = {1},
Pages = {141+},
Abstract = {Trillium kamtschaticum Pall. (Liliaceae) is a commonly distributed wild
   plant in northern Japan. The breedings of natural populations of the
   species are random in general. The Hakodateyama population (which is
   located in southern Hokkaido), the subject of this article, was found to
   be formed of several subgroups on the basis of Haldane''s test for the
   Hardy-Weinberg law and the homogeneity test as applied to chromosome
   compositions. The main factor in this production of sub-groups was a
   higher degree of inbreeding than occurred in the other populations. The
   high inbreeding may be considered to be counteracted, in the case of
   chromosome D, by a balance system which maintains an excess of
   heteromorphic pairs of this chromosome. On the other hand, the paucity
   of insect pollinators in this locality should contribute to this
   breeding system. Furthermore, the soil temperature in the snow melting
   season has been shown to cause a difference in the sprouting and
   flowering time among the subgroups, thus promoting seasonal isolation.},
