@article{ WOS:A1980JR96400016,
Author = {MESLER, MR and ACKERMAN, JD and LU, KL},
Title = {THE EFFECTIVENESS OF FUNGUS GNATS AS POLLINATORS},
Journal = {AMERICAN JOURNAL OF BOTANY},
Year = {1980},
Volume = {67},
Number = {4},
Pages = {564-567},
Abstract = {Fungus gnats (Sciaridae {[}Sciara sp. and Corynoptera sp.] and
   Mycetophilidae {[}Mycetophila sp.]) are the principal pollinators of
   Listera cordata (L.) R. Br. (Orchidaceae) and Scoliopus bigelovii Torr.
   (Liliaceae) in coastal redwood forests of northern California {[}USA].
   Although primitive Diptera have generally been regarded as relatively
   inefficient pollinators, fruit set for both species is high: 61-78\% for
   L. cordata (1976-1978) and 94.3-98.5\% for S. bigelovii (1978-1979).
   Since probability of pollination per visit is low, high fruit set was
   attributed to the large number of gnats present at the study sites and
   corresponding large number of visits to flowers. The relative frequency
   of geitonogamous vs. xenogamous pollen flow was estimated by
   emasculating flowers and subsequently comparing pollen reception or
   fruit set of emasculates with controls. Interplant movement of pollen is
   common. Fungus gnats can be effective pollen vectors, both in terms of
   overall fruit set and potential for cross-pollination.},
