Language = {English},
Affiliation = {Willemse, M (Corresponding Author), Univ Wageningen \& Res Ctr, Lab Plant Cell Biol, Arboretumlaan 4, NL-6703 BD Wageningen, Netherlands.
   Univ Wageningen \& Res Ctr, Lab Plant Cell Biol, NL-6703 BD Wageningen, Netherlands.},
ISSN = {0006-3088},
Keywords = {embryo; gametophyte; fertilization; sporophyte; sexual reproduction},
Keywords-Plus = {POLLEN-TUBE PENETRATION; GASTERIA-VERRUCOSA; CALCIUM DISTRIBUTION;
