DOI = {10.1046/j.1469-8137.2003.00951.x},
ISSN = {0028-646X},
EISSN = {1469-8137},
Keywords = {adaptive radiation; California Floristic Province; Calochortus;
   convergence; consequent radiation; floral syndromes; geographic
   cohesion; parallel evolution},
Keywords-Plus = {CHLOROPLAST DNA; METAL TOLERANCE; MOLECULAR EVOLUTION; POLLINATION
   SYSTEMS; GENUS CALOCHORTUS; MIMULUS-GUTTATUS; DIVERSIFICATION;
   ACCUMULATION; PATTERNS; PLANTS},
Research-Areas = {Plant Sciences},
Web-of-Science-Categories  = {Plant Sciences},
