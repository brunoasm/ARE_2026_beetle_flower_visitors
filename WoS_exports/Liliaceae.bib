Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {UNIV NEW ENGLAND, DEPT BOT, ARMIDALE, NSW 2351, AUSTRALIA.
