@article{ WOS:A1981LT48300014,
Author = {DAFNI, A and IVRI, Y},
Title = {FLORAL MIMICRY BETWEEN ORCHIS-ISRAELITICA BAUMANN AND DAFNI
   (ORCHIDACEAE) AND BELLEVALIA-FLEXUOSA BOISS (LILIACEAE)},
Journal = {OECOLOGIA},
Year = {1981},
Volume = {49},
Number = {2},
Pages = {229-232},
Abstract = {O. israelitica, which has no food reward, shared the pollinators of B.
   flexuosa: Eucera clypeata, Bombylius sp. and possibly also Anthophora
   sp. Since both species have a similar coloration pattern, flowering
   period and habitats, O. israelitica may mimic the flowers of B. flexuosa
   as a deceit syndrome of pollination. Aspects of floral mimicry, with
   special attention to floral adaptations in the genus Orchis, are
   discussed.},
