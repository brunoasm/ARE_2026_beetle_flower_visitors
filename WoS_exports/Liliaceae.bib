Title = {Onset and Duration of Stigma Receptivity in Eremurus Inderiensis
   (Liliaceae)},
Booktitle = {3RD CONFERENCE ON KEY TECHNOLOGY OF HORTICULTURE, CKTH 2011},
Year = {2011},
Pages = {231-235},
Note = {3rd Conference on Key Technology of Horticulture (CKTH 2011), Shenyang,
   PEOPLES R CHINA, DEC 17-18, 2011},
Organization = {Chinese Soc Horticultural Sci; Shenyang Agr Univ},
Abstract = {The stigmatic receptivity of E. inderiensis was evaluated at different
   stages during flower development by observing the stigmatic morphology,
   testing the enzymatic activity and artificial pollinating as a precursor
   to studies of reproductive strategy to desert environment. This species
   has a `special type of wet stigma', and sticky secretion accumulates
   under the cuticle. Once the cuticle rupture, the secretion is released
   and the pollen grains can be adhered. Peroxidase activity was detected
   one day after anthesis, increased from Days 2 to a peak at Days 3, and
   disappeared at Days 5. The optimum pollination period ranged from 32 to
   96 h, to a maximum at 48 h after anthesis. E. inderiensis is
   proterandrous due to the stigma present after the pollen presentation
   within a flower.},
