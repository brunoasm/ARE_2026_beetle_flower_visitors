@article{ WOS:000345137000002,
Author = {Canale, A. and Benelli, G. and Benvenuti, S.},
Title = {First record of insect pollinators visiting <i>Muscari comosum</i> (L.)
   Miller (Liliaceae-Hyacinthaceae), an ancient Mediterranean food plant},
Journal = {PLANT BIOSYSTEMS},
Year = {2014},
Volume = {148},
Number = {5},
Pages = {889-894},
Month = {SEP 3},
Abstract = {Insects foraging on Muscari comosum flowers belong to 3 families, 10
   genera and 13 species. The most abundant species was the hairy-footed
   flower bee, Anthophora plumipes. All species, except two
   cleptoparasites, presented pollen on their bodies. Muscari comosum
   flowering in early spring can be a key food source for pollinators.},
