Keywords = {Cardiocrinum; demography; habitat fragmentation; monocarpic perennial;
   vegetative reproduction},
Keywords-Plus = {DISC ELECTROPHORESIS; RESOURCE-ALLOCATION; PLANTS; DIVERSITY; SIZE;
   PATTERNS; BEHAVIOR; DENSITY; GROWTH; SEEDS},
Research-Areas = {Plant Sciences; Environmental Sciences \& Ecology},
