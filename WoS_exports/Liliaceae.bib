@article{ WOS:A1986C450500010,
Author = {MANNING, JC and BROTHERS, DJ},
Title = {FLORAL RELATIONS OF 4 SPECIES OF REDIVIVA IN NATAL (HYMENOPTERA,
   APOIDEA, MELLITTIDAE)},
Journal = {JOURNAL OF THE ENTOMOLOGICAL SOCIETY OF SOUTHERN AFRICA},
Year = {1986},
Volume = {49},
Number = {1},
Pages = {107-114},
Month = {APR},
Abstract = {The southern-Africa genus Rediviva is unusual in that various species
   have the legs, and especially the fore tarsi, modified in the females
   for collecting oils from certain flowers (which do not produce nectar).
   Females visit other flowers for nectar and pollen, and males use nectar
   for food. Observations on species of Rediviva in the Natal midlands and
   Drakensberg have identified the pollinators of various species of plants
   for which they were previously unknown: R. politissima pollinates 
   Diascia anastrepta, D. cordata, D. integerrima and D. barberae
   (Scorphulariaceae), as also a species of Pterygodium or Corycim
   (Orchidaceae), and individuals visit the flowers of Wahlenbergia
   undulata (Campanulaceae), Geranium pulchrum (Geraniaceae) and Dierama
   tysonii (Iridaceae), amongst other; R. sp. pollinates D. purpurea and a
   (probably different) species of Pterygodium or Corycium; R. rufocincta
   pollinates Bowkeria verticillata (Scrophulariaceae) and females visit
   Buchenroedeta lotononoides (Leguminosiae); R. colorata has not been seen
   collecting oil, but pollinates Disperis fanniniae, and individuals visit
   Impatiens hochstetteri (Balsaminaceae), Plectranthus laxiflorus
