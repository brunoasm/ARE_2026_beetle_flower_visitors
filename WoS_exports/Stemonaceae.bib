@article{ WOS:000468419700006,
Author = {Yao, Gang and Chen, Gao},
Title = {First record of the genus <i>Empidideicus</i> Becker, 1907 (Diptera,
   Mythicomyiidae) in China and the Oriental Region, with description of a
   new species},
Journal = {ZOOKEYS},
Year = {2019},
Number = {846},
Pages = {65-73},
Month = {MAY 16},
Abstract = {Empidideicus Becker, 1907 is newly recorded from China and the Oriental
   Region, with one new species, E. pentagonius sp. n., described and
   illustrated. Observations are provided on the biology of E. pentagonius
   sp. n. visiting flowers of Stemona mairei (Levl.) Krause (Liliflorae,
   Stemonaceae). A key to the genera of Mythicomyiidae known to occur in
   China is provided.},
