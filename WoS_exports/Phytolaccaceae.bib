
@article{ WOS:A1988Q050500008,
Author = {MIKESELL, J},
Title = {COMPARATIVE DEVELOPMENT OF VIABLE AND ABORTED OVULES IN
   PHYTOLACCA-AMERICANA L (PHYTOLACCACEAE)},
Journal = {BOTANICAL GAZETTE},
Year = {1988},
Volume = {149},
Number = {2},
Pages = {196-202},
Month = {JUN},
Abstract = {Phytolacca americana (pokeweed) can produce more than 80,000 seeds per
   plant. Plants in this study averaged six shoots per plant; each shoot
   differentiated 34 racemes. In each inflorescence 40 fruits developed;
   each fruit produced 10 seeds. In populations near the
   Maryland-Pennsylvania {[}USA] border, no fruits developed a full
   complement of seeds; from 40\% to 100\% of the ovules or seeds aborted.
   Ovules aborted either during the formation of the female gametophyte or
   the globular embryo.  Approximately 87\% of investigated ovules or seeds
   aborted, with 72\% and 15\% aborting at the time of female gametophyte
   or globular embryo formation, respectively. Only young seeds with
   globular embryos were analyzed quantitatively as ovules aborting at the
   time of female gametophyte formation had obscure cellular details.
   Viable ovules had twice as many cells as aborted ovules, which could be
   attributed to the nucellus. However, both outer and inner integuments of
   aborted ovules contained more cells, as well as larger cells, then
   comparably aged viable ovules. Cell size of the nucellus, the obturator,
   and the dimensions of ovules and locules were greater in aborted ovules
   also. Abortion was believed to be a result of poor pollination, with a
   subsequent inhibition of fertilization, resulting from fungal-infected
   pollen grains.},
Publisher = {UNIV CHICAGO PRESS},
Address = {1427 E 60TH ST, CHICAGO, IL 60637-2954 USA},
Type = {Article},
Language = {English},
Affiliation = {GETTYSBURG COLL, DEPT BIOL, GETTYSBURG, PA 17325 USA.},
DOI = {10.1086/337707},
ISSN = {0006-8071},
Research-Areas = {Plant Sciences},
