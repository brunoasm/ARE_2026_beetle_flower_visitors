Pages = {E41-E43},
Month = {FEB},
Abstract = {Premise of the study: To investigate genetic structure of the pollinator
   and, indirectly, gene flow in its plant host, Blastophaga javana
   microsatellite primers were developed.
   Methods and Results: Ten polymorphic microsatellite loci were developed
   using the Fast Isolation by AFLP of Sequences Containing (FIASCO)
   repeats protocol. Numbers of alleles per locus ranged from 2 to 19, with
   observed and expected heterozygosities ranging from 0.000 to 0.800 and
   from 0.000 to 0.925, respectively.
   Conclusions: These markers may be useful for further investigation of
   population genetics of Blastophaga javana and other congeneric species.},
