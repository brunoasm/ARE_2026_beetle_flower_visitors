@article{ WOS:A1997XY70000005,
Author = {Thomson, JD and DentAcosta, S and EscobarParamo, P and Nason, JD},
Title = {Within-crown flowering synchrony in strangler figs, and its relationship
   to allofusion},
Journal = {BIOTROPICA},
Year = {1997},
Volume = {29},
Number = {3},
Pages = {291-297},
Month = {SEP},
Abstract = {We studied flowering phenology at the level of individual branches
   within strangler fig trees to determine (1) whether branches bloomed
   asynchronously within trees and (2) whether asynchrony, if observed,
   could be ascribed to genetically different branches of mosaic trees
   (i.e., trees formed by spontaneous grafting of generically different
   individuals) undergoing individual flowering cycles that were out of
   phase with each ocher. Although asynchrony was fairly common, it most of
   reflected individual branches failing to bloom during one flowering
   episode, chen coming back to bloom in synchrony at the next episode. We
   detected fewer mosaic trees than expected, and found only a very weak
   suggestion that mosaic trees may show less within-tree synchrony than
   simple trees.},
