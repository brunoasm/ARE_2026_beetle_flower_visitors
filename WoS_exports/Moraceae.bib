   SMITHSONIAN TROP RES INST,UNIT 0948,APO,AA 34002.},
DOI = {10.1111/j.1365-2699.1996.tb00015.x},
ISSN = {0305-0270},
Keywords = {Agaonidae; co-evolution; COII; mitochondrial DNA; molecular phylogeny;
   mutualism; 12S rRNA},
Keywords-Plus = {MITOCHONDRIAL-DNA; HYMENOPTERA CHALCIDOIDEA; SPECIES RICHNESS; FICUS
   MORACEAE; SEX-RATIOS; NEW-WORLD; SEQUENCE; RATES; AMPLIFICATION;
   ASSEMBLAGES},
