@incollection{ WOS:000286906400002,
Author = {Menon, Rema and Peter, K. V.},
Editor = {Valavi, SG and Peter, KV and Thottappilly, G},
Title = {Origin, Distribution and Biodiversity of Jackfruit},
Booktitle = {JACKFRUIT},
Year = {2011},
Pages = {19-32},
Abstract = {The jackfruit (Artocarpus heterophyllus Lam.), a member of the family
   Moraceae is indigenous to the rain forests of the Western Ghats and is
   adapted to humid tropical and near tropical climates. A fairly good
   source of vitamins and minerals, jackfruit is a common ingredient in
   South and Southeast Asian cuisines. All other parts of the tree have
   been exploited for numerous uses. Being cross pollinated and
   predominantly seed propagated, jackfruit exhibits wide variation in
   terms of vegetative, flowering, fruiting and quality characters. Based
   on the firmness of flesh, cultivated types are of two general
   groups-soft flesh and firm flesh in which many local varieties exist.
   The heterogenous nature of the seedling population offers tremendous
   potential for selection of superior types suited for commercial
   cultivation. Vegetative propagation facilitates the large scale
   multiplication of desired types. Systematic breeding work to develop new
   varieties is lacking. In India and other jackfruit growing countries,
   explorations have been undertaken to identify elite trees having good
   agronomic and economic traits. Many clones have been developed and
   released.},
