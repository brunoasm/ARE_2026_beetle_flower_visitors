@article{ WOS:001358206800001,
Author = {Dieringer, Gregg and Cabrera, R. Leticia},
Title = {Contrasting floral insect visitors to sympatric populations of
   <i>Arisaema triphyllum</i> and <i>A. dracontium</i> (Araceae) in
   northwest Missouri},
Journal = {PLANT ECOLOGY},
Year = {2024},
Month = {2024 NOV 19},
Abstract = {Sympatric co-flowering congeners present an opportunity to examine
   possible competitive shifts in pollen vectors to increase reproductive
   isolation. Arisaema triphyllum and A. dracontium (Araceae) are two
   spring-flowering members of dry mesic woodlands of northwest Missouri.
   An observational study was conducted over 5 years to compare flowering
   duration, abundance of insect pollen vectors, and overall similarity of
   visiting insect to spathes of each species. Over the course of 4 years,
   we recorded a 50-79\% overlap of their flowering durations suggesting an
   arena for competitive interactions. Visiting insect assemblages (at the
   family level) differed dramatically between the two species as recorded
   over 3 years. Fourteen taxa were recorded visiting the spathes of
   Arisaema triphyllum, with 84.5\% being Heterothripidae (thrips) and
   6.6\% being Mycetophilidae (fungus gnats), whereas only three taxa were
   recorded visiting the spathes of Arisaema dracontium, with 92.7\% being
   Cecidomyiidae (gall midges) and 7.2\% being Heterothripidae (thrips).
   Typically, within Arisaema, diversity of visiting insects is high with
   thrips and fungus gnats overwhelming being the more common visitors. The
   restrictive number of visiting taxa and near exclusivity of gall midges
   observed in A. dracontium may be reflective of past competition for
   pollinators leading to a partitioning of available pollen vectors to
   increase reproductive isolation between the two species.},
Publisher = {SPRINGER},
Address = {VAN GODEWIJCKSTRAAT 30, 3311 GZ DORDRECHT, NETHERLANDS},
Type = {Article; Early Access},
Language = {English},
