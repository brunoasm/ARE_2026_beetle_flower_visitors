@article{ WOS:A1997WP99500010,
Author = {deFigueiredo, RA and Sazima, M},
Title = {Phenology and pollination ecology of three Brazilian fig species
   (Moraceae)},
Journal = {BOTANICA ACTA},
Year = {1997},
Volume = {110},
Number = {1},
Pages = {73-78},
Month = {FEB},
Abstract = {The phenology and pollination ecology of three native fig species were
   studied in southeastern Brazil. Populations displayed continual syconia
   production, with one species showing intra-tree flowering asynchrony.
   Pollination of the fig flowers was necessary for the development of the
   syconia; lack of pollination induced abortion of syconia. All three
   species follow the general pattern of pollination known for figs, but
   the behavior of the pollinator wasps, Pegoscapus spp., differed in some
   aspects from those of other neotropical and paleotropical fig wasps,
   mainly with respect to pollen loading and unloading during pollination.
   The longevity of Pegoscopus wasps outside the syconium was about two
   days.},
