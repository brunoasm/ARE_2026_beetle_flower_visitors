@article{ WOS:000565908600002,
Author = {Clement, Wendy L. and Bruun-Lund, Sam and Cohen, Alanna and Kjellberg,
   Finn and Weiblen, George D. and Ronsted, Nina},
Title = {Evolution and classification of figs (<i>Ficus</i>, Moraceae) and their
   close relatives (Castilleae) united by involucral bracts},
Journal = {BOTANICAL JOURNAL OF THE LINNEAN SOCIETY},
Year = {2020},
Volume = {193},
Number = {3},
Pages = {316-339},
Month = {JUL},
Abstract = {Figs and fig wasps are a classic example of an obligate pollination
   mutualism. Decades of work untangling the ecology and evolution of these
   organisms has simultaneously contributed to development of the fields of
   mutualism, coevolution and plant-insect interactions at large. With >
   800 species, figs (Ficus, Moraceae) are among some of the larger genera
   of angiosperms. Phylogenetic studies of Moraceae have supported the
   Glade Castilleae as the sister lineage of Ficus. Compared to Ficus,
   Castilleae have many fewer species (60 species in 11 genera), suggesting
   changes in rates of diversification along these two branches. Relatively
   little is known about Castilleae compared to Ficus, and we argue that
   defining the Glade comprising Ficus and Castilleae, hereafter
   Involucrata, focuses attention on opportunities for comparative studies
   of pollination mutualisms and diversification rates. In this study, we
   define Involucrata and propose a revised classification scheme that
   accounts for the phylogenetic reconstruction based on the most
   comprehensive sampling of this group to date. Moving forward, this
   classification will better guide and support evolutionary, ecological
   and comparative pollination biology studies of this group.},
Publisher = {OXFORD UNIV PRESS},
Address = {GREAT CLARENDON ST, OXFORD OX2 6DP, ENGLAND},
Type = {Article},
Language = {English},
Affiliation = {Ronsted, N (Corresponding Author), Univ Copenhagen, Nat Hist Museum Denmark, Oster Voldgade 5-7, DK-2100 Copenhagen, Denmark.
   Ronsted, N (Corresponding Author), Nat Trop Bot Garden, 3530 Papalina Rd, Kauai, HI 96741 USA.
   Clement, Wendy L.; Cohen, Alanna, Coll New Jersey, Dept Biol, 2000 Pennington Rd, Ewing, NJ 08638 USA.
   Bruun-Lund, Sam; Ronsted, Nina, Univ Copenhagen, Nat Hist Museum Denmark, Oster Voldgade 5-7, DK-2100 Copenhagen, Denmark.
   Cohen, Alanna, Rutgers State Univ, Dept Biochem \& Microbiol, 76 Lipman Dr, New Brunswick, NJ 08901 USA.
   Kjellberg, Finn, Univ Montpellier, Univ Paul Valery Montpellier, EPHE, CEFE,CNRS,IRD, 1919 Route Mende, F-34293 Montpellier 5, France.
   Weiblen, George D., Univ Minnesota, Dept Plant Biol, 1479 Gortner Ave, St Paul, MN 55108 USA.
   Ronsted, Nina, Nat Trop Bot Garden, 3530 Papalina Rd, Kauai, HI 96741 USA.},
DOI = {10.1093/botlinnean/boaa022},
ISSN = {0024-4074},
EISSN = {1095-8339},
