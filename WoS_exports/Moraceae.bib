@article{ WOS:000335378400034,
Author = {Araujo, Nathalia Diniz and Coelho, Victor Pecanha M. and Ventrella,
   Marilia Contin and Agra, Maria De Fatima},
Title = {Leaf Anatomy and Histochemistry of Three Species of Ficus sect.
   Americanae Supported by Light and Electron Microscopy},
Journal = {MICROSCOPY AND MICROANALYSIS},
Year = {2014},
Volume = {20},
Number = {1},
Pages = {296-304},
Month = {FEB},
Abstract = {In this work the leaf anatomy of three species of Ficus section
   Americanae (Miq.) Miq. from Brazil, whose leaves and latex are used in
   folk medicine is reported. The work was carried out using light and
   scanning electron microscopy in order to characterize these species and
   to evaluate their taxonomic significance, and also contribute to the
   quality control of their ethnodrugs. The three species (Ficus
   cyclophylla, Ficus elliotiana, and Ficus caatingae) showed hypostomatic
   leaves, anomocytic stomata, straight epidermal cell outlines, and a
   dorsiventral mesophyll. Some micro-morphological characters such as
   density and distribution of epicuticular waxes, glandular trichomes, the
   length and width of stomata, as well as the palisade of mesophyll and
   petiole outlines proved to be the most useful and distinctive characters
