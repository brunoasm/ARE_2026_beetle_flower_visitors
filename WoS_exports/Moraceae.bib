EISSN = {1916-2804},
Keywords = {figs; Agaonidae wasps; reproductive event; Ficus; syconium development},
Keywords-Plus = {LOS-TUXTLAS; ECOLOGY; CONSEQUENCES; POLLINATION; EVOLUTION; WASPS;
   COEVOLUTION; DISPERSAL; MORACEAE; AUREA},
