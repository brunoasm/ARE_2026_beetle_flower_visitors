Language = {English},
Affiliation = {Mayle, FE (Corresponding Author), Univ Edinburgh, Sch Geosci, Drummond St, Edinburgh EH8 9XP, Midlothian, Scotland.
   Jones, Huw T.; Mayle, Francis E., Univ Edinburgh, Sch Geosci, Edinburgh EH8 9XP, Midlothian, Scotland.
   Pennington, R. Toby, Royal Bot Garden Edinburgh, Edinburgh EH3 5LR, Midlothian, Scotland.
   Killeen, Timothy J., Conservat Int, Ctr Appl Biodivers Sci, Washington, DC 20037 USA.
   Killeen, Timothy J., Museo Hist Nat Noel Kempff Mercado, Santa Cruz, Santa Cruz, Bolivia.},
