Keywords = {Ficus; agaonid wasp; wasp size; ostiole role; dioecy; Ceratosolen solmsi
   marchali; Moraceae; pollination; Hymenoptera; Agaonidae},
Keywords-Plus = {COEVOLUTION; LONGEVITY},
