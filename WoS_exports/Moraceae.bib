   Kyoto Univ, Ctr Ecol Res, Kyoto 6068502, Japan.
   Kyoto Univ, Grad Sch Human \& Environm Studies, Kyoto 6068501, Japan.
   Kyoto Univ Museum, Kyoto 6068501, Japan.},
DOI = {10.2307/2656640},
