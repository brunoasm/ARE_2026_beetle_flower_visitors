   Compton, S. G.; Thomas, P. J., Univ Leeds, Sch Biol, Leeds LS2 9JT, W Yorkshire, England.
   Stavrinides, M.; Kaponas, C., Cyprus Univ Technol, Dept Agr Sci, Arch Kyprianos 30, CY-3036 Limassol, Cyprus.},
DOI = {10.1007/s10530-019-02132-4},
ISSN = {1387-3547},
EISSN = {1573-1464},
Keywords = {Biological control; Ficus microcarpa; Street trees; Trophic cascades},
Keywords-Plus = {PSYLLID MACROHOMOTOMA GLADIATA; SINGHIELLA-SIMPLEX HEMIPTERA;
   FICUS-MICROCARPA L.; BIOLOGICAL-CONTROL; HYMENOPTERA; MORACEAE;
   ALEYRODIDAE; AGAONIDAE; WASPS},
