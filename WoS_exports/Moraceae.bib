@article{ WOS:000669988600001,
Author = {Gardner, Elliot M. and Garner, Mira and Cowan, Robyn and Dodsworth,
   Steven and Epitawalage, Niroshini and Arifiani, Deby and Sahromi and
   Baker, William J. and Forest, Felix and Maurin, Olivier and Zerega,
   Nyree J. C. and Monro, Alexandre and Hipp, Andrew L.},
Title = {Repeated parallel losses of inflexed stamens in Moraceae: Phylogenomics
   and generic revision of the tribe Moreae and the reinstatement of the
   tribe Olmedieae (Moraceae)},
Journal = {TAXON},
Year = {2021},
Volume = {70},
Number = {5},
Pages = {946-988},
Month = {OCT},
Abstract = {We present a densely sampled phylogenomic study of the mulberry tribe
   (Moreae, Moraceae), an economically important clade with a global
   distribution, revealing multiple losses of inflexed stamens, a character
   traditionally used to circumscribe Moreae. Inflexed stamens facilitate
   ballistic pollen release and are associated with wind pollination, and
   the results presented here suggest that losses of this character state
   may have evolved repeatedly in Moraceae. Neither Moreae nor several of
   its major genera (Morus, Streblus, Trophis) were found to be
   monophyletic. A revised system for a monophyletic Moreae is presented,
   including the reinstatement of the genera Ampalis, Maillardia,
   Taxotrophis, and Paratrophis, and the recognition of the new genus
   Afromorus. Pseudostreblus is reinstated and transferred to the
   Parartocarpeae, and Sloetiopsis is reinstated and transferred to the
   Dorstenieae. The tribe Olmedieae is reinstated, replacing the
   Castilleae, owing to the reinstatement of the type Olmedia and its
   exclusion from Moreae. Streblus s.str. is excluded from Moreae and
   transferred to the Olmedieae, which is characterized primarily by
   involucrate inflorescences without regard to stamen position. Nine new
   combinations are made.},
Publisher = {WILEY},
Address = {111 RIVER ST, HOBOKEN 07030-5774, NJ USA},
Type = {Article},
Language = {English},
Affiliation = {Gardner, EM (Corresponding Author), Morton Arboretum, 4100 IL-53, Lisle, IL 60532 USA.
   Gardner, EM (Corresponding Author), Singapore Bot Gardens, Natl Pk Board, 1 Cluny Rd, Singapore 259569, Singapore.
   Gardner, EM (Corresponding Author), Florida Int Univ, Int Ctr Trop Bot, Inst Environm, 11200 SW 8th St,OE 148, Miami, FL 33199 USA.
