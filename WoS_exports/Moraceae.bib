ISSN = {0305-0270},
Keywords = {Australia; Cape Tribulation; dioecy; Ficus variegata; figs; flowering
   asynchrony; phenology; seasonality},
Keywords-Plus = {RAIN-FOREST; CARICA L; FIG; CONSEQUENCES; CLASSIFICATION; PATTERNS;
   MORACEAE; FRUIT},
