DOI = {10.1111/j.1365-2699.1996.tb00013.x},
ISSN = {0305-0270},
Keywords = {evolution; fig tree; fig wasp; speciation; symbiosis},
Keywords-Plus = {FICUS; SPECIFICITY; CONSEQUENCES; COEVOLUTION; SPECIATION; MORACEAE},
