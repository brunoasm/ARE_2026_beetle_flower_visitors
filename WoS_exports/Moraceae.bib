   Weiblen, George D., Univ Minnesota, Bell Museum, St Paul, MN 55108 USA.
   Weiblen, George D., Univ Minnesota, Dept Plant Biol, St Paul, MN 55108 USA.},
DOI = {10.1111/j.1558-5646.2012.01727.x},
ISSN = {0014-3820},
EISSN = {1558-5646},
Keywords = {Ceratosolen; coevolution; hybridization; speciation},
Keywords-Plus = {HOST-SPECIFICITY; PHYLOGENETIC-RELATIONSHIPS; VOLATILE COMPOUNDS;
   DNA-SEQUENCES; WASPS; COEVOLUTION; ATTRACTION; SPECIATION; MUTUALISM;
