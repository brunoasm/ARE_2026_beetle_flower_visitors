@article{ WOS:000220044100009,
Author = {Abdulrazak, IP and Abdurahiman, UC},
Title = {Evolutionary strategies in the pollen collecting organs of fig wasps
   (Agaonidae: Hymenoptera) with respect to the floral topography of their
   host <i>Ficus</i> (Moraceae)},
Journal = {JOURNAL OF ADVANCED ZOOLOGY},
Year = {2002},
Volume = {23},
Number = {1},
Pages = {48-53},
Month = {JUN},
Abstract = {Pollination in Ficus is effected by minute agaonid wasps with specially
   modified organs to carry pollen grains, viz: pollen pockets and coxal
   corbiculae. Observations on the distribution and organisation of the
   pollen carrying devices of fourteen species of pollinator wasps
   belonging to the genera Eupristina, Dolichoris, Liporrhopalum, Kradibia,
   Ceratosolen and Platyscapa and the floral characters of their respective
   host Ficus revealed that these specialised organs of pollinator wasps
   are modified and evolved in response to the distribution and arrangement
   of male flowers in the syconium. These features of the figs also play a
   decisive role in regulating the pollen collecting behaviour of the
   wasps.},
