ISSN = {0013-8746},
EISSN = {1938-2901},
Keywords = {phylogeography; Wallacea; mitochondrial DNA},
Keywords-Plus = {PHYLOGENETIC-RELATIONSHIPS; HOST-SPECIFICITY; DIOECIOUS FICUS; BREEDING
   STRUCTURE; MITOCHONDRIAL-DNA; FIG POLLINATORS; WALLACES LINE;
   BIOGEOGRAPHY; LEPIDOPTERA; DISPERSAL},
