@article{ WOS:A1987J509900005,
Author = {NICHOLLS, MS},
Title = {POLLEN FLOW, SELF-POLLINATION AND GENDER SPECIALIZATION - FACTORS
   AFFECTING SEED-SET IN THE TRISTYLOUS SPECIES LYTHRUM-SALICARIA
   (LYTHRACEAE)},
Journal = {PLANT SYSTEMATICS AND EVOLUTION},
Year = {1987},
Volume = {156},
Number = {3-4},
Pages = {151-157},
Abstract = {Some of the factors governing seed-set in three populations of Lythrum
   salicaria are examined during two seasons. Plants spatially segregated
   from legitimate neighbours by distances exceeding 1 m set few seeds.
   Plants with small inflorescences set fewer seeds than those with medium
   or large inflorescences. Flowers having self pollen applied to the
