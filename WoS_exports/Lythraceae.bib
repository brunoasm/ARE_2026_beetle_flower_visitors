Keywords = {Menyanthes trifoliata; distyly; homostyle; reciprocal herkogamy; clonal
   aquatic macrophyte; island of Newfoundland},
Keywords-Plus = {DECODON-VERTICILLATUS LYTHRACEAE; SPRENG SOLMS PONTEDERIACEAE;
